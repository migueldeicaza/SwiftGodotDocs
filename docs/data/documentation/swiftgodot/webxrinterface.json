dot\/XRInterface"],"type":"inheritsFrom","title":"Inherits From"},{"title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo","kind":"relationships"}],"abstract":[{"text":"XR interface using WebXR.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"WebXRInterface"}]}],"kind":"declarations"},{"content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"WebXR is an open standard that allows creating VR and AR applications that run in the web browser."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"As such, this interface is only available when running in Web exports."}],"type":"paragraph"},{"inlineContent":[{"text":"WebXR supports a wide range of devices, from the very capable (like Valve Index, HTC Vive, Oculus Rift and Quest) down to the much less capable (like Google Cardboard, Oculus Go, GearVR, or plain smartphones).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Since WebXR is based on JavaScript, it makes extensive use of callbacks, which means that "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface","isActive":true,"type":"reference"},{"type":"text","text":" is forced to use signals, where other XR interfaces would instead use functions that return a result immediately. This makes "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface"},{"type":"text","text":" quite a bit more complicated to initialize than other XR interfaces."}]},{"type":"paragraph","inlineContent":[{"text":"Here’s the minimum code required to start an immersive VR session:","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"There are a couple ways to handle “controller” input:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/XRController3D"},{"type":"text","text":" nodes and their [signal XRController3D.button_pressed] and [signal XRController3D.button_released] signals. This is how controllers are typically handled in XR apps in Godot, however, this will only work with advanced VR controllers like the Oculus Touch or Index controllers, for example."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Using the [signal select], [signal squeeze] and related signals. This method will work for both advanced VR controllers, and non-traditional input sources like a tap on the screen, a spoken voice command or a button press on the device itself."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"You can use both methods to allow your game or app to support a wider or narrower set of devices and input methods, or to allow more advanced interactions with more advanced devices."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This object emits the following signals:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface\/sessionSupported","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface\/sessionStarted"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"d