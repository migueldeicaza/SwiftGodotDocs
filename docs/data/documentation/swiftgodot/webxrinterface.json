or":0,"minor":3,"patch":0},"metadata":{"role":"symbol","roleHeading":"Class","title":"WebXRInterface","externalID":"s:10SwiftGodot14WebXRInterfaceC","modules":[{"name":"SwiftGodot"}],"navigatorTitle":[{"kind":"identifier","text":"WebXRInterface"}],"symbolKind":"class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WebXRInterface"}]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"WebXRInterface"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"WebXR is an open standard that allows creating VR and AR applications that run in the web browser."}]},{"inlineContent":[{"type":"text","text":"As such, this interface is only available when running in Web exports."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"WebXR supports a wide range of devices, from the very capable (like Valve Index, HTC Vive, Oculus Rift and Quest) down to the much less capable (like Google Cardboard, Oculus Go, GearVR, or plain smartphones)."}]},{"type":"paragraph","inlineContent":[{"text":"Since WebXR is based on JavaScript, it makes extensive use of callbacks, which means that ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface","isActive":true,"type":"reference"},{"type":"text","text":" is forced to use signals, where other XR interfaces would instead use functions that return a result immediately. This makes "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface","isActive":true},{"type":"text","text":" quite a bit more complicated to initialize than other XR interfaces."}]},{"type":"paragraph","inlineContent":[{"text":"Here’s the minimum code required to start an immersive VR session:","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"There are a couple ways to handle “controller” input:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Using "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/XRController3D","type":"reference","isActive":true},{"type":"text","text":" nodes and their [signal XRController3D.button_pressed] and [signal XRController3D.button_released] signals. This is how controllers are typically handled in XR apps in Godot, however, this will only work with advanced VR controllers like the Oculus Touch or Index controllers, for example."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Using the [signal select], [signal squeeze] and related signals. This method will work for both advanced VR controllers, and non-traditional input sources like a tap on the screen, a spoken voice command or a button press on the device itself.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use both methods to allow your game or app to support a wider or narrower set of devices and input methods, or to allow more advanced interactions with more advanced devices."}]},{"type":"paragraph","inlineContent":[{"text":"This object emits the following signals:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface\/sessionSupported","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface\/sessionStarted","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WebXRInterface\/sessionEnded","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":