{"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxPhysicsStepsPerFrame","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"maxPhysicsStepsPerFrame","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"text":" ","kind":"text"},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/engine\/maxphysicsstepsperframe"]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","abstract":[{"type":"text","text":"Controls the maximum number of physics steps that can be simulated each rendered frame. The default value is tuned to avoid “spiral of death” situations where expensive physics simulations trigger more expensive simulations indefinitely. However, the game will appear to slow down if the rendering FPS is less than "},{"code":"1 \/ max_physics_steps_per_frame","type":"codeVoice"},{"type":"text","text":" of "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond","isActive":true},{"type":"text","text":". This occurs even if "},{"code":"delta","type":"codeVoice"},{"text":" is consistently used in physics calculations. To avoid this, increase ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxPhysicsStepsPerFrame","isActive":true,"type":"reference"},{"type":"text","text":" if you have increased "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond","isActive":true},{"text":" significantly above its default value.","type":"text"}],"metadata":{"roleHeading":"Type Property","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot6EngineC23maxPhysicsStepsPerFrames5Int32VvpZ","symbolKind":"property","title":"maxPhysicsStepsPerFrame","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"maxPhysicsStepsPerFrame","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","kind":"typeIdentifier","text":"Int32"}]},"sections":[],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Engine/maxFps":{"fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"maxFps","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"}],"role":"symbol","title":"maxFps","abstract":[{"text":"The maximum number of frames per second that can be rendered. A value of ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":" means “no limit”. The actual number of frames per second may still be below this value if the CPU or GPU cannot keep up with the project logic and rendering."}],"type":"topic","url":"\/documentation\/swiftgodot\/engine\/maxfps","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxFps"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_physicsProcess(delta:)":{"url":"\/documentation\/swiftgodot\/node\/_physicsprocess(delta:)","title":"_physicsProcess(delta:)","type":"topic","abstract":[{"type":"text","text":"Called during the physics processing step of the main loop. Physics processing means that the frame rate is synced to the physics, i.e. the "},{"code":"delta","type":"codeVoice"},{"type":"text","text":" variable should be constant. "},{"code":"delta","type":"codeVoice"},{"text":" is in seconds.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"_physicsProcess","kind":"identifier"},{"text":"(","kind":"text"},{"text":"delta","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"text":")","kind":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)"},"doc://SwiftGodot/documentation/SwiftGodot/Engine/physicsTicksPerSecond":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"physicsTicksPerSecond","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"}],"role":"symbol","title":"physicsTicksPerSecond","abstract":[{"text":"The number of fixed iterations per second. This controls how often physics simulation and ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","type":"reference","isActive":true},{"type":"text","text":" methods are run. This value should generally always be set to "},{"code":"60","type":"codeVoice"},{"text":" or above, as Godot doesn’t interpolate the physics step. As a result, values lower than ","type":"text"},{"type":"codeVoice","code":"60"},{"text":" will look stuttery. This value can be increased to make input more reactive or work around collision tunneling issues, but keep in mind doing so will increase CPU usage. See also ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxFps","type":"reference"},{"type":"text","text":" and "},{"code":"ProjectSettings\/physics\/common\/physicsTicksPerSecond","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/swiftgodot\/engine\/physicstickspersecond","k