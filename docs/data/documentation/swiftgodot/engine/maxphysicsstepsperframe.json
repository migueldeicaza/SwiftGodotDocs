{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"The maximum number of physics steps that can be simulated each rendered frame."}],"sections":[],"metadata":{"roleHeading":"Type Property","symbolKind":"property","externalID":"s:10SwiftGodot6EngineC23maxPhysicsStepsPerFrames5Int32VvpZ","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"maxPhysicsStepsPerFrame"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int32","preciseIdentifier":"s:s5Int32V"}],"title":"maxPhysicsStepsPerFrame","modules":[{"name":"SwiftGodot"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"maxPhysicsStepsPerFrame","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"style":"note","name":"Note","content":[{"inlineContent":[{"text":"The default value is tuned to prevent expensive physics simulations from triggering even more expensive simulations indefinitely. However, the game will appear to slow down if the rendering FPS is less than ","type":"text"},{"type":"codeVoice","code":"1 \/ max_physics_steps_per_frame"},{"text":" of ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond","isActive":true,"type":"reference"},{"type":"text","text":". This occurs even if "},{"type":"codeVoice","code":"delta"},{"type":"text","text":" is consistently used in physics calculations. To avoid this, increase "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxPhysicsStepsPerFrame","type":"reference","isActive":true},{"type":"text","text":" if you have increased "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond"},{"type":"text","text":" significantly above its default value."}],"type":"paragraph"}],"type":"aside"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/engine\/maxphysicsstepsperframe"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxPhysicsStepsPerFrame"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node/_physicsProcess(delta:)":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"_physicsProcess"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"delta"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"text":")","kind":"text"}],"abstract":[{"text":"Called during the physics processing step of the main loop. Physics processing means that the frame rate is synced to the physics, i.e. the ","type":"text"},{"type":"codeVoice","code":"delta"},{"type":"text","text":" variable should be constant. "},{"code":"delta","type":"codeVoice"},{"type":"text","text":" is in seconds."}],"url":"\/documentation\/swiftgodot\/node\/_physicsprocess(delta:)","kind":"symbol","type":"topic","title":"_physicsProcess(delta:)","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Engine":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine","title":"Engine","url":"\/documentation\/swiftgodot\/engine","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Engine"}],"abstract":[{"text":"Provides access to engine properties.","type":"text"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Engine"}],"kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Engine/maxPhysicsStepsPerFrame":{"url":"\/documentation\/swiftgodot\/engine\/maxphysicsstepsperframe","role":"symbol","kind":"symbol","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"maxPhysicsStepsPerFrame","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxPhysicsStepsPerFrame","abstract":[{"text":"The maximum number of physics steps that can be simulated each rendered frame.","type":"text"}],"type":"topic","title":"maxPhysicsStepsPerFrame"},"doc://SwiftGodot/documentation/SwiftGodot/Engine/maxFps":{"abstract":[{"type":"text","text":"The maximum number of frames that can be rendered every second (FPS). A value of "},{"type":"codeVoice","code":"0"},{"type":"text","text":" means the framerate is uncapped."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxFps","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"maxFps","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int32","preciseIdentifier":"s:s5Int32V"}],"title":"maxFps","kind":"symbol","type":"topic","url":"\/documentation\/swiftgodot\/engine\/maxfps"},"doc://SwiftGodot/documentation/SwiftGodot/Engine/physicsTicksPerSecond":{"title":"physicsTicksPerSecond","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"physicsTicksPerSecond","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int32","preciseIdentifier":"s:s5Int32V","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond","kind":"symbol","url":"\/documentation\/swiftgodot\/engine\/physicstickspersecond","type":"topic","abstract":[{"type":"text","text":"The number of fixed iterations per second. This controls how often physics simulation and "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","isActive":true,"type":"reference"},{"type":"text","text":" methods are run. This value should generally always be set to "},{"type":"codeVoice","code":"60"},{"type":"text","text":" or above, as Godot doesn’t interpolate the physics step. As a result, values lower than "},{"code":"60","type":"codeVoice"},{"text":" will look stuttery. This value can be increased to make input more reactive or work around collision tunneling issues, but keep in mind doing so will increase CPU usage. See also ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxFps"},{"text":" and ","type":"text"},{"code":"ProjectSettings\/physics\/common\/physicsTicksPerSecond","type":"codeVoice"},{"text":".","type":"text"}],"role":"symbol"}}}