t3d\/param\/indirectenergy"},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/Param/intensity":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/Param\/intensity","url":"\/documentation\/swiftgodot\/light3d\/param\/intensity","abstract":[{"type":"text","text":"Constant for accessing "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/lightIntensityLumens","type":"reference","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/lightIntensityLux","isActive":true},{"type":"text","text":". Only used when "},{"code":"ProjectSettings\/rendering\/lightsAndShadows\/usePhysicalLightUnits","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":".","type":"text"}],"title":"Light3D.Param.intensity","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"intensity","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/DirectionalLight3D/directionalShadowMaxDistance":{"title":"directionalShadowMaxDistance","type":"topic","abstract":[{"text":"The maximum distance for shadow splits. Increasing this value will make directional shadows visible from further away, at the cost of lower overall shadow detail and performance (since more objects need to be included in the directional shadow rendering).","type":"text"}],"url":"\/documentation\/swiftgodot\/directionallight3d\/directionalshadowmaxdistance","kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"directionalShadowMaxDistance","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowMaxDistance"},"doc://SwiftGodot/documentation/SwiftGodot/SpotLight3D/spotAngle":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAngle","url":"\/documentation\/swiftgodot\/spotlight3d\/spotangle","abstract":[{"text":"The spotlight’s angle in degrees.","type":"text"}],"title":"spotAngle","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"spotAngle","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/shadowTransmittanceBias":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/shadowTransmittanceBias","abstract":[],"role":"symbol","title":"shadowTransmittanceBias","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"shadowTransmittanceBias"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/light3d\/shadowtransmittancebias","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/DirectionalLight3D/directionalShadowFadeStart":{"type":"topic","role":"symbol","kind":"symbol","title":"directionalShadowFadeStart","url":"\/documentation\/swiftgodot\/directionallight3d\/directionalshadowfadestart","abstract":[{"text":"Proportion of ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowMaxDistance","isActive":true,"type":"reference"},{"text":" at which point the shadow starts to fade. At ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowMaxDistance"},{"type":"text","text":", the shadow will disappear. The default value is a balance between smooth fading and distant shadow visibility. If the camera moves fast and the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowMaxDistance","type":"reference","isActive":true},{"text":" is low, consider lowering ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowFadeStart","type":"reference","isActive":true},{"text":" below ","type":"text"},{"code":"0.8","type":"codeVoice"},{"type":"text","text":" to make shadow transitions less noticeable. On the other hand, if you tuned "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowMaxDistance","type":"reference"},{"text":" to cover the entire scene, you can set ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowFadeStart","isActive":true,"type":"reference"},{"type":"text","text":" to "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" to prevent the shadow from fading in the distance (it will suddenly cut off instead)."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowFadeStart","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"directionalShadowFadeStart"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/lightIntensityLumens":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/lightIntensityLumens","url":"\/documentation\/swiftgodot\/light3d\/lightintensitylumens","abstract":[{"type":"text","text":"Used by positional lights ("},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D","type":"reference","isActive":true},{"text":") when ","type":"text"},{"code":"ProjectSettings\/rendering\/lightsAndShadows\/usePhysicalLightUnits","type":"codeVoice"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":". Sets the intensity of the light source measured in Lumens. Lumens are a measure of luminous flux, which is the total amount of visible light emitted by a light source per unit of time."}],"title":"lightIntensityLumens","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"lightIntensityLumens","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}]},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/Param/shadowBlur":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/Param\/shadowBlur","url":"\/documentation\/swiftgodot\/light3d\/param\/shadowblur","abstract":[{"text":"Constant for accessing ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/Param\/shadowBlur","isActive":true},{"type":"text","text":"."}],"title":"Light3D.Param.shadowBlur","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"shadowBlur","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/Param/shadowPancakeSize":{"kind":"symbol","type":"topic","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/Param\/shadowPancakeSize","url":"\/documentation\/swiftgodot\/light3d\/param\/shadowpancakesize","abstract":[{"type":"text","text":"Constant for accessing "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowPancakeSize","isActive":true,"type":"reference"},{"type":"text","text":"."}],"title":"Light3D.Param.shadowPancakeSize","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"shadowPancakeSize","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/lightIndirectEnergy":{"identifier":"doc:\/\/SwiftGodot\/docu