","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/light3d\/shadowenabled","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/shadowEnabled","title":"shadowEnabled","abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"text":", the light will cast real-time shadows. This has a significant performance cost. Only enable shadow rendering when it makes a noticeable difference in the scene’s appearance, and consider using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/distanceFadeEnabled"},{"type":"text","text":" to hide the light when far away from the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera3D","type":"reference","isActive":true},{"text":".","type":"text"}],"kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/distanceFadeEnabled":{"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"distanceFadeEnabled","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/light3d\/distancefadeenabled","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/distanceFadeEnabled","title":"distanceFadeEnabled","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", the light will smoothly fade away when far from the active ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera3D"},{"type":"text","text":" starting at "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/distanceFadeBegin","type":"reference","isActive":true},{"type":"text","text":". This acts as a form of level of detail (LOD). The light will fade out over "},{"identifier":"doc:\