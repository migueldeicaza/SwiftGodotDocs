{"abstract":[{"type":"text","text":"Configures throttle parameter for a peer."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer"]]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/throttleConfigure(interval:acceleration:deceleration:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/swiftgodot\/enetpacketpeer\/throttleconfigure(interval:acceleration:deceleration:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"externalID":"s:10SwiftGodot14ENetPacketPeerC17throttleConfigure8interval12acceleration12decelerationys5Int32V_A2ItF","symbolKind":"method","modules":[{"name":"SwiftGodot"}],"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"throttleConfigure"},{"kind":"text","text":"("},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","kind":"typeIdentifier","text":"Int32"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"acceleration"},{"kind":"text","text":": "},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"kind":"text","text":", "},{"text":"deceleration","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int32V","kind":"typeIdentifier","text":"Int32"},{"kind":"text","text":")"}],"title":"throttleConfigure(interval:acceleration:deceleration:)","role":"symbol","roleHeading":"Instance Method"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"throttleConfigure"},{"kind":"text","text":"("},{"text":"interval","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"acceleration"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"deceleration"},{"kind":"text","text":": "},{"preciseIdentifier":"s:s5Int32V","text":"Int32","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Unreliable packets are dropped by ENet in response to the varying conditions of the Internet connection to the peer. The throttle represents a probability that an unreliable packet should not be dropped and thus sent by ENet to the peer. By measuring fluctuations in round trip times of reliable packets over the specified "},{"type":"codeVoice","code":"interval"},{"text":", ENet will either increase the probability by the amount specified in the ","type":"text"},{"type":"codeVoice","code":"acceleration"},{"text":" parameter, or decrease it by the amount specified in the ","type":"text"},{"type":"codeVoice","code":"deceleration"},{"text":" parameter (both are ratios to ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/packetThrottleScale"},{"type":"text","text":")."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"When the throttle has a value of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/packetThrottleScale"},{"text":", no unreliable packets are dropped by ENet, and so 100% of all unreliable packets will be sent.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the throttle has a value of "},{"type":"codeVoice","code":"0"},{"type":"text","text":", all unreliable packets are dropped by ENet, and so 0% of all unreliable packets will be sent."}]},{"inlineContent":[{"text":"Intermediate values for the throttle represent intermediate probabilities between 0% and 100% of unreliable packets being sent. The bandwidth limits of the local and foreign hosts are taken into account to determine a sensible limit for the throttle probability above which it should not raise even in the best of conditions.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/ENetPacketPeer/packetThrottleScale":{"kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"kind":"text","text":" "},{"text":"packetThrottleScale","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Si","text":"Int"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/packetThrottleScale","title":"packetThrottleScale","url":"\/documentation\/swiftgodot\/enetpacketpeer\/packetthrottlescale","abstract":[{"type":"text","text":"The reference value for throttle configuration. The default value is "},{"type":"codeVoice","code":"32"},{"type":"text","text":". See "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/throttleConfigure(interval:acceleration:deceleration:)","type":"reference"},{"type":"text","text":"."}],"role":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/ENetPacketPeer":{"navigatorTitle":[{"text":"ENetPacketPeer","kind":"identifier"}],"role":"symbol","abstract":[{"text":"A wrapper class for an ","type":"text"},{"text":"ENetPeer","type":"text"},{"type":"text","text":"."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ENetPacketPeer","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/enetpacketpeer","ti