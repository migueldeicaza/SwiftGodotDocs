{"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Configures throttle parameter for a peer."}],"sections":[],"variants":[{"paths":["\/documentation\/swiftgodot\/enetpacketpeer\/throttleconfigure(interval:acceleration:deceleration:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/throttleConfigure(interval:acceleration:deceleration:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"throttleConfigure","kind":"identifier"},{"text":"(","kind":"text"},{"text":"interval","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"},{"kind":"text","text":", "},{"kind":"externalParam","text":"acceleration"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"deceleration"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"text":")","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Unreliable packets are dropped by ENet in response to the varying conditions of the Internet connection to the peer. The throttle represents a probability that an unreliable packet should not be dropped and thus sent by ENet to the peer. By measuring fluctuations in round trip times of reliable packets over the specified "},{"code":"interval","type":"codeVoice"},{"type":"text","text":", ENet will either increase the probability by the amount specified in the "},{"type":"codeVoice","code":"acceleration"},{"type":"text","text":" parameter, or decrease it by the amount specified in the "},{"code":"deceleration","type":"codeVoice"},{"type":"text","text":" parameter (both are ratios to "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/packetThrottleScale","isActive":true},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the throttle has a value of "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/packetThrottleScale","isActive":true,"type":"reference"},{"type":"text","text":", no unreliable packets are dropped by ENet, and so 100% of all unreliable packets will be sent."}]},{"type":"paragraph","inlineContent":[{"text":"When the throttle has a value of ","type":"text"},{"code":"0","type":"codeVoice"},{"text":", all unreliable packets are dropped by ENet, and so 0% of all unreliable packets will be sent.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Intermediate values for the throttle represent intermediate probabilities between 0% and 100% of unreliable packets being sent. The bandwidth limits of the local and foreign hosts are taken into account to determine a sensible limit for the throttle probability above which it should not raise even in the best of conditions."}]}]}],"metadata":{"role":"symbol","modules":[{"name":"SwiftGodot"}],"roleHeading":"Instance Method","title":"throttleConfigure(interval:acceleration:deceleration:)","externalID":"s:10SwiftGodot14ENetPacketPeerC17throttleConfigure8interval12acceleration12decelerationys5Int32V_A2ItF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"throttleConfigure"},{"kind":"text","text":"("},{"text":"interval","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"acceleration"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"},{"kind":"text","text":", "},{"text":"deceleration","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int32","preciseIdentifier":"s:s5Int32V"},{"kind":"text","text":")"}],"symbolKind":"method"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer"]]},"kind":"symbol","references":{"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/ENetPacketPeer":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer","title":"ENetPacketPeer","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ENetPacketPeer","kind":"identifier"}],"abstract":[{"type":"text","text":"A wrapper class for an "},{"text":"ENetPeer","type":"text"},{"type":"text","text":"."}],"url":"\/documentation\/swiftgodot\/enetpacketpeer","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ENetPacketPeer"}],"kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/ENetPacketPeer/throttleConfigure(interval:acceleration:deceleration:)":{"type":"topic","abstract":[{"text":"Configures throttle parameter for a peer.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetPacketPeer\/throttleConfigure(interval:acceleration:deceleration:)","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"throttleConfigure","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"interval"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:s5Int3