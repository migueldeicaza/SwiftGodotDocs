{"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","interfaceLanguage":"swift"},"kind":"article","seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"],"title":"Articles and Tutorials"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/variants"]}],"metadata":{"title":"Variants","role":"article","modules":[{"name":"SwiftGodot"}],"roleHeading":"Article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"type":"text","text":"Follow up on the fundamental building block of Godot’s data types."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"text":"You will often find the type ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true},{"text":" in Godot source code.   Variants are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Godot’s way of passing around certain data types.  They are similar to Swift’s"},{"type":"text","text":" "},{"code":"Any","type":"codeVoice"},{"text":" type, but they can only hold Godot types (most structures and classes","type":"text"},{"text":" ","type":"text"},{"text":"that derive from ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","isActive":true},{"text":").","type":"text"}]},{"level":2,"type":"heading","anchor":"Creating-Variant-values","text":"Creating Variant values"},{"type":"paragraph","inlineContent":[{"text":"You can create Variants from types that conform to the VariantStorable","type":"text"},{"type":"text","text":" "},{"text":"protocol.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This includes the following types:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Godot’s native types: GString, Vector, Rect, Transform, Plane, Quaternion,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"AABB,  Basis, Projection, Int64, NodePaths, RIDs, Callable, GDictionary, Array"},{"type":"text","text":" "},{"text":"and PackedArrays.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Swift types that SwiftGodot adds convenience conformances for: Bool, Int, String and Float","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Godot’s objects: e.g. Node, Area2D"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Your own subclasses of SwiftGodot.Object type.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Other types that you can manually conform to VariantStorable.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You wrap your data type by calling one of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant"},{"type":"text","text":" constructors, and then"},{"text":" ","type":"text"},{"text":"you can pass this variant to Godot functions that expect a ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","isActive":true},{"text":".","type":"text"}]},{"inlineContent":[{"type":"text","text":"For example, to pass the value "},{"type":"codeVoice","code":"true"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["let trueVaraint = Variant (true)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"You can get a string representation of a variant by calling ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true},{"text":"’s","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/description","type":"reference"},{"text":" method:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["print (trueVariant.description)"]},{"type":"heading","text":"Extracting values from Variants","anchor":"Extracting-values-from-Variants","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you know the kind of return that a variant will return, you can invoke the"},{"text":" ","type":"text"},{"type":"text","text":"failing initializer for that specific type for most structures. Every VariantStorable"},{"type":"text","text":" "},{"type":"text","text":"will have an "},{"type":"codeVoice","code":"init(_ variant: Variant)"},{"type":"text","text":" implementation."}]},{"inlineContent":[{"text":"For example, this is how you could get a Vector2 from a variant:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func distance (variant: Variant) -> Float? {","    guard let vector = Vector2 (variant) else {","\treturn nil","    }","    return vector.length ()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Notice that this might return "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", which would be the case if the variant"},{"text":" ","type":"text"},{"type":"text","text":"contains a different type than the one you were expecting. You can check the"},{"text":" ","type":"text"},{"text":"type of the variant by accessing the ","type":"text"},{"code":".gtype","type":"codeVoice"},{"text":" property of the variant.","type":"text"}]},{"type":"heading","text":"Extracting Godot-derived objects from Variants","anchor":"Extracting-Godot-derived-objects-from-Variants","level":2},{"inlineContent":[{"type":"text","text":"Godot-derived objects are slightly different. If you know you have a"},{"type":"text","text":" "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","type":"reference","isActive":true},{"text":" stored in the variant, you can call the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","isActive":true},{"type":"text","text":" "},{"text":"instead.  This is a generic method, so you would invoke it like this:","type":"text"}],"type":"paragraph"},{"code":["func getNode (variant: Variant) -> Node? {","    guard let node = variant.asObject (Node.self)) else {","\t  return nil","    }","    return node","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Swift type inference can also be used, so you can avoid specifying the type if"},{"type":"text","text":" "},{"text":"the compiler can infer the type, like here:","type":"text"}],"type":"paragraph"},{"code":["func getNode (variant: Variant) -> Node? {","    var node: Node?","    node = variant.asObject ()","    return node","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The reason to rely on calling the "},{"code":"asObject","type":"codeVoice"},{"text":" method rather than having a","type":"text"},{"text":" ","type":"text"},{"text":"constructor for the type that takes a variant (like the case for the non-object","type":"text"},{"type":"text","text":" "},{"text":"types) is that the method can ensure that only one instance of your objects is surfaced to Swift.","type":"text"}]},{"level":2,"text":"Accessing Array Elements","type":"heading","anchor":"Accessing-Array-Elements"},{"type":"paragraph","inlineContent":[{"text":"Some of the variant types contain arrays, either objects, or a particular","type":"text"},{"text":" ","type":"text"},{"text":"packed version of those.   You can access the individual elements of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"those with a convenient subscript provided on the array."}]},{"level":2,"anchor":"Calling-Variant-Methods","type":"heading","text":"Calling Variant Methods"},{"type":"paragraph","inlineContent":[{"text":"It is possible to invoke the built-in variant methods that exist in the Godot","type":"text"},{"type":"text","text":" "},{"type":"text","text":"universe by using the "},{"code":"call","type":"codeVoice"},{"type":"text","text":" method on a Variant.   This is very similar to the"},{"text":" ","type":"text"},{"text":"call method on an Object.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For example, you can invoke this generic “size” method on an array to get the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"size of an array, regardless of the specific type of array:"}]},{"syntax":"swift","code":["func printSize (myArray: Variant) {","    switch variant.call(method: \"size\") {","    case .failure(let err):","        print (err)","        return 0","    case .success(let val):","        return Int (val) ?? 0","    }","}"],"type":"codeListing"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Variant/asObject(_:)":{"title":"asObject(_:)","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"asObject"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"T"},{"text":".Type) -> ","kind":"text"},{"kind":"typeIdentifier","text":"T"},{"text":"?","kind":"text"}],"role":"symbol","url":"\/documentation\/swiftgodot\/variant\/asobject(_:)","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","type":"topic","abstract":[{"text":"Attempts to cast the Variant into a GodotObject, if the variant contains a value of type ","type":"text"},{"code":".object","type":"codeVoice"},{"type":"text","text":", then"},{"type":"text","text":" "},{"text":"a ","type":"text"},{"code":".object, the value ","type":"codeVoice"},{"type":"text","text":"nil` is returned."}]},"doc://SwiftGodot/documentation/SwiftGodot/BindingNodes":{"kind":"article","url":"\/documentation\/swiftgodot\/bindingnodes","title":"Referencing Nodes from your Scene","abstract":[{"text":"You will find yourself referencing nodes from a scene in your code.   In","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GDScript, that is usually achieved by using the dollar sign and the name of the"},{"type":"text","text":" "},{"text":"object you want to reference.","type":"text"}],"role":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes"},"doc://SwiftGodot/documentation/SwiftGodot/Variant/description":{"kind":"symbol","type":"topic","url":"\/documentation\/swiftgodot\/variant\/description","title":"description","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/description","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"description"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"abstract":[]},"doc://SwiftGodot/documentation/SwiftGodot/GodotObject":{"navigatorTitle":[{"kind":"identifier","text":"GodotObject"}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"GodotObject","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","url":"\/documentation\/swiftgodot\/godotobject","abstract":[{"type":"text","text":"Protocol implemented by the built-in classes in Godot to allow to be wrapped in a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true}],"title":"GodotObject"},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"type":"topic","url":"\/documentation\/swiftgodot\/exports","title":"Exports","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","kind":"article","abstract":[{"text":"In Godot, class members can be exported. This means their value gets saved along","type":"text"},{"type":"text","text":" "},{"text":"with the resource (such as the scene) they’re attached to. They will also be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"available for editing in the property editor. Exporting is done by using the"}]},"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"type":"topic","url":"\/documentation\/swiftgodot\/signals","title":"Signals","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","kind":"article","abstract":[{"type":"text","text":"Signals in Godot are used by objects to post interesting events that are"},{"type":"text","text":" "},{"text":"taking place, and can be used by users to easily add behavior and react","type":"text"},{"type":"text","text":" "},{"text":"to changes.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/RunningInEditor":{"type":"topic","url":"\/documentation\/swiftgodot\/runningineditor","title":"Running Code in the Godot Editor","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor","kind":"article","abstract":[{"text":"There are cases where you might want some of your Swift code for your extension","type":"text"},{"type":"text","text":" "},{"text":"to run while it is being used in the Godot Editor.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot":{"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","abstract":[{"text":"Framework to write Godot Game Extensions using the Swift Programming Language.","type":"text"}],"kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"type":"topic","url":"\/documentation\/swiftgodot\/customtypes","title":"Using Custom Types","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","kind":"article","abstract":[{"text":"You will typically extend the functionality of your Godot game by creating","type":"text"},{"type":"text","text":" "},{"text":"classes that derive from one of the various Godot types and adjust the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior accordingly."}]},"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"type":"topic","url":"\/documentation\/swiftgodot\/differences","title":"SwiftGodot API differences to GDScript","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","kind":"article","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}]},"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Variant"}],"url":"\/documentation\/swiftgodot\/variant","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Variant"}],"type":"topic","title":"Variant","abstract":[{"text":"Variant objects box various Godot Objects, you create them with one of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructors, and you can retrieve the contents using the various extension"},{"text":" ","type":"text"},{"text":"constructors that are declared on the various types that are wrapped.","type":"text"}],"kind":"symbol"}}}