{"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint\/flags","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"flags","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The hint string is a comma separated list of names such as "},{"code":"\"Bit0,Bit1,Bit2,Bit3\"","type":"codeVoice"},{"type":"text","text":". Whitespaces are "},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" removed from either end of a name. The first name in the list has value 1, the next 2, then 4, 8, 16 and so on. Explicit values can also be specified by appending "},{"code":":integer","type":"codeVoice"},{"type":"text","text":" to the name, e.g. "},{"code":"\"A:4,B:8,C:16\"","type":"codeVoice"},{"text":". You can also combine several flags (","type":"text"},{"type":"codeVoice","code":"\"A:4,B:8,AB:12,C:16\""},{"text":").","type":"text"}]},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A flag value must be at least "},{"type":"codeVoice","code":"1"},{"text":" and at most ","type":"text"},{"type":"codeVoice","code":"2 ** 32 - 1"},{"text":".","type":"text"}]}],"type":"aside","style":"note"},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Unlike ``PropertyHint\/"},{"code":"enum```, the previous explicit value is not taken into account. For the hint ","type":"codeVoice"},{"text":"“A:16,B,C”`, A is 16, B is 2, C is 4.","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/propertyhint\/flags"]}],"metadata":{"modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot12PropertyHintO5flagsyA2CmF","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"flags"}],"role":"symbol","roleHeading":"Case","title":"PropertyHint.flags","symbolKind":"case"},"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint"]]},"kind":"symbol","abstract":[{"text":"Hints that an integer property is a bitmask with named bit flags.","type":"text"}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/PropertyHint/flags":{"url":"\/documentation\/swiftgodot\/propertyhint\/flags","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"flags","kind":"identifier"}],"kind":"symbol","role":"symbol","title":"PropertyHint.flags","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint\/flags","type":"topic","abstract":[{"type":"text","text":"Hints that an integer property is a bitmask with named bit flags."}]},"doc://SwiftGodot/documentation/SwiftGodot/PropertyHint":{"type":"topic","url":"\/documentation\/swiftgodot\/propertyhint","role":"symbol","kind":"symbol","navigatorTitle":[{"text":"PropertyHint","kind":"identifier"}],"title":"PropertyHint","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PropertyHint","kind":"identifier"}],"abstract":[],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint"},"doc://SwiftGodot/documentation/SwiftGodot":{"kind":"symbol","url":"\/documentation\/swiftgodot","title":"SwiftGodot","role":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"}}}