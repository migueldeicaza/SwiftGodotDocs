{"abstract":[{"type":"text","text":"Hints that an integer property is a bitmask with named bit flags."}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/propertyhint\/flags"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"roleHeading":"Case","modules":[{"name":"SwiftGodot"}],"symbolKind":"case","externalID":"s:10SwiftGodot12PropertyHintO5flagsyA2CmF","role":"symbol","title":"PropertyHint.flags","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"flags","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"flags","kind":"identifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The hint string is a comma separated list of names such as "},{"code":"\"Bit0,Bit1,Bit2,Bit3\"","type":"codeVoice"},{"type":"text","text":". Whitespaces are "},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" removed from either end of a name. The first name in the list has value 1, the next 2, then 4, 8, 16 and so on. Explicit values can also be specified by appending "},{"code":":integer","type":"codeVoice"},{"type":"text","text":" to the name, e.g. "},{"type":"codeVoice","code":"\"A:4,B:8,C:16\""},{"text":". You can also combine several flags (","type":"text"},{"type":"codeVoice","code":"\"A:4,B:8,AB:12,C:16\""},{"text":").","type":"text"}]},{"style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"A flag value must be at least ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" and at most ","type":"text"},{"type":"codeVoice","code":"2 ** 32 - 1"},{"type":"text","text":"."}]}],"type":"aside"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Unlike ``PropertyHint\/"},{"code":"enum```, the previous explicit value is not taken into account. For the hint ","type":"codeVoice"},{"text":"“A:16,B,C”`, A is 16, B is 2, C is 4.","type":"text"}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint\/flags","interfaceLanguage":"swift"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/PropertyHint/flags":{"kind":"symbol","title":"PropertyHint.flags","type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/propertyhint\/flags","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint\/flags","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"flags","kind":"identifier"}],"abstract":[{"text":"Hints that an integer property is a bitmask with named bit flags.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/PropertyHint":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PropertyHint","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PropertyHint","url":"\/documentation\/swiftgodot\/propertyhint","navigatorTitle":[{"kind":"identifier","text":"PropertyHint"}],"abstract":[],"type":"topic","title":"PropertyHint","kind":"symbol","role":"symbol"}}}