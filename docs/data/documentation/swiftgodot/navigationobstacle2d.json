{"abstract":[{"text":"2D Obstacle used in navigation to constrain avoidance controlled agents outside or inside an area.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/avoidanceEnabled","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/avoidanceLayers","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/radius","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/velocity","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/vertices"],"title":"Instance Properties"},{"title":"Instance Methods","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/getAvoidanceLayerValue(layerNumber:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/getNavigationMap()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/getRid()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/setAvoidanceLayerValue(layerNumber:value:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/setNavigationMap(_:)"]},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D\/godotClassName"],"title":"Type Properties"}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle2D","interfaceLanguage":"swift"},"metadata":{"symbolKind":"class","title":"NavigationObstacle2D","roleHeading":"Class","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot20NavigationObstacle2DC","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"NavigationObstacle2D"}],"navigatorTitle":[{"text":"NavigationObstacle2D","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NavigationObstacle2D","kind":"identifier"}]}]},{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"2D Obstacle used in navigation to constrain avoidance controlled agents outside or inside an area. The obstacle needs a navigation map and outline vertices defined to work correctly."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the obstacle’s vertices are winded in clockwise order, avoidance agents will be pushed in by the obstacle, otherwise, avoidance agents will be pushed out. Outlines must not cross or overlap."}]},{"type":"paragraph","inlineContent":[{"text":"Obstacles are ","type":"text"},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" a replacement for a (re)baked navigation mesh. Obstacles "},{"type":"strong","inlineContent":[{"text":"don’t","type":"text"}]},{"type":"text","text":" change the resulting path from the pathfinding, obstacles only affect the navigation avoidance agent movement by altering the suggested velocity of the avoidance agent."}]},{"type":"paragraph","inlineContent":[{"text":"Obstacles using vertices can warp to a new position but should not moved every frame as each move requires a rebuild of the avoidance map.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node2D"],"kind":"relationships"},{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships"}],"hierarchy":{"paths":[["doc:\/\/Sw