ifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GDExtension","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot11GDExtensionC"},{"kind":"text","text":"."},{"text":"InitializationLevel","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot11GDExtensionC19InitializationLevelO","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GDExtension\/InitializationLevel"},{"text":") -> ())","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Call this function from your declared Swift entry point passing the three"},{"text":" ","type":"text"},{"type":"text","text":"pointers that you receive from Godot and passing a method that will"},{"text":" ","type":"text"},{"type":"text","text":"be invoked during the various stages of the initialization."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This routine takes OpaquePointers to help you simplify the declaration of"},{"type":"text","text":" "},{"type":"text","text":"your Swift entry point, which can look like this:"}]},{"syntax":"swift","type":"codeListing","code":["@cdecl (\"swift_entry_point\")","public func swift_entry_point (i: OpaquePointer?, l: OpaquePointer?, e: OpaquePointer?) -> UInt8 {","    guard let iface, let lib, let ext else {","        return 0","    }","    initializeSwiftModule (iface, lib, ext, initHook: myInit, deInitHook: myDeinit)","    return 1","}","","func myInit (level: GDExtension.InitializationLevel) {","   if level == .scene {","      registerType (MySpinningCube.self)","   }","}","","func myDeInit (level: GDExtension.InitializationLevel) {","    if level == .scene {","        print (\"Deinitialized\")","    }","}"]},{"items":[{"content":[{"inlineContent":[{"text":"godotGetProcAddrPtr: the first parameter you got on your entry point, it points to the API in Godot to request pointers to the engine functions.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"libraryPtr: the second parameter you entry point gets, it is of type GDExtensionClassLibraryPtr"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"extensionPtr: the third parameter you get, it is of type GDExtensionInitialization and it is filled with our callbacks","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"initHook: this method is invoked repeatedly during the various stages of the extension"},{"type":"text","text":" "},{"type":"text","text":"initialization"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"deInitHook: this method is invoked repeatedly when various stages of the extension are wrapped up","type":"text"}]}]}],"type":"unorderedList"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/initializeSwiftModule(_:_:_:initHook:deInitHook:)"},"metadata":{"role":"symbol","externalID":"s:10SwiftGodot010initializeA6Module___8initHook06deInitF0ys13OpaquePointerV_A2FyAA11GDExtensionC19InitializationLevelOcyAJctF","roleHeading":"Function","modules":[{"name":"SwiftGodot"}],"title":"initializeSwiftModule(_:_:_:initHook:deInitHook:)","symbolKind":"func","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"initializeSwiftModule","kind":"identifier"},{"kind":"text","text":"("},{"text":"OpaquePointer","kind":"typeIdentifier","preciseIdentifier":"s:s13OpaquePointerV"},{"kind":"text","text":", "},{"text":"OpaquePointer","preciseIdentifier":"s:s13OpaquePointerV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"typeIdentifier","text":"OpaquePointer","preciseIdentifier":"s:s13OpaquePointerV"},{"kind":"text","text":", "},{"text":"initHook","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"GDExtension","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot11GDExtensionC"},{"text":".","kind":"t