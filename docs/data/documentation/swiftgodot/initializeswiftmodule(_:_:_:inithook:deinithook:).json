ond parameter you entry point gets, it is of type GDExtensionClassLibraryPtr","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"extensionPtr: the third parameter you get, it is of type GDExtensionInitialization and it is filled with our callbacks"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"initHook: this method is invoked repeatedly during the various stages of the extension"},{"type":"text","text":" "},{"text":"initialization","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"deInitHook: this method is invoked repeatedly when various stages of the extension are wrapped up"}],"type":"paragraph"}]}]}]}],"metadata":{"modules":[{"name":"SwiftGodot"}],"title":"initializeSwiftModule(_:_:_:initHook:deInitHook:)","symbolKind":"func","externalID":"s:10SwiftGodot010initializeA6Module___8initHook06deInitF0ys13OpaquePointerV_A2FyAA11GDExtensionC19InitializationLevelOcyAJctF","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"initializeSwiftModule"},{"text":"(","kind":"text"},{"text":"OpaquePointer","preciseIdentifier":"s:s13OpaquePointerV","kind":"typeIdentifier"},{"kind":"text","text":", "},{"preciseIdentifier":"s:s13OpaquePointerV","text":"OpaquePointer","kind":"typeIdentifier"},{"kind":"text","text":", "},{"preciseIdentifier":"s:s13OpaquePointerV","text":"OpaquePointer","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"initHook","kind":"externalParam"},{"kind":"text","text":": ("},{"text":"GDExtension","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot11GDExtensionC"},{"text":".","kind":"text"},{"text":"InitializationLevel","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot11GDExtensionC19InitializationLevelO"},{"kind":"text","text":") -> (), "},{"kind":"externalParam","text":"deInitHook"},{"text":": (","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot11GDExtensionC","text":"GDExtension","kind":"t