{"abstract":[{"text":"Rotates the node so that the local forward axis (-Z, ","type":"text"},{"type":"codeVoice","code":"Vector3.FORWARD"},{"type":"text","text":") points toward the "},{"code":"target","type":"codeVoice"},{"text":" position.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node3D"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot6Node3DC6lookAt6target2up13useModelFrontyAA7Vector3V_AISbtF","title":"lookAt(target:up:useModelFront:)","symbolKind":"method","roleHeading":"Instance Method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"lookAt","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"target"},{"kind":"text","text":": "},{"text":"Vector3","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7Vector3V"},{"text":", ","kind":"text"},{"text":"up","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7Vector3V","text":"Vector3"},{"text":", ","kind":"text"},{"text":"useModelFront","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":")","kind":"text"}]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node3D\/lookAt(target:up:useModelFront:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"lookAt","kind":"identifier"},{"text":"(","kind":"text"},{"text":"target","kind":"externalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Vector3","text":"Vector3","preciseIdentifier":"s:10SwiftGodot7Vector3V","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"up"},{"text":": ","kind":"text"},{"text":"Vector3","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7Vector3V","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Vector3"},{"text":" = Vector3 (x: 0, y: 1, z: 0), ","kind":"text"},{"text":"useModelFront","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":" = false)","kind":"text"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"The local up axis (+Y) points as close to the ","type":"text"},{"type":"codeVoice","code":"up"},{"type":"text","text":" vector as possible while staying perpendicular to the local forward axis. The resulting transform is orthogonal, and the scale is preserved. Non-uniform scaling may not work correctly."}]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"target","type":"codeVoice"},{"text":" position cannot be the same as the node’s position, the ","type":"text"},{"type":"codeVoice","code":"up"},{"text":" vector cannot be zero, and the direction from the node’s position to the ","type":"text"},{"code":"target","type":"codeVoice"},{"text":" vector cannot be parallel to the ","type":"text"},{"type":"codeVoice","code":"up"},{"type":"text","text":" vector."}]},{"inlineContent":[{"type":"text","text":"Operations take place in global space, which means that the node must be in the scene tree."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"useModelFront"},{"type":"text","text":" is "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the +Z axis (asset front) is treated as forward (implies +X is left) and points toward the "},{"code":"target","type":"codeVoice"},{"text":" position. By default, the -Z axis (ca