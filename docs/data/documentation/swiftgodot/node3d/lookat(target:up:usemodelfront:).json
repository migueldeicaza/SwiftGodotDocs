{"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Rotates the node so that the local forward axis (-Z, ","type":"text"},{"code":"Vector3.FORWARD","type":"codeVoice"},{"type":"text","text":") points toward the "},{"code":"target","type":"codeVoice"},{"text":" position.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/node3d\/lookat(target:up:usemodelfront:)"]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node3D"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"lookAt","kind":"identifier"},{"kind":"text","text":"("},{"text":"target","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Vector3","kind":"typeIdentifier","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Vector3","preciseIdentifier":"s:10SwiftGodot7Vector3V"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"up"},{"text":": ","kind":"text"},{"text":"Vector3","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Vector3","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7Vector3V"},{"text":" = Vector3 (x: 0, y: 1, z: 0), ","kind":"text"},{"text":"useModelFront","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":" = false)","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The local up axis (+Y) points as close to the "},{"type":"codeVoice","code":"up"},{"text":" vector as possible while staying perpendicular to the local forward axis. The resulting transform is orthogonal, and the scale is pre