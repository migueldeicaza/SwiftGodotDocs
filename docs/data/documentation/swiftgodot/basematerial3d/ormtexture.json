ftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/ormTexture":{"role":"symbol","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/ormTexture","kind":"symbol","title":"ormTexture","abstract":[{"type":"text","text":"The Occlusion\/Roughness\/Metallic texture to use. This is a more efficient replacement of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/aoTexture"},{"type":"text","text":", "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/roughnessTexture","isActive":true},{"type":"text","text":" and "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/metallicTexture","isActive":true},{"type":"text","text":" in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ORMMaterial3D"},{"type":"text","text":". Ambient occlusion is stored in the red channel. Roughness map is stored in the green channel. Metallic map is stored in the blue channel. The alpha channel is ignored."}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"ormTexture","kind":"identifier"},{"kind":"text","text":": "},{"text":"Texture2D","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot9Texture2DC"},{"kind":"text","text":"?"}],"url":"\/documentation\/swiftgodot\/basematerial3d\/ormtexture"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/roughness":{"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/roughness","kind":"symbol","title":"roughness","type":"topic","url":"\/documentation\/swiftgodot\/basematerial3d\/roughness","abstract":[{"text":"Surface reflection. A value of ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":" represents a perfect mirror while a value of "},{"code":"1","type":"codeVoice"},{"text":" completely blurs the reflection. See also ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/metallic","type":"reference","isActive":true},{"type":"text","text":"."}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"roughness"},{"kind":"text","text":": "},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/metallic":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/metallic","abstract":[{"text":"A high value makes the material appear more like a metal. Non-metals use their albedo as the diffuse color and add diffuse to the specular reflection. With non-metals, the reflection appears on top of the albedo color. Metals use their albedo as a multiplier to the specular reflection and set the diffuse color to black resulting in a tinted reflection. Materials work better when fully metal or fully non-metal, values between ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"1"},{"type":"text","text":" should only be used for blending between metal and non-metal sections. To alter the amount of reflection use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/roughness"},{"type":"text","text":"."}],"url":"\/documentation\/swiftgodot\/basematerial3d\/metallic","title":"metallic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"metallic","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"type":"topic","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Texture2D":{"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Texture2D","title":"Texture2D","role":"symbol","abstract":[{"type":"text","text":"Texture for 2D and 3D."}],"type":"topic","url":"\/documentation\/swiftgodot\/texture2d","navigatorTitle":[{"text":"Texture2D","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Texture2D","kind":"identifier"}]}}}