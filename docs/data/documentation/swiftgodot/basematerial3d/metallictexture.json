cumentation\/SwiftGodot\/BaseMaterial3D\/metallic","url":"\/documentation\/swiftgodot\/basematerial3d\/metallic","kind":"symbol","title":"metallic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"metallic"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"}],"abstract":[{"text":"A high value makes the material appear more like a metal. Non-metals use their albedo as the diffuse color and add diffuse to the specular reflection. With non-metals, the reflection appears on top of the albedo color. Metals use their albedo as a multiplier to the specular reflection and set the diffuse color to black resulting in a tinted reflection. Materials work better when fully metal or fully non-metal, values between ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":" and "},{"type":"codeVoice","code":"1"},{"type":"text","text":" should only be used for blending between metal and non-metal sections. To alter the amount of reflection use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/roughness"},{"text":".","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/roughness":{"url":"\/documentation\/swiftgodot\/basematerial3d\/roughness","type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/roughness","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"roughness","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"abstract":[{"text":"Surface reflection. A value of ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" represents a perfect mirror while a value of ","type":"text"},{"type":"codeVoice","code":"1"},{"type":"text","text":" completely blurs the reflection. See also "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/metallic","type":"reference"},{"text":".","type":"text"}],"title":"roughness"},"doc://SwiftGodot/documentation/SwiftGodot/Texture2D":{"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Texture2D","kind":"identifier"}],"title":"Texture2D","url":"\/documentation\/swiftgodot\/texture2d","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Texture2D","type":"topic","abstract":[{"text":"Texture for 2D and 3D.","type":"text"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Texture2D"}]},"doc://SwiftGodot/documentation/SwiftGodot":{"kind":"symbol","url":"\/documentation\/swiftgodot","title":"SwiftGodot","role":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"BaseMaterial3D"}],"type":"topic","abstract":[{"type":"text","text":"Abstract base class for defining the 3D rendering properties of meshes."}],"title":"BaseMaterial3D","role":"symbol","navigatorTitle":[{"text":"BaseMaterial3D","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/basematerial3d","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/metallicTexture":{"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/metallicTexture","url":"\/documentation\/swiftgodot\/basematerial3d\/metallictexture","kind":"symbol","title":"metallicTexture","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"metallicTexture"},{"text":": ","kind":"text"},{"kind":"typeIdentif