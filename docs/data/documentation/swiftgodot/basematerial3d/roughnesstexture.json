ole":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/roughness":{"url":"\/documentation\/swiftgodot\/basematerial3d\/roughness","type":"topic","role":"symbol","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/roughness","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"roughness","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"abstract":[{"text":"Surface reflection. A value of ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" represents a perfect mirror while a value of ","type":"text"},{"type":"codeVoice","code":"1"},{"type":"text","text":" completely blurs the reflection. See also "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D\/metallic","type":"reference"},{"text":".","type":"text"}],"title":"roughness"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D":{"kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"BaseMaterial3D"}],"type":"topic","abstract":[{"type":"text","text":"Abstract base class for defining the 3D rendering properties of meshes."}],"title":"BaseMaterial3D","role":"symbol","navigatorTitle":[{"text":"BaseMaterial3D","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/basematerial3d","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BaseMaterial3D"},"doc://SwiftGodot/documentation/SwiftGodot/BaseMaterial3D/roughnessTexture":{"role":"symbol","title":"roughnessTexture","url":"\/documentation\/swiftgodot\/basematerial3d\/roughnesstexture","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"roughnessTexture","kind":"identif