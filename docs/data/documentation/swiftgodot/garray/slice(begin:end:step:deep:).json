ative to the end of the array (i.e. ","type":"text"},{"type":"codeVoice","code":"arr.slice(0, -2)"},{"text":" is a shorthand for ","type":"text"},{"type":"codeVoice","code":"arr.slice(0, arr.size() - 2)"},{"type":"text","text":")."}]},{"type":"paragraph","inlineContent":[{"text":"If specified, ","type":"text"},{"code":"step","type":"codeVoice"},{"text":" is the relative index between source elements. It can be negative, then ","type":"text"},{"code":"begin","type":"codeVoice"},{"text":" must be higher than ","type":"text"},{"type":"codeVoice","code":"end"},{"type":"text","text":". For example, "},{"type":"codeVoice","code":"[0, 1, 2, 3, 4, 5].slice(5, 1, -2)"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"[5, 3]"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"deep"},{"type":"text","text":" is true, each element will be copied by value rather than by reference."}]},{"content":[{"inlineContent":[{"type":"text","text":"To include the first element when "},{"code":"step","type":"codeVoice"},{"type":"text","text":" is negative, use "},{"type":"codeVoice","code":"arr.slice(begin, -arr.size() - 1, step)"},{"type":"text","text":" (i.e. "},{"type":"codeVoice","code":"[0, 1, 2].slice(1, -4, -1)"},{"type":"text","text":" returns "},{"code":"[1, 0]","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/Swift