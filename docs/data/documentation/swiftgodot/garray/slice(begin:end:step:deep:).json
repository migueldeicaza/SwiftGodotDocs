{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Returns the slice of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray"},{"type":"text","text":", from "},{"type":"codeVoice","code":"begin"},{"text":" (inclusive) to ","type":"text"},{"code":"end","type":"codeVoice"},{"type":"text","text":" (exclusive), as a new "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","isActive":true,"type":"reference"},{"type":"text","text":"."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray\/slice(begin:end:step:deep:)"},"kind":"symbol","metadata":{"title":"slice(begin:end:step:deep:)","symbolKind":"method","externalID":"s:10SwiftGodot6GArrayC5slice5begin3end4step4deepACs5Int64V_A2JSbtF","modules":[{"name":"SwiftGodot"}],"role":"symbol","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"slice","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"begin"},{"kind":"text","text":": "},{"text":"Int64","kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V"},{"text":", ","kind":"text"},{"text":"end","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int64","kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"step"},{"text":": ","kind":"text"},{"text":"Int64","kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"deep"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot6GArrayC","text":"GArray"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text