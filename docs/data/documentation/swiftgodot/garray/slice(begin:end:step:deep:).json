text":" is a shorthand for "},{"type":"codeVoice","code":"arr.slice(0, arr.size() - 2)"},{"text":").","type":"text"}]},{"inlineContent":[{"type":"text","text":"If specified, "},{"type":"codeVoice","code":"step"},{"type":"text","text":" is the relative index between source elements. It can be negative, then "},{"type":"codeVoice","code":"begin"},{"type":"text","text":" must be higher than "},{"code":"end","type":"codeVoice"},{"type":"text","text":". For example, "},{"type":"codeVoice","code":"[0, 1, 2, 3, 4, 5].slice(5, 1, -2)"},{"type":"text","text":" returns "},{"code":"[5, 3]","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"code":"deep","type":"codeVoice"},{"type":"text","text":" is true, each element will be copied by value rather than by reference."}],"type":"paragraph"},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"To include the first element when "},{"type":"codeVoice","code":"step"},{"text":" is negative, use ","type":"text"},{"type":"codeVoice","code":"arr.slice(begin, -arr.size() - 1, step)"},{"text":" (i.e. ","type":"text"},{"code":"[0, 1, 2].slice(1, -4, -1)","type":"codeVoice"},{"type":"text","text":" returns "},{"type":"codeVoice","code":"[1, 0]"},{"type":"text","text":")."}],"type":"paragraph"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/garray\/slice(begin:end:step:deep:)"]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"},"doc://SwiftGodot/documentation/Swift