{"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/camera2d"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Camera2D"}]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"Camera node for 2D scenes. It forces the screen (current layer) to scroll following this node. This makes it easier (and faster) to program scrollable scenes than manually changing the position of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasItem"},{"type":"text","text":"-based nodes."}]},{"inlineContent":[{"type":"text","text":"Cameras register themselves in the nearest "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport"},{"type":"text","text":" node (when ascending the tree). Only one camera can be active per viewport. If no viewport is available ascending the tree, the camera will register in the global viewport."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This node is intended to be a simple helper to get things going quickly, but more functionality may be desired to change how the camera works. To make your own custom camera node, inherit it from "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node2D","isActive":true,"type":"reference"},{"text":" and change the transform of the canvas by setting ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/canvasTransform","isActive":true,"type":"reference"},{"type":"text","text":" in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport"},{"type":"text","text":" (you can obtain the current "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport"},{"type":"text","text":" by using "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/getViewport()","isActive":true,"type":"reference"},{"text":").","type":"text"}]},{"inlineContent":[{"type":"text","text":"Note that the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D","isActive":true,"type":"reference"},{"type":"text","text":" node’s "},{"type":"codeVoice","code":"position"},{"text":" doesn’t represent the actual position of the screen, which may differ due to applied smoothing or limits. You can use ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/getScreenCenterPosition()","isActive":true,"type":"reference"},{"type":"text","text":" to get the real position."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D"},"topicSections":[{"title":"Instance Properties","generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/anchorMode-swift.property","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/customViewport","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragBottomMargin","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragHorizontalEnabled","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragHorizontalOffset","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragLeftMargin","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragRightMargin","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragTopMargin","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragVerticalEnabled","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/dragVerticalOffset","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Camera2D\/editorDrawDragMargin","doc:\/\