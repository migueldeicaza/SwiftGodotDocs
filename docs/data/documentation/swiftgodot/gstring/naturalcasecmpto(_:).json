{"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"s:10SwiftGodot7GStringC16naturalcasecmpToys5Int64VACF","modules":[{"name":"SwiftGodot"}],"roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"naturalcasecmpTo","kind":"identifier"},{"kind":"text","text":"("},{"text":"GString","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7GStringC"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s5Int64V","kind":"typeIdentifier","text":"Int64"}],"title":"naturalcasecmpTo(_:)","role":"symbol"},"abstract":[{"text":"Performs a ","type":"text"},{"type":"strong","inlineContent":[{"text":"case-sensitive","type":"text"}]},{"type":"text","text":", "},{"type":"emphasis","inlineContent":[{"type":"text","text":"natural order"}]},{"type":"text","text":" comparison to another string. Returns "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" if less than, "},{"code":"1","type":"codeVoice"},{"text":" if greater than, or ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" if equal. “Less than” or “greater than” are determined by the ","type":"text"},{"text":"Unicode code points","type":"text"},{"text":" of each string, which roughly matches the alphabetical order.","type":"text"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"naturalcasecmpTo","kind":"identifier"},{"kind":"text","text":"("},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"to"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10SwiftGodot7GStringC","kind":"typeIdentifier","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString","text":"GString"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s5Int64V","kind":"typeIdentifier","text":"Int64"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"When used for sorting, natural order comparison orders sequences of numbers by the combined value of each digit as is often expected, instead of the single digit’s value. A sorted sequence of numbered strings will be "},{"type":"codeVoice","code":"[\"1\", \"2\", \"3\", ...]"},{"text":", not ","type":"text"},{"type":"codeVoice","code":"[\"1\", \"10\", \"2\", \"3\", ...]"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"With different string lengths, returns ","type":"text"},{"type":"codeVoice","code":"1"},{"text":" if this string is longer than the ","type":"text"},{"type":"codeVoice","code":"to"},{"type":"text","text":" string, or "},{"code":"-1","type":"codeVoice"},{"text":" if shorter. Note that the length of empty strings is ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"always"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"0"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To get a [bool] result from a string comparison, use the ","type":"text"},{"type":"codeVoice","code":"=="},{"type":"text","text":" operator instead. See also "},{"type":"codeVoice","code":"naturalnocasecmpTo(to:)"},{"text":", ","type":"text"},{"type":"codeVoice","code":"nocasecmpTo(to:)"},{"type":"text","text":", and "},{"type":"codeVoice","code":"casecmpTo(to:)"},{"text":".","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/gstring\/naturalcasecmpto(_:)"]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString\/naturalcasecmpTo(_:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString"]]},"references":{"