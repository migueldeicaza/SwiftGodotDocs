{"abstract":[{"type":"text","text":"Performs a "},{"inlineContent":[{"type":"text","text":"case-sensitive"}],"type":"strong"},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"natural order"}]},{"type":"text","text":" comparison to another string. Returns "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" if less than, "},{"code":"1","type":"codeVoice"},{"text":" if greater than, or ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":" if equal. “Less than” or “greater than” are determined by the "},{"type":"text","text":"Unicode code points"},{"text":" of each string, which roughly matches the alphabetical order.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/gstring\/naturalcasecmpto(_:)"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot7GStringC16naturalcasecmpToys5Int64VACF","roleHeading":"Instance Method","title":"naturalcasecmpTo(_:)","symbolKind":"method","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"naturalcasecmpTo"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot7GStringC","kind":"typeIdentifier","text":"GString"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Int64","preciseIdentifier":"s:s5Int64V"}]},"kind":"symbol","identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString\/naturalcasecmpTo(_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"naturalcasecmpTo","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"kind":"internalParam","text":"to"},{"text":": ","kind":"text"},{"text":"GString","preciseIdentifier":"s:10SwiftGodot7GStringC","kind":"typeIdentifier","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString"},{"kind":"text","text":") -> "},{"text":"Int64","kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"When used for sorting, natural order comparison orders sequences of numbers by the combined value of each digit as is often expected, instead of the single digit’s value. A sorted sequence of numbered strings will be "},{"type":"codeVoice","code":"[\"1\", \"2\", \"3\", ...]"},{"text":", not ","type":"text"},{"code":"[\"1\", \"10\", \"2\", \"3\", ...]","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"With different string lengths, returns ","type":"text"},{"type":"codeVoice","code":"1"},{"type":"text","text":" if this string is longer than the "},{"code":"to","type":"codeVoice"},{"text":" string, or ","type":"text"},{"code":"-1","type":"codeVoice"},{"text":" if shorter. Note that the length of empty strings is ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"always","type":"text"}]},{"type":"text","text":" "},{"code":"0","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To get a [bool] result from a string comparison, use the ","type":"text"},{"code":"==","type":"codeVoice"},{"type":"text","text":" operator instead. See also "},{"type":"codeVoice","code":"naturalnocasecmpTo(to:)"},{"type":"text","text":", "},{"code":"filecasecmpTo(to:)","type":"codeVoice"},{"type":"text","text":", and "},{"type":"codeVoice","code":"nocasecmpTo(to:)"},{"type":"text","text":"."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString"]]},"sections":[],"references