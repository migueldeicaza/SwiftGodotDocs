{"metadata":{"modules":[{"name":"SwiftGodot"}],"role":"symbol","title":"naturalnocasecmpTo(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"naturalnocasecmpTo"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"GString","preciseIdentifier":"s:10SwiftGodot7GStringC"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s5Int64V","text":"Int64","kind":"typeIdentifier"}],"externalID":"s:10SwiftGodot7GStringC18naturalnocasecmpToys5Int64VACF","roleHeading":"Instance Method","symbolKind":"method"},"kind":"symbol","abstract":[{"type":"text","text":"Performs a "},{"inlineContent":[{"type":"text","text":"case-insensitive"}],"type":"strong"},{"type":"text","text":", "},{"inlineContent":[{"text":"natural order","type":"text"}],"type":"emphasis"},{"type":"text","text":" comparison to another string. Returns "},{"type":"codeVoice","code":"-1"},{"text":" if less than, ","type":"text"},{"code":"1","type":"codeVoice"},{"type":"text","text":" if greater than, or "},{"code":"0","type":"codeVoice"},{"type":"text","text":" if equal. “Less than” or “greater than” are determined by the "},{"type":"text","text":"Unicode code points"},{"type":"text","text":" of each string, which roughly matches the alphabetical order. Internally, lowercase characters are converted to uppercase for the comparison."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"naturalnocasecmpTo","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"to"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7GStringC","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString","text":"GString"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s5Int64V","text":"Int64","kind":"typeIdentifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"When used for sorting, natural order comparison orders sequences of numbers by the combined value of each digit as is often expected, instead of the single digit’s value. A sorted sequence of numbered strings will be "},{"type":"codeVoice","code":"[\"1\", \"2\", \"3\", ...]"},{"text":", not ","type":"text"},{"type":"codeVoice","code":"[\"1\", \"10\", \"2\", \"3\", ...]"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"With different string lengths, returns "},{"type":"codeVoice","code":"1"},{"type":"text","text":" if this string is longer than the "},{"type":"codeVoice","code":"to"},{"type":"text","text":" string, or "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" if shorter. Note that the length of empty strings is "},{"type":"emphasis","inlineContent":[{"text":"always","type":"text"}]},{"type":"text","text":" "},{"type":"codeVoice","code":"0"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To get a [bool] result from a string comparison, use the ","type":"text"},{"type":"codeVoice","code":"=="},{"type":"text","text":" operator instead. See also "},{"code":"naturalcasecmpTo(to:)","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"filenocasecmpTo(to:)"},{"type":"text","text":", and "},{"code":"casecmpTo(to:)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString"]]},"variants":[{"paths":["\/documentation\/swiftgodot\/gstring\/naturalnocasecmpto(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString\/naturalnocasecmpTo(_:)","interfaceLanguage":"swift"},"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/GString/naturalnocasecmpTo(_:)":{"kind":"symbol","url":"\/documentation\/swiftgodot\/gstring\/naturalnocasecmpto(_:)","role":"symbol","title":"naturalnocasecmpTo(_:)","abstract":[{"text":"Performs a ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"case-insensitive"}]},{"text":", ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"natural order","type":"text"}]},{"type":"text","text":" comparison to another string. Returns "},{"type":"codeVoice","code":"-1"},{"text":" if less than, ","type":"text"},{"code":"1","type":"codeVoice"},{"text":" if greater than, or ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":" if equal. “Less than” or “greater than” are determined by the "},{"type":"text","text":"Unicode code points"},{"type":"text","text":" of each string, which roughly matches the alphabetical order. Internally, lowercase characters are converted to uppercase for the comparison."}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString\/naturalnocasecmpTo(_:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"naturalnocasecmpTo","kind":"identifier"},{"kind":"text","text":"("},{"preciseIdentifier":"s:10SwiftGodot7GStringC","kind":"typeIdentifier","text":"GString"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V","text":"Int64"}]},"doc://SwiftGodot/documentation/SwiftGodot/GString":{"abstract":[{"text":"A built-in type for strings.","type":"text"}],"fr