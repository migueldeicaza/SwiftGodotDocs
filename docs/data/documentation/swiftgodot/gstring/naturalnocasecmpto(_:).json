],"paths":["\/documentation\/swiftgodot\/gstring\/naturalnocasecmpto(_:)"]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","abstract":[{"text":"Framework to write Godot Game Extensions using the Swift Programming Language.","type":"text"}],"kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/GString/naturalnocasecmpTo(_:)":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString\/naturalnocasecmpTo(_:)","kind":"symbol","title":"naturalnocasecmpTo(_:)","abstract":[{"type":"text","text":"Performs a "},{"type":"strong","inlineContent":[{"type":"text","text":"case-insensitive"}]},{"type":"text","text":", "},{"inlineContent":[{"type":"text","text":"natural order"}],"type":"emphasis"},{"type":"text","text":" comparison to another string. Returns "},{"type":"codeVoice","code":"-1"},{"type":"text","text":" if less than, "},{"type":"codeVoice","code":"1"},{"text":" if greater than, or ","type":"text"},{"code":"0","type":"codeVoice"},{"type":"text","text":" if equal. “Less than” or “greater than” are determined by the "},{"text":"Unicode code points","type":"text"},{"type":"text","text":" of each string, which roughly matches the alphabetical order. Internally, lowercase characters are converted to uppercase for the comparison."}],"role":"symbol","url":"\/documentation\/swiftgodot\/gstring\/naturalnocasecmpto(_:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"naturalnocasecmpTo","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot7GStringC","text":"GString","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s5Int64V","text":"Int64","kind":"typeIdentifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/GString":{"url":"\/documentation\/swiftgodot\/gstring","kind":"symbol","identifier":