{"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString\/naturalnocasecmpTo(_:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Performs a "},{"type":"strong","inlineContent":[{"text":"case-insensitive","type":"text"}]},{"text":", ","type":"text"},{"inlineContent":[{"text":"natural order","type":"text"}],"type":"emphasis"},{"text":" comparison to another string. Returns ","type":"text"},{"code":"-1","type":"codeVoice"},{"type":"text","text":" if less than, "},{"code":"1","type":"codeVoice"},{"type":"text","text":" if greater than, or "},{"code":"0","type":"codeVoice"},{"type":"text","text":" if equal. “Less than” or “greater than” are determined by the "},{"type":"text","text":"Unicode code points"},{"text":" of each string, which roughly matches the alphabetical order. Internally, lowercase characters are converted to uppercase for the comparison.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString"]]},"metadata":{"title":"naturalnocasecmpTo(_:)","role":"symbol","modules":[{"name":"SwiftGodot"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"naturalnocasecmpTo"},{"text":"(","kind":"text"},{"text":"GString","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7GStringC"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int64V","text":"Int64"}],"externalID":"s:10SwiftGodot7GStringC18naturalnocasecmpToys5Int64VACF","roleHeading":"Instance Method","symbolKind":"method"},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"naturalnocasecmpTo","kind":"identifier"},{"kind":"text","text":"("},{"text":"_","