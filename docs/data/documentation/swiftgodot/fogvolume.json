nce","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/FogVolumeShape\/cone","isActive":true},{"type":"text","text":", "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/FogVolumeShape\/cylinder","isActive":true,"type":"reference"},{"type":"text","text":", "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/FogVolumeShape\/box"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/FogVolumeShape\/world","type":"reference","isActive":true},{"type":"text","text":"."}],"url":"\/documentation\/swiftgodot\/fogvolume\/shape","role":"symbol","kind":"symbol","title":"shape","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"shape"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot15RenderingServerC","text":"RenderingServer"},{"kind":"text","text":"."},{"text":"FogVolumeShape","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot15RenderingServerC14FogVolumeShapeO"}]},"doc://SwiftGodot/SQ":{"identifier":"doc:\/\/SwiftGodot\/SQ","type":"unresolvable","title":"Swift.Equatable"},"doc://SwiftGodot/documentation/SwiftGodot/RenderingServer/FogVolumeShape/ellipsoid":{"url":"\/documentation\/swiftgodot\/renderingserver\/fogvolumeshape\/ellipsoid","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ellipsoid"}],"role":"symbol","abstract":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FogVolume"},{"type":"text","text":" will be shaped like an ellipsoid (stretched sphere)."}],"title":"RenderingServer.FogVolumeShape.ellipsoid","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/FogVolumeShape\/ellipsoid","kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Environment/vo