{"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/swiftgodot\/animationmixer\/getrootmotionrotationaccumulator()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Retrieve the blended value of the rotation tracks with the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AnimationMixer\/rootMotionTrack","isActive":true,"type":"reference"},{"type":"text","text":" as a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Quaternion"},{"type":"text","text":" that can be used elsewhere."}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AnimationMixer\/getRootMotionRotationAccumulator()","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"getRootMotionRotationAccumulator"},{"kind":"text","text":"() -> "},{"text":"Quaternion","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Quaternion","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot10QuaternionV"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"This is necessary to apply the root motion position correctly, taking rotation into account. See also ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AnimationMixer\/getRootMotionPosition()","type":"reference"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"text","text":"Also, this is useful in cases where you want to respect the initial key values of the animation."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, if an animation with only one key ","type":"text"},{"type":"codeVoice","code":"Quaternion(0, 0, 0, 1)"},{"type":"text","text":" is played in the previous frame and then an animation with only one key "},{"type":"codeVoice","code":"Quaternion(0, 0.707, 0, 0.707)"},{"type":"text","text":" is played in the next frame, the difference can be calculated as follows:"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"However, if the animation loops, an unintended discrete change may occur, so this is only useful for some simple use cases."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"modules":[{"name":"SwiftGodot"}],"symbolKind":"method","title":"getRootMotionRotationAccumulator()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getRootMotionRotationAccumulator"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot10QuaternionV","text":"Quaternion"}],"externalID":"s:10SwiftGodot14AnimationMixerC32getRootMotionRotationAccumulatorAA10QuaternionVyF","role":"symbol","roleHeading":"Instance Method"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AnimationMixer"]]},"sections":[],"kind":"symbol","references":{"doc://SwiftGodot/documentation/SwiftGodot/AnimationMixer/getRootMotionRotationAccumulator()":{"type":"topic","url":"\/documentation\/swiftgodot\/animationmixer\/getrootmotionrotationaccumulator()","title":"getRootMotionRotationAccumulator()","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"getRootMotionRotationAccumulator","kind":"identifier"},{"kind":"text","text":"() -> "},{"preciseIdentifier":"s:10SwiftGodot10QuaternionV","text":"Quaternion","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AnimationMixer\/getRootMotionRotationAccumulator()","abstract":[{"type":"text","text":"Retrieve the blended value of the rotation tracks with the "},{"type":"reference","isActive":true,"identifier":"