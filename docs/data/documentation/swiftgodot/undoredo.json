e "},{"type":"codeVoice","code":"do_*"},{"type":"text","text":" methods will run. If the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/undo()","type":"reference","isActive":true},{"text":" method is used, the ","type":"text"},{"code":"undo_*","type":"codeVoice"},{"text":" methods will run. If the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/redo()","isActive":true},{"type":"text","text":" method is used, once again, all of the "},{"code":"do_*","type":"codeVoice"},{"type":"text","text":" methods will run."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here’s an example on how to add an action:"}],"type":"paragraph"},{"inlineContent":[{"text":"Before calling any of the ","type":"text"},{"type":"codeVoice","code":"add_(un)do_*"},{"type":"text","text":" methods, you need to first call "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/createAction(name:mergeMode:backwardUndoOps:)","isActive":true},{"text":". Afterwards you need to call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/commitAction(execute:)","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you don’t need to register a method, you can leave "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/addDoMethod(callable:)"},{"type":"text","text":" and "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/addUndoMethod(callable:)"},{"type":"text","text":" out; the same goes for properties. You can also register more than one method\/property."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you are making an "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorPlugin","isActive":true,"type":"reference"},{"text":" and want to integrate into the editor’s undo history, use ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager"},{"type":"text","text":" instead."}],"type":"paragraph"},{"inlineContent":[{"text":"If you are registering multiple properties\/method which depend on one another, be aware that by default undo operation are called in the same order they have been added. Therefore instead of grouping do operation with their undo operations it is better to group do on one side and undo on the other as shown below.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This object emits the following signals:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/versionChanged","isActive":true,"type":"reference"}],"type":"paragraph"}]}]}]}],"variants":[{"paths":["\/documentation\/swiftgodot\/undoredo"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo","interfaceLanguage":"swift"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/UndoRedo/undo()":{"abstract":[{"type":"text","text":"Undo the last action."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo\/undo()","title":"undo()","kind":"symbol","url":"\/documentation\/swiftgodot\/undoredo\/undo()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"undo","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/UndoRedo/addUndoMethod(callable:)":{"abstract":[{"text":"Register a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Callable","type":"reference","isActive":true},{"text":" that will be called when the acti