{"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsServer3D","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsServer3D\/AreaParameter"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"gravityPointUnitDistance"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The above is true only when the unit distance is a positive number. When this is set to 0.0, the gravity will be constant regardless of distance."}],"type":"paragraph"}]}],"metadata":{"title":"PhysicsServer3D.AreaParameter.gravityPointUnitDistance","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"gravityPointUnitDistance"}],"role":"symbol","externalID":"s:10SwiftGodot15PhysicsServer3DC13AreaParameterO24gravityPointUnitDistanceyA2EmF","modules":[{"name":"SwiftGodot"}],"symbolKind":"case","roleHeading":"Case"},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsServer3D\/AreaParameter\/gravityPointUnitDistance","interfaceLanguage":"swift"},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/physicsserver3d\/areaparameter\/gravitypointunitdistance"]}],"abstract":[{"text":"Constant to set\/get the distance at which the gravity strength is equal to the gravity controlled by .areaParamGravity. For example, on a planet 100 meters in radius with a surface gravity of 4.0 m\/s², set the gravity to 4.0 and the unit distance to 100.0. The gravity will have falloff according to the inverse square law, so in the example, at 200 meters from the center the gravity will be 1.0 m\/s² (twice the distance, 1\/4th the gravity), at 50 meters it will be 16.0 m\/s² (half the distance, 4x the gravity), and so on.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SwiftGodot/documentation/SwiftGodot/PhysicsServer3D/AreaParameter":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsServer3D\/AreaParameter","title":"PhysicsServer3D.AreaParameter","navigatorTitle":[{"kind":"identifier","text":"AreaParameter"}],"url":"\/documentation\/swiftgodot\/physicsserver3d\/areaparameter","abstract":[],"type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AreaParameter","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/PhysicsServer3D/AreaParameter/gravityPointUnitDistance":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsServer3D\/AreaParameter\/gravityPointUnitDistance","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"gravityPointUnitDistance"}],"role":"symbol","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Constant to set\/get the distance at which the gravity strength is equal to the gravity controlled by .areaParamGravity. For example, on a planet 100 meters in radius with a surface gravity of 4.0 m\/s², set the gravity to 4.0 and the unit distance to 100.0. The gravity will have falloff according to the inverse square law, so in the example, at 200 meters from the center the gravity will be 1.0 m\/s² (twice the distance, 1\/4th the gravity), at 50 meters it will be 16.0 m\/s² (half the distance, 4x the gravity), and so on."}],"url":"\/documentation\/swiftgodot\/physicsserver3d\/areaparameter\/gravitypointunitdistance","title":"PhysicsServer3D.AreaParameter.gravityPointUnitDistance"},"doc://SwiftGodot/documentation/SwiftGodot":{"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","abstract":[{"text":"Framework to write Godot Game Extensions using the Swift Programming Language.","type":"text"}],"kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/PhysicsServer3D":{"kind":"symbol","title":"PhysicsServer3D","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"PhysicsServer3D","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/physicsserver3d","type":"topic","role":"symbol","abstract":[{"type":"text","text":"A server interface for low-level 3D physics access."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsServer3D","navigatorTitle":[{"kind":"identifier","text":"PhysicsServer3D"}]}}}