xt"},{"code":"0.8","type":"codeVoice"},{"type":"text","text":" to make shadow transitions less noticeable. On the other hand, if you tuned "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowMaxDistance","type":"reference"},{"text":" to cover the entire scene, you can set ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowFadeStart","isActive":true,"type":"reference"},{"type":"text","text":" to "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" to prevent the shadow from fading in the distance (it will suddenly cut off instead)."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D\/directionalShadowFadeStart","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"directionalShadowFadeStart"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}]},"doc://SwiftGodot/s23CustomStringConvertibleP":{"identifier":"doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","title":"Swift.CustomStringConvertible","type":"unresolvable"}}}