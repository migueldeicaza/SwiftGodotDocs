,{"type":"text","text":"with no conversion.  These include all of the Variant types from Godot (for"},{"text":" ","type":"text"},{"text":"example ","type":"text"},{"code":"GString","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Rect"},{"type":"text","text":", "},{"code":"Plane","type":"codeVoice"},{"text":"), Godot objects (those that subclass","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SwiftGodot.Object) as well as the built-in Swift types UInt8, Int64 and Double."}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"VariantRepresentable","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","url":"\/documentation\/swiftgodot\/variantrepresentable"},"doc://SwiftGodot/documentation/SwiftGodot/ConcavePolygonShape3D/data":{"title":"data","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"data","kind":"identifier"},{"text":": ","kind":"text"},{"text":"PackedVector3Array","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot18PackedVector3ArrayC"}],"url":"\/documentation\/swiftgodot\/concavepolygonshape3d\/data","role":"symbol","kind":"symbol","abstract":[],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/data"},"doc://SwiftGodot/s23CustomStringConvertibleP":{"title":"Swift.CustomStringConvertible","type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/s23CustomStringConvertibleP"},"doc://SwiftGodot/documentation/SwiftGodot/GodotObject":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","title":"GodotObject","role":"symbol","url":"\/documentation\/swiftgodot\/godotobject","abstract":[{"type":"text","text":"Protocol implemented by the built-in classes in Godot to allow to be wrapped in a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant"}],"type":"topic","kind":"symbol",