{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D"},"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Shape3D"],"kind":"relationships"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"metadata":{"title":"ConcavePolygonShape3D","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"ConcavePolygonShape3D","kind":"identifier"}],"symbolKind":"class","role":"symbol","externalID":"s:10SwiftGodot21ConcavePolygonShape3DC","modules":[{"name":"SwiftGodot"}],"roleHeading":"Class","navigatorTitle":[{"kind":"identifier","text":"ConcavePolygonShape3D"}]},"kind":"symbol","topicSections":[{"title":"Instance Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/backfaceCollision","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/data"]},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/godotClassName"],"title":"Type Properties"}],"abstract":[{"type":"text","text":"A 3D trimesh shape used for physics collision."}],"variants":[{"paths":["\/documentation\/swiftgodot\/concavepolygonshape3d"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"ConcavePolygonShape3D","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"A 3D trimesh shape, intended for use in physics. Usually used to provide a shape for a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CollisionShape3D","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Being just a collection of interconnected triangles, ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true,"type":"reference"},{"text":" is the most freely configurable single 3D shape. It can be used to form polyhedra of any nature, or even shapes that don’t enclose a volume. However, ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true},{"type":"text","text":" is "},{"type":"emphasis","inlineContent":[{"text":"hollow","type":"text"}]},{"type":"text","text":" even if the interconnected triangles do enclose a volume, which often makes it unsuitable for physics or detection."}]},{"style":"note","content":[{"inlineContent":[{"text":"When used for collision, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D"},{"type":"text","text":" is intended to work with static "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CollisionShape3D","isActive":true},{"type":"text","text":" nodes like "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/StaticBody3D","isActive":true},{"text":" and will likely not behave well for ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CharacterBody3D"},{"text":"s or ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RigidBody3D","isActive":true,"type":"reference"},{"type":"text","text":"s in a mode other than Static."}],"type":"paragraph"}],"type":"aside","name":"Note"},{"style":"warning","name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Physics bodies that are small have a chance to clip through this shape when moving fast. This happens because on one frame, the physics body may be on the “outside” of the shape, and on the next frame it may be “inside” it. "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true},{"text":" is hollow, so it won’t detect a collision.","type":"text"}]}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Performance:"}]},{"type":"text","text":" Due to its complexity, "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true},{"type":"text","text":" is the slowest 3D collision shape to check collisions against. Its use should generally be limited to level geometry. For convex geometry, "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","type":"reference"},{"type":"text","text":" should be used. For dynamic physics bodies that need concave collision, several "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","isActive":true,"type":"reference"},{"text":"s can be used to represent its collision by using convex decomposition; see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D"},{"text":"’s documentation for instructions.","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://SwiftGodot/documentation/SwiftGodot/CharacterBody3D":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CharacterBody3D","navigatorTitle":[{"text":"CharacterBody3D","kind":"identifier"}],"type":"topic","title":"CharacterBody3D","kind":"symbol","url":"\/documentation\/swiftgodot\/characterbody3d","abstract":[{"type":"text","text":"A 3D physics body specialized for characters moved by script."}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CharacterBody3D"}]},"doc://SwiftGodot/SH":{"identifier":"doc:\/\/SwiftGodot\/SH","type":"unresolvable","title":"Swift.Hashable"},"doc://SwiftGodot/documentation/SwiftGodot/ConcavePolygonShape3D/backfaceCollision":{"title":"backfaceCollision","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"backfaceCollision"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/swiftgodot\/concavepolygonshape3d\/backfacecollision","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"If set to "},{"type":"codeVoice","code":"true"},{"text":", collisions occur on both sides of the concave shape faces. Otherwise they occur only along the face normals.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/backfaceCollision"},"doc://SwiftGodot/documentation/SwiftGodot/StaticBody3D":{"title":"StaticBody3D","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StaticBody3D","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/staticbody3d","role":"symbol","kind":"symbol","abstract":[{"text":"A 3D physics body that can’t be moved by external forces. When moved manually, it doesn’t affect other bodies in its path.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/StaticBody3D","navigatorTitle":[{"kind":"identifier","text":"StaticBody3D"}]},"doc://SwiftGodot/documentation/SwiftGodot/ConcavePolygonShape3D":{"kind":"symbol","url":"\/documentation\/swiftgodot\/conc