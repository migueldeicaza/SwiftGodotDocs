{"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"A 3D trimesh shape used for physics collision."}],"topicSections":[{"title":"Instance Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/backfaceCollision","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/data"]},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D\/godotClassName"]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/concavepolygonshape3d"]}],"relationshipsSections":[{"title":"Inherits From","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Shape3D"],"kind":"relationships","type":"inheritsFrom"},{"type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ConcavePolygonShape3D","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A 3D trimesh shape, intended for use in physics. Usually used to provide a shape for a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CollisionShape3D"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Being just a collection of interconnected triangles, ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true},{"type":"text","text":" is the most freely configurable single 3D shape. It can be used to form polyhedra of any nature, or even shapes that don’t enclose a volume. However, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D"},{"type":"text","text":" is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"hollow"}]},{"text":" even if the interconnected triangles do enclose a volume, which often makes it unsuitable for physics or detection.","type":"text"}]},{"type":"aside","content":[{"inlineContent":[{"type":"text","text":"When used for collision, "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","type":"reference","isActive":true},{"type":"text","text":" is intended to work with static "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CollisionShape3D","type":"reference"},{"type":"text","text":" nodes like "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/StaticBody3D","isActive":true,"type":"reference"},{"type":"text","text":" and will likely not behave well for "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CharacterBody3D","type":"reference"},{"type":"text","text":"s or "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RigidBody3D","type":"reference","isActive":true},{"text":"s in a mode other than Static.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Physics bodies that are small have a chance to clip through this shape when moving fast. This happens because on one frame, the physics body may be on the “outside” of the shape, and on the next frame it may be “inside” it. ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true},{"type":"text","text":" is hollow, so it won’t detect a collision."}]}],"name":"Warning","type":"aside","style":"warning"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Performance:"}]},{"text":" Due to its complexity, ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true},{"text":" is the slowest 3D collision shape to check collisions against. Its use should generally be limited to level geometry. For convex geometry, ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D"},{"text":" should be used. For dynamic physics bodies that need concave collision, several ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","type":"reference","isActive":true},{"text":"s can be used to represent its collision by using convex decomposition; see ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D"},{"text":"’s documentation for instructions.","type":"text"}]}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"sections":[],"metadata":{"symbolKind":"class","title":"ConcavePolygonShape3D","roleHeading":"Class","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ConcavePolygonShape3D"}],"navigatorTitle":[{"kind":"identifier","text":"ConcavePolygonShape3D"}],"externalID":"s:10SwiftGodot21ConcavePolygonShape3DC","modules":[{"name":"SwiftGodot"}]},"references":{"doc://SwiftGodot/SQ":{"identifier":"doc:\/\/SwiftGodot\/SQ","type":"unresolvable","title":"Swift.Equatable"},"doc://SwiftGodot/documentation/SwiftGodot/Collision