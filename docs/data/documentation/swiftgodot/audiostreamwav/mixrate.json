{"metadata":{"externalID":"s:10SwiftGodot14AudioStreamWAVC7mixRates5Int32Vvp","symbolKind":"property","modules":[{"name":"SwiftGodot"}],"title":"mixRate","role":"symbol","roleHeading":"Instance Property","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"mixRate","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"}]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamWAV\/mixRate","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"mixRate","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"text":" { ","kind":"text"},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"text":"set","kind":"keyword"},{"kind":"text","text":" }"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"In games, common sample rates in use are "},{"type":"codeVoice","code":"11025"},{"text":", ","type":"text"},{"type":"codeVoice","code":"16000"},{"type":"text","text":", "},{"code":"22050","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"32000"},{"type":"text","text":", "},{"type":"codeVoice","code":"44100"},{"type":"text","text":", and "},{"type":"codeVoice","code":"48000"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"According to the ","type":"text"},{"type":"text","text":"Nyquist-Shannon sampling theorem"},{"type":"text","text":", there is no quality difference to human hearing when going past 40,000 Hz (since most humans can only hear up to ~20,000 Hz, often less). If you are using lower-pitched sounds such as voices, lower sample rates such as "},{"code":"32000","type":"codeVoice"},{"type":"text","text":" or "},{"type":"codeVoice","code":"22050"},{"type":"text","text":" may be usable with no loss in quality."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"text":"The sample rate for mixing this audio. Higher values require more storage space, but result in better quality.","type":"text"}],"variants":[{"paths":["\/documentation\/swiftgodot\/audiostreamwav\/mixrate"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamWAV"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/AudioStreamWAV/mixRate":{"url":"\/documentation\/swiftgodot\/audiostreamwav\/mixrate","kind":"symbol","title":"mixRate","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"mixRate","kind":"identifier"},{"kind":"text","text":": "},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"}],"abstract":[{"type":"text","text":"The sample rate for mixing this audio. Higher values require more storage space, but result in better quality."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamWAV\/mixRate","type":"topic","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/AudioStreamWAV":{"url":"\/documentation\/swiftgodot\/audiostreamwav","abstract":[{"text":"Stores audio data loaded from WAV files.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","title":"AudioStreamWAV","navigatorTitle":[{"text":"AudioStrea