{"abstract":[{"text":"The node’s scale, relative to its ","type":"text"},{"code":"size","type":"codeVoice"},{"type":"text","text":". Change this property to scale the node around its "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Control\/pivotOffset","isActive":true},{"text":". The Control’s ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Control\/tooltipText"},{"text":" will also scale according to this value.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"kind":"text","text":" "},{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"scale","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7Vector2V","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Vector2","text":"Vector2"},{"kind":"text","text":" { "},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"This property is mainly intended to be used for animation purposes. To support multiple resolutions in your project, use an appropriate viewport stretch mode as described in the ","type":"text"},{"text":"documentation","type":"text"},{"text":" instead of scaling Controls individually.","type":"text"}],"type":"paragraph"}],"type":"aside"},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FontFile\/oversampling","isActive":true,"type":"reference"},{"type":"text","text":" does "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" take "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Control"},{"type":"text","text":" "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Control\/scale","isActive":true,"type":"reference"},{"type":"text","text":" into account. This means that scaling up\/down will cause bitmap fonts and rasterized (non-MSDF) dynamic fonts to appear blurry or pixelated. To ensure text remains crisp regardless of scale, you can enable MSDF font rendering by enabling "},{"type":"codeVoice","code":"ProjectSettings\/gui\/theme\/defaultFontMultichannelSignedDistanceField"},{"type":"text","text":" (applies to the default project font only), or enabling "},{"inlineContent":[{"text":"Multichannel Signed Distance Field","type":"text"}],"type":"strong"},{"text":" in the import options of a DynamicFont for custom fonts. On system fonts, ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SystemFont\/multichannelSignedDistanceField","isActive":true,"type":"reference"},{"type":"text","text":" can be enabled in the inspector."}],"type":"paragraph"}],"type":"aside"},{"content":[{"type":"paragraph","inlineContent":[{"text":"If the Control node is a child of a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Container","isActive":true,"type":"reference"},{"type":"text","text":" node, the scale will be reset to "},{"type":"codeVoice","code":"Vector2(1, 1)"},{"type":"text","text":" when the scene is instantiated. To set the Control’s scale when it’s instantiated, wait for one frame using "},{"type":"codeVoice","code":"await get_tree().process_frame"},{"type":"text","text":" then set its "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Control\/scale","type":"reference"},{"text":" property.","type":"text"}]}],"name":"Note","style":"note","type":"aside"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation