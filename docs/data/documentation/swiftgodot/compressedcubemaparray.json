:[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"inlineContent":[{"text":"A cubemap array that is loaded from a ","type":"text"},{"type":"codeVoice","code":".ccubearray"},{"type":"text","text":" file. This file format is internal to Godot; it is created by importing other image formats with the import system. "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedCubemapArray","type":"reference","isActive":true},{"type":"text","text":" can use one of 4 compresson methods:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Lossless (WebP or PNG, uncompressed on the GPU)","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Lossy (WebP, uncompressed on the GPU)","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"VRAM Compressed (compressed on the GPU)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"VRAM Uncompressed (uncompressed on the GPU)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Basis Universal (compressed on the GPU. Lower file sizes than VRAM Compressed, but slower to compress and lower quality than VRAM Compressed)"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only "},{"inlineContent":[{"text":"VRAM Compressed","type":"text"}],"type":"strong"},{"text":" actually reduces the memory usage on the GPU. The ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Lossless"}]},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"text":"Lossy","type":"text"}]},{"type":"text","text":" compression methods will reduce the required storage on disk, but they will not reduce memory usage on the GPU as the texture is sent to the GPU uncompressed."}]},{"type":"paragraph","inlineContent":[{"text":"Using ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"VRAM Compressed"}]},{"text":" also improves loading times, as VRAM-compressed textures are faster to load compared to textures using lossless or lossy compression. VRAM compression can exhibit noticeable artifacts and is intended to be used for 3D rendering, not 2D.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray"},{"type":"text","text":" for a general description of cubemap arrays."}]}]}],"sections":[],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/variant","title":"Variant","kind":"symbol","role":"symbol","type":"topic","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"abstract":[{"text":"Variant objects box various Godot Objects, you create them with one of the","type":"text"},{"type":"text","text":" "},{"text":"constructors, and you can retrieve the contents using the various extension","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constructors that are declared on the various types that are wrapped."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant"},"doc://SwiftGodot/documentation/SwiftGodot/VariantRepresentable":{"kind":"symbol","type":"topic","title":"VariantRepresentable","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRepresentable"}],"abstract":[{"text":"Types that conform to VariantRepresentable can be stored directly in ","type":"text"},{"type":"codeVoice","code":"Variant"},{"type":"text","text":" "},{"type":"text","text":"with no conversion.  These include all of the Variant types from Godot (for"},{"text":" ","type":"text"},{"text":"example ","type":"text"},{"code":"GString","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Rect"},{"type":"text","text":", "},{"c