{"metadata":{"externalID":"s:10SwiftGodot6ThreadC03setC19SafetyChecksEnabledyySbFZ","modules":[{"name":"SwiftGodot"}],"title":"setThreadSafetyChecksEnabled(_:)","roleHeading":"Type Method","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setThreadSafetyChecksEnabled","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"symbolKind":"method"},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread\/setThreadSafetyChecksEnabled(_:)"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"type":"text","text":"Sets whether the thread safety checks the engine normally performs in methods of certain classes (e.g., "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","type":"reference"},{"text":") should happen ","type":"text"},{"inlineContent":[{"type":"text","text":"on the current thread"}],"type":"strong"},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setThreadSafetyChecksEnabled"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"enabled"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"kind":"text","text":")"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"The default, for every thread, is that they are enabled (as if called with "},{"code":"enabled","type":"codeVoice"},{"type":"text","text":" being "},{"code":"true","type":"codeVoice"},{"text":").","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Those checks are conservative. That means that they will only succeed in considering a call thread-safe (and therefore allow it to happen) if the engine can guarantee such safety."}]},{"inlineContent":[{"type":"text","text":"Because of that, there may be cases where the user may want to disable them ("},{"type":"codeVoice","code":"enabled"},{"text":" being ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":") to make certain operations allowed again. By doing so, it becomes the user’s responsibility to ensure thread safety (e.g., by using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Mutex"},{"type":"text","text":") for those objects that are otherwise protected by the engine."}],"type":"paragraph"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This is an advanced usage of the engine. You are advised to use it only if you know what you are doing and there is no safer way."}]}]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This is useful for scripts running on either arbitrary ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread","type":"reference"},{"type":"text","text":" objects or tasks submitted to the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WorkerThreadPool","type":"reference","isActive":true},{"text":". It doesn’t apply to code running during ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","isActive":true,"type":"reference"},{"type":"text","text":" group processing, where the checks will be always performed."}]}],"style":"note"},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Even in the case of having disabled the checks in a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WorkerThreadPool","isActive":true,"type":"reference"},{"type":"text","text":" task, there’s no need to re-enable them at the end. The engine will do so."}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/thread\/setthreadsafetychecksenabled(_:)"]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node":{"url":"\/documentation\/swiftgodot\/node","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","navigatorTitle":[{"text":"Node","kind":"identifier"}],"abstract":[{"type":"text","text":"Base class for all scene objects."}],"role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Node"}],"kind":"symbol","type":"topic","title":"Node"},"doc://SwiftGodot/documentation/SwiftGodot/Thread/setThreadSafetyChecksEnabled(_:)":{"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread\/setThreadSafetyChecksEnabled(_:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setThreadSafetyChecksEnabled","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"text":")","kind":"text"}],"abstract":[{"text":"Sets whether the thread safety checks the engine normally performs in methods of certain classes (e.g., ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","isActive":true},{"text":") should happen ","type":"text"},{"type":"strong","inlineContent":[{"text":"on the current thread","type":"text"}]},{"text":".","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/swiftgodot\/thread\/setthreadsafetychecksenabled(_:)","title":"setThreadSafetyChecksEnabled(_:)"},"doc://SwiftGodot/documentation/SwiftGodot/Thread":{"kind":"symbol","abstract":[{"type":"text","text":"A unit of execution in a process."}],"role":"symbol","type":"topic","navigatorTitle":[{"text":"Thread","kind":"identifier"}],"title":"Thread","url":"\/documentation\/swiftgodot\/thread","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Thread"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread"},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Mutex":{"url":"\/documentation\/swiftgodot\/mutex","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Mutex","kind":"symbol","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Mutex"}],"title":"Mutex","role":"symbol","abstract":[{"type":"text","text":"A binary "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Semaphore","type":"reference","isActive":true},{"text":" for synchronization of multiple ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread","isActive":true,"type":"reference"},{"type":"text","text":"s."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Mutex","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Semaphore":{"role":"symbol","abstract":[{"type":"text","text":"A synchronization mechanism used to control access to a shared resource by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread"},{"type":"text","text":"s."}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Semaphore"}],"kind":"symbol","navigatorTitle":[{"text":"Semaphore","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/semaphore","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Semaphore","title":"Semaphore"},"doc://SwiftGodot/documentation/SwiftGodot/WorkerThreadPool":{"title":"WorkerThreadPool","role":"symbol","abstract":[{"type":"text","text":"A singleton that allocates some "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Thread"},{"text":"s on startup, used to offload tasks to these threads.","type":"text"}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"WorkerThreadPool"}],"navigatorTitle":[{"kind":"identifier","text":"WorkerThreadPool"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WorkerThreadPool","kind":"symbol","url":"\/documentation\/swiftgodot\/workerthreadpool"}}}