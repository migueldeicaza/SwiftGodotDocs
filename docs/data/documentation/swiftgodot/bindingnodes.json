{"kind":"article","metadata":{"title":"Referencing Nodes from your Scene","roleHeading":"Article","role":"article","modules":[{"name":"SwiftGodot"}]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","interfaceLanguage":"swift"},"seeAlsoSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"],"generated":true,"title":"Articles and Tutorials","anchor":"Articles-and-Tutorials"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"With SwiftGodot, you can achieve the same behavior by using the"},{"type":"text","text":" "},{"code":"SceneTreeMacro","type":"codeVoice"},{"text":" macro (or if you are not using Macros, the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindNode"},{"text":" ","type":"text"},{"type":"text","text":"property wrapper.    The macro can produce a nil value if the node is not found,"},{"type":"text","text":" "},{"text":"which forces you to check if it succeeded, and will produce more resilient code","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"as you modify your scenes."}]},{"type":"heading","level":2,"text":"SceneTree","anchor":"SceneTree"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You typically use the "},{"type":"codeVoice","code":"path"},{"type":"text","text":" parameter to specify the path to the node in your"},{"type":"text","text":" "},{"type":"text","text":"scene that you want to reference:"}]},{"code":["@Godot","class Main: Node {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"locations\/spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","}"],"syntax":"swift","type":"codeListing"},{"type":"heading","anchor":"BindNode","text":"BindNode","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"BindNode is an older version, but is not as convenient as using the SceneTree"},{"type":"text","text":" "},{"type":"text","text":"macro."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your class declaration, use the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindNode","type":"reference","isActive":true},{"type":"text","text":" property wrapper like this to"},{"type":"text","text":" "},{"type":"text","text":"reference the nodes that you created with the Godot Editor:"}]},{"type":"codeListing","code":["@Godot","class Main: Node {","    @BindNode(withPath:\"timer\") var startTimer: SwiftGodot.Timer","    @BindNode(withPath:\"music\") var music: AudioStreamPlayer","    @BindNode(withPath:\"mobTimer\") var mobTimer: SwiftGodot.Timer","","    func newGame () {","        startTimer.start ()","    }","}"],"syntax":"swift"},{"inlineContent":[{"text":"If you omit the ","type":"text"},{"type":"codeVoice","code":"withPath"},{"type":"text","text":" parameter, depending on your system, the result might"},{"text":" ","type":"text"},{"type":"text","text":"not resolve at runtime."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/swiftgodot\/bindingnodes"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"You will find yourself referencing nodes from a scene in your code.   In"},{"type":"text","text":" "},{"text":"GDScript, that is usually achieved by using the dollar sign and the name of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"object you want to referenc