{"metadata":{"modules":[{"name":"SwiftGodot"}],"role":"article","roleHeading":"Article","title":"Referencing Nodes from your Scene"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"inlineContent":[{"text":"With SwiftGodot, you can achieve the same behavior by using the","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"SceneTreeMacro"},{"type":"text","text":" macro (or if you are not using Macros, the "},{"code":"BindNode","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"property wrapper.    The macro can produce a nil value if the node is not found,"},{"text":" ","type":"text"},{"text":"which forces you to check if it succeeded, and will produce more resilient code","type":"text"},{"type":"text","text":" "},{"type":"text","text":"as you modify your scenes."}],"type":"paragraph"},{"level":2,"text":"SceneTree","anchor":"SceneTree","type":"heading"},{"inlineContent":[{"type":"text","text":"You typically use the "},{"code":"path","type":"codeVoice"},{"text":" parameter to specify the path to the node in your","type":"text"},{"type":"text","text":" "},{"type":"text","text":"scene that you want to reference:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Godot","class Main: Node {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"locations\/spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","}"]},{"anchor":"BindNode","type":"heading","text":"BindNode","level":2},{"inlineContent":[{"type":"text","text":"BindNode is an older version, but is not as convenient as using the SceneTree"},{"type":"text","text":" "},{"type":"text","text":"macro."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In your class declaration, use the ","type":"text"},{"code":"BindNode","type":"codeVoice"},{"type":"text","text":" property wrapper like this to"},{"type":"text","text":" "},{"text":"reference the nodes that you created with the Godot Editor:","type":"text"}]},{"type":"codeListing","code":["@Godot","class Main: Node {","    @BindNode(withPath:\"timer\") var startTimer: SwiftGodot.Timer","    @BindNode(withPath:\"music\") var music: AudioStreamPlayer","    @BindNode(withPath:\"mobTimer\") var mobTimer: SwiftGodot.Timer","","    func newGame () {","        startTimer.start ()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you omit the ","type":"text"},{"type":"codeVoice","code":"withPath"},{"text":" parameter, depending on your system, the result might","type":"text"},{"type":"text","text":" "},{"text":"not resolve at runtime.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/swiftgodot\/bindingnodes"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"],"title":"Articles and Tutorials"}],"abstract":[{"text":"You will find yourself referencing nodes from a scene in your code.   In","type":"text"},{"type":"text","text":" "},{"type":"text","text":"GDScript, that is usually achieved by using the dollar sign and the name of the"},{"type":"text","text":" "},{"text":"object you want to reference.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"kind":"article","sections":[],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"title":"SwiftGodot API differences to GDScript","url":"\/documentation\/swiftgodot\/differences"},"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","abstract":[{"type":"text","text":"Follow up on the fundamental building block of Godot’s data types."}],"title":"Variants","url":"\/documentation\/swiftgodot\/variants"},"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","abstract":[{"text":"Signals in Godot are used by objects to post interesting events that are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"taking place, and can be used by users to easily add behavior and react"},{"type":"text","text":" "},{"type":"text","text":"to changes."}],"title":"Signals","url":"\/documentation\/swiftgodot\/signals"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","abstract":[{"type":"text","text":"You will typically extend the functionality of your Godot game by creating"},{"type":"text","text":" "},{"type":"text","text":"classes that derive from one of the various Godot types and adjust the"},{"text":" ","type":"text"},{"text":"behavior accordingly.","type":"text"}],"title":"Using Custom Types","url":"\/documentation\/swiftgodot\/customtypes"},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","abstract":[{"type":"text","text":"In Godot, class members can be exported. This means their value gets saved along"},{"type":"text","text":" "},{"type":"text","text":"with the resource (such as the scene) they’re attached to. They will also be"},{"text":" ","type":"text"},{"text":"available for editing in the property editor. Exporting is done by using the","type":"text"}],"title":"Exports","url":"\/documentation\/swiftgodot\/exports"},"doc://SwiftGodot/documentation/SwiftGodot/RunningInEditor":{"type":"topic","abstract":[{"type":"text","text":"There are cases where you might want some of your Swift code for your extension"},{"type":"text","text":" "},{"text":"to run while it is being used in the Godot Editor.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor","role":"article","url":"\/documentation\/swiftgodot\/runningineditor","kind":"article","title":"Running Code in the Godot Editor"},"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"}}}