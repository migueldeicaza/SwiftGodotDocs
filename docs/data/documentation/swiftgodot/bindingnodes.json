{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/bindingnodes"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"With SwiftGodot, you can achieve the same behavior by using the"},{"type":"text","text":" "},{"code":"SceneTreeMacro","type":"codeVoice"},{"text":" macro (or if you are not using Macros, the ","type":"text"},{"code":"BindNode","type":"codeVoice"},{"type":"text","text":" "},{"text":"property wrapper.    The macro can produce a nil value if the node is not found,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which forces you to check if it succeeded, and will produce more resilient code"},{"type":"text","text":" "},{"type":"text","text":"as you modify your scenes."}]},{"text":"SceneTree","anchor":"SceneTree","level":2,"type":"heading"},{"inlineContent":[{"text":"You typically use the ","type":"text"},{"type":"codeVoice","code":"path"},{"text":" parameter to specify the path to the node in your","type":"text"},{"type":"text","text":" "},{"type":"text","text":"scene that you want to reference:"}],"type":"paragraph"},{"code":["@Godot","class Main: Node {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"locations\/spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","}"],"type":"codeListing","syntax":"swift"},{"text":"BindNode","anchor":"BindNode","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"BindNode is an older version, but is not as convenient as using the SceneTree"},{"text":" ","type":"text"},{"type":"text","text":"macro."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your class declaration, use the "},{"code":"BindNode","type":"codeVoice"},{"type":"text","text":" property wrapper like this to"},{"text":" ","type":"text"},{"type":"text","text":"reference the nodes that you created with the Godot Editor:"}]},{"code":["@Godot","class Main: Node {","    @BindNode(withPath:\"timer\") var startTimer: SwiftGodot.Timer","    @BindNode(withPath:\"music\") var music: AudioStreamPlayer","    @BindNode(withPath:\"mobTimer\") var mobTimer: SwiftGodot.Timer","","    func newGame () {","        startTimer.start ()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you omit the "},{"type":"codeVoice","code":"withPath"},{"text":" parameter, depending on your system, the result might","type":"text"},{"type":"text","text":" "},{"type":"text","text":"not resolve at runtime."}]}],"kind":"content"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","interfaceLanguage":"swift"},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"],"title":"Articles and Tutorials"}],"kind":"article","metadata":{"roleHeading":"Article","modules":[{"name":"SwiftGodot"}],"role":"article","title":"Referencing Nodes from your Scene"},"abstract":[{"type":"text","text":"You will find yourself referencing nodes from a scene in your code.   In"},{"type":"text","text":" "},{"text":"GDScript, that is usually achieved by using the dollar sign and the name of the","type":"text"},{"type":"text","text":" "},{"text":"object you want to reference.","type":"text"}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"type":"topic","url":"\/documentation\/swiftgodot\/variants","title":"Variants","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","kind":"article","abstract":[{"text":"Follow up on the fundamental building block of Godot’s data types.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/RunningInEditor":{"type":"topic","url":"\/documentation\/swiftgodot\/runningineditor","title":"Running Code in the Godot Editor","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor","kind":"article","abstract":[{"text":"There are cases where you might want some of your Swift code for your extension","type":"text"},{"type":"text","text":" "},{"text":"to run while it is being used in the Godot Editor.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"type":"topic","url":"\/documentation\/swiftgodot\/exports","title":"Exports","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","kind":"article","abstract":[{"text":"In Godot, class members can be exported. This means their value gets saved along","type":"text"},{"type":"text","text":" "},{"text":"with the resource (such as the scene) they’re attached to. They will also be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"available for editing in the property editor. Exporting is done by using the"}]},"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"type":"topic","url":"\/documentation\/swiftgodot\/differences","title":"SwiftGodot API differences to GDScript","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","kind":"article","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}]},"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"type":"topic","url":"\/documentation\/swiftgodot\/signals","title":"Signals","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","kind":"article","abstract":[{"type":"text","text":"Signals in Godot are used by objects to post interesting events that are"},{"type":"text","text":" "},{"text":"taking place, and can be used by users to easily add behavior and react","type":"text"},{"type":"text","text":" "},{"text":"to changes.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"type":"topic","url":"\/documentation\/swiftgodot\/customtypes","title":"Using Custom Types","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","kind":"article","abstract":[{"text":"You will typically extend the functionality of your Godot game by creating","type":"text"},{"type":"text","text":" "},{"text":"classes that derive from one of the various Godot types and adjust the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior accordingly."}]},"doc://SwiftGodot/documentation/SwiftGodot":{"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","abstract":[{"text":"Framework to write Godot Game Extensions using the Swift Programming Language.","type":"text"}],"kind":"symbol","type":"topic"}}}