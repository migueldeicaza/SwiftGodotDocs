artTimer.start ()","    }","}"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/bindingnodes"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/BindNode":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindNode","url":"\/documentation\/swiftgodot\/bindnode","type":"topic","title":"BindNode","kind":"symbol","role":"symbol","abstract":[{"type":"text","text":"Use the BindNode property wrapper in any subclass of Node to retrieve the node from the"},{"type":"text","text":" "},{"text":"current container that matches the name of the property.","type":"text"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"BindNode","kind":"identifier"}],"navigatorTitle":[{"text":"BindNode","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"type":"topic","url":"\/documentation\/swiftgodot\/differences","title":"SwiftGodot API differences to GDScript","role":"article","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","kind":"article"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","url":"\/documentation\/swiftgodot\/customtypes","type":"topic","title":"Using Custom Types","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"You will typically extend the functionality of your Godot game by creating"},{"text":" ","type":"text"},{"type":"text","text":"classes that derive from one of the various Godot types and adjust the"},{"text":" ","type":"text"},{"text":"behavior accordingly.","type":"text"}]},"doc://SwiftGodot/