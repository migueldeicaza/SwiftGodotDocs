"}]},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","title":"scaling3dScale","abstract":[{"type":"text","text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/scaling3d\/mode"},{"text":" to scale the output image to the full viewport size. Values lower than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons.","type":"text"}],"role":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"scaling3dScale"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"type":"topic","kind":"symbol"}}}