{"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum\/fsr","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"fsr","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"}],"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"text":"Use AMD FidelityFX Super Resolution 1.0 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","isActive":true},{"text":". Values less than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will be result in the viewport being upscaled using FSR. Values greater than "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" are not supported and bilinear downsampling will be used instead. A value of "},{"type":"codeVoice","code":"1.0"},{"text":" disables scaling.","type":"text"}],"variants":[{"paths":["\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum\/fsr"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"symbolKind":"case","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fsr","kind":"identifier"}],"title":"Viewport.Scaling3DMode.fsr","roleHeading":"Case","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot8ViewportC13Scaling3DModeO3fsryA2EmF"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Viewport/Scaling3DMode-swift.enum":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Scaling3DMode"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum","abstract":[],"type":"topic","navigatorTitle":[{"text":"Scaling3DMode","kind":"identifier"}],"title":"Viewport.Scaling3DMode","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/Scaling3DMode-swift.enum/fsr":{"kind":"symbol","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum\/fsr","abstract":[{"text":"Use AMD FidelityFX Super Resolution 1.0 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","isActive":true,"type":"reference"},{"text":". Values less than ","type":"text"},{"code":"1.0","type":"codeVoice"},{"text":" will be result in the viewport being upscaled using FSR. Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are not supported and bilinear downsampling will be used instead. A value of "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" disables scaling."}],"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"fsr","kind":"identifier"}],"title":"Viewport.Scaling3DMode.fsr","url":"\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum\/fsr","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"scaling3dScale","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","abstract":[{"type":"text","text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/scaling3d\/mode"},{"type":"text","text":" to scale the output image to the full viewport size. Values lower than "},{"type":"codeVoice","code":"1.0"},{"text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also ","type":"text"},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"type":"text","text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons."}],"title":"scaling3dScale","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport":{"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Viewport","kind":"identifier"}],"title":"Viewport","url":"\/documentation\/swiftgodot\/viewport","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Viewport","kind":"identifier"}],"abstract":[{"text":"Abstract base class for viewports. Encapsulates drawing and interaction with a game world.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"}}}