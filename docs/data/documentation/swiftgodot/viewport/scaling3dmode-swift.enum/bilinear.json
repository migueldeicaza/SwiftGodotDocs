{"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","sections":[],"metadata":{"symbolKind":"case","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"bilinear"}],"role":"symbol","title":"Viewport.Scaling3DMode.bilinear","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot8ViewportC13Scaling3DModeO8bilinearyA2EmF","roleHeading":"Case"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum\/bilinear"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"bilinear","kind":"identifier"}],"platforms":["macOS"]}]}],"abstract":[{"text":"Use bilinear scaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","isActive":true},{"type":"text","text":". Values less than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will result in undersampling while values greater than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will result in supersampling. A value of "},{"type":"codeVoice","code":"1.0"},{"text":" disables scaling.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum\/bilinear"]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","title":"scaling3dScale","abstract":[{"type":"text","text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/scaling3d\/mode"},{"text":" to scale the output image to the full viewport size. Values lower than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons.","type":"text"}],"role":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"scaling3dScale"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"type":"topic","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport":{"kind":"symbol","url":"\/documentation\/swiftgodot\/viewport","type":"topic","title":"Viewport","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","abstract":[{"type":"text","text":"Abstract base class for viewports. Encapsulates drawing and interaction with a game world."}],"navigatorTitle":[{"kind":"identifier","text":"Viewport"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Viewport"}]},"doc://