{"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum"]]},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"case","roleHeading":"Case","modules":[{"name":"SwiftGodot"}],"role":"symbol","title":"Viewport.Scaling3DMode.fsr2","externalID":"s:10SwiftGodot8ViewportC13Scaling3DModeO4fsr2yA2EmF","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"fsr2","kind":"identifier"}]},"sections":[],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum\/fsr2","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"text":"fsr2","kind":"identifier"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum\/fsr2"]}],"abstract":[{"text":"Use AMD FidelityFX Super Resolution 2.2 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale"},{"text":". Values less than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will be result in the viewport being upscaled using FSR2. Values greater than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are not supported and bilinear downsampling will be used instead. A value of "},{"type":"codeVoice","code":"1.0"},{"text":" will use FSR2 at native resolution as a TAA solution.","type":"text"}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Viewport":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","url":"\/documentation\/swiftgodot\/viewport","abstract":[{"type":"text","text":"Abstract base class for viewports. Encapsulates drawing and interaction with a game world."}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Viewport"}],"navigatorTitle":[{"text":"Viewport","kind":"identifier"}],"type":"topic","kind":"symbol","title":"Viewport"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","role":"symbol","title":"scaling3dScale","type":"topic","abstract":[{"text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in ","type":"text"},{"type":"codeVoice","code":"ProjectSettings\/rendering\/scaling3d\/mode"},{"type":"text","text":" to scale the output image to the full viewport size. Values lower than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than "},{"type":"codeVoice","code":"1.0"},{"text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also ","type":"text"},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"scaling3dScale","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/Scaling3DMode-swift.enum":{"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum","role":"symbol","title":"Viewport.Scaling3DMode