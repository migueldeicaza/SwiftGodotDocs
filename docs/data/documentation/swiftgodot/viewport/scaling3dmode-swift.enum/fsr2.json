{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum\/fsr2","interfaceLanguage":"swift"},"metadata":{"symbolKind":"case","title":"Viewport.Scaling3DMode.fsr2","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot8ViewportC13Scaling3DModeO4fsr2yA2EmF","role":"symbol","roleHeading":"Case","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"fsr2","kind":"identifier"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fsr2"}],"platforms":["macOS"]}]}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum\/fsr2"]}],"abstract":[{"text":"Use AMD FidelityFX Super Resolution 2.2 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale"},{"type":"text","text":". Values less than "},{"code":"1.0","type":"codeVoice"},{"text":" will be result in the viewport being upscaled using FSR2. Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are not supported and bilinear downsampling will be used instead. A value of "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will use FSR2 at native resolution as a TAA solution."}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Viewport/Scaling3DMode-swift.enum/fsr2":{"abstract":[{"type":"text","text":"Use AMD FidelityFX Super Resolution 2.2 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale"},{"type":"text","text":". Values less than "},{"type":"codeVoice","code":"1.0"},{"text":" will be result in the viewport being upscaled using FSR2. Values greater than ","type":"text"},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" are not supported and bilinear downsampling will be used instead. A value of "},{"type":"codeVoice","code":"1.0"},{"text":" will use FSR2 at native resolution as a TAA solution.","type":"text"}],"url":"\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum\/fsr2","kind":"symbol","title":"Viewport.Scaling3DMode.fsr2","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum\/fsr2","role":"symbol","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fsr2","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"scaling3dScale","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","abstract":[{"type":"text","text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/scaling3d\/mode"},{"type":"text","text":" to scale the output image to the full viewport size. Values lower than "},{"type":"codeVoice","code":"1.0"},{"text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also ","type":"text"},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"type":"text","text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons."}],"title":"scaling3dScale","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport":{"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Viewport","kind":"identifier"}],"title":"Viewport","url":"\/documentation\/swiftgodot\/viewport","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Viewport","kind":"identifier"}],"abstract":[{"text":"Abstract base class for viewports. Encapsulates drawing and interaction with a game world.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/Scaling3DMode-swift.enum":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Scaling3DMode"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dmode-swift.enum","abstract":[],"type":"topic","navigatorTitle":[{"text":"Scaling3DMode","kind":"identifier"}],"title":"Viewport.Scaling3DMode","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/Scaling3DMode-swift.enum","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"}}}