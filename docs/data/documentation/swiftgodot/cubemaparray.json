{"relationshipsSections":[{"kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ImageTextureLayered"],"title":"Inherits From"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"navigatorTitle":[{"text":"CubemapArray","kind":"identifier"}],"roleHeading":"Class","role":"symbol","modules":[{"name":"SwiftGodot"}],"title":"CubemapArray","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CubemapArray"}],"externalID":"s:10SwiftGodot12CubemapArrayC","symbolKind":"class"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"CubemapArray","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","type":"reference","isActive":true},{"type":"text","text":"s are made of an array of "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","type":"reference","isActive":true},{"text":"s. Like ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","isActive":true},{"text":"s, they are made of multiple textures, the amount of which must be divisible by 6 (one for each face of the cube). The primary benefit of ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","type":"reference","isActive":true},{"text":"s is that they can be accessed in shader code using a single texture reference. In other words, you can pass multiple ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","isActive":true},{"type":"text","text":"s into a shader using a single "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Moreover, ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","type":"reference","isActive":true},{"text":"s are allocated in adjacent cache regions on the GPU. This makes ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","type":"reference","isActive":true},{"type":"text","text":"s the most efficient way to store multiple "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","isActive":true,"type":"reference"},{"type":"text","text":"s."}]},{"type":"paragraph","inlineContent":[{"text":"Internally, Godot uses ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","isActive":true,"type":"reference"},{"text":"s for many effects, including the ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Sky","type":"reference","isActive":true},{"type":"text","text":" if you set "},{"code":"ProjectSettings\/rendering\/reflections\/skyReflections\/textureArrayReflections","type":"codeVoice"},{"type":"text","text":" to "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"inlineContent":[{"text":"To create such a texture file yourself, reimport your image files using the import presets of the File System dock.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/SwiftGodot\/do