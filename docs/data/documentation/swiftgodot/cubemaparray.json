ion\/SwiftGodot\/CubemapArray","isActive":true},{"text":"s for many effects, including the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Sky"},{"type":"text","text":" if you set "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/reflections\/skyReflections\/textureArrayReflections"},{"text":" to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create such a texture file yourself, reimport your image files using the import presets of the File System dock."}]},{"content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","isActive":true},{"type":"text","text":" is not supported in the OpenGL 3 rendering backend."}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://SwiftGodot/s12IdentifiableP":{"identifier":"doc:\/\/SwiftGodot\/s12IdentifiableP","type":"unresolvable","title":"Swift.Identifiable"},"doc://SwiftGodot/documentation/SwiftGodot/Sky":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Sky","url":"\/documentation\/swiftgodot\/sky","title":"Sky","navigatorTitle":[{"text":"Sky","kind":"identifier"}],"kind":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Sky"}],"abstract":[{"text":"Defines a 3D environment’s background by using a ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Material","isActive":true},{"text":".","type":"text"}],"role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/VariantStorable":{"kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VariantStorable"}],"navi