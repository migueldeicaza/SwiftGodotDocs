:[{"type":"text","text":"For example, to pass the value "},{"type":"codeVoice","code":"true"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["let trueVaraint = Variant (true)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can get a string representation of a variant by calling "},{"code":"Variant","type":"codeVoice"},{"type":"text","text":"’s"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/description","isActive":true},{"text":" method:","type":"text"}]},{"type":"codeListing","code":["print (trueVariant.description)"],"syntax":"swift"},{"text":"Extracting values from Variants","type":"heading","level":2,"anchor":"Extracting-values-from-Variants"},{"inlineContent":[{"text":"If you know the kind of return that a variant will return, you can invoke the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"failing initializer for that specific type for most structures."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, this is how you could get a Vector2 from a variant:"}],"type":"paragraph"},{"code":["func distance (variant: Variant) -> Float? {","    guard let vector = Vector2 (variant) else {","\treturn nil","    }","    return vector.length ()","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Notice that this might return ","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", which would be the case if the variant"},{"type":"text","text":" "},{"type":"text","text":"contains a different type than the one you were expecting.   You can check the"},{"text":" ","type":"text"},{"type":"text","text":"type of the variant by accessing the "},{"type":"codeVoice","code":".gtype"},{"type":"text","text":" property of the variant."}]},{"type":"heading","text":"Extracting Godot-derived objects from Variants","level":2,"anchor":"Extracting-Godot-derived-objects-from-Variants"},{"type":"paragraph","inlineContent":[{"text":"Godot-derived objects are slightly different.   If you know you have a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","isActive":true},{"type":"text","text":" stored in the variant, you can call the "},{"type":"codeVoice","code":"Variant.asObject()"},{"type":"text","text":" "},{"type":"text","text":"instead.  This is a generic method, so you would invoke it like this:"}]},{"type":"codeListing","syntax":"swift","code":["","func getNode (variant: Variant) -> Node? {","    guard let node = variant.asObject<Node> ()) else {","\treturn nil","    }","    return node","}"]},{"type":"paragraph","inlineContent":[{"text":"The reason to have a method rather than a constructor is that this method will","type":"text"},{"text":" ","type":"text"},{"text":"make sure that only one instance of your objects is surfaced to Swift.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"modules":[{"name":"SwiftGodot"}],"role":"article","title":"Godot’s Variants"},"kind":"article","sections":[],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Variant/GType-swift.enum":{"url":"\/documentation\/swiftgodot\/variant\/gtype-swift.enum","kind":"symbol","abstract":[],"title":"Variant.GType","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/GType-swift.enum","fragments":[{"kind":"keyword","text":"enum"},{"text":" ","kind":"text"},{"kind":"identifier","text":"GType"}],"navigatorTitle":[{"kind":"identifier","text":"GType"}],"role":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Variant/init(_:)-2xwk8":{"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"preciseIdentifier":"s:10SwiftGodot18PackedVector3ArrayC","text":"PackedVector3Array","kind":"typeIdentifier"},{"text":")","kind":"text"}],"identifier":"doc:\/\/SwiftGodo