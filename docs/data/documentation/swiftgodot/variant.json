{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Variant"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"You can retrieve the type of a variant from the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/gtype-swift.property","isActive":true},{"type":"text","text":" property."}]},{"inlineContent":[{"type":"text","text":"A Variant takes up only 20 bytes and can store almost any engine datatype"},{"text":" ","type":"text"},{"type":"text","text":"inside of it. Variants are rarely used to hold information for long periods of"},{"type":"text","text":" "},{"text":"time. Instead, they are used mainly for communication, editing, serialization and","type":"text"},{"text":" ","type":"text"},{"text":"moving data around.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A Variant:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Can store almost any Godot engine datatype."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Can perform operations between many variants. GDScript uses Variant as its atomic\/native datatype.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Can be hashed, so it can be compared to other variants.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Can be used to convert safely between datatypes.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Can be used to abstract calling methods and their arguments. Godot exports all its functions through variants.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Can be used to defer calls or move data between threads.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Can be serialized as binary and stored to disk, or transferred via network."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Can be serialized to text and use it for printing values and editable settings.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Can work as an exported property, so the editor can edit it universally."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Can be used for dictionaries, arrays, parsers, etc.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Containers ("},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","isActive":true},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GDictionary","isActive":true},{"text":"): Both are implemented using variants.","type":"text"},{"text":" ","type":"text"},{"text":"A ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GDictionary","isActive":true},{"text":" can match any datatype used as key to any other datatype.  An ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","isActive":true},{"type":"text","text":" "},{"text":"just holds an array of Variants.  A ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true},{"text":" can also hold a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GDictionary","type":"reference","isActive":true},{"type":"text","text":" and an "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"inside."}]}],"style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Modifications to a container will modify all references to it."}]}]}],"abstract":[{"text":"Variant objects box various Godot Objects, you create them with one of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructors, and you can retrieve the contents using the various extension"},{"text":" ","type":"text"},{"type":"text","text":"constructors that are declared on the various types that are wrapped."}],"metadata":{"roleHeading":"Class","symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"Variant"}],"modules":[{"name":"SwiftGodot"}],"title":"Variant","externalID":"s:10SwiftGodot7VariantC","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Variant","kind":"identifier"}],"role":"symbol"},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"title":"Operators","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/==(_:_:)"]},{"title":"Initializers","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/init()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/init(_:)-83jxe","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/init(_:)-wa53"]},{"title":"Instance Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/debugDescription","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/description","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/gtype-swift.property","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/isNull"]},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/call(method:_:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/hash(into:)"],"title":"Instance Methods"},{"identifiers":["doc:\/\/Sw