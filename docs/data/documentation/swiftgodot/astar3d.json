{"kind":"symbol","identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D","interfaceLanguage":"swift"},"sections":[],"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_computeCost(fromId:toId:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_estimateCost(fromId:toId:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/addPoint(id:position:weightScale:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/arePointsConnected(id:toId:bidirectional:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/clear()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/connectPoints(id:toId:bidirectional:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/disconnectPoints(id:toId:bidirectional:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getAvailablePointId()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getClosestPoint(toPosition:includeDisabled:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getClosestPositionInSegment(toPosition:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getIdPath(fromId:toId:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointCapacity()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointConnections(id:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointCount()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointIds()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointPath(fromId:toId:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointPosition(id:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointWeightScale(id:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/hasPoint(id:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/isPointDisabled(id:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/removePoint(id:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/reserveSpace(numNodes:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/setPointDisabled(id:disabled:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/setPointPosition(id:position:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/setPointWeightScale(id:weightScale:)"],"title":"Instance Methods"},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/godotClassName"],"title":"Type Properties"}],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RefCounted"],"title":"Inherits From","kind":"relationships"},{"type":"conformsTo","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"title":"Conforms To","kind":"relationships"}],"metadata":{"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"AStar3D","kind":"identifier"}],"navigatorTitle":[{"text":"AStar3D","kind":"identifier"}],"externalID":"s:10SwiftGodot7AStar3DC","title":"AStar3D","role":"symbol","modules":[{"name":"SwiftGodot"}],"symbolKind":"class"},"abstract":[{"type":"text","text":"An implementation of A* for finding the shortest path between two vertices on a connected graph in 3D space."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"AStar3D"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A* (A star) is a computer algorithm used in pathfinding and graph traversal, the process of plotting short paths among vertices (points), passing through a given set of edges (segments). It enjoys widespread use due to its performance and accuracy. Godot’s A* implementation uses points in 3D space and Euclidean distances by default."}]},{"inlineContent":[{"text":"You must add points manually with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/addPoint(id:position:weightScale:)"},{"text":" and create segments manually with ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/connectPoints(id:toId:bidirectional:)","isActive":true},{"text":". Once done, you can test if there is a path between two points with the ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/arePointsConnected(id:toId:bidirectional:)","isActive":true,"type":"reference"},{"type":"text","text":" function, get a path containing indices by "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getIdPath(fromId:toId:)"},{"text":", or one containing actual coordinates with ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointPath(fromId:toId:)","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It is also possible to use non-Euclidean distances. To do so, create a class that extends ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D"},{"type":"text","text":" and override methods "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_computeCost(fromId:toId:)"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_estimateCost(fromId:toId:)"},{"type":"text","text":". Both take two indices and return a length, as is shown in the following example."}]},{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_estimateCost(fromId:toId:)"},{"text":" should return a lower bound of the distance, i.e. ","type":"text"},{"code":"_estimate_cost(u, v) <= _compute_cost(u, v)","type":"codeVoice"},{"text":". This serves as a hint to the algorithm because the custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_computeCost(fromId:toId:)"},{"text":" might be computation-heavy. If this is not the case, make ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_estimateCost(fromId:toId:)","type":"reference"},{"text":" return the same value as ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_computeCost(fromId:toId:)"},{"text":" to provide the algorithm with the most accurate information.","type":"text"}]},{"inlineContent":[{"type":"text","text":"If the default "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_estimateCost(fromId:toId:)","type":"reference"},{"text":" and ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_computeCost(fromId:toId:)"},{"type":"text","text":" methods are used, or if the supplied "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_estimateCost(fromId:toId:)","isActive":true},{"type":"text","text":" method returns a lower bound of the cost, then the paths returned by A* will be the lowest-cost paths. Here, the cost of a path equals the sum of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/_computeCost(fromId:toId:)"},{"type":"text","text":" results of all segments in the path multiplied by the "},{"type":"codeVoice","code":"weight_scale"},{"type":"text","text":"s of the endpoints of the respective segments. If the default methods are used and the "},{"type":"codeVoice","code":"weight_scale"},{"text":"s of all points are set to ","type":"text"},{"code":"1.0","type":"codeVoice"},{"text":", then this equals the sum of Euclidean distances of all segments in the path.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"variants":[{"paths":["\/documentation\/swiftgodot\/astar3d"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/AStar3D/getPointPath(fromId:toId:)":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AStar3D\/getPointPath(fromId:toId:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getPointPath"},{"text":"(","kind":"text"},{"text":"fromId","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Int","kind":"typeIdentifier","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"text":"toId","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:10SwiftGodot18PackedVector3ArrayC","kind":"typeIdentifier","text":"PackedVector3Array"}],"title":"getPointPath(fromId:toId:)","type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/astar3d\/getpointpath(fromid:toid:)","abstract":[{"text":"Returns an array with the points that are in the path found by AStar3D between the given points. The array is ordered from the starting point to the ending point of the path.","type":"text"}],"kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/AStar3D/getPointIds()":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/A