:port:channelCount:inBandwidth:outBandwidth:localPort:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"createClient","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"address"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","kind":"typeIdentifier","text":"String"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"port"},{"kind":"text","text":": "},{"text":"Int32","preciseIdentifier":"s:s5Int32V","kind":"typeIdentifier"},{"kind":"text","text":", "},{"kind":"externalParam","text":"channelCount"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"kind":"text","text":", "},{"text":"inBandwidth","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V","text":"Int32"},{"kind":"text","text":", "},{"text":"outBandwidth","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"text":", ","kind":"text"},{"text":"localPort","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot0B5ErrorO","text":"GodotError","kind":"typeIdentifier"}],"kind":"symbol","title":"createClient(address:port:channelCount:inBandwidth:outBandwidth:localPort:)","url":"\/documentation\/swiftgodot\/enetmultiplayerpeer\/createclient(address:port:channelcount:inbandwidth:outbandwidth:localport:)","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetMultiplayerPeer\/createClient(address:port:channelCount:inBandwidth:outBandwidth:localPort:)","type":"topic","abstract":[{"text":"Create client that connects to a server at ","type":"text"},{"type":"codeVoice","code":"address"},{"text":" using specified ","type":"text"},{"type":"codeVoice","code":"port"},{"type":"text","text":". The given address needs to be either a fully qualified domain name (e.g. "},{"code":"\"www.example.com\"","type":"codeVoice"},{"text":") or an IP address in IPv4 or IPv6 format (e.g. ","type":"text"},{"code":"\"192.168.1.1\"","type":"codeVoice"},{"text":"). The ","type":"text"},{"type":"codeVoice","code":"port"},{"type":"text","text":" is the port the server is listening on. The "},{"code":"channelCount","type":"codeVoice"},{"type":"text","text":" parameter can be used to specify the number of ENet channels allocated for the connection. The "},{"code":"inBandwidth","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"outBandwidth","type":"codeVoice"},{"type":"text","text":" parameters can be used to limit the incoming and outgoing bandwidth to the given number of bytes per second. The default of 0 means unlimited bandwidth. Note that ENet will strategically drop packets on specific sides of a connection between peers to ensure the peer’s bandwidth is not overwhelmed. The bandwidth parameters also determine the window size of a connection which limits the amount of reliable packets that may be in transit at any given time. Returns "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotError\/ok","isActive":true},{"type":"text","text":" if a client was created, "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotError\/errAlreadyInUse"},{"type":"text","text":" if this ENetMultiplayerPeer instance already has an open connection (in which case you need to call "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MultiplayerPeer\/close()","type":"reference","isActive":true},{"text":" first) or ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotError\/errCantCreate","isActive":true},{"type":"text","text":" if the client could not be created. If "},{"code":"localPort","type":"codeVoice"},{"text":" is specified, the client will also listen to the given port; this is useful for some NAT traversal techniques.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/ENetConnection":{"url":"\/documentation\/swiftgodot\/enetconnection","type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ENetConnection","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ENetConnection"}],"abstract":[{"type":"text","text":"A wrapper class for an [url=http:\/\/enet.bespin.org\/group__host.html]ENetHost[\/url]."}],"title":"ENetConnection","navigatorTitle":[{"text":"ENetConnection","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/MultiplayerPeer":{"url":"\/documentation\/swiftgodot\/multiplayerpeer","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MultiplayerPeer","title":"MultiplayerPeer","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MultiplayerPeer"}],"navigatorTitle":[{"text":"MultiplayerPeer","kind":"identifier"}],"abstract":[{"text":"Abstract class for specialized ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PacketPeer","isActive":true,"type":"reference"},{"type":"text","text":"s used by the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MultiplayerAPI","isActive":true},{"text":".","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Variant","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/variant","title":"Variant","kind":"symbol","role":"symbol","type":"topic","navigatorTitle":[{"text":"Variant","kind":"identifier"}],"abstract":[{"text":"Variant objects box various Godot Objects, you create them with one of the","type":"text"},{"type":"text","text":" "},{"text":"constructors, and you can retriev