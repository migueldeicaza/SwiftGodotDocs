t\/EditorUndoRedoManager\/getObjectHistoryId(object:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager\/isCommittingAction()"],"title":"Instance Methods"},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager\/godotClassName"]},{"title":"Enumerations","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager\/SpecialHistory"]}],"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Object"]},{"title":"Conforms To","type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EditorUndoRedoManager","kind":"identifier"}]}]},{"content":[{"anchor":"overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager","type":"reference","isActive":true},{"type":"text","text":" is a manager for "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo","isActive":true,"type":"reference"},{"text":" objects associated with edited scenes. Each scene has its own undo history and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager","isActive":true},{"type":"text","text":" ensures that each action performed in the editor gets associated with a proper scene. For actions not related to scenes ("},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ProjectSettings","type":"reference","isActive":true},{"text":" edits, external resources, etc.), a separate global history is used.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The usage is mostly the same as "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo"},{"type":"text","text":". You create and commit actions and the manager automatically decides under-the-hood what scenes it belongs to. The scene is deduced based on the first operation in an action, using the object from the operation. The rules are as follows:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"If the object is a "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","isActive":true},{"type":"text","text":", use the currently edited scene;"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"If the object is a built-in resource, use the scene from its path;","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If the object is external resource or anything else, use global history.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guessing can sometimes yield false results, so you can provide a custom context object when creating an action."}]},{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager"},{"type":"text","text":" is intended to be used by Godot editor plugins. You can obtain it using "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorPlugin\/getUndoRedo()","isActive":true},{"text":". For non-editor uses or plugins that don’t need to integrate with the editor’s undo history, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo","isActive":true},{"type":"text","text":" instead."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The manager’s API is mostly the same as in ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/UndoRedo","type":"reference","isActive":true},{"type":"text","text":", so you can refer to its documentation for more examples. The main difference is that "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager","isActive":true},{"text":" uses object + method name for actions, instead of ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Callable","type":"reference","isActive":true},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This object emits the following signals:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager\/historyChanged","type":"reference","isActive":true}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager\/versionChanged","isActive":true,"type":"reference"}]}]}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorUndoRedoManager","interfaceLanguage":"swift"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node":{"navigatorTitle":[{"text":"Node","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Node"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","abstract":[{"type":"text","text":"Base class for all scene objects."}]},"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"kin