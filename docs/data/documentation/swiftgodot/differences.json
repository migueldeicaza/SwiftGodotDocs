{"sections":[],"kind":"article","schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"variants":[{"paths":["\/documentation\/swiftgodot\/differences"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"],"generated":true,"title":"Articles and Tutorials"}],"primaryContentSections":[{"kind":"content","content":[{"text":"General differences","type":"heading","anchor":"General-differences","level":2},{"inlineContent":[{"type":"text","text":"The SwiftGodot API follows the convention of the Swift platform, and one of the"},{"text":" ","type":"text"},{"text":"most notable places where this happens is in the use of camelCase style instead","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the snake_case style used in GDScript."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Enumerations and their values also change, for example, rather than having a"},{"text":" ","type":"text"},{"text":"constant value like ","type":"text"},{"code":"CORNER_TOP_LEFT","type":"codeVoice"},{"text":" for the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner","type":"reference"},{"text":" value, we use","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner\/topLeft","isActive":true},{"type":"text","text":"."}]},{"inlineContent":[{"text":"In Swift, function definitions take parameter names, and sometimes this","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"parameter name is omitted for the first argument. Instead of"},{"type":"text","text":" "},{"type":"codeVoice","code":"myNode.add_child(box)"},{"type":"text","text":", you would use "},{"type":"codeVoice","code":"myNode.addChild (node: box)"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"heading","anchor":"Global-Scope","level":2,"text":"Global Scope"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Global functions and some constants had to be moved to classes to avoid"},{"text":" ","type":"text"},{"type":"text","text":"polluting the global name space, and you can find them in the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","isActive":true,"type":"reference"},{"text":" class.","type":"text"}]},{"type":"heading","level":2,"anchor":"Type-Mappings","text":"Type Mappings"},{"inlineContent":[{"type":"text","text":"Godot comes with some of their own data types like strings and dictionaries, but"},{"text":" ","type":"text"},{"text":"those types would clash with the existing Swift types with the same names.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Here is a list of the current data type mappings:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"GDScript type"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"SwiftGodot Name","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"GString"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"dictionary","type":"text"}]}],[{"inlineContent":[{"type":"text","text":"GDictionary"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"array","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GArray"}],"type":"paragraph"}]]]},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","type":"reference","isActive":true},{"text":" is a type-erased array that can hold any sort of element that","type":"text"},{"type":"text","text":" "},{"text":"can be managed by Godot (Variants or Objects).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, there are two special kinds of strongly-typed versions of the"},{"text":" ","type":"text"},{"type":"text","text":"GArray:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantCollection","type":"reference"},{"text":" that holds any ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true},{"text":" instances.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ObjectCollection","type":"reference"},{"text":" that holds any ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject"},{"type":"text","text":" instances."}]}]}],"type":"unorderedList"},{"text":"GDScript Helper Functions","level":2,"type":"heading","anchor":"GDScript-Helper-Functions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many global helper functions that are exposed in GDScript have been exposed in"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD"},{"text":" class as static methods.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This means that you can invoke them like this:"}]},{"type":"codeListing","syntax":"swift","code":["func reportError (error: Variant) {","    GD.printerr (msg)","}"]},{"text":"Godot Math Functions","level":3,"anchor":"Godot-Math-Functions","type":"heading"},{"inlineContent":[{"text":"The various GDScript Math functions like ","type":"text"},{"type":"codeVoice","code":"abs"},{"type":"text","text":", "},{"type":"codeVoice","code":"acos"},{"type":"text","text":", "},{"code":"atan","type":"codeVoice"},{"type":"text","text":" as well as their"},{"type":"text","text":" "},{"type":"text","text":"helper functions like "},{"type":"codeVoice","code":"clamp"},{"type":"text","text":" are defined as static functions in the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","type":"reference","isActive":true},{"type":"text","text":" "},{"text":"class.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Generally, you can use the Swift versions instead of the GDScript versions,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which are more complete and do not incurr a marshaling overhead."}]},{"text":"Random Functions","level":3,"type":"heading","anchor":"Random-Functions"},{"type":"paragraph","inlineContent":[{"text":"The random functions like ","type":"text"},{"code":"randi","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"randf"},{"type":"text","text":" and under the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","type":"reference","isActive":true},{"type":"text","text":" class. But Swift"},{"text":" ","type":"text"},{"text":"provides a set of random functions that are just as good, like","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/int\/random(in:)-9mjpw","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"or"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/double\/random(in:)-6idef"},{"type":"text","text":" "},{"type":"text","text":"that operate on Swift ranges."}]},{"type":"heading","text":"Idiom Mapping","anchor":"Idiom-Mapping","level":2},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"GDScript Idiom","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftGodot Equivalent"}]}]],[[{"inlineContent":[{"text":"instance_from_id(n)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GD.instanceFromId (instanceId: n)"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"level":3,"anchor":"Checking-for-the-contents-of-a-variant","text":"Checking for the contents of a variant","type":"heading"},{"inlineContent":[{"text":"You can check in one go if a given variant contains a valid object and is of a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"given type, with the "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","type":"reference"},{"type":"text","text":" method, combined with Swift’s"},{"type":"text","text":" "},{"type":"text","text":"“let”:"}],"type":"paragraph"},{"code":["func demo(input: Variant) {","\tif let node = input.asObject(Node.self) {","\t\t\/\/ We have a happy node inside 'input'","\t} else {","\t\tprint (\"The variant did not wrap an object, if it did, it was either nil, or was not of type Node\")","\t}","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"@export annotations","type":"heading","anchor":"export-annotations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"@export"},{"type":"text","text":" annotation works the same way as it does in GDScript. Some"},{"type":"text","text":" "},{"text":"parameters and directives are different see the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","isActive":true},{"text":" documentation","type":"text"},{"text":" ","type":"text"},{"text":"for additional information.","type":"text"}]},{"level":2,"type":"heading","text":"Signals","anchor":"Signals"},{"inlineContent":[{"type":"text","text":"Generally, use the "},{"code":"#signal","type":"codeVoice"},{"text":" macro to declare a new signal for your classes,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"like this:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["class Demo: Node {","    #signal(\"lives_changed\", argument: [\"new_lives_count\": Int.self])","}"]},{"inlineContent":[{"type":"text","text":"For additional information on defining and connecting to signals see the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","type":"reference","isActive":true},{"type":"text","text":" documentation."}],"type":"paragraph"},{"text":"@onready annotation","anchor":"onready-annotation","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"GDScript supports an "},{"type":"codeVoice","code":"@onready"},{"type":"text","text":" annotation on variables, like this:"}]},{"type":"codeListing","syntax":"gdscript","code":["@onready var my_label = get_node(\"MyLabel\")"]},{"type":"paragraph","inlineContent":[{"text":"This does not exist in SwiftGodot, to achieve a similar behavior, initialize","type":"text"},{"type":"text","text":" "},{"type":"text","text":"those variables in an overwritten "},{"type":"codeVoice","code":"_ready"},{"type":"text","text":" method, so code like this:"}]},{"syntax":"swift","type":"codeListing","code":["@Godot","class Demo: Node {","\tvar myLabel: Node3D?","","\toverride func _ready () {","\t\tmyLabel = getNode (path: \"myLabel\") as? Node3D","\t}","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you do not need to load the node right away, and you merely need to be able"},{"type":"text","text":" "},{"type":"text","text":"to access it, you can use this instead:"}]},{"syntax":"swift","code":["class Demo: Node {","\t@BindNode var myLabel: Node3D","}"],"type":"codeListing"},{"level":2,"type":"heading","text":"Running code before nodes are added to the Scene Tree","anchor":"Running-code-before-nodes-are-added-to-the-Scene-Tree"},{"type":"paragraph","inlineContent":[{"text":"If you need to run some code in your constructor, but overriding the ","type":"text"},{"code":"_ready()","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"function is already too late for you, you can use the following idiom:"}]},{"syntax":"swift","code":["@Godot","class NetworkedNode: Node {","    required init() {","        super.init()","        onInit()","    }","","    required init(nativeHandle: UnsafeRawPointer) {","        super.init(nativeHandle: nativeHandle)","        onInit()","    }","","    func onInit() {","        print(\"Was init!\")","    }","}"],"type":"codeListing"},{"level":2,"text":"Singletons","type":"heading","anchor":"Singletons"},{"type":"paragraph","inlineContent":[{"text":"Godot Singletons surface their API as static methods, to make the code more","type":"text"},{"text":" ","type":"text"},{"text":"shorter, for example:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let pressed = Input.isActionPressed(ui_down)"]},{"type":"paragraph","inlineContent":[{"text":"However, in some very rare cases this is not enough. For example, you may want","type":"text"},{"type":"text","text":" "},{"text":"to access a member from the base class GodotObject, like ","type":"text"},{"code":"connect","type":"codeVoice"},{"type":"text","text":". For such"},{"text":" ","type":"text"},{"type":"text","text":"use cases we provide a static property named "},{"code":"shared","type":"codeVoice"},{"text":" that returns the singleton","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"instance."}]},{"type":"codeListing","code":["let demo = Input.shared.joyConnectionChanged.connect { device, connected in ","   print (\"joyConnectionChanged called\")","}"],"syntax":"swift"},{"type":"heading","level":2,"anchor":"String","text":"String"},{"inlineContent":[{"type":"text","text":"SwiftGodot generally exposes a Swift-string based API, but there are some"},{"type":"text","text":" "},{"type":"text","text":"convenience methods that you might have come to expect from the Godot String"},{"text":" ","type":"text"},{"text":"(things like ","type":"text"},{"code":"GString\/validateFilename","type":"codeVoice"},{"type":"text","text":", those APIs are available in the"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString","type":"reference"},{"type":"text","text":" class)."}],"type":"paragraph"},{"text":"Callable","anchor":"Callable","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"In SwiftGodot, you can create "},{"type":"codeVoice","code":"Callable"},{"type":"text","text":" instances by directly passing a Swift function that takes an array of "},{"code":"Variant","type":"codeVoice"},{"type":"text","text":" arguments,"},{"type":"text","text":" "},{"type":"text","text":"and returns an optional "},{"code":"Variant","type":"codeVoice"},{"type":"text","text":" result, like this:"}],"type":"paragraph"},{"syntax":"swift","code":["func myCallback(args: [Variant])-> Variant? {","\tprint (\"MyCallback invoked with \\(args.count) arguments\")","\treturn nil","}","","let myCallable = Callable(myCallback)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can use a StringName that binds a method that you have exported (via, the "},{"code":"@Callable","type":"codeVoice"},{"text":" macro), like this:","type":"text"}]},{"syntax":"swift","code":["@Callable func myCallback(message: String) {","\tGD.print(message)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can call the callable in GDScript by invoking call() method of the exported Swift type."}],"type":"paragraph"},{"code":["MySwiftNode.myCallback.call(\"Hello from Swift!\")"],"syntax":"GDScript","type":"codeListing"},{"type":"heading","text":"Async\/Await","level":2,"anchor":"AsyncAwait"},{"type":"paragraph","inlineContent":[{"text":"GDScript comes with an ","type":"text"},{"code":"await","type":"codeVoice"},{"type":"text","text":" primitive, you can achieve similar functionality"},{"type":"text","text":" "},{"text":"with the Swift built-in await\/async stack.   Unlike GDScript, await can only be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"invoked from "},{"code":"async","type":"codeVoice"},{"type":"text","text":" methods."}]},{"inlineContent":[{"type":"text","text":"This means that code like this wont work:"}],"type":"paragraph"},{"code":["func demo() {","\tawait someSignal.emitted","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"For this to work, this needs to be in an async context, like this one:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func demo() async {","\tawait someSignal.emitted","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you are inside of a function that is not async, you need to wrap your code in"},{"text":" ","type":"text"},{"type":"text","text":"Task, like this:"}]},{"code":["func demo() {","\t\/\/ We are not an async function, but we can start a Task","\tTask {","\t\tawait someSignal.emitted","\t}","}"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"SwiftGodot"}],"roleHeading":"Article","title":"SwiftGodot API differences to GDScript","role":"article"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","abstract":[{"text":"Signals in Godot are used by objects to post interesting events that are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"taking place, and can