entifier","text":"GString"}],"navigatorTitle":[{"text":"GString","kind":"identifier"}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"type":"topic","url":"\/documentation\/swiftgodot\/exports","title":"Exports","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","kind":"article","abstract":[{"text":"In Godot, class members can be exported. This means their value gets saved along","type":"text"},{"type":"text","text":" "},{"text":"with the resource (such as the scene) they’re attached to. They will also be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"available for editing in the property editor. Exporting is done by using the"}]},"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Variant"}],"url":"\/documentation\/swiftgodot\/variant","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Variant"}],"type":"topic","title":"Variant","abstract":[{"text":"Variant objects box various Godot Objects, you create them with one of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constructors, and you can retrieve the contents using the various extension"},{"text":" ","type":"text"},{"text":"constructors that are declared on the various types that are wrapped.","type":"text"}],"kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/GodotObject":{"navigatorTitle":[{"kind":"identifier","text":"GodotObject"}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"GodotObject","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","url":"\/documentation\/swiftgodot\/godotobject","abstract":[{"type":"text","text":"Protocol implemented by the built-in classes in Godot to allow to be wrapped in a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true}],"title":"GodotObject"},"doc://SwiftGodot/documentation/SwiftGodot/ObjectCollection":{"navigatorTitle":[{"text":"ObjectCollection","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ObjectCollection","url":"\/documentation\/swiftgodot\/objectcollection","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ObjectCollection"}],"title":"ObjectCollection","abstract":[{"text":"This represents a typed array of one of the built-in types from Godot","type":"text"}],"role":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot":{"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","abstract":[{"text":"Framework to write Godot Game Extensions using the Swift Programming Language.","type":"text"}],"kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/VariantCollection":{"kind":"symbol","abstract":[{"text":"This represents a typed array of one of the built-in types from Godot","type":"text"}],"url":"\/documentation\/swiftgodot\/variantcollection","type":"topic","title":"VariantCollection","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"VariantCollection","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VariantCollection"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantCollection"}}}