article","abstract":[{"type":"text","text":"Signals in Godot are used by objects to post interesting events that are"},{"type":"text","text":" "},{"text":"taking place, and can be used by users to easily add behavior and react","type":"text"},{"type":"text","text":" "},{"text":"to changes.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"type":"topic","url":"\/documentation\/swiftgodot\/variants","title":"Variants","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","kind":"article","abstract":[{"text":"Follow up on the fundamental building block of Godot’s data types.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/GArray":{"url":"\/documentation\/swiftgodot\/garray","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","role":"symbol","title":"GArray","abstract":[{"text":"A built-in data structure that holds a sequence of elements.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"GArray"}],"navigatorTitle":[{"text":"GArray","kind":"identifier"}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"type":"topic","url":"\/documentation\/swiftgodot\/customtypes","title":"Using Custom Types","role":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","kind":"article","abstract":[{"text":"You will typically extend the functionality of your Godot game by creating","type":"text"},{"type":"text","text":" "},{"text":"classes that derive from one of the various Godot types and adjust the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior accordingly."}]},"https://developer.apple.com/documentation/swift/double/random(in:)-6idef":{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/double\/random(in:)-6idef","type":"link","url":"https:\/\/developer.apple.com\/documentation\/swift\/double\/random(in:)-6idef","titleI