{"metadata":{"roleHeading":"Article","role":"article","title":"SwiftGodot API differences to GDScript","modules":[{"name":"SwiftGodot"}]},"kind":"article","seeAlsoSections":[{"title":"Articles and Tutorials","generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"sections":[],"variants":[{"paths":["\/documentation\/swiftgodot\/differences"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"primaryContentSections":[{"content":[{"anchor":"General-differences","text":"General differences","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"The SwiftGodot API follows the convention of the Swift platform, and one of the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"most notable places where this happens is in the use of camelCase style instead"},{"text":" ","type":"text"},{"type":"text","text":"of the snake_case style used in GDScript."}]},{"inlineContent":[{"text":"Enumerations and their values also change, for example, rather than having a","type":"text"},{"type":"text","text":" "},{"type":"text","text":"constant value like "},{"type":"codeVoice","code":"CORNER_TOP_LEFT"},{"type":"text","text":" for the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner"},{"text":" value, we use","type":"text"},{"type":"text","text":" "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner\/topLeft","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Swift, function definitions take parameter names, and sometimes this"},{"type":"text","text":" "},{"type":"text","text":"parameter name is omitted for the first argument. Instead of"},{"type":"text","text":" "},{"code":"myNode.add_child(box)","type":"codeVoice"},{"text":", you would use ","type":"text"},{"type":"codeVoice","code":"myNode.addChild (node: box)"},{"type":"text","text":"."}]},{"type":"heading","text":"Global Scope","level":2,"anchor":"Global-Scope"},{"type":"paragraph","inlineContent":[{"text":"Global functions and some constants had to be moved to classes to avoid","type":"text"},{"type":"text","text":" "},{"text":"polluting the global name space, and you can find them in the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","type":"reference"},{"type":"text","text":" class."}]},{"text":"Type Mappings","type":"heading","level":2,"anchor":"Type-Mappings"},{"inlineContent":[{"text":"Godot comes with some of their own data types like strings and dictionaries, but","type":"text"},{"type":"text","text":" "},{"type":"text","text":"those types would clash with the existing Swift types with the same names."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here is a list of the current data type mappings:"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"GDScript type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"SwiftGodot Name"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"string"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"GString"}]}]],[[{"inlineContent":[{"text":"dictionary","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"GDictionary"}]}]],[[{"inlineContent":[{"type":"text","text":"array"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GArray"}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray"},{"text":" is a type-erased array that can hold any sort of element that","type":"text"},{"type":"text","text":" "},{"type":"text","text":"can be managed by Godot (Variants or Objects)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In addition, there are two special kinds of strongly-typed versions of the"},{"text":" ","type":"text"},{"type":"text","text":"GArray:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantCollection","type":"reference","isActive":true},{"type":"text","text":" that holds any "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","isActive":true},{"text":" instances.","type":"text"}]}]},{"content":[{"inlineContent":[{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ObjectCollection","isActive":true,"type":"reference"},{"text":" that holds any ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","isActive":true,"type":"reference"},{"text":" instances.","type":"text"}],"type":"paragraph"}]}]},{"anchor":"GDScript-Helper-Functions","level":2,"type":"heading","text":"GDScript Helper Functions"},{"inlineContent":[{"type":"text","text":"Many global helper functions that are exposed in GDScript have been exposed in"},{"text":" ","type":"text"},{"type":"text","text":"the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD"},{"type":"text","text":" class as static methods."}],"type":"paragraph"},{"inlineContent":[{"text":"This means that you can invoke them like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["func reportError (error: Variant) {","    GD.printerr (msg)","}"],"syntax":"swift"},{"type":"heading","level":3,"text":"Godot Math Functions","anchor":"Godot-Math-Functions"},{"type":"paragraph","inlineContent":[{"text":"The various GDScript Math functions like ","type":"text"},{"code":"abs","type":"codeVoice"},{"text":", ","type":"text"},{"code":"acos","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"atan"},{"type":"text","text":" as well as their"},{"text":" ","type":"text"},{"type":"text","text":"helper functions like "},{"code":"clamp","type":"codeVoice"},{"text":" are defined as static functions in the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD"},{"text":" ","type":"text"},{"type":"text","text":"class."}]},{"inlineContent":[{"text":"Generally, you can use the Swift versions instead of the GDScript versions,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"which are more complete and do not incurr a marshaling overhead."}],"type":"paragraph"},{"text":"Random Functions","level":3,"anchor":"Random-Functions","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The random functions like "},{"type":"codeVoice","code":"randi"},{"type":"text","text":", "},{"code":"randf","type":"codeVoice"},{"text":" and under the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD"},{"type":"text","text":" class. But Swift"},{"type":"text","text":" "},{"type":"text","text":"provides a set of random functions that are just as good, like"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/int\/random(in:)-9mjpw","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/double\/random(in:)-6idef","isActive":true},{"text":" ","type":"text"},{"text":"that operate on Swift ranges.","type":"text"}]},{"text":"Idiom Mapping","level":2,"anchor":"Idiom-Mapping","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"GDScript Idiom","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftGodot Equivalent"}]}]],[[{"inlineContent":[{"text":"instance_from_id(n)","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"GD.instanceFromId (instanceId: n)"}]}]]],"type":"table","header":"row"},{"level":3,"text":"Checking for the contents of a variant","type":"heading","anchor":"Checking-for-the-contents-of-a-variant"},{"inlineContent":[{"text":"You can check in one go if a given variant contains a valid object and is of a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"given type, with the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)"},{"type":"text","text":" method, combined with Swift’s"},{"type":"text","text":" "},{"text":"“let”:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["func demo(input: Variant) {","\tif let node = input.asObject(Node.self) {","\t\t\/\/ We have a happy node inside 'input'","\t} else {","\t\tprint (\"The variant did not wrap an object, if it did, it was either nil, or was not of type Node\")","\t}","}"]},{"anchor":"export-annotations","level":2,"type":"heading","text":"@export annotations"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"@export"},{"text":" annotation works the same way as it does in GDScript. Some","type":"text"},{"text":" ","type":"text"},{"text":"parameters and directives are different see the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","isActive":true},{"type":"text","text":" documentation"},{"type":"text","text":" "},{"type":"text","text":"for additional information."}]},{"text":"Signals","type":"heading","level":2,"anchor":"Signals"},{"inlineContent":[{"type":"text","text":"Generally, use the "},{"type":"codeVoice","code":"#signal"},{"type":"text","text":" macro to declare a new signal for your classes,"},{"type":"text","text":" "},{"type":"text","text":"like this:"}],"type":"paragraph"},{"code":["class Demo: Node {","    #signal(\"lives_changed\", argument: [\"new_lives_count\": Int.self])","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"For additional information on defining and connecting to signals see the","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","isActive":true},{"type":"text","text":" documentation."}]},{"text":"@onready annotation","type":"heading","level":2,"anchor":"onready-annotation"},{"inlineContent":[{"text":"GDScript supports an ","type":"text"},{"type":"codeVoice","code":"@onready"},{"text":" annotation on variables, like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"gdscript","code":["@onready var my_label = get_node(\"MyLabel\")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This does not exist in SwiftGodot, to achieve a similar behavior, initialize"},{"text":" ","type":"text"},{"type":"text","text":"those variables in an overwritten "},{"code":"_ready","type":"codeVoice"},{"text":" method, so code like this:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["class Demo: Node {","\tvar myLabel: Node3D","","\toverride func _ready () {","\t\tmyLabel = getNode (path: \"myLabel\") as? Node3D","\t}","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you do not need to load the node right away, and you merely need to be able"},{"type":"text","text":" "},{"type":"text","text":"to access it, you can use this instead:"}]},{"syntax":"swift","type":"codeListing","code":["class Demo: Node {","\t@BindNode var myLabel: Node3D","}"]},{"type":"heading","text":"Running code before nodes are added to the Scene Tree","anchor":"Running-code-before-nodes-are-added-to-the-Scene-Tree","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need to run some code in your constructor, but overriding the "},{"type":"codeVoice","code":"_ready()"},{"type":"text","text":" "},{"type":"text","text":"function is already too late for you, you can use the following idiom:"}]},{"syntax":"swift","code":["@Godot","class NetworkedNode: Node {","    required init() {","        super.init()","        onInit()","    }","","    required init(nativeHandle: UnsafeRawPointer) {","        super.init(nativeHandle: nativeHandle)","        onInit()","    }","","    func onInit() {","        print(\"Was init!\")","    }","}"],"type":"codeListing"},{"level":2,"type":"heading","text":"Singletons","anchor":"Singletons"},{"inlineContent":[{"text":"Godot Singletons surface their API as static methods, to make the code more","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"shorter, for example:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let pressed = Input.isActionPressed(ui_down)"]},{"type":"paragraph","inlineContent":[{"text":"However, in some very rare cases this is not enough. For example, you may want","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to access a member from the base class GodotObject, like "},{"code":"connect","type":"codeVoice"},{"text":". For such","type":"text"},{"text":" ","type":"text"},{"text":"use cases we provide a static property named ","type":"text"},{"type":"codeVoice","code":"shared"},{"type":"text","text":" that returns the singleton"},{"type":"text","text":" "},{"type":"text","text":"instance."}]},{"type":"codeListing","syntax":"swift","code":["let demo = Input.shared.joyConnectionChanged.connect { device, connected in ","   print (\"joyConnectionChanged called\")","}"]},{"text":"String","level":2,"type":"heading","anchor":"String"},{"inlineContent":[{"type":"text","text":"SwiftGodot generally exposes a Swift-string based API, but there are some"},{"type":"text","text":" "},{"type":"text","text":"convenience methods that you might have come to expect from the Godot String"},{"type":"text","text":" "},{"text":"(things like ","type":"text"},{"type":"codeVoice","code":"GString\/validateFilename"},{"text":", those APIs are available in the","type":"text"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString","type":"reference"},{"type":"text","text":" class)."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Callable","anchor":"Callable"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In SwiftGodot, you can create "},{"code":"Callable","type":"codeVoice"},{"type":"text","text":" instances by directly passing a Swift function that takes an array of "},{"type":"codeVoice","code":"Variant"},{"text":" arguments,","type":"text"},{"type":"text","text":" "},{"text":"and returns an optional ","type":"text"},{"code":"Variant","type":"codeVoice"},{"type":"text","text":" result, like this:"}]},{"type":"codeListing","syntax":"swift","code":["func myCallback(args: [Variant])-> Variant? {","\tprint (\"MyCallback invoked with \\(args.count) arguments\")","\treturn nil","}","","let myCallable = Callable(myCallback)"]},{"inlineContent":[{"type":"text","text":"Alternatively, you can use a StringName that binds a method that you have exported (via, the "},{"code":"@Callable","type":"codeVoice"},{"text":" macro), like this:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Callable func myCallback(message: String) {","\tGD.print(message)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can call the callable in GDScript by invoking call() method of the exported Swift type."}],"type":"paragraph"},{"type":"codeListing","code":["MySwiftNode.myCallback.call(\"Hello from Swift!\")"],"syntax":"GDScript"},{"type":"heading","text":"Async\/Await","level":2,"anchor":"AsyncAwait"},{"inlineContent":[{"type":"text","text":"GDScript comes with an "},{"type":"codeVoice","code":"await"},{"type":"text","text":" primitive, you can achieve similar functionality"},{"type":"text","text":" "},{"text":"with the Swift built-in await\/async stack.   Unlike GDScript, await can only be","type":"text"},{"type":"text","text":" "},{"type":"text","text":"invoked from "},{"type":"codeVoice","code":"async"},{"text":" methods.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This means that code like this wont work:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["func demo() {","\tawait someSignal.emitted","}"]},{"type":"paragraph","inlineContent":[{"text":"For this to work, this needs to be in an async context, like this one:","type":"text"}]},{"code":["func demo() async {","\tawait someSignal.emitted","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"If you are inside of a function that is not async, you need to wrap your code in"},{"text":" ","type":"text"},{"text":"Task, like this:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["func demo() {","\t\/\/ We are not an async function, but we can start a Task","\tTask {","\t\tawait someSignal.emitted","\t}","}"],"syntax":"swift"}],"kind":"content"}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Variant/asObject(_:)":{"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","url":"\/documentation\/swiftgodot\/variant\/asobject(_:)","abstract":[{"text":"Attempts to cast the Variant into a GodotObject, if the variant contains a value of type ","type":"text"},{"type":"co