{"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","interfaceLanguage":"swift"},"metadata":{"roleHeading":"Article","modules":[{"name":"SwiftGodot"}],"title":"SwiftGodot API differences to GDScript","role":"article"},"seeAlsoSections":[{"generated":true,"anchor":"Articles-and-Tutorials","title":"Articles and Tutorials","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"]}],"primaryContentSections":[{"kind":"content","content":[{"text":"General differences","anchor":"General-differences","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The SwiftGodot API follows the convention of the Swift platform, and one of the"},{"text":" ","type":"text"},{"text":"most notable places where this happens is in the use of camelCase style instead","type":"text"},{"type":"text","text":" "},{"type":"text","text":"of the snake_case style used in GDScript."}]},{"type":"paragraph","inlineContent":[{"text":"Enumerations and their values also change, for example, rather than having a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"constant value like "},{"type":"codeVoice","code":"CORNER_TOP_LEFT"},{"text":" for the ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner","isActive":true,"type":"reference"},{"text":" value, we use","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner\/topLeft","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In Swift, function definitions take parameter names, and sometimes this"},{"text":" ","type":"text"},{"text":"parameter name is omitted for the first argument. Instead of","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"myNode.add_child(box)"},{"text":", you would use ","type":"text"},{"type":"codeVoice","code":"myNode.addChild (node: box)"},{"type":"text","text":"."}]},{"text":"Global Scope","type":"heading","level":2,"anchor":"Global-Scope"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Global functions and some constants had to be moved to classes to avoid"},{"type":"text","text":" "},{"type":"text","text":"polluting the global name space, and you can find them in the "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","type":"reference"},{"type":"text","text":" class."}]},{"type":"heading","level":2,"text":"Type Mappings","anchor":"Type-Mappings"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Godot comes with some of their own data types like strings and dictionaries, but"},{"type":"text","text":" "},{"type":"text","text":"those types would clash with the existing Swift types with the same names."}]},{"inlineContent":[{"type":"text","text":"Here is a list of the current data type mappings:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GDScript type"}]}],[{"inlineContent":[{"type":"text","text":"SwiftGodot Name"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"string","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"GString","type":"text"}]}]],[[{"inlineContent":[{"text":"dictionary","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"GDictionary"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"text":"array","type":"text"}]}],[{"inlineContent":[{"text":"GArray","type":"text"}],"type":"paragraph"}]]],"type":"table","header":"row"},{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GArray","type":"reference","isActive":true},{"text":" is a type-erased array that can hold any sort of element that","type":"text"},{"text":" ","type":"text"},{"text":"can be managed by Godot (Variants or Objects).","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In addition, there are two special kinds of strongly-typed versions of the","type":"text"},{"type":"text","text":" "},{"text":"GArray:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantCollection","isActive":true},{"text":" that holds any ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference"},{"text":" instances.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ObjectCollection"},{"type":"text","text":" that holds any "},{"type":"codeVoice","code":"SwiftGodot.Object"},{"text":" instances.","type":"text"}],"type":"paragraph"}]}]},{"level":2,"anchor":"GDScript-Helper-Functions","type":"heading","text":"GDScript Helper Functions"},{"type":"paragraph","inlineContent":[{"text":"Many global helper functions that are exposed in GDScript have been exposed in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD"},{"type":"text","text":" class as static methods."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This means that you can invoke them like this:"}]},{"type":"codeListing","syntax":"swift","code":["func reportError (error: Variant) {","    GD.printerr (msg)","}"]},{"level":3,"type":"heading","text":"Godot Math Functions","anchor":"Godot-Math-Functions"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The various GDScript Math functions like "},{"code":"abs","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"acos"},{"type":"text","text":", "},{"type":"codeVoice","code":"atan"},{"type":"text","text":" as well as their"},{"type":"text","text":" "},{"text":"helper functions like ","type":"text"},{"code":"clamp","type":"codeVoice"},{"type":"text","text":" are defined as static functions in the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","type":"reference","isActive":true},{"text":" ","type":"text"},{"type":"text","text":"class."}]},{"type":"paragraph","inlineContent":[{"text":"Generally, you can use the Swift versions instead of the GDScript versions,","type":"text"},{"type":"text","text":" "},{"text":"which are more complete and do not incurr a marshaling overhead.","type":"text"}]},{"anchor":"Random-Functions","level":3,"text":"Random Functions","type":"heading"},{"inlineContent":[{"text":"The random functions like ","type":"text"},{"type":"codeVoice","code":"randi"},{"text":", ","type":"text"},{"type":"codeVoice","code":"randf"},{"text":" and under the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD","type":"reference"},{"type":"text","text":" class. But Swift"},{"type":"text","text":" "},{"type":"text","text":"provides a set of random functions that are just as good, like"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/int\/random(in:)-9mjpw","isActive":true},{"type":"text","text":" "},{"type":"text","text":"or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/double\/random(in:)-6idef"},{"text":" ","type":"text"},{"text":"that operate on Swift ranges.","type":"text"}],"type":"paragraph"},{"text":"Idiom Mapping","anchor":"Idiom-Mapping","level":2,"type":"heading"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"GDScript Idiom"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"SwiftGodot Equivalent","type":"text"}]}]],[[{"inlineContent":[{"type":"text","text":"instance_from_id(n)"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"text":"GD.instanceFromId (instanceId: n)","type":"text"}]}]]]},{"text":"Checking for the contents of a variant","level":3,"type":"heading","anchor":"Checking-for-the-contents-of-a-variant"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can check in one go if a given variant contains a valid object and is of a"},{"type":"text","text":" "},{"text":"given type, with the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","type":"reference"},{"text":" method, combined with Swift’s","type":"text"},{"type":"text","text":" "},{"text":"“let”:","type":"text"}]},{"code":["func demo(input: Variant) {","\tif let node = input.asObject(Node.self) {","\t\t\/\/ We have a happy node inside 'input'","\t} else {","\t\tprint (\"The variant did not wrap an object, if it did, it was either nil, or was not of type Node\")","\t}","}"],"type":"codeListing","syntax":"swift"},{"level":2,"text":"@export annotations","type":"heading","anchor":"export-annotations"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"@export"},{"text":" annotation works the same way as it does in GDScript. Some","type":"text"},{"type":"text","text":" "},{"text":"parameters and directives are different see the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports"},{"type":"text","text":" documentation"},{"type":"text","text":" "},{"text":"for additional information.","type":"text"}]},{"anchor":"Signals","type":"heading","level":2,"text":"Signals"},{"type":"paragraph","inlineContent":[{"text":"Generally, use the ","type":"text"},{"code":"#signal","type":"codeVoice"},{"text":" macro to declare a new signal for your classes,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"like this:"}]},{"syntax":"swift","type":"codeListing","code":["class Demo: Node {","    #signal(\"lives_changed\", argument: [\"new_lives_count\": Int.self])","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For additional information on defining and connecting to signals see the"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","isActive":true},{"type":"text","text":" documentation."}]},{"text":"@onready annotation","level":2,"anchor":"onready-annotation","type":"heading"},{"inlineContent":[{"text":"GDScript supports an ","type":"text"},{"type":"codeVoice","code":"@onready"},{"text":" annotation on variables, like this:","type":"text"}],"type":"paragraph"},{"syntax":"gdscript","code":["@onready var my_label = get_node(\"MyLabel\")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"This does not exist in SwiftGodot, to achieve a similar behavior, initialize"},{"type":"text","text":" "},{"text":"those variables in an overwritten ","type":"text"},{"type":"codeVoice","code":"_ready"},{"type":"text","text":" method, so code like this:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Godot","class Demo: Node {","\tvar myLabel: Node3D?","","\toverride func _ready () {","\t\tmyLabel = getNode (path: \"myLabel\") as? Node3D","\t}","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you do not need to load the node right away, and you merely need to be able"},{"text":" ","type":"text"},{"type":"text","text":"to access it, you can use this instead:"}]},{"code":["class Demo: Node {","\t@BindNode var myLabel: Node3D","}"],"type":"codeListing","syntax":"swift"},{"text":"Running code before nodes are added to the Scene Tree","type":"heading","level":2,"anchor":"Running-code-before-nodes-are-added-to-the-Scene-Tree"},{"inlineContent":[{"type":"text","text":"If you need to run some code in your constructor, but overriding the "},{"code":"_ready()","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"function is already too late for you, you can use the following idiom:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Godot","class NetworkedNode: Node {","    required init() {","        super.init()","        onInit()","    }","","    required init(nativeHandle: UnsafeRawPointer) {","        super.init(nativeHandle: nativeHandle)","        onInit()","    }","","    func onInit() {","        print(\"Was init!\")","    }","}"]},{"type":"heading","anchor":"Singletons","level":2,"text":"Singletons"},{"inlineContent":[{"text":"Godot Singletons surface their API as static methods, to make the code more","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"shorter, for example:"}],"type":"paragraph"},{"syntax":"swift","code":["let pressed = Input.isActionPressed(ui_down)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"However, in some very rare cases this is not enough. For example, you may want"},{"text":" ","type":"text"},{"type":"text","text":"to access a member from the base class SwiftGodot.Object, like "},{"type":"codeVoice","code":"connect"},{"type":"text","text":". For such"},{"type":"text","text":" "},{"type":"text","text":"use cases we provide a static property named "},{"type":"codeVoice","code":"shared"},{"text":" that returns the singleton","type":"text"},{"type":"text","text":" "},{"text":"instance.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let demo = Input.shared.joyConnectionChanged.connect { device, connected in ","   print (\"joyConnectionChanged called\")","}"]},{"anchor":"String","text":"String","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"SwiftGodot generally exposes a Swift-string based API, but there are some"},{"type":"text","text":" "},{"text":"convenience methods that you might have come to expect from the Godot String","type":"text"},{"type":"text","text":" "},{"text":"(things like ","type":"text"},{"type":"codeVoice","code":"GString\/validateFilename"},{"text":", those APIs are available in the","type":"text"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString","isActive":true},{"type":"text","text":" class)."}],"type":"paragraph"},{"level":2,"text":"Callable","type":"heading","anchor":"Callable"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In SwiftGodot, you can create "},{"type":"codeVoice","code":"Callable"},{"type":"text","text":" instances by directly passing a Swift function that takes an array of "},{"code":"Variant","type":"codeVoice"},{"text":" arguments,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"and returns an optional "},{"code":"Variant","type":"codeVoice"},{"text":" result, like this:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["func myCallback(args: borrowing Arguments)-> Variant? {","\tprint (\"MyCallback invoked with \\(args.count) arguments\")","\treturn nil","}","","let myCallable = Callable(myCallback)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Alternatively, you can use a StringName that binds a method that you have exported (via, the "},{"type":"codeVoice","code":"@Callable"},{"type":"text","text":" macro), like this:"}]},{"syntax":"swift","code":["@Callable func myCallback(message: String) {","\tGD.print(message)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can call the callable in GDScript by invoking call() method of the exported Swift type."}]},{"type":"codeListing","syntax":"GDScript","code":["MySwiftNode.myCallback.call(\"Hello from Swift!\")"]},{"level":2,"anchor":"AsyncAwait","type":"heading","text":"Async\/Await"},{"type":"paragraph","inlineContent":[{"text":"GDScript comes with an ","type":"text"},{"code":"await","type":"codeVoice"},{"type":"text","text":" primitive, you can achieve similar functionality"},{"type":"text","text":" "},{"type":"text","text":"with the Swift built-in await\/async stack.   Unlike GDScript, await can only be"},{"type":"text","text":" "},{"type":"text","text":"invoked from "},{"type":"codeVoice","code":"async"},{"text":" methods.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This means that code like this wont work:"}]},{"code":["func demo() {","\tawait someSignal.emitted","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"For this to work, this needs to be in an async context, like this one:","type":"text"}]},{"type":"codeListing","code":["func demo() async {","\tawait someSignal.emitted","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"If you are inside of a function that is not async, you need to wrap your code in","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Task, like this:"}]},{"type":"codeListing","syntax":"swift","code":["func demo() {","\t\/\/ We are not an async function, but we can start a Task","\tTask {","\t\tawait someSignal.emitted","\t}","}"]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/differences"]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"kind":"article","sections":[],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","role":"article","title":"Signals","kind":"article","url":"\/documentation\/swiftgodot\/signals","type":"topic","abstract":[{"type":"text","text":"Signals in Godot are used by objects to post interesting events that are"},{"type":"text","text":" "},{"type":"text","text":"taking place, and can be used by users to easily add behavior and react"},{"text":" ","type":"text"},{"type":"text","text":"to changes."}]},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","role":"article","title":"Exports","kind":"article","url":"\/documentation\/swiftgodot\/exports","type":"topic","abstract":[{"type":"text","text":"In Godot, class members can be exported. This means their value gets saved along"},{"type":"text","text":" "},{"type":"text","text":"with the resource (such as the scene) they’re attached to. They will also be"},{"text":" ","type":"text"},{"type":"text","text":"available for editing in the property editor. Exporting is done by using the"}]},"doc://SwiftGodot/documentation/SwiftGodot/GString":{"abstract":[{"text":"A built-in type for strings.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"GString"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"GString","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GString","title":"GString","url":"\/documentation\/swiftgodot\/gstring"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"role":"article","title":"Using Custom Types","url":"\/documentation\/swiftgodot\/customtypes","type":"topic","abstract":[{"type":"text","text":"You will typically extend the functionality of your Godot game by creating"},{"type":"text","text":" "},{"text":"classes that derive from one of the various Godot types and adjust the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior accordingly."}],"kind":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes"},"doc://SwiftGodot/documentation/SwiftGodot/Corner":{"url":"\/documentation\/swiftgodot\/corner","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner","navigatorTitle":[{"kind":"identifier","text":"Corner"}],"abstract":[],"type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Corner"}],"kind":"symbol","title":"Corner"},"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Variant","kind":"identifier"}],"abstract":[{"type":"text","text":"Variant objects box various Godot Objects, you create them with one of the"},{"text":" ","type":"text"},{"type":"text","text":"constructors, and you can retrieve the contents using the various extension"},{"text":" ","type":"text"},{"text":"constructors that are declared on the various types that are wrapped.","type":"text"}],"title":"Variant","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Variant"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","url":"\/documentation\/swiftgodot\/variant","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Variant/asObject(_:)":{"abstract":[{"type":"text","text":"Attempts to cast the Variant into a SwiftGodot.Object, if the variant contains a value of type "},{"type":"codeVoice","code":".object"},{"type":"text","text":", then"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":".object, the value "},{"type":"text","text":"nil` is returned."}],"title":"asObject(_:)","type":"topic","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant\/asObject(_:)","role":"symbol","url":"\/documentation\/swiftgodot\/variant\/asobject(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"asObject","kind":"identifier"},{"text":"<","kind":"text"},{"text":"T","kind":"genericParameter"},{"text":">(","kind":"text"},{"kind":"typeIdentifier","text":"T"},{"text":".Type) -> ","kind":"text"},{"text":"T","kind":"typeIdentifier"},{"text":"?","kind":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","role":"article","title":"Variants","kind":"article","url":"\/documentation\/swiftgodot\/variants","type":"topic","abstract":[{"text":"Follow up on the fundamental building block of Godot’s data types.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/BindingNodes":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","role":"article","title":"Referencing Nodes from your Scene","kind":"article","url":"\/documentation\/swiftgodot\/bindingnodes","type":"topic","abstract":[{"type":"text","text":"You will find yourself referencing nodes from a scene in your code.   In"},{"type":"text","text":" "},{"type":"text","text":"GDScript, that is usually achieved by using the dollar sign and the name of the"},{"text":" ","type":"text"},{"type":"text","text":"object you want to reference."}]},"doc://SwiftGodot/documentation/SwiftGodot/ObjectCollection":{"title":"ObjectCollection","type":"topic","navigatorTitle":[{"text":"ObjectCollection","kind":"identifier"}],"abstract":[{"type":"text","text":"This represents a typed array of one of the built-in types from Godot"}],"role":"symbol","url":"\/documentation\/swiftgodot\/objectcollection","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ObjectCollection","kind":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ObjectCollection"}]},"doc://SwiftGodot/documentation/SwiftGodot/Corner/topLeft":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Corner\/topLeft","type":"topic","fragments":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"topLeft","kind":"identifier"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/corner\/topleft","title":"Corner.topLeft","abstract":[{"type":"text","text":"Top-left corner."}],"role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/GD":{"type":"topic","url":"