{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"NodePath","kind":"identifier"}],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath"},{"type":"text","text":" built-in "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","isActive":true},{"type":"text","text":" type represents a path to a node or property in a hierarchy of nodes. It is designed to be efficiently passed into many built-in methods (such as "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/getNode(path:)","isActive":true,"type":"reference"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Object\/setIndexed(propertyPath:value:)"},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Tween\/tweenProperty(object:property:finalVal:duration:)","isActive":true},{"type":"text","text":", etc.) without a hard dependence on the node or property they point to."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A node path is represented as a "},{"type":"codeVoice","code":"String"},{"type":"text","text":" composed of slash-separated ("},{"code":"\/","type":"codeVoice"},{"text":") node names and colon-separated (","type":"text"},{"type":"codeVoice","code":":"},{"text":") property names (also called “subnames”). Similar to a filesystem path, ","type":"text"},{"type":"codeVoice","code":"\"..\""},{"text":" and ","type":"text"},{"type":"codeVoice","code":"\".\""},{"text":" are special node names. They refer to the parent node and the current node, respectively.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"The following examples are paths relative to the current node:","type":"text"}]},{"inlineContent":[{"type":"text","text":"A leading slash means the path is absolute, and begins from the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SceneTree","type":"reference","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Despite their name, node paths may also point to a property:"}]},{"type":"paragraph","inlineContent":[{"text":"Node paths cannot check whether they are valid and may point to nodes or properties that do not exist. Their meaning depends entirely on the context in which they’re used.","type":"text"}]},{"inlineContent":[{"text":"You usually do not have to worry about the ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath","isActive":true,"type":"reference"},{"type":"text","text":" type, as strings are automatically converted to the type when necessary. There are still times when defining node paths is useful. For example, exported "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath","type":"reference","isActive":true},{"text":" properties allow you to easily select any node within the currently edited scene. They are also automatically updated when moving, renaming or deleting nodes in the scene tree editor. See also [annotation @GDScript.@export_node_path].","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See also "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/StringName"},{"type":"text","text":", which is a similar type designed for optimized strings."}]},{"type":"aside","name":"Note","style":"note","content":[{"inlineContent":[{"text":"In a boolean context, a ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath","isActive":true},{"text":" will evaluate to ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":" if it is empty ("},{"type":"codeVoice","code":"NodePath(\"\")"},{"text":"). Otherwise, a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath","isActive":true,"type":"reference"},{"type":"text","text":" will always evaluate to "},{"code":"true","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ContentVariantRepresentable","doc:\/\/SwiftGodot\/s8CopyableP","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/s43ExpressibleByExtendedGraphemeClusterLiteralP","doc:\/\/SwiftGodot\/s32ExpressibleByStringInterpolationP","doc:\/\/SwiftGodot\/s26ExpressibleByStringLiteralP","doc:\/\/SwiftGodot\/s33ExpressibleByUnicodeScalarLiteralP","doc:\/\/SwiftGodot\/s25LosslessStringConvertibleP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo","kind":"relationships"}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"externalID":"s:10SwiftGodot8NodePathC","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"NodePath"}],"symbolKind":"class","role":"symbol","title":"NodePath","navigatorTitle":[{"text":"NodePath","kind":"identifier"}],"roleHeading":"Class","modules":[{"name":"SwiftGodot"}]},"topicSections":[{"generated":true,"title":"Operators","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath\/!=(_:_:)-53o10","doc:\/\/SwiftGodot\/documentation\/SwiftG