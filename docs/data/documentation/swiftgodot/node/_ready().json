forceReadableName:`internal`:)"},{"text":" in a script). If the node has children, its ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()","isActive":true,"type":"reference"},{"type":"text","text":" callback will be called first, and then that of the children."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"_enterTree","kind":"identifier"},{"kind":"text","text":"()"}],"type":"topic","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Node/requestReady()":{"role":"symbol","kind":"symbol","title":"requestReady()","abstract":[{"text":"Requests that ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"type":"text","text":" be called again. Note that the method won’t be called immediately, but is scheduled for when the node is added to the scene tree again. "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","type":"reference"},{"type":"text","text":" is called only for the node which requested it, which means that you need to request ready for each child if you want them to call "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","type":"reference","isActive":true},{"text":" too (in which case, ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true},{"type":"text","text":" will be called in the same order as it would normally)."}],"type":"topic","url":"\/documentation\/swiftgodot\/node\/requestready()","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/requestReady()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"requestReady","kind":"identifier"},{"text":"()","kind":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Node/notificationReady":{"abstract":[{"type":"text","text":"Notificati