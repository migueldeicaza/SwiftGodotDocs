t\/Node\/requestReady()","isActive":true},{"type":"text","text":", which may be called anywhere before adding the node again."}]}],"style":"note"}],"kind":"content"}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Called when the node is “ready”, i.e. when both the node and its children have entered the scene tree. If the node has children, their "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},{"type":"text","text":" callbacks get triggered first, and the parent node will receive the ready notification afterwards."}],"variants":[{"paths":["\/documentation\/swiftgodot\/node\/_ready()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"SwiftGodot"}],"title":"_ready()","externalID":"s:10SwiftGodot4NodeC6_readyyyF","roleHeading":"Instance Method","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"_ready","kind":"identifier"},{"text":"()","kind":"text"}],"role":"symbol"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node/notificationReady":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationReady","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notificationReady","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"title":"notificationReady","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Notification received when the node is ready. See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},{"text":".","type":"text"}],"role":"symbol","url":"\/documentation\/swiftgodot\/node\/notificationready"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_ready()":{"title":"_ready()","kind":"symbol","abstract":[{"text":"Called when the node is “ready”, i.e. when both the node and its children have entered the scene tree. If the node has children, their ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","type":"reference","isActive":true},{"type":"text","text":" callbacks get triggered first, and the parent node will receive the ready notification afterwards."}],"url":"\/documentation\/swiftgodot\/node\/_ready()","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"_ready","kind":"identifier"},{"kind":"text","text":"()"}],"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},"doc://SwiftGodot/documentation/SwiftGodot/Node":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Node"}],"navigatorTitle":[{"text":"Node","kind":"identifier"}],"type":"topic","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","role":"symbol","title":"Node","url":"\/documentation\/swiftgodot\/node","abstract":[{"type":"text","text":"Base class for all scene objects."}]},"doc://SwiftGodot/documentation/SwiftGodot":{"kind":"symbol","url":"\/documentation\/swiftgodot","title":"SwiftGodot","role":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"},"doc://SwiftGodot/documentation/SwiftGodot/SceneTree":{"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SceneTree","title":"SceneTree","kind":"symbol","abstract":[{"type":"text","text":"Manages the game loop via a hierarchy of nodes."}],"url":"\/documentation\/swiftgodot\/scenetree","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SceneTree"}],"navigatorTitle":[{"kind":"identifier","text":"SceneTree"}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_enterTree()":{"abstract":[{"text":"Called when the node enters the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SceneTree"},{"type":"text","text":" (e.g. upon instancing, scene changing, or after calling "},{"code":"addChild(node:forceReadableName:`internal`:)","type":"codeVoice"},{"text":" in a script). If the node has children, its ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()","type":"reference","isActive":true},{"type":"text","text":" callback will be called first, and then that of the children."}],"type":"topic","kind":"symbol","url":"\/documentation\/swiftgodot\/node\/_entertree()","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()","title":"_enterTree()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"_enterTree"},{"text":"()","kind":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Node/requestReady()":{"abstract":[{"text":"Requests that ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},{"text":" be called again. Note that the method won’t be called immediately, but is scheduled for when the node is added to the scene tree again. ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true},{"type":"text","text":" is called only for the node which requested it, which means that you need to request ready for each child if you want them to call "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true},{"text":" too (in which case, ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","i