{"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"_ready"},{"text":"()","kind":"text"}]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Corresponds to the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationReady","isActive":true,"type":"reference"},{"text":" notification in ","type":"text"},{"type":"codeVoice","code":"Object\/_notification()"},{"text":". See also the ","type":"text"},{"type":"codeVoice","code":"@onready"},{"type":"text","text":" annotation for variables."}]},{"inlineContent":[{"type":"text","text":"Usually used for initialization. For even earlier initialization, "},{"type":"codeVoice","code":"Object\/_init()"},{"text":" may be used. See also ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":""},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"text":" may be called only once for each node. After removing a node from the scene tree and adding it again, ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"type":"text","text":" will not be called a second time. This can be bypassed by requesting another call with "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Sw