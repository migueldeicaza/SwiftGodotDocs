{"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/node\/_ready()"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"_ready","kind":"identifier"},{"text":"()","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Corresponds to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationReady"},{"text":" notification in ","type":"text"},{"code":"Object\/_notification()","type":"codeVoice"},{"type":"text","text":". See also the "},{"type":"codeVoice","code":"@onready"},{"type":"text","text":" annotation for variables."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Usually used for initialization. For even earlier initialization, "},{"type":"codeVoice","code":"Object\/_init()"},{"type":"text","text":" may be used. See also "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()"},{"type":"text","text":"."}]},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},{"type":"text","text":" may be called only once for each node. After removing a node from the scene tree and adding it again, "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","type":"reference"},{"text":" will not be called a second time. This can be bypassed by requesting another call with ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/requestReady()","isActive":true,"type":"reference"},{"type":"text","text":", which may be called anywhere before adding the node again."}],"type":"paragraph"}]}],"kind":"content"}],"abstract":[{"type":"text","text":"Called when the node is “ready”, i.e. when both the node and its children have entered the scene tree. If the node has children, their "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"text":" callbacks get triggered first, and the parent node will receive the ready notification afterwards.","type":"text"}],"metadata":{"symbolKind":"method","modules":[{"name":"SwiftGodot"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"_ready"},{"kind":"text","text":"()"}],"externalID":"s:10SwiftGodot4NodeC6_readyyyF","roleHeading":"Instance Method","role":"symbol","title":"_ready()"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node":{"abstract":[{"type":"text","text":"Base class for all scene objects."}],"navigatorTitle":[{"kind":"identifier","text":"Node"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Node","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","kind":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Node/notificationReady":{"role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notificationReady","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"}],"url":"\/documentation\/swiftgodot\/node\/notificationready","type":"topic","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationReady","title":"notificationReady","abstract":[{"type":"text","text":"Notification received when the node is ready. See "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","type":"reference","isActive":true},{"type":"text","text":"."}]},"doc://SwiftGodot/documentation/SwiftGodot/Node/_enterTree()":{"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()","kind":"symbol","url":"\/documentation\/swiftgodot\/node\/_entertree()","title":"_enterTree()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"_enterTree","kind":"identifier"},{"text":"()","kind":"text"}],"abstract":[{"type":"text","text":"Called when the node enters the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SceneTree","isActive":true},{"type":"text","text":" (e.g. upon instancing, scene changing, or after calling "},{"code":"addChild(node:forceReadableName:`internal`:)","type":"codeVoice"},{"type":"text","text":" in a script). If the node has children, its "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_enterTree()","isActive":true,"type":"reference"},{"type":"text","text":" callback will be called first, and then that of the children."}]},"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Node/requestReady()":{"url":"\/documentation\/swiftgodot\/node\/requestready()","type":"topic","abstract":[{"type":"text","text":"Requests that "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"type":"text","text":" be called again. Note that the method won’t be called immediately, but is scheduled for when the node is added to the scene tree again. "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"type":"text","text":" is called only for the node which requested it, which means that you need to request ready for each child if you want them to call "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true},{"type":"text","text":" too (in which case, "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true},{"type":"text","text":" will be called in the same order as it would normally)."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"requestReady","kind":"identifier"},{"text":"()","kind":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/requestReady()","kind":"symbol","role":"symbol","title":"requestReady()"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_ready()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"_ready","kind":"identifier"},{"text":"()","kind":"text"}],"role":"symbol","title":"_ready()","abstract":[{"type":"text","text":"Called when the node is “ready”, i.e. when both the node and its children have entered the scene tree. If the node has children, their "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"text":" callbacks get triggered first, and the parent node will receive the ready notification afterwards.","type":"text"}],"type":"topic","url":"\/documentation\/swiftgodot\/node\/_ready()","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},"doc://SwiftGodot/documentation/SwiftGodot/SceneTree":{"abstract":[{"text":"Manages the game loop via a hierarchy of nodes.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"SceneTree"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"SceneTree","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SceneTree","type":"topic","kind":"symbol","url":"\/documentation\/swiftgodot\/scenetree","title":"SceneTree","role":"symbol"}}}