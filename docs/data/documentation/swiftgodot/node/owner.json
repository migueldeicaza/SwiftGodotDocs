scripts"},{"type":"text","text":" and "},{"type":"text","text":"editor plugins"},{"type":"text","text":". If a new node is added to the tree without setting its owner as an ancestor in that tree, it will be visible in the 2D\/3D view, but not in the scene tree (and not persisted when packing or saving)."}]}],"type":"aside","style":"note","name":"Note"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner"},"abstract":[{"text":"The node owner. A node can have any ancestor node as owner (i.e. a parent, grandparent, etc. node ascending in the tree). This implies that ","type":"text"},{"code":"addChild(node:forceReadableName:`internal`:)","type":"codeVoice"},{"type":"text","text":" should be called before setting the owner, so that this relationship of parenting exists. When saving a node (using "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedScene","isActive":true},{"type":"text","text":"), all the nodes it owns will be saved with it. This allows for the creation of complex scene trees, with instancing and subinstancing."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Node":{"abstract":[{"type":"text","text":"Base class for all scene objects."}],"navigatorTitle":[{"kind":"identifier","text":"Node"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Node","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","kind":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","role":"symbol"},"doc://Sw