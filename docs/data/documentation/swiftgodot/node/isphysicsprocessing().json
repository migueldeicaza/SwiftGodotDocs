sProcess(delta:)","isActive":true},{"type":"text","text":" methods are run. This value should generally always be set to "},{"code":"60","type":"codeVoice"},{"text":" or above, as Godot doesn’t interpolate the physics step. As a result, values lower than ","type":"text"},{"code":"60","type":"codeVoice"},{"type":"text","text":" will look stuttery. This value can be increased to make input more reactive or work around collision tunneling issues, but keep in mind doing so will increase CPU usage. See also "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxFps"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"ProjectSettings\/physics\/common\/physicsTicksPerSecond"},{"text":".","type":"text"}],"title":"physicsTicksPerSecond","url":"\/documentation\/swiftgodot\/engine\/physicstickspersecond","role":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Node":{"navigatorTitle":[{"text":"Node","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Node"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","abstract":[{"type":"text","text":"Base class for all scene objects."}]},"doc://SwiftGodot/documentation/SwiftGodot/Node/isPhysicsProcessing()":{"role":"symbol","abstract":[{"text":"Returns ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" if physics processing is enabled (see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/setPhysicsProcess(enable:)"},{"type":"text","text":")."}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/isPhysicsProcessing()","title":"isPhysicsProcessing()","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"isPhysics