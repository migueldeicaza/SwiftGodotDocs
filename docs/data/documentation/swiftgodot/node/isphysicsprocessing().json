s get triggered first, and the parent node will receive the ready notification afterwards.","type":"text"}],"type":"topic","url":"\/documentation\/swiftgodot\/node\/_ready()","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_physicsProcess(delta:)":{"url":"\/documentation\/swiftgodot\/node\/_physicsprocess(delta:)","title":"_physicsProcess(delta:)","type":"topic","abstract":[{"type":"text","text":"Called during the physics processing step of the main loop. Physics processing means that the frame rate is synced to the physics, i.e. the "},{"code":"delta","type":"codeVoice"},{"type":"text","text":" variable should be constant. "},{"code":"delta","type":"codeVoice"},{"text":" is in seconds.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"_physicsProcess","kind":"identifier"},{"text":"(","kind":"text"},{"text":"delta","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"text":")","kind":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)"}}}