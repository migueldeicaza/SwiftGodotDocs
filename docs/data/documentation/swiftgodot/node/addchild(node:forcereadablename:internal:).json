{"sections":[],"variants":[{"paths":["\/documentation\/swiftgodot\/node\/addchild(node:forcereadablename:internal:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/addChild(node:forceReadableName:internal:)"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addChild"},{"kind":"text","text":"("},{"kind":"externalParam","text":"node"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot4NodeC","text":"Node","kind":"typeIdentifier","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"},{"text":"?, ","kind":"text"},{"kind":"externalParam","text":"forceReadableName"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" = false, ","kind":"text"},{"kind":"externalParam","text":"internal"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","text":"Node","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot4NodeC"},{"kind":"text","text":"."},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/InternalMode","text":"InternalMode","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot4NodeC12InternalModeO"},{"text":" = .disabled)","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"If "},{"code":"forceReadableName","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":", improves the readability of the added "},{"code":"node","type":"codeVoice"},{"text":". If not named, the ","type":"text"},{"code":"node","type":"codeVoice"},{"text":" is renamed to its type, and if it shares ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/name"},{"text":" with a sibling, a number is suffixed more appropriately. This operation is very slow. As such, it is recommended leaving this to ","type":"text"},{"type":"codeVoice","code":"false"},{"type":"text","text":", which assigns a dummy name featuring "},{"type":"codeVoice","code":"@"},{"type":"text","text":" in both situations."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"internal"},{"type":"text","text":" is different than .disabled, the child will be added as internal node. Such nodes are ignored by methods like "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/getChildren(includeInternal:)","isActive":true,"type":"reference"},{"type":"text","text":", unless their parameter "},{"code":"include_internal","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":". The intended usage is to hide the internal nodes from the user, so the user won’t accidentally delete or modify them. Used by some GUI nodes, e.g. ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ColorPicker","isActive":true},{"type":"text","text":". See "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/InternalMode","isActive":true,"type":"reference"},{"text":" for available modes.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"If the child node already has a parent, the function will fail. Use ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/removeChild(node:)","type":"reference","isActive":true},{"type":"text","text":" first to remove the node from its current parent. For example:"}],"type":"paragraph"}]},{"inlineContent":[{"type":"text","text":"If you need the child node to be added below a specific node in the list of children, use "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/addSibling(_:forceReadableName:)","isActive":true,"type":"reference"},{"type":"text","text":" instead of this method."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"If you want a child to be persisted to a "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedScene","isActive":true},{"type":"text","text":", you must set "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner","type":"reference","isActive":true},{"text":" in addition to calling ","type":"text"},{"type":"codeVoice","code":"addChild(node:forceReadableName:`internal`:)"},{"text":". This is typically relevant for ","type":"text"},{"type":"text","text":"tool scripts"},{"type":"text","text":" and "},{"text":"editor plugins","type":"text"},{"text":". If ","type":"text"},{"type":"codeVoice","code":"addChild(node:forceReadableName:`internal`:)"},{"text":" is called without setting ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner","isActive":true},{"text":", the newly added ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","type":"reference","isActive":true},{"type":"text","text":" will not be visible in the scene tree, though it will be visible in the 2D\/3D view."}],"type":"paragraph"}],"type":"aside","style":"note","name":"Note"}]}],"metadata":{"role":"symbol","modules":[{"name":"SwiftGodot"}],"fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"addChild"},{"text":"(","kind":"text"},{"text":"node","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot4NodeC","kind":"typeIdentifier","text":"Node"},{"kind":"text","text":"?, "},{"text":"forceReadableName","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":", ","kind":"text"},{"text":"internal","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Node","preciseIdentifier":"s:10SwiftGodot4NodeC"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"InternalMode","preciseIdentifier":"s:10SwiftGodot4NodeC12InternalModeO"},{"text":")","kind":"text"}],"roleHeading":"Instance Method","symbolKind":"method","title":"addChild(node:forceReadableName:internal:)","externalID":"s:10SwiftGodot4NodeC8addChild4node17forceReadableName8internalyACSg_SbAC12InternalModeOtF"},"abstract":[{"type":"text","text":"Adds a child "},{"code":"node","type":"codeVoice"},{"type":"text","text":". Nodes can have any number of children, but every child must have a unique name. Child nodes are automatically deleted when the parent node is deleted, so an entire scene can be removed by deleting its topmost node."}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node/addChild(node:forceReadableName:internal:)":{"role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addChild","kind":"identifier"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"node"},{"kind":"text","text":": "},{"text":"Node","preciseIdentifier":"s:10SwiftGodot4NodeC","kind":"typeIdentifier"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"forceReadableName"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"kind":"text","text":", "},{"text":"internal","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot4NodeC","text":"Node","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot4NodeC12InternalModeO","kind":"typeIdentifier","text":"InternalMode"},{"kind":"text","text":")"}],"url":"\/documentation\/swiftgodot\/node\/addchild(node:forcereadablename:internal:)","title":"addChild(node:forceReadableName:internal:)","abstract":[{"text":"Adds a child ","type":"text"},{"code":"node","type":"codeVoice"},{"type":"text","text":". Nodes can have any number of children, but every child must have a unique name. Child nodes are automatically deleted when the parent node is deleted, so an entire scene can be removed by deleting its topmost node."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/addChild(node:forceReadableName:internal:)"},"doc://SwiftGodot/documentation/SwiftGodot/Node/owner":{"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner","abstract":[{"text":"The node owner. A node can have any ancestor node as owner (i.e. a parent, grandparent, etc. node ascending in the tree). This implies that ","type":"text"},{"type":"codeVoice","code":"addChild(node:forceReadableName:`internal`:)"},{"type":"text","text":" should be called before setting the owner, so that this relationship of parenting exists. When saving a node (using "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedScene","type":"reference","isActive":true},{"text":"), all the nodes it owns will be saved with it. This allows for the creation of complex scene trees, with instancing and subinstancing.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"owner"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Node","preciseIdentifier":"s:10SwiftGodot4NodeC"},{"text":"?","kind":"text"}],"url":"\/documentation\/swiftgodot\/node\/owner","title":"owner"},"doc://SwiftGodot/documentation/SwiftGodot/Node":{"navigatorTitle":[{"text":"Node","kind":"identifier"}],"type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Node"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","abstract":[{"type":"text","text":"Base class for all scene objects."}]},"doc://SwiftGodot/documentation/SwiftGodot/Node/addSibling(_:forceReadableName:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"addSibling","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot4NodeC","kind":"typeIdentifier","text":"Node"},{"text":"?, ","kind":"text"},{"text":"forceReadableName","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/swiftgodot\/node\/addsibling(_:forcereadablename:)","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/addSibling(_:forceReadableName:)","title":"addSibling(_:forceReadableName:)","abstract":[{"text":"Adds a ","type":"text"},{"code":"sibling","type":"codeVoice"},{"type":"text","text":" node to current’s node parent, at the same level as that node, right below it."}],"type":"topic","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Node/name":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"name","kind":"identifier"},{"kind":"text","text":": "},{"text":"StringName","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot10StringNameC"}],"role":"symbol","title":"name","abstract":[{"type":"text","text":"The name of the node. This name is unique among the siblings (other child nodes from the same parent). When set to an existing name, the node will be automatically renamed."}],"type":"topic","url":"\/documentation\/swiftgodot\/node\/name","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/name","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Node/InternalM