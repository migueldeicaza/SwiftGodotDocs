{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/node\/findchild(pattern:recursive:owned:)"]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"]]},"kind":"symbol","sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Finds the first descendant of this node whose name matches "},{"code":"pattern","type":"codeVoice"},{"type":"text","text":" as in "},{"type":"codeVoice","code":"String\/match(expr:)"},{"type":"text","text":". Internal children are also searched over (see "},{"type":"codeVoice","code":"internal"},{"type":"text","text":" parameter in "},{"type":"codeVoice","code":"addChild(node:forceReadableName:`internal`:)"},{"text":").","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/findChild(pattern:recursive:owned:)"},"metadata":{"externalID":"s:10SwiftGodot4NodeC9findChild7pattern9recursive5ownedACSgSS_S2btF","symbolKind":"method","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"findChild"},{"kind":"text","text":"("},{"text":"pattern","kind":"externalParam"},{"kind":"text","text":": "},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"text":"recursive","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"text":"owned","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot4NodeC","kind":"typeIdentifier","text":"Node"},{"text":"?","kind":"text"}],"title":"findChild(pattern:recursive:owned:)","modules":[{"name":"SwiftGodot"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"findChild"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"pattern"},{"kind":"text","text":": "},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"recursive"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"kind":"text","text":" = true, "},{"kind":"externalParam","text":"owned"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":" = true) -> ","kind":"text"},{"text":"Node","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot4NodeC","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"},{"text":"?","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"pattern"},{"type":"text","text":" does not match against the full path, just against individual node names. It is case-sensitive, with "},{"type":"codeVoice","code":"\"*\""},{"type":"text","text":" matching zero or more characters and "},{"code":"\"?\"","type":"codeVoice"},{"type":"text","text":" matching any single character except "},{"type":"codeVoice","code":"\".\""},{"text":").","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If ","type":"text"},{"code":"recursive","type":"codeVoice"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":", all child nodes are included, even if deeply nested. Nodes are checked in tree order, so this node’s first direct child is checked first, then its own direct children, etc., before moving to the second direct child, and so on. If "},{"code":"recursive","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":", only this node’s direct children are matched."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"owned"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":", this method only finds nodes who have an assigned ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner","isActive":true},{"type":"text","text":". This is especially important for scenes instantiated through a script, because those scenes don’t have an owner."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns "},{"code":"null","type":"codeVoice"},{"type":"text","text":" if no matching "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"},{"type":"text","text":" is found."}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"text":"As this method walks through all the descendants of the node, it is the slowest way to get a reference to another node. Whenever possible, consider using ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/getNode(path:)","isActive":true},{"type":"text","text":" with unique names instead (see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/uniqueNameInOwner"},{"type":"text","text":"), or caching the node references into variable."}],"type":"paragraph"}]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"To find all descendant nodes matching a pattern or a class type, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/findChildren(pattern:type:recursive:owned:)"},{"text":".","type":"text"}],"type":"paragraph"}]}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/NodePath":{"navigatorTitle":[{"kind":"identifier","text":"NodePath"}],"abstract":[{"type":"text","text":"A pre-parsed scene tree path."}],"url":"\/documentation\/swiftgodot\/nodepath","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"NodePath"}],"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath","kind":"symbol","type":"topic","title":"NodePath"},"doc://SwiftGodot/documentation/SwiftGodot/Node/getNode(path:)":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/getNode(path:)","role":"symbol","kind":"symbol","url":"\/documentation\/swiftgodot\/node\/getnode(path:)","abstract":[{"text":"Fetches a node. The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NodePath"},{"type":"text","text":" can be either a relative path (from the current node) or an absolute path (in the scene tree) to a node. If the path does not exist, "},{"type":"codeVoice","code":"null"},{"text":" is returned and an error is logged. Attempts to access methods on the return value will result in an “Attempt to call ","type":"text"},{"type":"text","text":" on a null instance.” error."}],"title":"getNode(path:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getNode"},{"kind":"text","text":"("},{"kind":"externalParam","text":"path"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"NodePath","preciseIdentifier":"s:10SwiftGodot8NodePathC"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","text":"Node","preciseIdentifier":"s:10SwiftGodot4NodeC"},{"text":"?","kind":"text"}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Node/uniqueNameInOwner":{"url":"\/documentation\/swiftgodot\/node\/uniquenameinowner","abstract":[{"text":"Sets this node’s name as a unique name in its ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner","type":"reference","isActive":true},{"text":". This allows the node to be accessed as ","type":"text"},{"code":"%Name","type":"codeVoice"},{"text":" instead of the full path, from any node within that scene.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/uniqueNameInOwner","title":"uniqueNameInOwner","role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"uniqueNameInOwner","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"doc://SwiftGodot/documentation/SwiftGodot/Object/isClass(_:)":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Object\/isClass(_:)","role":"symbol","abstract":[{"type":"text","text":"Returns "},{"type":"codeVoice","code":"true"},{"text":" if the object inherits from the given ","type":"text"},{"type":"codeVoice","code":"class"},{"type":"text","text":". See also "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Object\/getClass()","isActive":true,"type":"reference"},{"text":".","type":"text"}],"url":"\/documentation\/swiftgodot\/object\/isclass(_:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isClass"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"kind":"symbol","type":"topic","title":"isClass(_:)"},"doc://SwiftGodot/documentation/SwiftGodot/Node/findChildren(pattern:type:recursive:owned:)":{"fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"findChildren"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"pattern"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"},{"text":", ","kind":"text"},{"kind":"externalParam","text":"