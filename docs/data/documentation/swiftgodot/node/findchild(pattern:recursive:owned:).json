\/Node","kind":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Node/owner":{"url":"\/documentation\/swiftgodot\/node\/owner","abstract":[{"type":"text","text":"The node owner. A node can have any ancestor node as owner (i.e. a parent, grandparent, etc. node ascending in the tree). This implies that "},{"type":"codeVoice","code":"addChild(node:forceReadableName:`internal`:)"},{"type":"text","text":" should be called before setting the owner, so that this relationship of parenting exists. When saving a node (using "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedScene","type":"reference","isActive":true},{"type":"text","text":"), all the nodes it owns will be saved with it. This allows for the creation of complex scene trees, with instancing and subinstancing."}],"title":"owner","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/owner","role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"owner","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Node","preciseIdentifier":"s:10SwiftGodot4NodeC"},{"text":"?","kind":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/PackedScene":{"type":"topic","url":"\/documentation\/swiftgodot\/packedscene","role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PackedScene","kind":"identifier"}],"title":"PackedScene","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedScene","kind":"symbol","abstract":[{"type":"text","text":"An abstraction of a serialized scene."}],"navigatorTitle":[{"text":"PackedScene","kind":"identifier"}]}}}