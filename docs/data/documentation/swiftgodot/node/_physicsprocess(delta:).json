{"kind":"symbol","sections":[],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Called during the physics processing step of the main loop. Physics processing means that the frame rate is synced to the physics, i.e. the "},{"code":"delta","type":"codeVoice"},{"text":" variable should be constant. ","type":"text"},{"code":"delta","type":"codeVoice"},{"type":"text","text":" is in seconds."}],"metadata":{"title":"_physicsProcess(delta:)","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"_physicsProcess"},{"kind":"text","text":"("},{"text":"delta","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"kind":"text","text":")"}],"roleHeading":"Instance Method","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot4NodeC15_physicsProcess5deltaySd_tF","role":"symbol","symbolKind":"method"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"_physicsProcess","kind":"identifier"},{"text":"(","kind":"text"},{"text":"delta","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":")","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"It is only called if physics processing is enabled, which is done automatically if this method is overridden, and can be toggled with "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/setPhysicsProcess(enable:)","type":"reference","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"Corresponds to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationPhysicsProcess"},{"type":"text","text":" notification in "},{"code":"Object\/_notification()","type":"codeVoice"},{"text":".","type":"text"}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method is only called if the node is present in the scene tree (i.e. if it’s not an orphan)."}]}],"type":"aside","name":"Note"}]}],"variants":[{"paths":["\/documentation\/swiftgodot\/node\/_physicsprocess(delta:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Node":{"abstract":[{"type":"text","text":"Base class for all scene objects."}],"navigatorTitle":[{"kind":"identifier","text":"Node"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"Node","kind":"identifier"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node","kind":"symbol","url":"\/documentation\/swiftgodot\/node","title":"Node","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_physicsProcess(delta:)":{"url":"\/documentation\/swiftgodot\/node\/_physicsprocess(delta:)","title":"_physicsProcess(delta:)","type":"topic","abstract":[{"type":"text","text":"Called during the physics processing step of the main loop. Physics processing means that the frame rate is synced to the physics, i.e. the "},{"code":"delta","type":"codeVoice"},{"type":"text","text":" variable should be constant. "},{"code":"delta","type":"codeVoice"},{"text":" is in seconds.","type":"text"}],"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"_physicsProcess","kind":"identifier"},{"text":"(","kind":"text"},{"text":"delta","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"text":")","kind":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)"},"doc://SwiftGodot/documentation/SwiftGodot/Node/setPhysicsProcess(enable:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setPhysicsProcess","kind":"identifier"},{"kind":"text","text":"("},{"kind":"externalParam","text":"enable"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":")","kind":"text"}],"role":"symbol","title":"setPhysicsProcess(enable:)","abstract":[{"text":"Enables or disables physics (i.e. fixed framerate) processing. When a node is being processed, it will receive a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationPhysicsProcess","isActive":true,"type":"reference"},{"type":"text","text":" at a fixed (usually 60 FPS, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond"},{"text":" to change) interval (and the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)"},{"text":" callback will be called if exists). Enabled automatically if ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","isActive":true},{"text":" is overridden. Any calls to this before ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","type":"reference"},{"text":" will be ignored.","type":"text"}],"type":"topic","url":"\/documentation\/swiftgodot\/node\/setphysicsprocess(enable:)","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/setPhysicsProcess(enable:)"},"doc://SwiftGodot/documentation/SwiftGodot/Engine/physicsTicksPerSecond":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"physicsTicksPerSecond","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Int32","kind":"typeIdentifier","preciseIdentifier":"s:s5Int32V"}],"role":"symbol","title":"physicsTicksPerSecond","abstract":[{"text":"The number of fixed iterations per second. This controls how often physics simulation and ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","type":"reference","isActive":true},{"type":"text","text":" methods are run. This value should generally always be set to "},{"code":"60","type":"codeVoice"},{"text":" or above, as Godot doesn’t interpolate the physics step. As a result, values lower than ","type":"text"},{"type":"codeVoice","code":"60"},{"text":" will look stuttery. This value can be increased to make input more reactive or work around collision tunneling issues, but keep in mind doing so will increase CPU usage. See also ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/maxFps","type":"reference"},{"type":"text","text":" and "},{"code":"ProjectSettings\/physics\/common\/physicsTicksPerSecond","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","url":"\/documentation\/swiftgodot\/engine\/physicstickspersecond","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/physicsTicksPerSecond"},"doc://SwiftGodot/documentation/SwiftGodot/Node/_ready()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"_ready","kind":"identifier"},{"text":"()","kind":"text"}],"role":"symbol","title":"_ready()","abstract":[{"type":"text","text":"Called when the node is “ready”, i.e. when both the node and its children have entered the scene tree. If the node has children, their "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()","isActive":true,"type":"reference"},{"text":" callbacks get triggered first, and the parent node will receive the ready notification afterwards.","type":"text"}],"type":"topic","url":"\/documentation\/swiftgodot\/node\/_ready()","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_ready()"},"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Node/notificationPhysicsProcess":{"url":"\/documentation\/swiftgodot\/node\/notificationphysicsprocess","title":"notificationPhysicsProcess","type":"topic","abstract":[{"text":"Notification received every frame when the physics process flag is set (see ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/setPhysicsProcess(enable:)","isActive":true},{"type":"text","text":")."}],"kind":"symbol","role":"symbol","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"notificationPhysicsProcess","kind":"identifier"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Si","text":"Int","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/notificationPhysicsProcess"}}}