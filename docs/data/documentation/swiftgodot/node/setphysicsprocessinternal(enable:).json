{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"setPhysicsProcessInternal","kind":"identifier"},{"text":"(","kind":"text"},{"text":"enable","kind":"externalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"text":")","kind":"text"}],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"aside","style":"warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Built-in Nodes rely on the internal processing for their own logic, so changing this value from your code may lead to unexpected behavior. Script access to this internal logic is provided for specific advanced uses, but is unsafe and not supported."}]}],"name":"Warning"}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/setPhysicsProcessInternal(enable:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Enables or disables internal physics for this node. Internal physics processing happens in isolation from the normal "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/_physicsProcess(delta:)","type":"reference","isActive":true},{"type":"text","text":" calls and is used by some nodes internally to guarantee proper functioning even if the node is paused or physics processing is disabled for scripting ("},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node\/setPhysicsProcess(enable:)"},{"text":"). Only useful for advanced uses to manipulate built-in nodes’ behavior.","type":"text"}],"me