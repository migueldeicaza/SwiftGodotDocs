xt","text":" "},{"text":"affectNavigationMesh","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}]},"doc://SwiftGodot/documentation/SwiftGodot/RID":{"title":"RID","role":"symbol","url":"\/documentation\/swiftgodot\/rid","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RID","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"RID","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"RID","kind":"identifier"}],"abstract":[{"type":"text","text":"A handle for a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Resource"},{"type":"text","text":"’s unique identifier."}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/NavigationObstacle3D/vertices":{"url":"\/documentation\/swiftgodot\/navigationobstacle3d\/vertices","title":"vertices","abstract":[{"text":"The outline vertices of the obstacle. If the vertices are winded in clockwise order agents will be pushed in by the obstacle, else they will be pushed out. Outlines can not be crossed or overlap. Should the vertices using obstacle be warped to a new position agent’s can not predict this movement and may get trapped inside the obstacle.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/vertices","kind":"symbol","role":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"vertices","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot18PackedVector3ArrayC","text":"PackedVector3Array"}]},"doc://SwiftGodot/s23CustomStringConvertibleP":{"identifier":"doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","title":"Swift.CustomStringConvertible","type":"unresolvable"},"doc://SwiftGodot/SQ":{"identifier":"doc:\/\/SwiftGodot\/SQ","title":"Swift.Equatable","type":"unresolvable"},"doc://SwiftGodot/documentat