{"sections":[],"metadata":{"roleHeading":"Class","role":"symbol","symbolKind":"class","modules":[{"name":"SwiftGodot"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"NavigationObstacle3D","kind":"identifier"}],"title":"NavigationObstacle3D","navigatorTitle":[{"kind":"identifier","text":"NavigationObstacle3D"}],"externalID":"s:10SwiftGodot20NavigationObstacle3DC"},"relationshipsSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node3D"],"type":"inheritsFrom","title":"Inherits From","kind":"relationships"},{"identifiers":["doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"NavigationObstacle3D","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"inlineContent":[{"text":"An obstacle needs a navigation map and outline ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/vertices"},{"type":"text","text":" defined to work correctly. The outlines can not cross or overlap and are restricted to a plane projection. This means the y-axis of the vertices is ignored, instead the obstacle’s global y-axis position is used for placement. The projected shape is extruded by the obstacles height along the y-axis."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Obstacles can be included in the navigation mesh baking process when "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/affectNavigationMesh","isActive":true,"type":"reference"},{"type":"text","text":" is enabled. They do not add walkable geometry, instead their role is to discard other source geometry inside the shape. This can be used to prevent navigation mesh from appearing in unwanted places, e.g. inside “solid” geometry or on top of it. If "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/carveNavigationMesh"},{"type":"text","text":" is enabled the baked shape will not be affected by offsets of the navigation mesh baking, e.g. the agent radius."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"With ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/avoidanceEnabled","isActive":true},{"type":"text","text":" the obstacle can constrain the avoidance velocities of avoidance using agents. If the obstacle’s vertices are wound in clockwise order, avoidance agents will be pushed in by the obstacle, otherwise, avoidance agents will be pushed out. Obstacles using vertices and avoidance can warp to a new position but should not be moved every single frame as each change requires a rebuild of the avoidance map."}]}]}],"topicSections":[{"generated":true,"anchor":"Instance-Properties","title":"Instance Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/affectNavigationMesh","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/avoidanceEnabled","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/avoidanceLayers","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/carveNavigationMesh","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/height","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/radius","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/use3dAvoidance","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/velocity","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/vertices"]},{"title":"Instance Methods","generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/getAvoidanceLayerValue(layerNumber:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/getNavigationMap()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/getRid()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/setAvoidanceLayerValue(layerNumber:value:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/setNavigationMap(_:)"],"anchor":"Instance-Methods"},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/godotClassName"],"anchor":"Type-Properties","generated":true,"title":"Type Properties"}],"variants":[{"paths":["\/documentation\/swiftgodot\/navigationobstacle3d"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"kind":"symbol","abstract":[{"text":"3D obstacle used to affect navigation mesh baking or constrain velocities of avoidance controlled agents.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://SwiftGodot/documentation/SwiftGodot/NavigationObstacle3D/setNavigationMap(_:)":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"setNavigationMap"},{"text":"(","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot3RIDC","text":"RID"},{"text":")","kind":"text"}],"kind":"symbol","title":"setNavigationMap(_:)","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/NavigationObstacle3D\/setNavigationMap(_:)","url":"\/documentation\/swiftgodot