{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ResourceFormatLoader","kind":"identifier"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Godot loads resources in the editor or in exported games using ResourceFormatLoaders. They are queried automatically via the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceLoader","isActive":true},{"type":"text","text":" singleton, or when a resource with internal dependencies is loaded. Each file type may load as a different resource type, so multiple ResourceFormatLoaders are registered in the engine."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Extending this class allows you to define your own loader. Be sure to respect the documented return types and values. You should give it a global class name with "},{"type":"codeVoice","code":"class_name"},{"text":" for it to be registered. Like built-in ResourceFormatLoaders, it will be called automatically when loading resources of its handled type(s). You may also implement a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatSaver","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also extend "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorImportPlugin","type":"reference","isActive":true},{"text":" if the resource type you need exists but Godot is unable to load its format. Choosing one way over another depends on if the format is suitable or not for the final exported game. For example, it’s better to import ","type":"text"},{"type":"codeVoice","code":".png"},{"type":"text","text":" textures as "},{"type":"codeVoice","code":".ctex"},{"type":"text","text":" ("},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedTexture2D","isActive":true},{"type":"text","text":") first, so they can be loaded with better efficiency on the graphics card."}]}],"name":"Note","type":"aside","style":"note"}]}],"sections":[],"metadata":{"title":"ResourceFormatLoader","role":"symbol","externalID":"s:10SwiftGodot20ResourceFormatLoaderC","navigatorTitle":[{"text":"ResourceFormatLoader","kind":"identifier"}],"modules":[{"name":"SwiftGodot"}],"roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"ResourceFormatLoader"}],"symbolKind":"class"},"kind":"symbol","identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Loads a specific resource type from a file."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/swiftgodot\/resourceformatloader"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_exists(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_getClassesUsed(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_getDependencies(path:addTypes:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_getRecognizedExtensions()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_getResourceScriptClass(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_getResourceType(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_getResourceUid(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceFormatLoader\/_handlesType(_:)","doc:\/\/SwiftGodot\/docum