tps://code.visualstudio.com/Download":{"identifier":"https:\/\/code.visualstudio.com\/Download","title":"official Visual Studio Code website","url":"https:\/\/code.visualstudio.com\/Download","type":"link","titleInlineContent":[{"type":"text","text":"official Visual Studio Code website"}]},"https://godotengine.org/download/":{"title":"official Godot website","url":"https:\/\/godotengine.org\/download\/","type":"link","identifier":"https:\/\/godotengine.org\/download\/","titleInlineContent":[{"text":"official Godot website","type":"text"}]},"https://www.swift.org/install/":{"identifier":"https:\/\/www.swift.org\/install\/","title":"official Swift website","url":"https:\/\/www.swift.org\/install\/","type":"link","titleInlineContent":[{"type":"text","text":"official Swift website"}]},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials":{"type":"topic","url":"\/tutorials\/swiftgodot-tutorials","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","kind":"overview","role":"overview","abstract":[{"text":"SwiftGodot allows developers to take new and existing Swift packages and use them as extensions for the Godot game engine.","type":"text"}],"title":"Meet SwiftGodot"},"https://marketplace.visualstudio.com/items?itemName=sswg.swift-lang":{"title":"Visual Studio Marketplace","url":"https:\/\/marketplace.visualstudio.com\/items?itemName=sswg.swift-lang","type":"link","identifier":"https:\/\/marketplace.visualstudio.com\/items?itemName=sswg.swift-lang","titleInlineContent":[{"text":"Visual Studio","type":"text"},{"text":" ","type":"text"},{"text":"Marketplace","type":"text"}]}}}