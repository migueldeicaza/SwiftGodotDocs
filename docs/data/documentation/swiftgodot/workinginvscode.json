{"variants":[{"paths":["\/documentation\/swiftgodot\/workinginvscode"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"article","identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/WorkingInVsCode","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Develop and debug SwiftGodot Code in Visual Studio Code"}],"seeAlsoSections":[{"anchor":"Developing-with-SwiftGodot","generated":true,"identifiers":["doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DebugInXcode"],"title":"Developing with SwiftGodot"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Visual Studio Code provides a compelling alternative to Xcode for SwiftGodot","type":"text"},{"type":"text","text":" "},{"text":"developers on Mac, Linux, or Windows.","type":"text"}]},{"text":"Prerequisites","level":3,"anchor":"Prerequisites","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"To develop with SwiftGodot in Visual Studio Code, you will need the following","type":"text"},{"type":"text","text":" "},{"type":"text","text":"prerequisites:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Godot Engine without .NET support from the "},{"identifier":"https:\/\/godotengine.org\/download\/","type":"reference","isActive":true},{"type":"text","text":"."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Visual Studio Code from the "},{"type":"reference","isActive":true,"identifier":"https:\/\/code.visualstudio.com\/Download"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Install Swift from the "},{"type":"reference","identifier":"https:\/\/www.swift.org\/install\/","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"level":3,"type":"heading","text":"Configuring Visual Studio Code","anchor":"Configuring-Visual-Studio-Code"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift Extension for Visual Studio Code from the Swift Server Work Group"},{"type":"text","text":" "},{"text":"provides code completion, code navigation, build task creation, and integration","type":"text"},{"type":"text","text":" "},{"type":"text","text":"with LLDB for debugging, along with many other features for devloping code with"},{"type":"text","text":" "},{"text":"Swift.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Install the Swift Extension for Visual Studio from the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/marketplace.visualstudio.com\/items?itemName=sswg.swift-lang"},{"type":"text","text":","},{"type":"text","text":" "},{"text":"or search for Swift on the Extensions tab in Visual Studio Code.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Installing the Swift Extension will automatically install the CodeLLDB Extension"},{"text":" ","type":"text"},{"text":"as a dependency for Visual Studio Code for debugging support.","type":"text"}],"type":"paragraph"},{"type":"heading","level":3,"text":"Create a Swift library package for your project","anchor":"Create-a-Swift-library-package-for-your-project"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a folder on disk in a file location near the Godot project that you want"},{"text":" ","type":"text"},{"type":"text","text":"to use with SwiftGodot.  For this article, we will assume you are working"},{"text":" ","type":"text"},{"text":"against the sample project and code from the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/migueldeicaza.github.io\/SwiftGodotDocs\/tutorials\/swiftgodot-tutorials"}]},{"inlineContent":[{"type":"text","text":"On the commmand line, change directories into the folder you created and run the"},{"type":"text","text":" "},{"text":"swift package command to initialize a new library package:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"swift package init --type library","type":"codeVoice"}]},{"inlineContent":[{"text":"You can now open your package folder in Visual Studio Code:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"code":"code .","type":"codeVoice"}]},{"type":"paragraph","inlineContent":[{"text":"Or use the “Open Folder…” File menu option in Visual Studio Code.","type":"text"}]},{"anchor":"Setup-SwiftGodot-in-Packageswift","level":3,"text":"Setup SwiftGodot in Package.swift","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Inside Visual Studio Code, open Package.swift"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set the minimum platform target to macOS 13 and set your library type to dynamic by adding "},{"code":"type: .dynamic,","type":"codeVoice"},{"type":"text","text":" to the products library section of your package configuration. E.g.,"}]},{"syntax":"swift","code":["platforms: [.macOS(.v13)],","products: [","   .library(","      name: \"SimpleRunnerDriver\",","      type: .dynamic,","      targets: [\"SimpleRunnerDriver\"]),","]"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Add the SwiftGodot dependency to your package."}],"type":"paragraph"},{"syntax":"swift","code":["dependencies: [","   .package(url: \"https:\/\/github.com\/migueldeicaza\/SwiftGodot\", branch: \"main\")","],"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Modify your library target to reference the SwitGodot dependency, and add","type":"text"},{"type":"text","text":" "},{"type":"text","text":"necessary swift compiler and linker settings:"}]},{"code":[".target(","   name: \"SimpleRunnerDriver\",","   dependencies: [","         \"SwiftGodot\",","   ],","   swiftSettings: [.unsafeFlags([\"-suppress-warnings\"])]","),"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At this point, you should be able to follow the Meet SwiftGodot Tutorial"},{"text":" ","type":"text"},{"type":"text","text":"beginning in Section 2."}]},{"level":3,"anchor":"Building-your-SwiftGodot-package","type":"heading","text":"Building your SwiftGodot package"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you are ready to build your SwiftGodot package, the Swift Extension"},{"type":"text","text":" "},{"type":"text","text":"provides a default Build task you can execute with Visual Studio Code’s Build"},{"text":" ","type":"text"},{"type":"text","text":"Shortcut - Ctrl+Shift+B (or Cmd+Shift+B on Mac)."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The initial build, especially on Windows, may take a very long time."}]},{"anchor":"Setting-up-your-gdextension","text":"Setting up your gdextension","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"When creating your "},{"type":"codeVoice","code":"gdextension"},{"type":"text","text":" file, your configuration file will need to"},{"text":" ","type":"text"},{"text":"contain settings specific to your platform, and you will need to copy the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"libraries for your operating system and architecture to the "},{"code":"bin","type":"codeVoice"},{"text":" folder inside","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"your Godot project."}],"type":"paragraph"},{"anchor":"Windows","level":4,"text":"Windows","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Windows does not deal well with long paths, so you should make sure that you","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"either checkout your SwiftGodot into a toplevel directory, or use the Windows"},{"type":"text","text":" "},{"type":"codeVoice","code":"subst"},{"type":"text","text":" command to map a drive name to the location that contains your"},{"type":"text","text":" "},{"type":"text","text":"SwiftGodot builds."}]},{"inlineContent":[{"type":"text","text":"If you are developing on Windows, your "},{"code":"libraries","type":"codeVoice"},{"type":"text","text":" and "},{"code":"dependencies","type":"codeVoice"},{"type":"text","text":" will need"},{"text":" ","type":"text"},{"type":"text","text":"to be specified as "},{"code":"windows.debug.x86_64","type":"codeVoice"},{"text":" and your libraries will be compiled","type":"text"},{"type":"text","text":" "},{"text":"into ","type":"text"},{"code":".dll","type":"codeVoice"},{"type":"text","text":" files, so that these sections should look like this:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["[libraries]","windows.debug.x86_64 = \"res:\/\/bin\/SimpleRunnerDriver.dll\"","","[dependencies]","windows.debug.x86_64 = {\"res:\/\/bin\/SwiftGodot.dll\" : \"\"}"]},{"inlineContent":[{"text":"You can copy these files to your Godot projects ","type":"text"},{"code":"bin","type":"codeVoice"},{"text":" folder from the build","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"output folder located in "},{"type":"codeVoice","code":".build\\x86_64-unknown-windows-msvc\\debug\\"},{"text":" inside","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the directory where you initialized your Swift package."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As an additional step on Windows, you will need to copy all of the Swift"},{"text":" ","type":"text"},{"type":"text","text":"runtime libraries into the "},{"type":"codeVoice","code":"bin"},{"type":"text","text":" folder with SwiftGodot.dll.  This is means"},{"type":"text","text":" "},{"type":"text","text":"copying all "},{"code":"*.dll","type":"codeVoice"},{"type":"text","text":" files from "},{"code":"C:\\Program Files\\Swift\\runtime-development\\usr\\bin\\","type":"codeVoice"}]},{"level":4,"anchor":"Linux","type":"heading","text":"Linux"},{"inlineContent":[{"type":"text","text":"If you are developing on Linux, your "},{"type":"codeVoice","code":"libraries"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"dependencies"},{"type":"text","text":" will need"},{"type":"text","text":" "},{"type":"text","text":"to be specified as "},{"code":"linux.debug.x86_64","type":"codeVoice"},{"type":"text","text":" and your libraries will be compiled into"},{"text":" ","type":"text"},{"type":"codeVoice","code":"lib*.so"},{"text":" files, so that these sections should look like this:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["[libraries]","linux.debug.x86_64 = \"res:\/\/bin\/libSimpleRunnerDriver.so\"","","[dependencies]","linux.debug.x86_64 = {\"res:\/\/bin\/libSwiftGodot.so\" : \"\"}"]},{"inlineContent":[{"text":"You can copy these files to your Godot projects ","type":"text"},{"code":"bin","type":"codeVoice"},{"text":" folder from the build","type":"text"},{"type":"text","text":" "},{"text":"output folder located in ","type":"text"},{"code":".build\/x86_64-unknown-linux-gnu\/debug\/","type":"codeVoice"},{"text":" inside","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the directory where you initialized your Swift package."}],"type":"paragraph"},{"anchor":"Debugging-your-SwiftGodot-code","level":3,"type":"heading","text":"Debugging your SwiftGodot code"},{"inlineContent":[{"type":"text","text":"You can debug your SwiftGodot code on Windows or Linux using the"},{"text":" ","type":"text"},{"type":"text","text":"CodeLLDB Extension to launch your game directly from vscode."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"In order to do this, you will need to add a Launch","type":"text"},{"type":"text","text":" "},{"type":"text","text":"task to your project."},{"text":" ","type":"text"},{"text":"In Visual Sutdio Code, switch to the “Run and Debug” tab.","type":"text"}]},{"inlineContent":[{"text":"Create a ","type":"text"},{"type":"codeVoice","code":"launch.json"},{"type":"text","text":" file by tapping on “create a launch.json file”"},{"text":" ","type":"text"},{"type":"text","text":"and selecting “LLDB”, which should be the first suggested option."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the newly created launch.json file, you should modify the existing"},{"type":"text","text":" "},{"type":"text","text":"lldb task to support launching as follows:"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Change the value for "},{"type":"codeVoice","code":"name"},{"type":"text","text":" to "},{"code":"Launch Godot Game","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Add a line for "},{"type":"codeVoice","code":"program"},{"text":" with the path to your Godot executable","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add a line for "},{"type":"codeVoice","code":"args"},{"text":" with any necessary arguments to launch your game,","type":"text"},{"type":"text","text":" "},{"text":"such as the path to your godot project","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"specify the ","type":"text"},{"type":"codeVoice","code":"cwd"},{"type":"text","text":" (current working directory)"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Your launch configuration for lldb should now look like this:"}]},{"syntax":"json","code":["{","   \"type\": \"lldb\",","   \"request\": \"launch\",","   \"name\": \"Launch Godot Game\",","   \"program\": \"path\/to\/your\/Godot\/executable\",","   \"args\": [\"--path\", \"path\/to\/your\/game\/project\"],","   \"cwd\": \"${workspaceFolder}\"","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Once you save this file, “Launch Godot Game” will appear as the default debug"},{"type":"text","text":" "},{"type":"text","text":"task in the “Run and Debug” sidebar."},{"type":"text","text":" "},{"text":"To run this task, click on the green play button next to","type":"text"},{"type":"text","text":" "},{"type":"text","text":"“Launch Godot Game” in the “Run and Debug” sidebar."},{"type":"text","text":" "},{"type":"text","text":"This action will launch the game with the LLDB debugger attached."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"At this point, Visual Studio Code should now stop on any breakpoints you have"},{"type":"text","text":" "},{"text":"set, and you should be able to inspect Variables, set Watches, etc.","type":"text"}]},{"level":4,"type":"heading","text":"(Optional) Add a `Attach` Debug task","anchor":"Optional-Add-a-Attach-Debug-task"},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Open the launch.json file."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Add a comma after the last closing brace "},{"type":"codeVoice","code":"}"},{"text":" of the existing configuration.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Paste the following configuration:"}],"type":"paragraph"}]}]},{"type":"codeListing","code":["{","    \"type\": \"lldb\",","    \"request\": \"attach\",","    \"name\": \"Attach to PID\",","    \"pid\": \"${command:pickProcess}\"","}"],"syntax":"json"},{"inlineContent":[{"type":"text","text":"Your "},{"type":"codeVoice","code":"launch.json"},{"type":"text","text":" should now look something like this:"}],"type":"paragraph"},{"syntax":"json","code":["{","   \"version\": \"0.2.0\",","   \"configurations\": [","      {","         \"type\": \"lldb\",","         \"request\": \"launch\",","         \"name\": \"Launch Godot Game\",","         \"program\": \"path\/to\/your\/Godot\/executable\",","         \"args\": [\"--path\", \"path\/to\/your\/game\/project\"],","         \"cwd\": \"${workspaceFolder}\"","      },","      {","         \"type\": \"lldb\",","         \"request\": \"attach\",","         \"name\": \"Attach to PID\",","         \"pid\": \"${command:pickProcess}\"","      }","   ]","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once you save this file, “Attach to PID” should appear in the debug options list."}]},{"type":"paragraph","inlineContent":[{"text":"To debug your app using “Attach to PID”, follow these steps:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"First, take note of running Godot process PIDs by running “Attach to PID”"},{"text":" ","type":"text"},{"type":"text","text":"and searching for Godot."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Launch your game from Godot"}]}]},{"content":[{"inlineContent":[{"text":"Return to Visual Studio and press F5 to run “Attach to PID” again.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Search again for Godot and select the PID for your game, which should be the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"only process that wasn’t listed in step (1) above."}]}]}]},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"On Linux or Mac, it may be possible to differentiate your game’s PID from other","type":"text"},{"type":"text","text":" "},{"type":"text","text":"Godot PIDs by looking at the additional information Visual Studio Code lists about"},{"type":"text","text":" "},{"type":"text","text":"each process, including command line options.  On Windows, the Godot processes are"},{"text":" ","type":"text"},{"type":"text","text":"pretty much identical, making it difficult to differentiate your game from the editor."}]}],"type":"aside","name":"Note"},{"name":"Warning","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"text","text":" "},{"type":"text","text":"On Mac, you will need to make your Godot engine debuggable following the steps from"},{"text":" ","type":"text"},{"text":"this article ","type":"text"},{"identifier":"https:\/\/migueldeicaza.github.io\/SwiftGodotDocs\/documentation\/swiftgodot\/debuginxcode","type":"reference","isActive":true}],"type":"paragraph"}],"type":"aside","style":"warning"}]}],"metadata":{"role":"article","title":"Working in VS Code","modules":[{"name":"SwiftGodot"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/DebugInXcode":{"url":"\/documentation\/swiftgodot\/debuginxcode","kind":"article","title":"Debug in Xcode","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DebugInXcode","abstract":[{"text":"Debug Swift code written for Godot in Xcode.","type":"text"}],"type":"topic","role":"article"},"https://migueldeicaza.github.io/SwiftGodotDocs/tutorials/swiftgodot-tutorials":{"identifier":"https:\/\/migueldeicaza.github.io\/SwiftGodotDocs\/tutorials\/swiftgodot-tutorials","url":"https:\/\/migueldeicaza.github.io\/SwiftGodotDocs\/tutorials\/swiftgodot-tutorials","type":"link","title":"Meet SwiftGodot Tutorial","titleInlineContent":[{"text":"Meet SwiftGodot Tutorial","type":"text"}]},"https://code.visualstudio.com/Download":{"identifier":"https:\/\/code.visualstudio.com\/Download","url":"https:\/\/code.visualstudio.com\/Download","type":"link","title":"official Visual Studio Code website","titleInlineContent":[{"text":"official Visual Studio Code website","type":"text"}]},"https://www.swift.org/install/":{"identifier":"https:\/\/www.swift.org\/install\/","url":"https:\/\/www.swift.org\/install\/","type":"link","title":"official Swift website","titleInlineContent":[{"text":"official Swift website","type":"text"}]},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials":{"kind":"overview","abstract":[{"text":"SwiftGodot allows developers to take new and existing Swift packages and use them as extensions for the Godot game engine.","type":"text"}],"type":"topic","title":"Meet SwiftGodot","role":"overview","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","url":"\/tutorials\/swiftgodot-tutorials"},"https://marketplace.visualstudio.com/items?itemName=sswg.swift-lang":{"identifier":"https:\/\/marketplace.visualstudio.com\/items?itemName=sswg.swift-lang","url":"https:\/\/marketplace.visualstudio.com\/items?itemName=sswg.swift-lang","type":"link","title":"Visual Studio Marketplace","titleInlineContent":[{"text":"Visual Studio","type":"text"},{"text":" ","type":"text"},{"text":"Marketplace","type":"text"}]},"https://migueldeicaza.github.io/SwiftGodotDocs/documentation/swiftgodot/debuginxcode":{"identifier":"https:\/\/migueldeicaza.github.io\/SwiftGodotDocs\/documentation\/swiftgodot\/debuginxcode","url":"https:\/\/migueldeicaza.github.io\/SwiftGodotDocs\/documentation\/swiftgodot\/debuginxcode","type":"link","title":"Debug in Xcode","titleInlineContent":[{"text":"Debug in Xcode","type":"text"}]},"https://godotengine.org/download/":{"identifier":"https:\/\/godotengine.org\/download\/","url":"https:\/\/godotengine.org\/download\/","type":"link","title":"official Godot website","titleInlineContent":[{"text":"official Godot website","type":"text"}]}}}