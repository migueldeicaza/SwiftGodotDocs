{"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"Performance","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This class provides access to a number of different monitors related to performance, such as memory usage, draw calls, and FPS. These are the same as the values displayed in the "},{"type":"strong","inlineContent":[{"type":"text","text":"Monitor"}]},{"type":"text","text":" tab in the editor’s "},{"inlineContent":[{"text":"Debugger","type":"text"}],"type":"strong"},{"type":"text","text":" panel. By using the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Performance\/getMonitor(_:)","isActive":true},{"type":"text","text":" method of this class, you can access this data from your code."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can add custom monitors using the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Performance\/addCustomMonitor(id:callable:arguments:)","type":"reference","isActive":true},{"text":" method. Custom monitors are available in ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Monitor"}]},{"type":"text","text":" tab in the editor’s "},{"inlineContent":[{"type":"text","text":"Debugger"}],"type":"strong"},{"text":" panel together with built-in monitors.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Some of the built-in monitors are only available in debug mode and will always return ","type":"text"},{"type":"codeVoice","code":"0"},{"type":"text","text":" when used in a project exported in release mode."}]}],"name":"Note","type":"aside","style":"note"},{"style":"note","name":"Note","type":"aside","content":[{"type":"paragraph","inlineContent":