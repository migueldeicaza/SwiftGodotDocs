{"variants":[{"paths":["\/documentation\/swiftgodot\/spotlight3d"],"traits":[{"interfaceLanguage":"swift"}]}],"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAngle","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAngleAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotRange"],"title":"Instance Properties"},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/godotClassName"]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"SpotLight3D","kind":"identifier"}],"externalID":"s:10SwiftGodot11SpotLight3DC","title":"SpotLight3D","modules":[{"name":"SwiftGodot"}],"role":"symbol","symbolKind":"class","navigatorTitle":[{"text":"SpotLight3D","kind":"identifier"}],"roleHeading":"Class"},"kind":"symbol","abstract":[{"text":"A spotlight, such as a reflector spotlight or a lantern.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpotLight3D"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"A Spotlight is a type of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"},{"text":" node that emits lights in a specific direction, in the shape of a cone. The light is attenuated through the distance. This attenuation can be configured by changing the energy, radius and attenuation parameters of ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"},{"text":".","type":"text"}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When using the Mobile rendering method, only 8 spot lights can be displayed on each mesh resource. Attempting to display more than 8 spot lights on a single mesh resource will result in spot lights flickering in and out as the camera moves. When using the Compatibility rendering method, only 8 spot lights can be displayed on each mesh resource by default, but this can be increased by adjusting "},{"code":"ProjectSettings\/rendering\/limits\/opengl\/maxLightsPerObject","type":"codeVoice"},{"type":"text","text":"."}]}]},{"type":"aside","content":[{"inlineContent":[{"text":"When using the Mobile or Compatibility rendering methods, spot lights will only correctly affect meshes whose visibility AABB intersects with the light’s AABB. If using a shader to deform the mesh in a way that makes it go outside its AABB, ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D\/extraCullMargin","isActive":true},{"type":"text","text":" must be increased on the mesh. Otherwise, the light may not be visible on the mesh."}],"type":"paragraph"}],"style":"note","name":"Note"}],"kind":"content"}],"relationshipsSections":[{"title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"],"kind":"relationships"},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships","title":"Co