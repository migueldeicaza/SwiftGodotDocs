{"kind":"symbol","abstract":[{"text":"A spotlight, such as a reflector spotlight or a lantern.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAngle","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAngleAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/spotRange"],"title":"Instance Properties"},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D\/godotClassName"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/spotlight3d"]}],"metadata":{"modules":[{"name":"SwiftGodot"}],"title":"SpotLight3D","role":"symbol","symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"SpotLight3D"}],"externalID":"s:10SwiftGodot11SpotLight3DC","roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"SpotLight3D"}]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SpotLight3D"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Spotlight is a type of "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D","isActive":true,"type":"reference"},{"text":" node that emits lights in a specific direction, in the shape of a cone. The light is attenuated through the distance. This attenuation can be configured by changing the energy, radius and attenuation parameters of ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D","isActive":true},{"text":".","type":"text"}]},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When using the Mobile rendering method, only 8 spot lights can be displayed on each mesh resource. Attempting to display more than 8 spot lights on a single mesh resource will result in spot lights flickering in and out as the camera moves. When using the Compatibility rendering method, only 8 spot lights can be displayed on each mesh resource by default, but this can be increased by adjusting "},{"code":"ProjectSettings\/rendering\/limits\/opengl\/maxLightsPerObject","type":"codeVoice"},{"type":"text","text":"."}]}]},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"When using the Mobile or Compatibility rendering methods, spot lights will only correctly affect meshes whose visibility AABB intersects with the light’s AABB. If using a shader to deform the mesh in a way that makes it go outside its AABB, "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D\/extraCullMargin"},{"type":"text","text":" must be increased on the mesh. Otherwise, the light may not be visible on the mesh."}],"type":"paragraph"}],"type":"aside"}]}],"sections":[],"relationshipsSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"],"title":"Inherits From","kind":"relationships","type":"inheritsFrom"},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships","type":"conformsTo","title":"Conforms To"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SpotLight3D"},"hierarchy":{"paths":[["doc