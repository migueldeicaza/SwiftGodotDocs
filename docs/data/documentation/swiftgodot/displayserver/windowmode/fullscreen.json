{"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/displayserver\/windowmode\/fullscreen"]}],"metadata":{"title":"DisplayServer.WindowMode.fullscreen","externalID":"s:10SwiftGodot13DisplayServerC10WindowModeO10fullscreenyA2EmF","role":"symbol","modules":[{"name":"SwiftGodot"}],"roleHeading":"Case","symbolKind":"case","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"fullscreen"}]},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DisplayServer","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DisplayServer\/WindowMode"]]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DisplayServer\/WindowMode\/fullscreen","interfaceLanguage":"swift"},"sections":[],"abstract":[{"type":"text","text":"Full screen mode with full multi-window support."}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"case"},{"text":" ","kind":"text"},{"text":"fullscreen","kind":"identifier"}]}]},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Full screen window covers the entire display area of a screen and has no decorations. The display’s video mode is not changed.","type":"text"}]},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"On Windows:","type":"text"}]},{"type":"text","text":" Multi-window full-screen mode has a 1px border of the "},{"code":"ProjectSettings\/rendering\/environment\/defaults\/defaultClearColor","type":"codeVoice"},{"type":"text","text":" color."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"On macOS:","type":"text"}]},{"text":" A new desktop is used to display the running project.","type":"text"}],"type":"parag