{"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/TileMap"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Triggers a direct update of the TileMap. Usually, calling this function is not needed, as TileMap node updates automatically when one of its properties or cells is modified.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/TileMap\/updateInternals()"},"metadata":{"symbolKind":"method","role":"symbol","roleHeading":"Instance Method","title":"updateInternals()","modules":[{"name":"SwiftGodot"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"updateInternals","kind":"identifier"},{"text":"()","kind":"text"}],"externalID":"s:10SwiftGodot7TileMapC15updateInternalsyyF"},"variants":[{"paths":["\/documentation\/swiftgodot\/tilemap\/updateinternals()"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"final","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"updateInternals"},{"text":"()","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"However, for performance reasons, those updates are batched and delayed to the end of the frame. Calling this function will force the TileMap to update right away instead.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"Updating the TileMap is computationally expensive and may impact performance. Try to limit the number of updates and how many tiles they impact.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Warning","style":"warning"}],"kind":"content"}],"sections":[],"references":{"doc://SwiftGodot/documentatio