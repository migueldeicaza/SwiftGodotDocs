{"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"kind":"symbol","sections":[],"abstract":[{"text":"A single texture resource which consists of multiple, separate images. Each image has the same dimensions and number of mipmap levels.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Texture2DArray"},"relationshipsSections":[{"type":"inheritsFrom","kind":"relationships","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ImageTextureLayered"],"title":"Inherits From"},{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo"}],"metadata":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Texture2DArray"}],"navigatorTitle":[{"text":"Texture2DArray","kind":"identifier"}],"modules":[{"name":"SwiftGodot"}],"symbolKind":"class","roleHeading":"Class","title":"Texture2DArray","role":"symbol","externalID":"s:10SwiftGodot14Texture2DArrayC"},"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"title":"Instance Methods","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Texture2DArray\/createPlaceholder()"]},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Texture2DArray\/godotClassName"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Texture2DArray"}],"platforms":["macOS"]}]},{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Texture2DArray is different from a Texture3D: The Texture2DArray does not support trilinear interpolation between the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Image","isActive":true},{"text":"s, i.e. no blending. See also ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","type":"reference","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CubemapArray","isActive":true,"type":"reference"},{"text":", which are texture arrays with specialized cubemap functions.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Texture2DArray is also different from an "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AtlasTexture","isActive":true},{"text":": In a Texture2DArray, all images are treated separately. In an atlas, the regions (i.e. the single images) can be of different sizes. Furthermore, you usually need to add a padding around the regions, to prevent accidental UV mapping to more than one region. The same goes for mipmapping: Mipmap chains are handled separately for each layer. In an atlas, the slicing has to be done manually in the fragment shader.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create such a texture file yourself, reimport your image files using the Godot Editor import presets."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swiftgodot\/texture2darray"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"kind":"symbol","url":"\/documentation\/swiftgodot","title":"SwiftGodot","role":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"},"doc://SwiftGodot/docum