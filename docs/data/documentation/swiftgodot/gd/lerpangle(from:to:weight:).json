{"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GD\/lerpAngle(from:to:weight:)"},"abstract":[{"type":"text","text":"Linearly interpolates between two angles (in radians) by a "},{"type":"codeVoice","code":"weight"},{"type":"text","text":" value between 0.0 and 1.0."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"lerpAngle","kind":"identifier"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"kind":"text","text":", "},{"kind":"externalParam","text":"to"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"},{"kind":"text","text":", "},{"text":"weight","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Similar to ","type":"text"},{"type":"codeVoice","code":"lerp()"},{"type":"text","text":", but interpolates correctly when the angles wrap around "},{"type":"codeVoice","code":"@GDScript.TAU"},{"text":". To perform eased interpolation with ","type":"text"},{"code":"lerpAngle()","type":"codeVoice"},{"text":", combine it with ","type":"text"},{"type":"codeVoice","code":"ease()"},{"text":" or ","type":"text"},{"code":"smoothstep()","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This function lerps through the shortest path between "},{"code":"from","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"to"},{"text":". However, when these two angles are approximately ","type":"text"},{"code":"PI + k * TAU","type":"codeVoice"},{"text":" apart for any integer ","type":"text"},{"code":"k","type":"codeVoice"},{"text":", it’s not obvious which way they lerp due to floating-point precision errors. For example, ","type":"text"},{"type":"codeVoice","code":"lerp_angle(0, PI, weight)"},{"text":" lerps counter-clockwise, while ","type":"text"},{"code":"lerp_angle(0, PI + 5 * TAU, weight)","type":"codeVoice"},{"text":" lerps clockwise.","type":"text"}]}],"name":"Note","style":"note"}],"kind":"content"}],"kind":"symbol","metadata":{"title":"lerpAngle(from:to:weight:)","fragments":[{"text":"static","kind":"keyword"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"lerpAngle","kind":"identifier"},{"text":"(","kind":"text"},{"text":"from","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"},{"kind":"text","text":", "},{"text":"to","kind":"externalParam"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"text":", ","kind":"text"},{"text":"weight","kind":"externalParam"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":") -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"externalID":"s:10SwiftGodot2GDC9lerpAngle4from2to6weightS2d_S2dtFZ","symbolKind":"method","role":"symbol","roleHeading":"Type Method","modules":[{"name":"SwiftGodot"}]},"variants":[{"paths":["\/documentation\/swiftgodot\/gd\/lerpangle(from:to:weight:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"references":{"doc://SwiftGodot/docum