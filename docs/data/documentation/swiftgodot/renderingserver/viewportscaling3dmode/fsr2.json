,"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale","type":"topic","abstract":[{"text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in ","type":"text"},{"code":"ProjectSettings\/rendering\/scaling3d\/mode","type":"codeVoice"},{"text":" to scale the output image to the full viewport size. Values lower than ","type":"text"},{"code":"1.0","type":"codeVoice"},{"text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"type":"text","text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons."}],"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"scaling3dScale"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","title":"scaling3dScale"},"doc://SwiftGodot/documentation/SwiftGodot/RenderingServer":{"type":"topic","url":"\/documentation\/swiftgodot\/renderingserver","title":"RenderingServer","kind":"symbol","abstract":[{"text":"Server for anything visible.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"RenderingServer"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"RenderingServer"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer","role":"symbol"}}}