{"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/ViewportScaling3DMode\/fsr2","interfaceLanguage":"swift"},"sections":[],"kind":"symbol","variants":[{"paths":["\/documentation\/swiftgodot\/renderingserver\/viewportscaling3dmode\/fsr2"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Use AMD FidelityFX Super Resolution 2.2 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale"},{"text":". Values less than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will be result in the viewport being upscaled using FSR2. Values greater than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" are not supported and bilinear downsampling will be used instead. A value of "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" will use FSR2 at native resolution as a TAA solution."}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/ViewportScaling3DMode"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"fsr2","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"symbol","externalID":"s:10SwiftGodot15RenderingServerC21ViewportScaling3DModeO4fsr2yA2EmF","roleHeading":"Case","modules":[{"name":"SwiftGodot"}],"title":"RenderingServer.ViewportScaling3DMode.fsr2","fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"text":"fsr2","kind":"identifier"}],"symbolKind":"case"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/RenderingServer/ViewportScaling3DMode":{"title":"RenderingServe