{"abstract":[{"text":"Use AMD FidelityFX Super Resolution 2.2 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","isActive":true},{"text":". Values less than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will be result in the viewport being upscaled using FSR2. Values greater than "},{"type":"codeVoice","code":"1.0"},{"text":" are not supported and bilinear downsampling will be used instead. A value of ","type":"text"},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will use FSR2 at native resolution as a TAA solution."}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/ViewportScaling3DMode"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/ViewportScaling3DMode\/fsr2","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"fsr2"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"}],"metadata":{"role":"symbol","externalID":"s:10SwiftGodot15RenderingServerC21ViewportScaling3DModeO4fsr2yA2EmF","symbolKind":"case","modules":[{"name":"SwiftGodot"}],"title":"RenderingServer.ViewportScaling3DMode.fsr2","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fsr2","kind":"identifier"}],"roleHeading":"Case"},"variants":[{"paths":["\/documentation\/swiftgodot\/renderingserver\/viewportscaling3dmode\/fsr2"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/RenderingServer/ViewportScaling3DMode":{"url":"\/documentation\