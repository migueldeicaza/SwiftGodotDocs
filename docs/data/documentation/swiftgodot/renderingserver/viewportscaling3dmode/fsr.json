 viewport size. Values lower than "},{"type":"codeVoice","code":"1.0"},{"text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"text":" are only valid for bilinear mode and can be used to improve 3D rendering quality at a high performance cost (supersampling). See also ","type":"text"},{"type":"codeVoice","code":"ProjectSettings\/rendering\/antiAliasing\/quality\/msaa3d"},{"type":"text","text":" for multi-sample antialiasing, which is significantly cheaper but only smooths the edges of polygons."}],"title":"scaling3dScale","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/RenderingServer/ViewportScaling3DMode/fsr":{"fragments":[{"text":"case","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"fsr"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/renderingserver\/viewportscaling3dmode\/fsr","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/ViewportScaling3DMode\/fsr","abstract":[{"type":"text","text":"Use AMD FidelityFX Super Resolution 1.0 upscaling for the viewport’s 3D buffer. The amount of scaling can be set using "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","isActive":true},{"text":". Values less than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"text":" will be result in the viewport being upscaled using FSR. Values greater than ","type":"text"},{"type":"codeVoice","code":"1.0"},{"text":" are not supported and bilinear downsampling will be used instead. A value of ","type":"text"},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" disables scaling."}],"title":"RenderingServer.ViewportScaling3DMode.fsr","role":"symbol"}}}