d if "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/lightSize","isActive":true,"type":"reference"},{"text":" and ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/lightAngularDistance","isActive":true},{"text":" is ","type":"text"},{"type":"codeVoice","code":"0.0"},{"text":".","type":"text"}],"type":"topic","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RenderingServer\/ShadowQuality\/hard"},"doc://SwiftGodot/documentation/SwiftGodot/DirectionalLight3D":{"navigatorTitle":[{"kind":"identifier","text":"DirectionalLight3D"}],"url":"\/documentation\/swiftgodot\/directionallight3d","abstract":[{"text":"Directional light from a distance, as from the Sun.","type":"text"}],"type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D","title":"DirectionalLight3D","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"DirectionalLight3D"}]},"doc://SwiftGodot/documentation/SwiftGodot/OmniLight3D":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D","title":"OmniLight3D","type":"topic","url":"\/documentation\/swiftgodot\/omnilight3d","navigatorTitle":[{"text":"OmniLight3D","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OmniLight3D","kind":"identifier"}],"role":"symbol","abstract":[{"text":"Omnidirectional light, such as a light bulb or a candle.","type":"text"}],"kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/shadowBlur":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/shadowBlur","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"shadowBlur","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"role":"symbol","type":"topic","title":"shadow