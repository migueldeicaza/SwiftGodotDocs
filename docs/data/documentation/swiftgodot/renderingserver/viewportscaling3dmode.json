SwiftGodot\/RenderingServer\/ViewportScaling3DMode\/bilinear","abstract":[{"type":"text","text":"Use bilinear scaling for the viewport’s 3D buffer. The amount of scaling can be set using "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","isActive":true},{"type":"text","text":". Values less than "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":" will result in undersampling while values greater than "},{"type":"codeVoice","code":"1.0"},{"type":"text","text":" will result in supersampling. A value of "},{"type":"codeVoice","code":"1.0"},{"text":" disables scaling.","type":"text"}],"title":"RenderingServer.ViewportScaling3DMode.bilinear","role":"symbol"},"doc://SwiftGodot/s12CaseIterableP":{"type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/s12CaseIterableP","title":"Swift.CaseIterable"},"doc://SwiftGodot/s28CustomDebugStringConvertibleP":{"type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/s28CustomDebugStringConvertibleP","title":"Swift.CustomDebugStringConvertible"},"doc://SwiftGodot/documentation/SwiftGodot/Viewport/scaling3dScale":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"scaling3dScale","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/viewport\/scaling3dscale","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Viewport\/scaling3dScale","abstract":[{"type":"text","text":"Scales the 3D render buffer based on the viewport size uses an image filter specified in "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/scaling3d\/mode"},{"type":"text","text":" to scale the output image to the full viewport size. Values lower than "},{"type":"codeVoice","code":"1.0"},{"text":" can be used to speed up 3D rendering at the cost of quality (undersampling). Values greater than ","type":"text"},{"type":"codeVoice