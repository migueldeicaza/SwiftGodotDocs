RenderingServer\/instanceSetIgnoreCulling(instance:enabled:)","isActive":true,"type":"reference"},{"type":"text","text":" on the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D","type":"reference","isActive":true},{"type":"text","text":"’s "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RID"},{"type":"text","text":"."}],"type":"topic","title":"customAabb"},"doc://SwiftGodot/documentation/SwiftGodot/GeometryInstance3D":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D","navigatorTitle":[{"kind":"identifier","text":"GeometryInstance3D"}],"title":"GeometryInstance3D","url":"\/documentation\/swiftgodot\/geometryinstance3d","role":"symbol","abstract":[{"type":"text","text":"Base node for geometry-based visual instances."}],"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"GeometryInstance3D","kind":"identifier"}]}}}