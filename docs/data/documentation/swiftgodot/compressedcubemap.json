{"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedCubemap\/godotClassName"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/compressedcubemap"]}],"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedTextureLayered"],"kind":"relationships"},{"kind":"relationships","type":"conformsTo","title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"]}],"metadata":{"roleHeading":"Class","modules":[{"name":"SwiftGodot"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CompressedCubemap","kind":"identifier"}],"title":"CompressedCubemap","symbolKind":"class","navigatorTitle":[{"text":"CompressedCubemap","kind":"identifier"}],"externalID":"s:10SwiftGodot17CompressedCubemapC"},"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"abstract":[{"text":"An optionally compressed ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","isActive":true},{"type":"text","text":"."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CompressedCubemap"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A cubemap that is loaded from a "},{"type":"codeVoice","code":".ccube"},{"type":"text","text":" file. This file format is internal to Godot; it is created by importing other image formats with the import system. "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedCubemap","isActive":true},{"type":"text","text":" can use one of 4 compresson methods:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Lossless (WebP or PNG, uncompressed on the GPU)","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Lossy (WebP, uncompressed on the GPU)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"VRAM Compressed (compressed on the GPU)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"VRAM Uncompressed (uncompressed on the GPU)"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Basis Universal (compressed on the GPU. Lower file sizes than VRAM Compressed, but slower to compress and lower quality than VRAM Compressed)","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"Only ","type":"text"},{"inlineContent":[{"type":"text","text":"VRAM Compressed"}],"type":"strong"},{"type":"text","text":" actually reduces the memory usage on the GPU. The "},{"inlineContent":[{"text":"Lossless","type":"text"}],"type":"strong"},{"type":"text","text":" and "},{"type":"strong","inlineContent":[{"text":"Lossy","type":"text"}]},{"text":" compression methods will reduce the required storage on disk, but they will not reduce memory usage on the GPU as the texture is sent to the GPU uncompressed.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using "},{"inlineContent":[{"text":"VRAM Compressed","type":"text"}],"type":"strong"},{"type":"text","text":" also improves loading times, as VRAM-compressed textures are faster to load compared to textures using lossless or lossy compression. VRAM compression can exhibit noticeable artifacts and is intended to be used for 3D rendering, not 2D."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","isActive":true,"type":"reference"},{"type":"text","text":" for a general description of cubemaps."}]}]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedCubemap","interfaceLanguage":"swift"},"kind":"symbol","references":{"doc://SwiftGodot/documentation/SwiftGodot/CompressedCubemap":{"abstract":[{"type":"text","text":"An optionally compressed "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap"},{"type":"text","text":"."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CompressedCubemap","title":"CompressedCubemap","kind":"symbol","role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"CompressedCubemap"}],"url":"\/documentation\/swiftgodot\/compressedcubemap","navigatorTitle":[{"kind":"identifier","text":"CompressedCubemap"}]},"doc://SwiftGodot/s23CustomStringConvertibleP":{"type":"unresolvable","title":"Swift.CustomStringConvertible","identifier":"doc:\/\/SwiftGodot\/s23CustomStringConvertibleP"},"doc://SwiftGodot/SQ":{"type":"unresolvable","title":"Swift.Equatable","identifier":"doc:\/\/SwiftGodot\/SQ"},"doc://SwiftGodot/s12IdentifiableP":{"type":"unresolvable","title":"Swift.Identifiable","identifier":"doc:\/\/SwiftGodot\/s12IdentifiableP"},"doc://SwiftGodot/documentation/SwiftGodot/GodotObject":{"navigatorTitle":[{"kind":"identifier","text":"GodotObject"}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"kind":"text","text":" "},{"text":"GodotObject","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","url":"\/documentation\/swiftgodot\/godotobject","abstract":[{"type":"te