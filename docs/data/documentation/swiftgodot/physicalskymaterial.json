{"schemaVersion":{"minor":3,"major":0,"patch":0},"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Material"]},{"title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships"}],"metadata":{"title":"PhysicalSkyMaterial","navigatorTitle":[{"text":"PhysicalSkyMaterial","kind":"identifier"}],"roleHeading":"Class","symbolKind":"class","role":"symbol","modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot19PhysicalSkyMaterialC","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"PhysicalSkyMaterial","kind":"identifier"}]},"kind":"symbol","sections":[],"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/energyMultiplier","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/groundColor","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/mieCoefficient","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/mieColor","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/mieEccentricity","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/nightSky","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/rayleighCoefficient","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/rayleighColor","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/sunDiskScale","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/turbidity","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/useDebanding"],"title":"Instance Properties"},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/godotClassName"],"title":"Type Properties"}],"abstract":[{"text":"A material that defines a sky for a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Sky","isActive":true,"type":"reference"},{"text":" resource by a set of physical properties.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"PhysicalSkyMaterial","kind":"identifier"}]}]},{"content":[{"type":"heading","anchor":"overview","level":2,"text":"Overview"},{"inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial","type":"reference"},{"type":"text","text":" uses the Preetham analytic daylight model to draw a sky based on physical properties. This results in a substantially more realistic sky than the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ProceduralSkyMaterial","isActive":true,"type":"reference"},{"type":"text","text":", but it is slightly slower and less flexible."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial","isActive":true},{"type":"text","text":" only supports one sun. The color, energy, and direction of the sun are taken from the first "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D"},{"type":"text","text":" in the scene tree."}]},{"inlineContent":[{"type":"text","text":"As it is based on a daylight model, the sky fades to black as the sunset ends. If you want a full day\/night cycle, you will have to add a night sky by converting this to a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ShaderMaterial","type":"reference","isActive":true},{"text":" and adding a night sky directly into the resulting shader.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/physicalskymaterial"]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/PhysicalSkyMaterial/mieEccentricity":{"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"mieEccentricity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"title":"mieEccentricity","type":"topic","url":"\/documentation\/swiftgodot\/physicalskymaterial\/mieeccentricity","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/mieEccentricity","role":"symbol","abstract":[{"type":"text","text":"Controls the direction of the "},{"text":"Mie scattering","type":"text"},{"type":"text","text":". A value of "},{"code":"1","type":"codeVoice"},{"text":" means that when light hits a particle it’s passing through straight forward. A value of ","type":"text"},{"code":"-1","type":"codeVoice"},{"text":" means that all light is scatter backwards.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/VariantRepresentable":{"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"VariantRepresentable","kind":"identifier"}],"url":"\/documentation\/swiftgodot\/variantrepresentable","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","role":"symbol","navigatorTitle":[{"text":"VariantRepresentable","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"text":"Types that conform to VariantRepresentable can be stored directly in ","type":"text"},{"code":"Variant","type":"codeVoice"},{"type":"text","text":" "},{"text":"with no conversion.  These include all of the Variant types from Godot (for","type":"text"},{"text":" ","type":"text"},{"text":"example ","type":"text"},{"code":"GString","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"Rect"},{"text":", ","type":"text"},{"code":"Plane","type":"codeVoice"},{"type":"text","text":"), Godot objects (those that subclass"},{"type":"text","text":" "},{"text":"SwiftGodot.Object) as well as the built-in Swift types UInt8, Int64 and Double.","type":"text"}],"title":"VariantRepresentable"},"doc://SwiftGodot/documentation/SwiftGodot/DirectionalLight3D":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/DirectionalLight3D","kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"DirectionalLight3D"}],"url":"\/documentation\/swiftgodot\/directionallight3d","abstract":[{"type":"text","text":"Directional light from a distance, as from the Sun."}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"DirectionalLight3D"}],"type":"topic","title":"DirectionalLight3D","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/PhysicalSkyMaterial/mieCoefficient":{"title":"mieCoefficient","role":"symbol","type":"topic","abstract":[{"type":"text","text":"Controls the strength of "},{"text":"Mie scattering","type":"text"},{"type":"text","text":" for the sky. Mie scattering results from light colliding with larger particles (like water). On earth, Mie scattering results in a whitish color around the sun and horizon."}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"mieCoefficient"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/mieCoefficient","url":"\/documentation\/swiftgo