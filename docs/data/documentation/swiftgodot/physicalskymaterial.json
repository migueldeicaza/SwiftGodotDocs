ract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"type":"text","text":", enables debanding. Debanding adds a small amount of noise which helps reduce banding that appears from the smooth changes in color in the sky."}],"kind":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/PhysicalSkyMaterial/mieEccentricity":{"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"mieEccentricity"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/mieEccentricity","role":"symbol","title":"mieEccentricity","url":"\/documentation\/swiftgodot\/physicalskymaterial\/mieeccentricity","kind":"symbol","abstract":[{"type":"text","text":"Controls the direction of the "},{"type":"text","text":"Mie scattering"},{"type":"text","text":". A value of "},{"code":"1","type":"codeVoice"},{"type":"text","text":" means that when light hits a particle it’s passing through straight forward. A value of "},{"code":"-1","type":"codeVoice"},{"type":"text","text":" means that all light is scatter backwards."}],"type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/GodotObject":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"GodotObject","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"GodotObject"}],"title":"GodotObject","abstract":[{"type":"text","text":"Protocol implemented by the built-in classes in Godot to allow to be wrapped in a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","url":"\/documentation\/swiftgodot\/godotobject"},"doc://SwiftGodot/documentation/SwiftGodot/PhysicalSkyMaterial/mieCoefficient":{"role":"symbol","fragments":[{"kind":"keywo