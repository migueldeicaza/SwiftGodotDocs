":[{"type":"text","text":"As it is based on a daylight model, the sky fades to black as the sunset ends. If you want a full day\/night cycle, you will have to add a night sky by converting this to a "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ShaderMaterial","isActive":true},{"type":"text","text":" and adding a night sky directly into the resulting shader."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/ProceduralSkyMaterial":{"title":"ProceduralSkyMaterial","abstract":[{"text":"A material that defines a simple sky for a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Sky","type":"reference","isActive":true},{"text":" resource.","type":"text"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ProceduralSkyMaterial","navigatorTitle":[{"text":"ProceduralSkyMaterial","kind":"identifier"}],"role":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ProceduralSkyMaterial"}],"type":"topic","url":"\/documentation\/swiftgodot\/proceduralskymaterial"},"doc://SwiftGodot/documentation/SwiftGodot/PhysicalSkyMaterial/turbidity":{"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"turbidity"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicalSkyMaterial\/turbidity","role":"symbol","title":"turbidity","url":"\/documentation\/swiftgodot\/physicalskymaterial\/turbidity","kind":"symbol","abstract":[{"type":"text","text":"Sets the thickness of the atmosphere. High turbidity creates a foggy-looking atmosphere, while a low turbidity results in a clearer atmosphere."}],"type":"topic"},"doc://SwiftGodot/s12IdentifiableP":{"identifier":"doc:\/\/Swi