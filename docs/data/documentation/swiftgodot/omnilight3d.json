{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"s:10SwiftGodot11OmniLight3DC","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"OmniLight3D"}],"roleHeading":"Class","modules":[{"name":"SwiftGodot"}],"navigatorTitle":[{"kind":"identifier","text":"OmniLight3D"}],"symbolKind":"class","title":"OmniLight3D","role":"symbol"},"variants":[{"paths":["\/documentation\/swiftgodot\/omnilight3d"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"relationshipsSections":[{"title":"Inherits From","kind":"relationships","type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"]},{"kind":"relationships","title":"Conforms To","type":"conformsTo","identifiers":["doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"]}],"kind":"symbol","topicSections":[{"anchor":"Instance-Properties","title":"Instance Properties","generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniRange","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniShadowMode"]},{"anchor":"Type-Properties","generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/godotClassName"],"title":"Type Properties"},{"title":"Enumerations","generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/ShadowMode"],"anchor":"Enumerations"}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OmniLight3D","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"An Omnidirectional light is a type of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"},{"text":" that emits light in all directions. The light is attenuated by distance and this attenuation can be configured by changing its energy, radius, and attenuation parameters.","type":"text"}]},{"name":"Note","style":"note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"When using the Mobile rendering method, only 8 omni lights can be displayed on each mesh resource. Attempting to display more than 8 omni lights on a single mesh resource will result in omni lights flickering in and out as the camera moves. When using the Compatibility rendering method, only 8 omni lights can be displayed on each mesh resource by default, but this can be increased by adjusting "},{"code":"ProjectSettings\/rendering\/limits\/opengl\/maxLightsPerObject","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"When using the Mobile or Compatibility rendering methods, omni lights will only correctly affect meshes whose visibility AABB intersects with the light’s AABB. If using a shader to deform the mesh in a way that makes it go outside its AABB, "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D\/extraCullMargin","isActive":true,"type":"reference"},{"type":"text","text":" must be increased on the mesh. Otherwise, the light may not be visible on the mesh."}]}]}]}],"abstract":[{"text":"Omnidirectional light, such as a light bulb or a candle.","type":"text"}],"reference