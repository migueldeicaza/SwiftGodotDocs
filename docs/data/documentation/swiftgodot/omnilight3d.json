{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/omnilight3d"]}],"kind":"symbol","abstract":[{"type":"text","text":"Omnidirectional light, such as a light bulb or a candle."}],"relationshipsSections":[{"type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"],"kind":"relationships","title":"Inherits From"},{"type":"conformsTo","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"OmniLight3D","kind":"identifier"}]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"inlineContent":[{"type":"text","text":"An Omnidirectional light is a type of "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D","isActive":true},{"type":"text","text":" that emits light in all directions. The light is attenuated by distance and this attenuation can be configured by changing its energy, radius, and attenuation parameters."}],"type":"paragraph"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"When using the Mobile rendering method, only 8 omni lights can be displayed on each mesh resource. Attempting to display more than 8 omni lights on a single mesh resource will result in omni lights flickering in and out as the camera moves. When using the Compatibility rendering method, only 8 omni lights can be displayed on each mesh resource by default, but this can be increased by adjusting ","type":"text"},{"code":"ProjectSettings\/rendering\/limits\/opengl\/maxLightsPerObject","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"type":"aside"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"When using the Mobile or Compatibility rendering methods, omni lights will only correctly affect meshes whose visibility AABB intersects with the light’s AABB. If using a shader to deform the mesh in a way that makes it go outside its AABB, ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D\/extraCullMargin","isActive":true,"type":"reference"},{"type":"text","text":" must be increased on the mesh. Otherwise, the light may not be visible on the mesh."}]}],"name":"Note","type":"aside"}],"kind":"content"}],"metadata":{"symbolKind":"class","role":"symbol","externalID":"s:10SwiftGodot11OmniLight3DC","modules":[{"name":"SwiftGodot"}],"roleHeading":"Class","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"OmniLight3D","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"OmniLight3D"}],"title":"OmniLight3D"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D","interfaceLanguage":"swift"},"topicSections":[{"title":"Instance Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniRange","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniShadowMode"]},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/godotClassName"]},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/ShadowMode"],"title":"Enumerations"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"fragments":[{"