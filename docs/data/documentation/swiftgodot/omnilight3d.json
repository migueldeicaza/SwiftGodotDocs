{"variants":[{"paths":["\/documentation\/swiftgodot\/omnilight3d"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Omnidirectional light, such as a light bulb or a candle."}],"topicSections":[{"title":"Instance Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniAttenuation","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniRange","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/omniShadowMode"]},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/godotClassName"]},{"title":"Enumerations","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OmniLight3D\/ShadowMode"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"relationshipsSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"],"title":"Inherits From","kind":"relationships","type":"inheritsFrom"},{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"OmniLight3D"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"An Omnidirectional light is a type of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D"},{"type":"text","text":" that emits light in all directions. The light is attenuated by distance and this attenuation can be configured by changing its energy, radius, and attenuation parameters."}]},{"name":"Note","style":"note","content":[{"inlineContent":[{"type":"text","text":"When using the Mobile rendering method, only 8 omni lights can be displayed on each mesh resource. Attempting to display more than 8 omni lights on a single mesh resource will result in omni lights flickering in and out as the camera moves. When using the Compatibility rendering method, only 8 omni lights can be displayed on each mesh resource by default, but this can be increased by adjusting "},{"code":"ProjectSettings\/rendering\/limits\/opengl\/maxLightsPerObject","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"aside"},{"content":[{"inlineContent":[{"text":"When using the Mobile or Compatibility rendering methods, omni lights will only correctly affect meshes whose visibility AABB intersects with the light’s AABB. If using a shader to deform the mesh in a way that makes it go outside its AABB, ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D\/extraCullMargin"},{"text":" must be increased on the mesh. Otherwise, the light may not be visible on the mesh.","type":"text"}],"type":"paragraph"}],"style":"note","type":"aside","name":"Note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"metadata":{"title":"OmniLight3D","modules":[{"name":"SwiftGodot"}],"fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"OmniLight3D"}],"symbolKind":"class","navigatorTitle":[{"kind":"identifier","text":"OmniLight3D"}],"externalID":"s:10SwiftGodot11OmniLight3DC","role":"symbol","roleHeading":"Class"},"kind":"symbol","references":{"doc://SwiftGodot/documentation/SwiftGodot/Light3D":{"navigatorTitle