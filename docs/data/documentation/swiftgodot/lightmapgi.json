isActive":true},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"text":" and ","type":"text"},{"code":"ProjectSettings\/rendering\/lightmapping\/denoising\/denoiser","type":"codeVoice"},{"text":" is set to JNLM.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/environmentCustomSky":{"title":"environmentCustomSky","type":"topic","abstract":[{"type":"text","text":"The sky to use as a source of environment lighting. Only effective if "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/environmentMode-swift.property","isActive":true,"type":"reference"},{"type":"text","text":" is .customSky."}],"role":"symbol","kind":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/environmentcustomsky","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/environmentCustomSky","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environmentCustomSky"},{"kind":"text","text":": "},{"text":"Sky","preciseIdentifier":"s:10SwiftGodot3SkyC","kind":"typeIdentifier"},{"kind":"text","text":"?"}]},"doc://SwiftGodot/SQ":{"identifier":"doc:\/\/SwiftGodot\/SQ","title":"Swift.Equatable","type":"unresolvable"},"doc://SwiftGodot/documentation/SwiftGodot/VoxelGI":{"title":"VoxelGI","abstract":[{"text":"Real-time global illumination (GI) probe.","type":"text"}],"url":"\/documentation\/swiftgodot\/voxelgi","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VoxelGI","navigatorTitle":[{"kind":"identifier","text":"VoxelGI"}],"type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"VoxelGI","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/CSGShape3D":{"navigatorTitle":[{"kind":"identifier","text":"CSGShape3D"}],"role":"symbol","type":"topic","title":"CSGShape3D","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CSGShape3D","url":"\/documentation\/swiftgodot\/csgshape3d","abstract":[{"type":"text","text":"The CSG base class."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"CSGShape3D","kind":"identifier"}]},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/godotClassName":{"abstract":[],"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/godotClassName","kind":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/godotclassname","title":"godotClassName","type":"topic","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"godotClassName"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot10StringNameC","text":"StringName"}]},"doc://SwiftGodot/documentation/SwiftGodot/Environment/sdfgiEnabled":{"role":"symbol","url":"\/documentation\/swiftgodot\/environment\/sdfgienabled","kind":"symbol","title":"sdfgiEnabled","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Environment\/sdfgiEnabled","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"sdfgiEnabled"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"type":"topic","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", enables signed distance field global illumination for meshes that have their ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GeometryInstance3D\/giMode-swift.property","type":"reference"},{"text":" set to ``GeometryInstance3D\/GIMode\/`static```. SDFGI is a real-time global illumination technique that works well with procedurally generated and user-built levels, including in situations where geometry is created during gameplay. The signed distance field is automatically generated around the camera as it moves. Dynamic lights are supported, but dynamic occluders and emissive surfaces are not.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/environmentMode-swift.property":{"title":"environmentMode","type":"topic","abstract":[{"text":"The environment mode to use when baking lightmaps.","type":"text"}],"role":"symbol","kind":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/environmentmode-swift.property","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/environmentMode-swift.property","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environmentMode"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot10LightmapGIC","text":"LightmapGI"},{"text":".","kind":"text"},{"text":"EnvironmentMode","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot10LightmapGIC15EnvironmentModeO"}]},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/directional":{"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/directional","url":"\/documentation\/swiftgodot\/lightmapgi\/directional","title":"directional","abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"type":"text","text":", bakes lightmaps to contain directional information as spherical harmonics. This results in more realistic lighting appearance, especially with normal mapped materials and for lights that have their direct light baked ("},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/lightBakeMode"},{"type":"text","text":" set to "},{"type":"codeVoice","code":"Light3D\/BakeMode\/bakeStatic"},{"text":" and with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/editorOnly"},{"type":"text","text":" set to "},{"code":"false","type":"codeVoice"},{"text":"). The directional information is also used to provide rough reflections for static and dynamic objects. This has a small run-time performance cost as the shader has to perform more work to interpret the direction information from the lightmap. Directional lightmaps also take longer to bake and result in larger file sizes.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"directional","kind":"identifier"},{"kind":"text","text":": "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"role":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/VariantRepresentable":{"type":"topic","navigatorTitle":[{"kind":"identifier","text":"VariantRepresentable"}],"abstract":[{"text":"Types that conform to VariantRepresentable can be stored directly in ","type":"text"},{"code":"Variant","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"with no conversion.  These include all of the Variant types from Godot (for"},{"text":" ","type":"text"},{"type":"text","text":"example "},{"code":"GString","type":"codeVoice"},{"type":"text","text":", "},{"code":"Rect","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Plane"},{"type":"text","text":"), Godot objects (those that subclass"},{"type":"text","text":" "},{"type":"text","text":"SwiftGodot.Object) as well as the built-in Swift types UInt8, Int64 and Double."}],"fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"VariantRepresentable"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/variantrepresentable","role":"symbol","title":"VariantRepresentable","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable"},"doc://SwiftGodot/documentation/SwiftGodot/Light3D/lightBakeMode":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"lightBakeMode"},{"kind":"text","text":": "},{"text":"Light3D","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot7Light3DC"},{"text":".","