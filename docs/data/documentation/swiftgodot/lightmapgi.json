ot/documentation/SwiftGodot/LightmapGI/bounceIndirectEnergy":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"bounceIndirectEnergy"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"type":"topic","role":"symbol","title":"bounceIndirectEnergy","abstract":[{"text":"The energy multiplier for each bounce. Higher values will make indirect lighting brighter. A value of ","type":"text"},{"code":"1.0","type":"codeVoice"},{"text":" represents physically accurate behavior, but higher values can be used to make indirect lighting propagate more visibly when using a low number of bounces. This can be used to speed up bake times by lowering the number of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/bounces"},{"text":" then increasing ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/bounceIndirectEnergy","isActive":true,"type":"reference"},{"text":".","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/bounceIndirectEnergy","kind":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/bounceindirectenergy"},"doc://SwiftGodot/documentation/SwiftGodot/CameraAttributes":{"kind":"symbol","title":"CameraAttributes","type":"topic","abstract":[{"type":"text","text":"Parent class for camera settings."}],"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"CameraAttributes","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CameraAttributes","navigatorTitle":[{"text":"CameraAttributes","kind":"identifier"}],"role":"symbol","url":"\/documentation\/swiftgodot\/cameraattributes"},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/environmentCustomEnergy":{"kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environmentCustomEnergy","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"}],"abstract":[{"type":"text","text":"The color multiplier to use for environment lighting. Only effective if "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/environmentMode-swift.property","type":"reference","isActive":true},{"text":" is .customColor.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/environmentCustomEnergy","type":"topic","url":"\/documentation\/swiftgodot\/lightmapgi\/environmentcustomenergy","role":"symbol","title":"environmentCustomEnergy"},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/useTextureForBounces":{"title":"useTextureForBounces","abstract":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":", a texture with the lighting information will be generated to speed up the generation of indirect lighting at the cost of some accuracy. The geometry might exhibit extra light leak artifacts when using low resolution lightmaps or UVs that stretch the lightmap significantly across surfaces. Leave "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/useTextureForBounces","isActive":true},{"type":"text","text":" at its default value of "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if unsure."}],"role":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/usetextureforbounces","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"useTextureForBounces","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/useTextureForBounces"},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/cameraAttributes":{"title":"cameraAttributes","identifier":"doc:\/\/SwiftGodot\/documentat