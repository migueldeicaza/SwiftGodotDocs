 an effect on the light’s rendering. See "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Light3D\/BakeMode","isActive":true},{"type":"text","text":"."}]},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/generateProbesSubdiv":{"title":"generateProbesSubdiv","abstract":[{"type":"text","text":"The level of subdivision to use when automatically generating "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapProbe","isActive":true},{"type":"text","text":"s for dynamic object lighting. Higher values result in more accurate indirect lighting on dynamic objects, at the cost of longer bake times and larger file sizes."}],"role":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/generateprobessubdiv","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"generateProbesSubdiv"},{"kind":"text","text":": "},{"preciseIdentifier":"s:10SwiftGodot10LightmapGIC","text":"LightmapGI","kind":"typeIdentifier"},{"kind":"text","text":"."},{"text":"GenerateProbes","preciseIdentifier":"s:10SwiftGodot10LightmapGIC14GenerateProbesO","kind":"typeIdentifier"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/generateProbesSubdiv"},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/useDenoiser":{"title":"useDenoiser","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/useDenoiser","role":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/usedenoiser","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"useDenoiser"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"If "},{"code":"true","type":"codeVoice"},{"type":"text","text":", uses a GPU-based denoising algorithm on the generated lightmap. This eliminates most noise within the generated lightmap at the cost of longer bake times. File sizes are generally not impacted significantly by the use of a denoiser, although lossless compression may do a better job at compressing a denoised image."}]},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/denoiserStrength":{"title":"denoiserStrength","abstract":[{"type":"text","text":"The strength of denoising step applied to the generated lightmaps. Only effective if "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/useDenoiser","isActive":true,"type":"reference"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ProjectSettings\/rendering\/lightmapping\/denoising\/denoiser"},{"type":"text","text":" is set to JNLM."}],"role":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/denoiserstrength","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"denoiserStrength","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/denoiserStrength"},"doc://SwiftGodot/documentation/SwiftGodot/LightmapGI/lightData":{"title":"lightData","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGI\/lightData","role":"symbol","url":"\/documentation\/swiftgodot\/lightmapgi\/lightdata","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"lightData"},{"kind":"text","text":": "},{"text":"LightmapGIData","preciseIdentifier":"s:10SwiftGodot14LightmapGIDataC","kind":"typeIdentifier"},{"kind":"text","text":"?"}],"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"The "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/LightmapGIData","isActive":true,"type":"reference"},{"type":"text","text":" associated to this "},{"type":"reference","identi