:"text","text":" extension is used here, but any other extension such as "},{"code":".ini","type":"codeVoice"},{"text":" is also valid. Since neither ","type":"text"},{"type":"codeVoice","code":".cfg"},{"type":"text","text":" nor "},{"code":".ini","type":"codeVoice"},{"type":"text","text":" are standardized, Godot’s ConfigFile formatting may differ from files written by other programs."}]}],"style":"note"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/clear()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/encodeToText()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/eraseSection(_:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/eraseSectionKey(section:key:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/getSectionKeys(section:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/getSections()","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/getValue(section:key:default:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/hasSection(_:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/hasSectionKey(section:key:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/load(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/loadEncrypted(path:key:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/loadEncryptedPass(path:password:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/parse(data:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/save(path:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/saveEncrypted(path:key:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/saveEncryptedPass(path:password:)","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConfigFile\/setValue(se