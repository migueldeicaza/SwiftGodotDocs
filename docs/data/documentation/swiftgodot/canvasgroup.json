gin","url":"\/documentation\/swiftgodot\/canvasgroup\/fitmargin","role":"symbol","abstract":[{"type":"text","text":"Sets the size of a margin used to expand the drawable rect of this "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup","isActive":true,"type":"reference"},{"text":". The size of the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup","isActive":true},{"type":"text","text":" is determined by fitting a rect around its children then expanding that rect by "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup\/fitMargin"},{"type":"text","text":". This increases both the backbuffer area used and the area covered by the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup","type":"reference","isActive":true},{"text":" both of which can reduce performance. This should be kept as small as possible and should only be expanded when an increased size is needed (e.g. for custom shader effects).","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"fitMargin"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup\/fitMargin"},"doc://SwiftGodot/documentation/SwiftGodot/CanvasGroup/clearMargin":{"kind":"symbol","type":"topic","title":"clearMargin","url":"\/documentation\/swiftgodot\/canvasgroup\/clearmargin","role":"symbol","abstract":[{"type":"text","text":"Sets the size of the margin used to expand the clearing rect of this "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup","isActive":true},{"type":"text","text":". This expands the area of the backbuffer that will be used by the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup","isA