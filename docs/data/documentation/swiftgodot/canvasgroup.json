erence"},{"type":"text","text":" and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasItem\/clipChildren"},{"type":"text","text":" both utilize the backbuffer, children of a "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasGroup","isActive":true},{"type":"text","text":" who have their "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CanvasItem\/clipChildren","isActive":true},{"type":"text","text":" set to anything other than "},{"type":"codeVoice","code":"CanvasItem\/ClipChildrenMode\/clipChildrenDisabled"},{"text":" will not function correctly.","type":"text"}],"type":"paragraph"}]}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/ShaderMaterial":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ShaderMaterial"}],"abstract":[{"type":"text","text":"A material defined by a custom "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Shader"},{"type":"text","text":" program and the values of its shader parameters."}],"navigatorTitle":[{"kind":"identifier","text":"ShaderMaterial"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ShaderMaterial","title":"ShaderMaterial","role":"symbol","type":"topic","url":"\/documentation\/swiftgodot\/shadermaterial","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/VariantStorable":{"kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VariantStorable"}],"navigatorTitle":[{"kind":"identifier","text":"VariantStorable"}],"title":"VariantStorable","abstract":[{"text":"Types that conform to VariantStorable can be stored in a Variant and can be extracted","type":"text"},{"text":" ","type":"text"},{"text":"back out of a Variant.","type":"text"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/do