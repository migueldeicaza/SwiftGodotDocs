 the per-wheel ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/engineForce","isActive":true},{"type":"text","text":" value instead."}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"useAsTraction"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"}]},"doc://SwiftGodot/documentation/SwiftGodot/VariantRepresentable":{"kind":"symbol","type":"topic","title":"VariantRepresentable","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VariantRepresentable"}],"abstract":[{"text":"Types that conform to VariantRepresentable can be stored directly in ","type":"text"},{"type":"codeVoice","code":"Variant"},{"type":"text","text":" "},{"type":"text","text":"with no conversion.  These include all of the Variant types from Godot (for"},{"text":" ","type":"text"},{"text":"example ","type":"text"},{"code":"GString","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"Rect"},{"type":"text","text":", "},{"code":"Plane","type":"codeVoice"},{"text":"), Godot objects (those that subclass","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SwiftGodot.Object) as well as the built-in Swift types UInt8, Int64 and Double."}],"fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"VariantRepresentable","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","url":"\/documentation\/swiftgodot\/variantrepresentable"},"doc://SwiftGodot/documentation/SwiftGodot":{"kind":"symbol","url":"\/documentation\/swiftgodot","title":"SwiftGodot","role":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"},"doc://SwiftGodot/documentation/SwiftGodot/RigidBody3D":{"role":"symbol