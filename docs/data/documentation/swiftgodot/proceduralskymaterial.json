gular projection (similar to ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PanoramaSkyMaterial","isActive":true},{"type":"text","text":"). The texture’s colors will be "},{"inlineContent":[{"text":"added","type":"text"}],"type":"emphasis"},{"text":" to the existing sky color, and will be multiplied by ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ProceduralSkyMaterial\/skyEnergyMultiplier","isActive":true},{"type":"text","text":" and "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ProceduralSkyMaterial\/skyCoverModulate","isActive":true,"type":"reference"},{"type":"text","text":". This is mainly suited to displaying stars at night, but it can also be used to display clouds at day or night (with a non-physically-accurate look)."}],"url":"\/documentation\/swiftgodot\/proceduralskymaterial\/skycover","type":"topic","title":"skyCover","role":"symbol","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/ProceduralSkyMaterial/useDebanding":{"type":"topic","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"useDebanding","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"url":"\/documentation\/swiftgodot\/proceduralskymaterial\/usedebanding","role":"symbol","title":"useDebanding","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ProceduralSkyMaterial\/useDebanding","abstract":[{"type":"text","text":"If "},{"code":"true","type":"codeVoice"},{"text":", enables debanding. Debanding adds a small amount of noise which helps reduce banding that appears from the smooth changes in color in the sky.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/PanoramaSkyMaterial":{"fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"PanoramaSkyMaterial","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodo