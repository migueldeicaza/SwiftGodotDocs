ode3D","isActive":true,"type":"reference"},{"type":"text","text":". At the moment, "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GridMap","isActive":true},{"text":" is not supported so the node will be always of type ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PhysicsBody3D"},{"type":"text","text":"."}],"role":"symbol","kind":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/getcontactbody()","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/getContactBody()","fragments":[{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"kind":"identifier","text":"getContactBody"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:10SwiftGodot6Node3DC","text":"Node3D","kind":"typeIdentifier"},{"kind":"text","text":"?"}]},"doc://SwiftGodot/documentation/SwiftGodot/VehicleBody3D/steering":{"abstract":[{"type":"text","text":"The steering angle for the vehicle. Setting this to a non-zero value will result in the vehicle turning when it’s moving. Wheels that have "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/useAsSteering","isActive":true},{"type":"text","text":" set to "},{"type":"codeVoice","code":"true"},{"text":" will automatically be rotated.","type":"text"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/vehiclebody3d\/steering","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleBody3D\/steering","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"steering","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"title":"steering"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/wheelRollInfluence":{"role":"symbol","abstract":[{"text":"This value affects the roll of your vehicle. If set to 1.0 for all wheels, your vehicle will be prone to rolling over, while a value of 0.0 will resist body roll.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/wheelRollInfluence","type":"topic","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/wheelrollinfluence","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"wheelRollInfluence","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"kind":"symbol","title":"wheelRollInfluence"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/dampingRelaxation":{"abstract":[{"type":"text","text":"The damping applied to the spring when relaxing. This value should be between 0.0 (no damping) and 1.0. This value should always be slightly higher than the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/dampingCompression","isActive":true},{"text":" property. For a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/dampingCompression"},{"text":" value of 0.3, try a relaxation value of 0.5.","type":"text"}],"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/dampingrelaxation","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/dampingRelaxation","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"dampingRelaxation","kind":"identifier"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"title":"dampingRelaxation"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/brake":{"role":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/brake","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/brake","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"brake","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"title":"brake","kind":"symbol","type":"topic","abstract":[{"text":"Slows down the wheel by applying a braking force. The wheel is only slowed down if it is in contact with a surface. The force you need to apply to adequately slow down your vehicle depends on the ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RigidBody3D\/mass","isActive":true,"type":"reference"},{"text":" of the vehicle. For a vehicle with a mass set to 1000, try a value in the 25 - 30 range for hard braking.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/suspensionMaxForce":{"abstract":[{"text":"The maximum force the spring can resist. This value should be higher than a quarter of the ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RigidBody3D\/mass","isActive":true,"type":"reference"},{"type":"text","text":" of the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleBody3D","type":"reference","isActive":true},{"type":"text","text":" or the spring will not carry the weight of the vehicle. Good results are often obtained by a value that is about 3× to 4× this number."}],"kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"suspensionMaxForce","kind":"identifier"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/suspensionmaxforce","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/suspensionMaxForce","title":"suspensionMaxForce"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/useAsSteering":{"abstract":[{"type":"text","text":"If "},{"type":"codeVoice","code":"true"},{"text":", this wheel will be turned when the car steers. This value is used in conjunction with ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleBody3D\/steering","isActive":true,"type":"reference"},{"text":" and ignored if you are using the per-wheel ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/steering"},{"type":"text","text":" value instead."}],"kind":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/useassteering","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/useAsSteering","type":"topic","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"text":"useAsSteering","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"title":"useAsSteering"},"doc://SwiftGodot/s23CustomStringConvertibleP":{"title":"Swift.CustomStringConvertible","type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/s23CustomStringConvertibleP"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/suspensionTravel":{"title":"suspensionTravel","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/suspensionTravel","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"text":"suspensionTravel","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"}],"url":"\/documentation\/swiftgodot\/vehiclewheel3d\/suspensiontravel","abstract":[{"type":"text","text":"This is the distance the suspension can travel. As Godot units are equivalent to meters, keep this setting relatively low. Try a value between 0.1 and 0.3 depending on the type of car."}]},"doc://SwiftGodot/documentation/SwiftGodot/VariantStorable":{"kind":"symbol","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"VariantStorable"}],"navigatorTitle":[{"kind":"identifier","text":"VariantStorable"}],"title":"VariantStorable","abstract":[{"text":"Types that conform to VariantStorable can be stored in a Variant and can be extracted","type":"text"},{"text":" ","type":"text"},{"text":"back out of a Variant.","type":"text"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable","url":"\/documentation\/swiftgodot\/variantstorable"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D":{"url":"\/documentation\/swiftgodot\/vehiclewheel3d","abstract":[{"text":"A 3D physics body for a ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleBody3D","type":"reference","isActive":true},{"text":" that simulates the behavior of a wheel.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D","type":"topic","title":"VehicleWheel3D","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"VehicleWheel3D","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"VehicleWheel3D"}]},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/wheelRestLength":{"title":"wheelRestLength","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/wheelrestlength","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"wheelRestLength"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"abstract":[{"type":"text","text":"This is the distance in meters the wheel is lowered from its origin point. Don’t set this to 0.0 and move the wheel into position, instead move the origin point of your wheel (the gizmo in Godot) to the position the wheel will take when bottoming out, then use the rest length to move the wheel down to the position it should be in when the car is in rest."}],"type":"topic","kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/wheelRestLength","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/suspensionStiffness":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/suspensionStiffness","kind":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"suspensionStiffness"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"}],"abstract":[{"type":"text","text":"This value defines the stiffness of the suspension. Use a value lower than 50 for an off-road car, a value between 50 and 100 for a race car and try something around 200 for something like a Formula 1 car."}],"title":"suspensionStiffness","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/suspensionstiffness","role":"symbol","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/Variant":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Variant"}],"navigatorTitle":[{"kind":"identifier","text":"Variant"}],"title":"Variant","abstract":[{"type":"text","text":"Variant objects box various Godot Objects, you create them with one of the"},{"text":" ","type":"text"},{"text":"constructors, and you can retrieve the contents using the various extension","type":"text"},{"text":" ","type":"text"},{"text":"constructors that are declared on the various types that are wrapped.","type":"text"}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","url":"\/documentation\/swiftgodot\/variant"},"doc://SwiftGodot/documentation/SwiftGodot/Node3D":{"navigatorTitle":[{"kind":"identifier","text":"Node3D"}],"abstract":[{"type":"text","text":"Most basic 3D game object, parent of all 3D-related nodes."}],"url":"\/documentation\/swiftgodot\/node3d","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"Node3D"}],"role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Node3D","kind":"symbol","type":"topic","title":"Node3D"},"doc://SwiftGodot/s12IdentifiableP":{"title":"Swift.Identifiable","type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/s12IdentifiableP"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/wheelFrictionSlip":{"role":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/wheelfrictionslip","abstract":[{"type":"text","text":"This determines how much grip this wheel has. It is combined with the friction setting of the surface the wheel is in contact with. 0.0 means no grip, 1.0 is normal grip. For a drift car setup, try setting the grip of the rear wheels slightly lower than the front wheels, or use a lower value to simulate tire wear."}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"wheelFrictionSlip","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/wheelFrictionSlip","title":"wheelFrictionSlip","type":"topic"},"doc://SwiftGodot/SQ":{"type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/SQ","title":"Swift.Equatable"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/steering":{"abstract":[{"text":"The steering angle for the wheel, in radians. Setting this to a non-zero value will result in the vehicle turning when it’s moving.","type":"text"}],"kind":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/steering","role":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/steering","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"steering"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"}],"title":"steering"},"doc://SwiftGodot/SH":{"type":"unresolvable","identifier":"doc:\/\/SwiftGodot\/SH","title":"Swift.Hashable"},"doc://SwiftGodot/documentation/SwiftGodot/RigidBody3D/mass":{"type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/swiftgodot\/rigidbody3d\/mass","title":"mass","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RigidBody3D\/mass","abstract":[{"text":"The body’s mass.","type":"text"}],"fragments":[{"text":"var","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"mass"},{"text":": ","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}]},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/dampingCompression":{"abstract":[{"type":"text","text":"The damping applied to the spring when the spring is being compressed. This value should be between 0.0 (no damping) and 1.0. A value of 0.0 means the car will keep bouncing as the spring keeps its energy. A good value for this is around 0.3 for a normal car, 0.5 for a race car."}],"kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/dampingcompression","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/dampingCompression","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"dampingCompression","kind":"identifier"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}],"title":"dampingCompression"},"doc://SwiftGodot/documentation/SwiftGodot/VehicleWheel3D/engineForce":{"type":"topic","role":"symbol","kind":"symbol","url":"\/documentation\/swiftgodot\/vehiclewheel3d\/engineforce","title":"engineForce","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VehicleWheel3D\/engineForce","abstract":[{"type":"text","text":"Accelerates the wheel by applying an engine force. The wheel is only sped up if it is in contact with a surface. The "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RigidBody3D\/mass","isActive":true,"type":"reference"},{"type":"text","text":" of the vehicle has an effect on the acceleration of the vehicle. For a vehicle with a mass set to 1000, try a value in the 25 - 50 range for acceleration."}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"engineForce"},{"kind":"text","text":": "},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"}]}}}