{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"kind":"identifier","text":"Cubemap"}],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A cubemap is made of 6 textures organized in layers. They are typically used for faking reflections in 3D rendering (see "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ReflectionProbe","type":"reference"},{"type":"text","text":"). It can be used to make an object look as if it’s reflecting its surroundings. This usually delivers much better performance than other reflection methods."}]},{"inlineContent":[{"type":"text","text":"This resource is typically used as a uniform in custom shaders. Few core Godot methods make use of "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Cubemap","type":"reference"},{"text":" resources.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create such a texture file yourself, reimport your image files using the Godot Editor import presets."}]},{"type":"aside","content":[{"inlineContent":[{"text":"Godot doesn’t support using cubemaps in a ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PanoramaSkyMaterial","isActive":true},{"type":"text","text":". You can use "},{"type":"text","text":"this tool"},{"text":" to convert a cubemap to an equirectangular sky map.","type":"text"}],"type":"paragraph"}],"style":"note","name":"Note"}]}],"abstract":[{"type":"text","text":"Six square textures representing the faces of a cube. Commonly used as a skybox."}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"kind":"symbol","schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits"