{"metadata":{"navigatorTitle":[{"kind":"identifier","text":"CSGCombiner3D"}],"symbolKind":"class","role":"symbol","roleHeading":"Class","modules":[{"name":"SwiftGodot"}],"title":"CSGCombiner3D","externalID":"s:10SwiftGodot13CSGCombiner3DC","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"CSGCombiner3D"}]},"schemaVersion":{"major":0,"minor":3,"patch":0},"relationshipsSections":[{"type":"inheritsFrom","title":"Inherits From","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CSGShape3D"],"kind":"relationships"},{"kind":"relationships","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo","title":"Conforms To"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"CSGCombiner3D","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"inlineContent":[{"text":"For complex arrangements of shapes, it is sometimes needed to add structure to your CSG nodes. The CSGCombiner3D node allows you to create this structure. The node encapsulates the result of the CSG operations of its children. In this way, it is possible to do operations on one set of shapes that are children of one CSGCombiner3D node, and a set of separate operations on a second set of shapes that are children of a second CSGCombiner3D node, and then do an operation that takes the two end results as its input to create the final shape.","type":"text"}],"type":"paragraph"},{"type":"aside","content":[{"inlineContent":[{"text":"CSG nodes are intended to be used for level prototyping. Creating CSG nodes has a significant CPU cost compared to creating a ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MeshInstance3D","isActive":true},{"text":" with a ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PrimitiveMesh","isActive":true},{"text":". Moving a CSG node within another CSG node also has a significant CPU cost, so it should be avoided during gameplay.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CSGCombiner3D"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/csgcombiner3d"]}],"abstract":[{"text":"A CSG node that allows you to combine other CSG modifiers.","type":"text"}],"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CSGCombiner3D\/godotClassName"],"title":"Type Properties"}],"references":{"doc://SwiftGodot/SH":{"type":"unresolvable","title":"Swift.Hashable","identifier":"doc:\/\/SwiftGodot\/SH"},"doc://SwiftGodot/documentation/SwiftGodot/GodotObject":{"kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"text":" ","kind":"text"},{"text":"GodotObject","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"GodotObject"}],"title":"GodotObject","abstract":[{"type":"text","text":"Protocol implemented by the built-in classes in Godot to allow to be wrapped in a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variant","type":"reference","isActive":true}],"type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","url":"\/documentation\/swiftgodot\/godotobject"},"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc