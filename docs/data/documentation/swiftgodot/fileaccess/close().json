{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"final"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"close"},{"text":"()","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess","isActive":true},{"type":"text","text":" will automatically close when it’s freed, which happens when it goes out of scope or when it gets assigned with "},{"type":"codeVoice","code":"null"},{"type":"text","text":". In C# the reference must be disposed after we are done using it, this can be done with the "},{"type":"codeVoice","code":"using"},{"type":"text","text":" statement or calling the "},{"type":"codeVoice","code":"Dispose"},{"text":" method directly.","type":"text"}]}],"type":"aside"}],"kind":"content"}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess\/close()","interfaceLanguage":"swift"},"abstract":[{"text":"Closes the currently opened file and prevents subsequent read\/write operations. Use ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess\/flush()","type":"reference"},{"type":"text","text":" to persist the data to disk without closing the file."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess"]]},"metadata":{"modules":[{"name":"SwiftGodot"}],"symbolKind":"method","role":"symbol","title":"close()","externalID":"s:10SwiftGodot10FileAccessC5closeyyF","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text