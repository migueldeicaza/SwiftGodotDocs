{"abstract":[{"type":"text","text":"Closes the currently opened file and prevents subsequent read\/write operations. Use "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess\/flush()","type":"reference"},{"type":"text","text":" to persist the data to disk without closing the file."}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"final"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"close","kind":"identifier"},{"text":"()","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"name":"Note","style":"note","content":[{"inlineContent":[{"text":"","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess","isActive":true,"type":"reference"},{"type":"text","text":" will automatically close when it’s freed, which happens when it goes out of scope or when it gets assigned with "},{"code":"null","type":"codeVoice"},{"type":"text","text":". In C# the reference must be disposed after we are done using it, this can be done with the "},{"code":"using","type":"codeVoice"},{"type":"text","text":" statement or calling the "},{"code":"Dispose","type":"codeVoice"},{"type":"text","text":" method directly."}],"type":"paragraph"}],"type":"aside"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess"]]},"metadata":{"title":"close()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"close","kind":"identifier"},{"text":"()","kind":"text"}],"role":"symbol","roleHeading":"Instance Method","symbolKind":"method","externalID":"s:10SwiftGodot10FileAccessC5closeyyF","modules":[{"name":"SwiftGodot"}]},"identifier":{"interfaceLangua