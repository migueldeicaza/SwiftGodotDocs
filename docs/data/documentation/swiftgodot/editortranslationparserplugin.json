{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorTranslationParserPlugin"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"EditorTranslationParserPlugin"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorTranslationParserPlugin","isActive":true},{"type":"text","text":" is invoked when a file is being parsed to extract strings that require translation. To define the parsing and string extraction logic, override the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorTranslationParserPlugin\/_parseFile(path:msgids:msgidsContextPlural:)"},{"text":" method in script.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Add the extracted strings to argument ","type":"text"},{"type":"codeVoice","code":"msgids"},{"text":" or ","type":"text"},{"code":"msgids_context_plural","type":"codeVoice"},{"type":"text","text":" if context or plural is used."}]},{"type":"paragraph","inlineContent":[{"text":"When adding to ","type":"text"},{"type":"codeVoice","code":"msgids_context_plural"},{"text":", you must add the data using the format ","type":"text"},{"code":"[\"A\", \"B\", \"C\"]","type":"codeVoice"},{"text":", where ","type":"text"},{"type":"codeVoice","code":"A"},{"text":" represents the extracted string, ","type":"text"},{"type":"codeVoice","code":"B"},{"type":"text","text":" represents the context, and "},{"type":"codeVoice","code":"C"},{"type":"text","text":" represents the plural version of the extracted string. If you want to add only context but not plural, put "},{"type":"codeVoice","code":"\"\""},{"text":" for the plural slot. The idea is the same if you only want to add plural but not context. See the code below for concrete examples.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The extracted strings will be written into a POT file selected by user under “POT Generation” in “Localization” tab in “Project Settings” menu."}]},{"type":"paragraph","inlineContent":[{"text":"Below shows an example of a custom parser that extracts strings from a CSV file to write into a POT.","type":"text"}]},{"inlineContent":[{"type":"text","text":"To add a translatable string associated with context or plural, add it to "},{"type":"codeVoice","code":"msgids_context_plural"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you override parsing logic for standard script types (GDScript, C#, etc.), it would be better to load the "},{"code":"path","type":"codeVoice"},{"type":"text","text":" argument using "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ResourceLoader\/load(path:typeHint:cacheMode:)","isActive":true,"type":"reference"},{"text":". This is because built-in scripts are loaded as ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Resource"},{"text":" type, not ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/FileAccess","type":"reference","isActive":true},{"type":"text","text":" type."}]}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example:"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorTranslationParserPlugin"},{"type":"text","text":", register it using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/EditorPlugin\/addTran