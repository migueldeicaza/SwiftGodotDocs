ntation\/SwiftGodot\/ConvexPolygonShape3D","isActive":true},{"type":"text","text":" is "},{"type":"emphasis","inlineContent":[{"text":"solid","type":"text"}]},{"type":"text","text":", which means it detects collisions from objects that are fully inside it, unlike "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true,"type":"reference"},{"type":"text","text":" which is hollow. This makes it more suitable for both detection and physics."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Convex decomposition:"}]},{"type":"text","text":" A concave polyhedron can be split up into several convex polyhedra. This allows dynamic physics bodies to have complex concave collisions (at a performance cost) and can be achieved by using several "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D"},{"type":"text","text":" nodes. To generate a convex decomposition from a mesh, select the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MeshInstance3D","type":"reference","isActive":true},{"type":"text","text":" node, go to the "},{"type":"strong","inlineContent":[{"text":"Mesh","type":"text"}]},{"type":"text","text":" menu that appears above the viewport, and choose "},{"inlineContent":[{"text":"Create Multiple Convex Collision Siblings","type":"text"}],"type":"strong"},{"type":"text","text":". Alternatively, "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MeshInstance3D\/createMultipleConvexCollisions(settings:)","isActive":true,"type":"reference"},{"text":" can be called in a script to perform this decomposition at run-time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Performance:","type":"text"}],"type":"strong"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","type":"ref