{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","metadata":{"modules":[{"name":"SwiftGodot"}],"externalID":"s:10SwiftGodot20ConvexPolygonShape3DC","role":"symbol","title":"ConvexPolygonShape3D","symbolKind":"class","roleHeading":"Class","navigatorTitle":[{"text":"ConvexPolygonShape3D","kind":"identifier"}],"fragments":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConvexPolygonShape3D"}]},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"A 3D convex polyhedron shape used for physics collision."}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"topicSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D\/points"],"title":"Instance Properties"},{"title":"Type Properties","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D\/godotClassName"]}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","type":"inheritsFrom","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Shape3D"]},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GodotObject","doc:\/\/SwiftGodot\/s23CustomStringConvertibleP","doc:\/\/SwiftGodot\/SQ","doc:\/\/SwiftGodot\/SH","doc:\/\/SwiftGodot\/s12IdentifiableP","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantRepresentable","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/VariantStorable"],"type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"ConvexPolygonShape3D"}]}]},{"content":[{"anchor":"overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"A 3D convex polyhedron shape, intended for use in physics. Usually used to provide a shape for a "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CollisionShape3D","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","isActive":true},{"type":"text","text":" is "},{"type":"emphasis","inlineContent":[{"type":"text","text":"solid"}]},{"text":", which means it detects collisions from objects that are fully inside it, unlike ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D","isActive":true,"type":"reference"},{"type":"text","text":" which is hollow. This makes it more suitable for both detection and physics."}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Convex decomposition:"}]},{"type":"text","text":" A concave polyhedron can be split up into several convex polyhedra. This allows dynamic physics bodies to have complex concave collisions (at a performance cost) and can be achieved by using several "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D"},{"text":" nodes. To generate a convex decomposition from a mesh, select the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MeshInstance3D"},{"type":"text","text":" node, go to the "},{"type":"strong","inlineContent":[{"type":"text","text":"Mesh"}]},{"text":" menu that appears above the viewport, and choose ","type":"text"},{"inlineContent":[{"text":"Create Multiple Convex Collision Siblings","type":"text"}],"type":"strong"},{"type":"text","text":". Alternatively, "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/MeshInstance3D\/createMultipleConvexCollisions(settings:)","type":"reference"},{"text":" can be called in a script to perform this decomposition at run-time.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Performance:"}]},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConvexPolygonShape3D","isActive":true},{"type":"text","text":" is faster to check collisions against compared to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/ConcavePolygonShape3D"},{"type":"text","text":", but it is slower than primitive collision shapes such as "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/SphereShape3D","isActive":true},{"text":" and ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BoxShape3D","type":"reference","isActive":true},{"text":". Its use should generally be limited to medium-sized objects that cannot have their collision accurately represented by primitive shapes.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swiftgodot\/convexpolygonshape3d"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/Shape3D":{"abstract":[{"type":"text","text":"Abstract base class for 3D shapes used for physics collision."}],"url":"\/documentation\/swiftgodot\/shape3d","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"Shape3D","kind":"identifier"}],"navigatorTitle":[{"text":"Shape3D","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Shape3D","type":"topic","kind":"symbol","title":"Shape3D","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/StaticBody3D":{"abstract":[{"text":"A 3D physics body that can’t be moved by external forces. When moved manually, it doesn’t affect other bodies in its path.","type":"text"}],"url":"\/documentation\/swiftgodot\/staticbody3d","title":"StaticBody3D","ki