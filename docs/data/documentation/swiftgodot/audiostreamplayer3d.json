{"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"text":" ","kind":"text"},{"text":"AudioStreamPlayer3D","kind":"identifier"}]}]},{"content":[{"text":"Overview","level":2,"type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Plays audio with positional sound effects, based on the relative position of the audio listener. Positional effects include distance attenuation, directionality, and the Doppler effect. For greater realism, a low-pass filter is applied to distant sounds. This can be disabled by setting "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamPlayer3D\/attenuationFilterCutoffHz","isActive":true,"type":"reference"},{"type":"text","text":" to "},{"code":"20500","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default, audio is heard from the camera position. This can be changed by adding an "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioListener3D","type":"reference","isActive":true},{"type":"text","text":" node to the scene and enabling it by calling "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioListener3D\/makeCurrent()"},{"text":" on it.","type":"text"}]},{"inlineContent":[{"type":"text","text":"See also "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamPlayer","type":"reference","isActive":true},{"text":" to play a sound non-positionally.","type":"text"}],"type":"paragraph"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Hiding an "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamPlayer3D","isActive":true},{"text":" node does not disable its audio output. To temporarily disable an ","type":"text"},{"identifier":"doc: