 ","type":"text"},{"code":"44100","type":"codeVoice"},{"type":"text","text":", and "},{"code":"48000","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"According to the "},{"type":"text","text":"Nyquist-Shannon sampling theorem"},{"type":"text","text":", there is no quality difference to human hearing when going past 40,000 Hz (since most humans can only hear up to ~20,000 Hz, often less). If you are generating lower-pitched sounds such as voices, lower sample rates such as "},{"type":"codeVoice","code":"32000"},{"type":"text","text":" or "},{"type":"codeVoice","code":"22050"},{"text":" may be usable with no loss in quality.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/AudioStreamGenerator":{"role":"symbol","type":"topic","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"AudioStreamGenerator","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/AudioStreamGenerator","navigatorTitle":[{"text":"AudioStreamGenerator","kind":"identifier"}],"abstract":[{"text":"An audio stream with utilities for procedural sound generation.","type":"text"}],"title":"AudioStreamGenerator","url":"\/documentation\/swiftgodot\/audiostreamgenerator"},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/AudioStreamGenerator/mixRate":{"title":"mixRate","role":"symbol","kind":"symbol","abstract":[{"type":"text","text":"The sample rate to use (in Hz). Higher values are more demanding for the CPU to generate, but result in better quality."}],"url":"\/documentation\/swiftgodot\/audiostreamgenerat