{"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"overview","text":"Overview","level":2},{"inlineContent":[{"text":"To achieve this, you can include the ","type":"text"},{"type":"codeVoice","code":".tool"},{"type":"text","text":" parameter to the "},{"type":"codeVoice","code":"@Godot"},{"text":" macro,","type":"text"},{"type":"text","text":" "},{"type":"text","text":"like this:"}],"type":"paragraph"},{"code":["@Godot(.tool)","class Line3D: MeshInstance3D {","","    \/\/ This will be called in the editor","    override func _ready() {","\t\/\/ Run some code here","    }","","    \/\/ And so will this one","    override func _process(delta _: Double) {","\t\/\/ Check if we are running in the editor, or in the game","        if Engine.isEditorHint() {","            doEditorWork ()","        } else {","\t    doGameWork ()","\t}","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use it for doing many things, but it is mostly useful in level design"},{"type":"text","text":" "},{"text":"for visually presenting things that are hard to predict ourselves. Here are some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use cases:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"If you have a cannon that shoots cannonballs affected by physics (gravity),","type":"text"},{"text":" ","type":"text"},{"text":"you  can draw the cannonball’s trajectory in the editor, making level design a","type":"text"},{"type":"text","text":" "},{"text":"lot easier.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have jumppads with varying jump heights, you can draw the maximum jump"},{"type":"text","text":" "},{"text":"height a player would reach if it jumped on one, also making level design","type":"text"},{"type":"text","text":" "},{"type":"text","text":"easier."}]}]},{"content":[{"inlineContent":[{"text":"If your player doesn’t use a sprite, but draws itself using code, you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"make that drawing code execute in the editor to see your player."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"aside","style":"warning","name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":".tool"},{"type":"text","text":" extensions run inside the editor, and let you access the"},{"type":"text","text":" "},{"text":"scene tree of the currently edited scene. This is a powerful feature which","type":"text"},{"type":"text","text":" "},{"type":"text","text":"also comes with caveats, as the editor does not include protections for"},{"type":"text","text":" "},{"type":"text","text":"potential misuse of "},{"code":"@Godot(.tool)","type":"codeVoice"},{"type":"text","text":" scripts. Be extremely cautious when"},{"text":" ","type":"text"},{"text":"manipulating the scene tree, especially via ","type":"text"},{"type":"codeVoice","code":"Node\/queueFree"},{"text":", as it can","type":"text"},{"type":"text","text":" "},{"type":"text","text":"cause crashes if you free a node while the editor runs logic involving it."}]}]},{"type":"heading","anchor":"Detecting-the-Editor","text":"Detecting the Editor","level":1},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your code, you can call the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/isEditorHint()","type":"reference","isActive":true},{"type":"text","text":" to determine whether"},{"type":"text","text":" "},{"type":"text","text":"the code is running inside the editor or in the game, and adjust your various"},{"type":"text","text":" "},{"type":"text","text":"methods accordingly."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"article","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"variants":[{"paths":["\/documentation\/swiftgodot\/runningineditor"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor"},"metadata":{"role":"article","title":"Running Code in the Godot Editor","modules":[{"name":"SwiftGodot"}],"roleHeading":"Article"},"abstract":[{"type":"text","text":"There are cases where you might want some of your Swift code for your extension"},{"type":"text","text":" "},{"type":"text","text":"to run while it is being used in the Godot Editor."}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes"],"title":"Articles and Tutorials","generated":true}],"references":{"doc://SwiftGodot/documentation/SwiftGodot":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","kind":"symbol","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"title":"SwiftGodot","url":"\/documentation\/swiftgodot","role":"collection","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/BindingNodes":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","abstract":[{"text":"You will find yourself referencing nodes from a scene in your code.   In","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"GDScript, that is usually achieved by using the dollar sign and the name of the"},{"type":"text","text":" "},{"type":"text","text":"object you want to reference."}],"title":"Referencing Nodes from your Scene","url":"\/documentation\/swiftgodot\/bindingnodes"},"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","abstract":[{"type":"text","text":"Follow up on the fundamental building block of Godot’s data types."}],"title":"Variants","url":"\/documentation\/swiftgodot\/variants"},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","abstract":[{"type":"text","text":"In Godot, class members can be exported. This means their value gets saved along"},{"type":"text","text":" "},{"type":"text","text":"with the resource (such as the scene) they’re attached to. They will also be"},{"text":" ","type":"text"},{"text":"available for editing in the property editor. Exporting is done by using the","type":"text"}],"title":"Exports","url":"\/documentation\/swiftgodot\/exports"},"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","abstract":[{"text":"Signals in Godot are used by objects to post interesting events that are","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"taking place, and can be used by users to easily add behavior and react"},{"type":"text","text":" "},{"type":"text","text":"to changes."}],"title":"Signals","url":"\/documentation\/swiftgodot\/signals"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","abstract":[{"type":"text","text":"You will typically extend the functionality of your Godot game by creating"},{"type":"text","text":" "},{"type":"text","text":"classes that derive from one of the various Godot types and adjust the"},{"text":" ","type":"text"},{"text":"behavior accordingly.","type":"text"}],"title":"Using Custom Types","url":"\/documentation\/swiftgodot\/customtypes"},"doc://SwiftGodot/documentation/SwiftGodot/Engine/isEditorHint()":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isEditorHint"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"}],"role":"symbol","kind":"symbol","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/isEditorHint()","abstract":[{"text":"Returns ","type":"text"},{"code":"true","type":"codeVoice"},{"type":"text","text":" if the script is currently running inside the editor, "},{"code":"false","type":"codeVoice"},{"type":"text","text":" otherwise. This is useful for "},{"type":"codeVoice","code":"@tool"},{"type":"text","text":" scripts to conditionally draw editor helpers, or prevent accidentally running “game” code that would affect the scene state while in the editor:"}],"title":"isEditorHint()","url":"\/documentation\/swiftgodot\/engine\/iseditorhint()"},"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"role":"article","kind":"article","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"title":"SwiftGodot API differences to GDScript","url":"\/documentation\/swiftgodot\/differences"}}}