{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor","interfaceLanguage":"swift"},"abstract":[{"text":"There are cases where you might want some of your Swift code for your extension","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to run while it is being used in the Godot Editor."}],"kind":"article","variants":[{"paths":["\/documentation\/swiftgodot\/runningineditor"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes"],"anchor":"Articles-and-Tutorials","title":"Articles and Tutorials","generated":true}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"To achieve this, you can include the ","type":"text"},{"code":".tool","type":"codeVoice"},{"type":"text","text":" parameter to the "},{"type":"codeVoice","code":"@Godot"},{"text":" macro,","type":"text"},{"type":"text","text":" "},{"text":"like this:","type":"text"}]},{"syntax":"swift","code":["@Godot(.tool)","class Line3D: MeshInstance3D {","","    \/\/ This will be called in the editor","    override func _ready() {","\t\/\/ Run some code here","    }","","    \/\/ And so will this one","    override func _process(delta _: Double) {","\t\/\/ Check if we are running in the editor, or in the game","        if Engine.isEditorHint() {","            doEditorWork ()","        } else {","\t    doGameWork ()","\t}","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can use it for doing many things, but it is mostly useful in level design"},{"text":" ","type":"text"},{"text":"for visually presenting things that are hard to predict ourselves. Here are some","type":"text"},{"text":" ","type":"text"},{"text":"use cases:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have a cannon that shoots cannonballs affected by physics (gravity),"},{"type":"text","text":" "},{"text":"you  can draw the cannonball’s trajectory in the editor, making level design a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lot easier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have jumppads with varying jump heights, you can draw the maximum jump"},{"text":" ","type":"text"},{"text":"height a player would reach if it jumped on one, also making level design","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"easier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If your player doesn’t use a sprite, but draws itself using code, you can","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"make that drawing code execute in the editor to see your player."}]}]}],"type":"unorderedList"},{"name":"Warning","style":"warning","type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":".tool"},{"type":"text","text":" extensions run inside the editor, and let you access the"},{"type":"text","text":" "},{"type":"text","text":"scene tree of the currently edited scene. This is a powerful feature which"},{"type":"text","text":" "},{"text":"also comes with caveats, as the editor does not include protections for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"potential misuse of "},{"code":"@Godot(.tool)","type":"codeVoice"},{"text":" scripts. Be extremely cautious when","type":"text"},{"type":"text","text":" "},{"text":"manipulating the scene tree, especially via ","type":"text"},{"code":"Node\/queueFree","type":"codeVoice"},{"type":"text","text":", as it can"},{"text":" ","type":"text"},{"text":"cause crashes if you free a node while the editor runs logic involving it.","type":"text"}],"type":"paragraph"}]},{"anchor":"Detecting-the-Editor","level":1,"text":"Detecting the Editor","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your code, you can call the "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/isEditorHint()","isActive":true},{"text":" to determine whether","type":"text"},{"type":"text","text":" "},{"text":"the code is running inside the editor or in the game, and adjust your various","type":"text"},{"type":"text","text":" "},{"type":"text","text":"methods accordingly."}]}],"kind":"content"}],"metadata":{"title":"Running Code in the Godot Editor","role":"article","modules":[{"name":"SwiftGodot"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"references":{"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","role":"article","title":"Exports","kind":"article","url":"\/documentation\/swiftgodot\/exports","type":"topic","abstract":[{"type":"text","text":"In Godot, class members can be exported. This means their value gets saved along"},{"type":"text","text":" "},{"type":"text","text":"with the resource (such as the scene) they’re attached to. They will also be"},{"text":" ","type":"text"},{"type":"text","text":"available for editing in the property editor. Exporting is done by using the"}]},"doc://SwiftGodot/documentation/SwiftGodot":{"abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"kind":"symbol","role":"collection","url":"\/documentation\/swiftgodot","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot","title":"SwiftGodot","type":"topic"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"role":"article","title":"Using Custom Types","url":"\/documentation\/swiftgodot\/customtypes","type":"topic","abstract":[{"type":"text","text":"You will typically extend the functionality of your Godot game by creating"},{"type":"text","text":" "},{"text":"classes that derive from one of the various Godot types and adjust the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"behavior accordingly."}],"kind":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes"},"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","role":"article","title":"Signals","kind":"article","url":"\/documentation\/swiftgodot\/signals","type":"topic","abstract":[{"type":"text","text":"Signals in Godot are used by objects to post interesting events that are"},{"type":"text","text":" "},{"type":"text","text":"taking place, and can be used by users to easily add behavior and react"},{"text":" ","type":"text"},{"type":"text","text":"to changes."}]},"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","role":"article","title":"Variants","kind":"article","url":"\/documentation\/swiftgodot\/variants","type":"topic","abstract":[{"text":"Follow up on the fundamental building block of Godot’s data types.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Engine/isEditorHint()":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/isEditorHint()","fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"isEditorHint"},{"text":"() -> ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":" if the script is currently running inside the editor, otherwise returns "},{"type":"codeVoice","code":"false"},{"text":". This is useful for ","type":"text"},{"type":"codeVoice","code":"@tool"},{"text":" scripts to conditionally draw editor helpers, or prevent accidentally running “game” code that would affect the scene state while in the editor:","type":"text"}],"type":"topic","role":"symbol","title":"isEditorHint()","url":"\/documentation\/swiftgodot\/engine\/iseditorhint()","kind":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/BindingNodes":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","role":"article","title":"Referencing Nodes from your Scene","kind":"article","url":"\/documentation\/swiftgodot\/bindingnodes","type":"topic","abstract":[{"type":"text","text":"You will find yourself referencing nodes from a scene in your code.   In"},{"type":"text","text":" "},{"type":"text","text":"GDScript, that is usually achieved by using the dollar sign and the name of the"},{"text":" ","type":"text"},{"type":"text","text":"object you want to reference."}]},"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","role":"article","title":"SwiftGodot API differences to GDScript","kind":"article","url":"\/documentation\/swiftgodot\/differences","type":"topic","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}]}}}