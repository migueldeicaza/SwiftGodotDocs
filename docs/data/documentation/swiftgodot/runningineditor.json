{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/runningineditor"]}],"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/RunningInEditor","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot"]]},"metadata":{"roleHeading":"Article","role":"article","title":"Running Code in the Godot Editor","modules":[{"name":"SwiftGodot"}]},"abstract":[{"type":"text","text":"There are cases where you might want some of your Swift code for your extension"},{"text":" ","type":"text"},{"text":"to run while it is being used in the Godot Editor.","type":"text"}],"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes"],"title":"Articles and Tutorials"}],"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"inlineContent":[{"text":"To achieve this, you can include the ","type":"text"},{"type":"codeVoice","code":".tool"},{"text":" parameter to the ","type":"text"},{"type":"codeVoice","code":"@Godot"},{"text":" macro,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"like this:"}],"type":"paragraph"},{"code":["@Godot(.tool)","class Line3D: MeshInstance3D {","","    \/\/ This will be called in the editor","    override func _ready() {","\t\/\/ Run some code here","    }","","    \/\/ And so will this one","    override func _process(delta _: Double) {","\t\/\/ Check if we are running in the editor, or in the game","        if Engine.isEditorHint() {","            doEditorWork ()","        } else {","\t    doGameWork ()","\t}","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can use it for doing many things, but it is mostly useful in level design","type":"text"},{"type":"text","text":" "},{"text":"for visually presenting things that are hard to predict ourselves. Here are some","type":"text"},{"type":"text","text":" "},{"type":"text","text":"use cases:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you have a cannon that shoots cannonballs affected by physics (gravity),"},{"text":" ","type":"text"},{"text":"you  can draw the cannonball’s trajectory in the editor, making level design a","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"lot easier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If you have jumppads with varying jump heights, you can draw the maximum jump","type":"text"},{"text":" ","type":"text"},{"text":"height a player would reach if it jumped on one, also making level design","type":"text"},{"type":"text","text":" "},{"type":"text","text":"easier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If your player doesn’t use a sprite, but draws itself using code, you can","type":"text"},{"type":"text","text":" "},{"text":"make that drawing code execute in the editor to see your player.","type":"text"}]}]}]},{"style":"warning","name":"Warning","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":".tool"},{"text":" extensions run inside the editor, and let you access the","type":"text"},{"type":"text","text":" "},{"text":"scene tree of the currently edited scene. This is a powerful feature which","type":"text"},{"text":" ","type":"text"},{"text":"also comes with caveats, as the editor does not include protections for","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"potential misuse of "},{"type":"codeVoice","code":"@Godot(.tool)"},{"type":"text","text":" scripts. Be extremely cautious when"},{"type":"text","text":" "},{"type":"text","text":"manipulating the scene tree, especially via "},{"type":"codeVoice","code":"Node\/queueFree"},{"text":", as it can","type":"text"},{"type":"text","text":" "},{"text":"cause crashes if you free a node while the editor runs logic involving it.","type":"text"}]}]},{"level":1,"anchor":"Detecting-the-Editor","type":"heading","text":"Detecting the Editor"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In your code, you can call the "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/isEditorHint()","type":"reference","isActive":true},{"type":"text","text":" to determine whether"},{"text":" ","type":"text"},{"type":"text","text":"the code is running inside the editor or in the game, and adjust your various"},{"type":"text","text":" "},{"type":"text","text":"methods accordingly."}]}]}],"references":{"doc://SwiftGodot/documentation/SwiftGodot/BindingNodes":{"kind":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/BindingNodes","url":"\/documentation\/swiftgodot\/bindingnodes","title":"Referencing Nodes from your Scene","abstract":[{"type":"text","text":"You will find yourself referencing nodes from a scene in your code.   In GDScript, that is usually"},{"text":" ","type":"text"},{"type":"text","text":"achieved by using the dollar sign and the name of the object you want to reference."}],"type":"topic","role":"article"},"doc://SwiftGodot/documentation/SwiftGodot/Differences":{"type":"topic","url":"\/documentation\/swiftgodot\/differences","title":"SwiftGodot API differences to GDScript","role":"article","abstract":[{"type":"text","text":"This document lists some common differences between GDSscript and SwiftGodot."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Differences","kind":"article"},"doc://SwiftGodot/documentation/SwiftGodot/Exports":{"abstract":[{"type":"text","text":"In Godot, class members can be exported. This means their value gets saved along"},{"text":" ","type":"text"},{"text":"with the resource (such as the scene) they’re attached to. They will also be","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"available for editing in the property editor. Exporting is done by using the"}],"title":"Exports","type":"topic","url":"\/documentation\/swiftgodot\/exports","kind":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Exports","role":"article"},"doc://SwiftGodot/documentation/SwiftGodot/Variants":{"title":"Variants","type":"topic","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Variants","kind":"article","role":"article","abstract":[{"type":"text","text":"Follow up on the fundamental building block of Godot’s data types."}],"url":"\/documentation\/swiftgodot\/variants"},"doc://SwiftGodot/documentation/SwiftGodot/Signals":{"type":"topic","title":"Signals","url":"\/documentation\/swiftgodot\/signals","abstract":[{"type":"text","text":"Signals in Godot are used by objects to post interesting events that are"},{"text":" ","type":"text"},{"text":"taking place, and can be used by users to easily add behavior and react","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to changes."}],"kind":"article","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Signals","role":"article"},"doc://SwiftGodot/documentation/SwiftGodot":{"kind":"symbol","url":"\/documentation\/swiftgodot","title":"SwiftGodot","role":"collection","type":"topic","abstract":[{"type":"text","text":"Framework to write Godot Game Extensions using the Swift Programming Language."}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot"},"doc://SwiftGodot/documentation/SwiftGodot/CustomTypes":{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/CustomTypes","url":"\/documentation\/swiftgodot\/customtypes","type":"topic","title":"Using Custom Types","kind":"article","role":"collectionGroup","abstract":[{"type":"text","text":"You will typically extend the functionality of your Godot game by creating"},{"text":" ","type":"text"},{"type":"text","text":"classes that derive from one of the various Godot types and adjust the"},{"text":" ","type":"text"},{"text":"behavior accordingly.","type":"text"}]},"doc://SwiftGodot/documentation/SwiftGodot/Engine/isEditorHint()":{"url":"\/documentation\/swiftgodot\/engine\/iseditorhint()","title":"isEditorHint()","abstract":[{"type":"text","text":"Returns "},{"code":"true","type":"codeVoice"},{"text":" if the script is currently running inside the editor, ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" otherwise. This is useful for "},{"type":"codeVoice","code":"@tool"},{"type":"text","text":" scripts to conditionally draw editor helpers, or prevent accidentally running “game” code that would affect the scene state while in the editor:"}],"role":"symbol","kind":"symbol","type":"topic","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"isEditorHint","kind":"identifier"},{"kind":"text","text":"() -> "},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/Engine\/isEditorHint()"}}}