ould actually be emitted. If set to a value lower than "},{"type":"codeVoice","code":"1.0"},{"text":", this will set the amount of emitted particles throughout the lifetime to ","type":"text"},{"code":"amount * amount_ratio","type":"codeVoice"},{"type":"text","text":". Unlike changing "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amount","isActive":true},{"type":"text","text":", changing "},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio","type":"reference","isActive":true},{"type":"text","text":" while emitting does not affect already-emitted particles and doesn’t cause the particle system to restart. "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio"},{"text":" can be used to create effects that make the number of emitted particles vary over time.","type":"text"}],"fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"text":"amountRatio","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio","title":"amountRatio","kind":"symbol","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/GPUParticles2D/amount":{"url":"\/documentation\/swiftgodot\/gpuparticles2d\/amount","type":"topic","abstract":[{"type":"text","text":"The number of particles to emit in one emission cycle. The effective emission rate is "},{"type":"codeVoice","code":"(amount * amount_ratio) \/ lifetime"},{"text":" particles per second. Higher values will increase GPU requirements, even if not all particles are visible at a given time or if ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio","isActive":true},{"type":"text","text":" is decreased."}],"fragments":[{"text":"var","kind":"k