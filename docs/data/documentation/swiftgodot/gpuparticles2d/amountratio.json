{"abstract":[{"type":"text","text":"The ratio of particles that should actually be emitted. If set to a value lower than "},{"code":"1.0","type":"codeVoice"},{"type":"text","text":", this will set the amount of emitted particles throughout the lifetime to "},{"type":"codeVoice","code":"amount * amount_ratio"},{"type":"text","text":". Unlike changing "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amount"},{"text":", changing ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio","isActive":true,"type":"reference"},{"type":"text","text":" while emitting does not affect already-emitted particles and doesn’t cause the particle system to restart. "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio"},{"type":"text","text":" can be used to create effects that make the number of emitted particles vary over time."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/swiftgodot\/gpuparticles2d\/amountratio"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","sections":[],"metadata":{"title":"amountRatio","fragments":[{"kind":"keyword","text":"var"},{"text":" ","kind":"text"},{"kind":"identifier","text":"amountRatio"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"}],"roleHeading":"Instance Property","modules":[{"name":"SwiftGodot"}],"symbolKind":"property","role":"symbol","externalID":"s:10SwiftGodot14GPUParticles2DC11amountRatioSdvp"},"identifier":{"url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D\/amountRatio","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/GPUParticles2D"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"final","kin