ftgodot\/os\/getcmdlineuserargs()","abstract":[{"text":"Similar to ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OS\/getCmdlineArgs()","type":"reference","isActive":true},{"type":"text","text":", but this returns the user arguments (any argument passed after the double dash "},{"type":"codeVoice","code":"--"},{"type":"text","text":" or double plus "},{"code":"++","type":"codeVoice"},{"text":" argument). These are left untouched by Godot for the user. ","type":"text"},{"type":"codeVoice","code":"++"},{"text":" can be used in situations where ","type":"text"},{"type":"codeVoice","code":"--"},{"text":" is intercepted by another program (such as ","type":"text"},{"code":"startx","type":"codeVoice"},{"type":"text","text":")."}],"role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/OS":{"kind":"symbol","type":"topic","url":"\/documentation\/swiftgodot\/os","navigatorTitle":[{"text":"OS","kind":"identifier"}],"abstract":[{"type":"text","text":"Provides access to common operating system functionalities."}],"title":"OS","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"text":"OS","kind":"identifier"}],"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OS","role":"symbol"},"doc://SwiftGodot/documentation/SwiftGodot/PackedStringArray":{"role":"symbol","type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"kind":"text","text":" "},{"text":"PackedStringArray","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"PackedStringArray"}],"abstract":[{"text":"A packed array of ","type":"text"},{"type":"codeVoice","code":"String"},{"text":"s.","type":"text"}],"title":"PackedStringArray","url":"\/documentation\/swiftgodot\/packedstringarray","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedStringArray"}}}