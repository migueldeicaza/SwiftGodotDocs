{"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/documentation\/SwiftGodot","doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OS"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"getCmdlineArgs","kind":"identifier"},{"kind":"text","text":"() -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot17PackedStringArrayC","text":"PackedStringArray","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/PackedStringArray"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Command-line arguments can be written in any form, including both "},{"code":"--key value","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"--key=value"},{"type":"text","text":" forms so they can be properly parsed, as long as custom command-line arguments do not conflict with engine arguments."}]},{"type":"paragraph","inlineContent":[{"text":"You can also incorporate environment variables using the ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OS\/getEnvironment(variable:)","isActive":true},{"text":" method.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set "},{"type":"codeVoice","code":"ProjectSettings\/editor\/run\/mainRunArgs"},{"type":"text","text":" to define command-line arguments to be passed by the editor when running the project."}]},{"type":"paragraph","inlineContent":[{"text":"Here’s a minimal example on how to parse command-line arguments into a dictionary using the ","type":"text"},{"type":"codeVoice","code":"--key=value"},{"type":"text","text":" form for arguments:"}]},{"content":[{"inlineContent":[{"text":"Passing custom user arguments directly is not recommended, as the engine may discard or modify them. Instead, the best way is to use the standard UNIX double dash (","type":"text"},{"type":"codeVoice","code":"--"},{"type":"text","text":") and then pass custom arguments, which the engine itself will ignore. These can be read via "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OS\/getCmdlineUserArgs()"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"Note","type":"aside","style":"note"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiftgodot\/os\/getcmdlineargs()"]}],"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"Returns the command-line arguments passed to the engine.","type":"text"}],"metadata":{"fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"getCmdlineArgs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot17PackedStringArrayC","text":"PackedStringArray"}],"modules":[{"name":"SwiftGodot"}],"role":"symbol","symbolKind":"method","roleHeading":"Type Method","externalID":"s:10SwiftGodot2OSC14getCmdlineArgsAA17PackedStringArrayCyFZ","title":"getCmdlineArgs()"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/documentation\/SwiftGodot\/OS\/getCmdlineArgs()"},"references":{"doc://SwiftGodot/documentation/SwiftGodot/OS/getCmdlineArgs()":{"kind":"symbol","abstract":[{"type":"text","text":"Returns the command-line arguments passed to the engine."}],"fragments":[{"kind":"keyword","text":"static"},{"text":" ","kind":"text"},{"kind":"keyword","text":"func"},{"text":" ","kind":"text"},{"text":"getCmdlineArgs","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"PackedStringArray","kind":"typeIdentifier","preciseIdentifier":"s:10SwiftGodot17PackedStringArrayC"}],"url":"\/documentation