it","estimatedTime":"5min","kind":"project","role":"project","abstract":[{"text":"SwiftGodotKit lets you drive Godot entirely from Swift, and treat Godot as just another Swift framework you can call into.","type":"text"}],"title":"Using SwiftGodotKit"},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts#Handle-vertical-movement":{"type":"section","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Handle-vertical-movement","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Handle-vertical-movement","kind":"section","role":"pseudoSymbol","abstract":[{"text":"This tutorial builds off the Simple Runner game introduced in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","type":"reference"},{"type":"text","text":" and will introduce you"},{"text":" ","type":"text"},{"text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating","type":"text"},{"text":" ","type":"text"},{"text":"an infinite runner.","type":"text"}],"title":"Handle vertical movement"},"SwiftGodotKit-Xcode-2-AddPackage.png":{"identifier":"SwiftGodotKit-Xcode-2-AddPackage.png","type":"image","alt":"Adding the package to the project","variants":[{"traits":["1x","light"],"url":"\/images\/SwiftGodotKit-Xcode-2-AddPackage.png"}]},"SwiftGodotKit-Xcode-4-HardenedRuntime.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/SwiftGodotKit-Xcode-4-HardenedRuntime.png"}],"type":"image","identifier":"SwiftGodotKit-Xcode-4-HardenedRuntime.png","alt":"Two Finder windows that show the dynamic library files being copied to the game's files."},"SwiftGodotKit-Main.swift":{"syntax":"swift","content":["\/\/","\/\/  main.swift","\/\/  SimpleGodotApp","\/\/","\/\/  Created by Miguel de Icaza on 9\/6\/23.","\/\/","","import Foundation","import SwiftGodotKit","import SwiftGodot","","func loadScene (scene: SceneTree) {","    let rootNode = Node3D()","    let camera = Camera3D ()","    camera.current = true","    camera.position = Vector3(x: 0, y: 0, z: 2)","    ","    rootNode.addChild(node: camera)","    ","    func makeCuteNode (_ pos: Vector3) -> Node {","        let n = SpinningCube()","        n.position = pos","        return n","    }","    rootNode.addChild(node: makeCuteNode(Vector3(x: 1, y: 1, z: 1)))","    rootNode.addChild(node: makeCuteNode(Vector3(x: -1, y: -1, z: -1)))","    rootNode.addChild(node: makeCuteNode(Vector3(x: 0, y: 1, z: 1)))","    scene.root?.addChild(node: rootNode)","}","","@Godot","class SpinningCube: Node3D {","    override func _ready () {","        let meshRender = MeshInstance3D()","        meshRender.mesh = BoxMesh()","        addChild(node: meshRender)","    }   ","","    override func _input (event: InputEvent) {","        guard event.isPressed () && !event.isEcho () else { return }","        print (\"SpinningCube: event: isPressed \")","    }","    ","    public override func _process(delta: Double) {","        rotateY(angle: delta)","    }","}","","func registerTypes (level: GDExtension.InitializationLevel) {","    switch level {","    case .scene:","        register (type: SpinningCube.self)","    default:","        break","    }","}","","guard let projectPath = Bundle.module.path(forResource: \"Project\", ofType: nil) else {","    fatalError(\"Could not load resource path\")","}","","runGodot(args: [\"--path\", projectPath], initHook: registerTypes, loadScene: loadScene, loadProjectSettings: { settings in })"],"highlights":[],"identifier":"SwiftGodotKit-Main.swift","fileName":"SwiftGodotKit-Main.swift","fileType":"swift","type":"file"},"SwiftGodotKit-Xcode-3-AddTarget.png":{"variants":[{"traits":["1x","light"],"url":"\/images\/SwiftGodotKit-Xcode-3-AddTarget.png"}],"type":"image","identifier":"SwiftGodotKit-Xcode-3-AddTarget.png","alt":"Dialog showing which package products are available from SwiftGodotKit"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension":{"type":"