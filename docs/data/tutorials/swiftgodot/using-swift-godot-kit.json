{"metadata":{"title":"Using SwiftGodotKit","role":"project","category":"SwiftGodot Tutorials","categoryPathComponent":"SwiftGodot-Tutorials"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/swiftgodot\/using-swift-godot-kit"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[{"chapter":"Embedding Godot in Swift","kind":"hero","estimatedTimeInMinutes":5,"backgroundImage":"RunnerHeader.png","image":"RunnerHeader.png","title":"Using SwiftGodotKit","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"SwiftGodotKit lets you drive Godot entirely from Swift, and treat Godot as just another Swift framework you can call into."}]}]},{"kind":"tasks","tasks":[{"anchor":"SwiftGodotKit-from-Xcode","title":"SwiftGodotKit from Xcode","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"SwiftGodot provides the API bridge between the Swift world and the Godot API.   This API can be used to implement new capabilities in both Godot extensions, or to drive Godot entirely from Swift.   This tutorial covers how to drive Godot entirely from Swift, rather than how to extend Godot with Swift or implementing functionality for Godot in Swift.","type":"text"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"caption":[],"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In Xcode, create a new project.   In our example, we are going to create a new MacOS project and make this a command line tool.   You can use other options, but this shows the most minimal project you can create."}]}],"media":"SwiftGodotKit-Xcode-1-MacOS-NewProject.png","runtimePreview":null},{"caption":[],"media":null,"runtimePreview":null,"code":null,"content":[{"inlineContent":[{"type":"text","text":"You will now Add a dependency on the "},{"type":"codeVoice","code":"SwiftGodotKit"},{"type":"text","text":" library."}],"type":"paragraph"}],"type":"step"},{"media":"SwiftGodotKit-Xcode-2-AddPackage.png","type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To do this, after you create your project, select your project from the navigator, and go to “Package Dependencies”.  There click the “+” button and when the package selector comes up, enter the URL for the SwiftGodotKit package: https:\/\/github.com\/migueldeicaza\/SwiftGodotKit"}]}],"code":null,"runtimePreview":null},{"caption":[],"media":"SwiftGodotKit-Xcode-3-AddTarget.png","code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The SwiftGodotKit package comes with various samples, you only need the SwiftGodotKit package to be added to your project, so you can safely set all the Package Products to “None” in the “Add to Target” column"}]}],"type":"step","runtimePreview":null},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Since this contains a native library that has not been signed, go to your “Signing & Capabilities”  tab for your target, and in the “Hardened Runtime” which is checked-in by default, enable the “Disable Library Validation”.   Alternatively, you can remove the “Hardened Runtime”.","type":"text"}]}],"caption":[],"media":"SwiftGodotKit-Xcode-4-HardenedRuntime.png","runtimePreview":null,"type":"step"},{"content":[{"inlineContent":[{"type":"text","text":"Create a “Project” directory where you place your Godot-assets.   These include things like the main entry point "},{"type":"codeVoice","code":"project.godot"},{"type":"text","text":", your scene files, and resources that your app will use"}],"type":"paragraph"}],"media":null,"type":"step","code":null,"runtimePreview":null,"caption":[]},{"media":null,"code":"SwiftGodotKit-Main.swift","runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"type":"text","text":"You can now enter a sample SwiftGodot project.   This needs to import both the  "},{"type":"codeVoice","code":"SwiftGodotKit"},{"text":" API which provides one entry point: the ","type":"text"},{"type":"codeVoice","code":"runGodot"},{"type":"text","text":" method, and the "},{"code":"SwiftGodot","type":"codeVoice"},{"text":" API, that contains the bulk of the code.","type":"text"}],"type":"paragraph"}],"type":"step"}]}]}],"kind":"project","identifier":{"url":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit","interfaceLanguage":"swift"},"hierarchy":{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","modules":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/SwiftGodot-Essentials","projects":[{"sections":[{"kind":"task","reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-Swift-package"},{"kind":"task","reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-player-character"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Set-up-the-extension","kind":"task"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Use-the-new-player-controller","kind":"task"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension"},{"sections":[{"kind":"task","reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Handle-vertical-movement"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Teleport-the-player","kind":"task"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Using-the-new-main-level-node","kind":"task"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts"}]},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/Embedding-Godot-in-Swift","projects":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit","sections":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit#SwiftGodotKit-from-Xcode","kind":"task"}]}]}],"paths":[["doc:\/\/SwiftGodot\/tutorials\/SwiftGodot