/SwiftGodot\/Your-First-Extension","interfaceLanguage":"swift"},"variants":[{"paths":["\/tutorials\/swiftgodot\/your-first-extension"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[{"title":"Your First Extension","image":"RunnerHeader.png","projectFiles":"SimpleRunner-Starter.zip","kind":"hero","backgroundImage":"RunnerHeader.png","content":[{"type":"paragraph","inlineContent":[{"text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll","type":"text"},{"type":"text","text":" "},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"text":" ","type":"text"},{"type":"text","text":"the horizontal axis."}]}],"chapter":"SwiftGodot Essentials","estimatedTimeInMinutes":30},{"kind":"tasks","tasks":[{"contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Your extension for Godot lives as a Swift package alongside your Godot project. While Godot currently"},{"type":"text","text":" "},{"text":"doesn’t support editing Swift packages in its editor, you can use Xcode to do most of the heavy lifting.","type":"text"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"code":null,"type":"step","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Open Xcode and select ","type":"text"},{"inlineContent":[{"text":"File > New > Package…","type":"text"}],"type":"strong"},{"text":" to create a new Swift package.","type":"text"}]}],"media":"NewPackage.png","runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"In the template chooser, select "},{"inlineContent":[{"type":"text","text":"Library"}],"type":"strong"},{"text":" and save the project near your game’s project files as","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"text":"SimpleRunnerDriver","type":"text"}]},{"text":".","type":"text"}],"type":"paragraph"}],"runtimePreview":null,"type":"step","caption":[],"media":"LibraryPackageTemplate.png","code":null},{"content":[{"type":"paragraph","inlineContent":[{"text":"In Package.swift, add the SwiftGodot binary dependency to your package.","type":"text"}]}],"media":null,"code":"Package-starter-2.swift","runtimePreview":null,"caption":[],"type":"step"},{"type":"step","media":null,"code":"Package-starter-3.swift","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Set the type of the SimpleRunnerDriver library to dynamic and set the minimum platform target to macOS 13.","type":"text"}]}]},{"caption":[],"media":null,"code":"Package-starter-4.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update the SimpleRunnerDriver target to add in the appropriate Swift compiler and linker settings. These"},{"text":" ","type":"text"},{"type":"text","text":"flags are needed to allow dynamic lookup with the Godot engine."}]}],"runtimePreview":null,"type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In SimpleRunnerDriver.swift, import the SwiftGodot library and call the"},{"text":" ","type":"text"},{"code":"initSwiftExtension","type":"codeVoice"},{"text":" macro to create an entry point. For now, we can pass an empty array for the nodes","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to be registered."}]}],"caption":[],"type":"step","code":"SimpleRunnerDriver-starter-2.swift","runtimePreview":null,"media":null}],"anchor":"Create-a-Swift-package","title":"Create a Swift package"},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file called "},{"type":"strong","inlineContent":[{"type":"text","text":"PlayerController.swift"}]},{"text":" in the ","type":"text"},{"type":"codeVoice","code":"Sources\/SimpleRunnerDriver"},{"text":" directory and import the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"SwiftGodot library."}],"type":"paragraph"}],"caption":[],"runtimePreview":null,"media":null,"code":"PlayerController-starter-init.swift","type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Write a new "},{"code":"PlayerController","type":"codeVoice"},{"type":"text","text":" class that inherits from "},{"type":"codeVoice","code":"CharacterBody2D"},{"type":"text","text":" and add its required"},{"type":"text","text":" "},{"type":"text","text":"initializers."}]}],"type":"step","caption":[],"media":null,"runtimePreview":null,"code":"PlayerController-starter-2.swift"},{"runtimePreview":null,"caption":[{"inlineContent":[{"text":"These will be used to calculate the final velocity of the player.","type":"text"}],"type":"paragraph"}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"code":"acceleration","type":"codeVoice"},{"text":", ","type":"text"},{"code":"friction","type":"codeVoice"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"speed"},{"type":"text","text":" properties to the player controller."}]}],"media":null,"code":"PlayerController-starter-3.swift"},{"media":null,"code":"PlayerController-starter-4.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Create a ","type":"text"},{"code":"movementVector","type":"codeVoice"},{"type":"text","text":" computed property that creates a new vector and sets its X coordinate to the"},{"type":"text","text":" "},{"type":"text","text":"difference between the "},{"code":"move_right","type":"codeVoice"},{"type":"text","text":" and "},{"type":"codeVoice","code":"move_left"},{"type":"text","text":" actions. Return the normalized vector in the block."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"This vector will be used to determine the direction that the player is moving in along the X axis. For","type":"text"},{"type":"text","text":" "},{"type":"text","text":"now, we will assume that the player does "},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"type":"text","text":" move on the vertical axis."}]}],"type":"step"},{"content":[{"inlineContent":[{"text":"Add the ","type":"text"},{"type":"codeVoice","code":"_physicsProcess"},{"text":" method to the player controller class and return from the function if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"engine reports that we’re in the editor."}],"type":"paragraph"}],"code":"PlayerController-starter-5.swift","caption":[{"type":"paragraph","inlineContent":[{"text":"This check is needed here to ensure that keypresses are registered only when running in-game, as the","type":"text"},{"text":" ","type":"text"},{"text":"extension runs at the engine level.","type":"text"}]}],"type":"step","runtimePreview":null,"media":null},{"caption":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"limitLength","type":"codeVoice"},{"text":" method is used to clamp the velocity down to the maximum ","type":"text"},{"code":"speed","type":"codeVoice"},{"text":" value so that the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"player doesn’t build up a lot of speed."}]}],"code":"PlayerController-starter-6.swift","content":[{"inlineContent":[{"type":"text","text":"Check if the movement vector is a non-zero value (i.e., the player is actively pressing a key), and"},{"text":" ","type":"text"},{"type":"text","text":"calculate the velocity at which the player moves. If your "},{"type":"codeVoice","code":"acceleration"},{"text":", ","type":"text"},{"type":"codeVoice","code":"friction"},{"text":", and\/or ","type":"text"},{"code":"speed","type":"codeVoice"},{"text":" ","type":"text"},{"type":"text","text":"values are integers, be sure to explicitly define their types as floats\/doubles."}],"type":"paragraph"}],"type":"step","runtimePreview":null,"media":null},{"runtimePreview":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Add an else case that will have the player’s velocity moving towards zero, applying any "},{"code":"friction","type":"codeVoice"},{"text":" as","type":"text"},{"type":"text","text":" "},{"type":"text","text":"necessary."}],"type":"paragraph"}],"caption":[],"media":null,"code":"PlayerController-starter-7.swift"},{"runtimePreview":null,"type":"step","code":"PlayerController-starter-8.swift","media":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, call "},{"type":"codeVoice","code":"moveAndSlide"},{"text":" to move the player, sliding along any edges the player collides with, and","type":"text"},{"type":"text","text":" "},{"text":"call the parent’s ","type":"text"},{"type":"codeVoice","code":"physicsProcess(delta:)"},{"text":" method.","type":"text"}]}]},{"runtimePreview":null,"caption":[{"inlineContent":[{"text":"This registration call exposed the class type to Godot as a valid node that can be used in the engine.","type":"text"}],"type":"paragraph"}],"media":null,"content":[{"inlineContent":[{"text":"In, SimpleRunnerDriver.swift, register the ","type":"text"},{"type":"codeVoice","code":"PlayerController"},{"type":"text","text":" class type by adding this to the array"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"code":"initSwiftExtension","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}],"code":"SimpleRunnerDriver-starter-3.swift","type":"step"}],"anchor":"Create-a-player-character","title":"Create a player character","contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that our package is set up, we can create a player controller to move the player around in."}]}],"kind":"contentAndMedia"}]},{"contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Before our Swift package can be built and used, the extension must be created and registered with Godot. To"},{"text":" ","type":"text"},{"type":"text","text":"do