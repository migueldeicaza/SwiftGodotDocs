ssing the Play button in the toolbar and press either the A\/D or left\/right arrow","type":"text"},{"type":"text","text":" "},{"text":"keys. Congrats; the player moves! 🎉","type":"text"}],"type":"paragraph"}],"media":"SimpleRunner-complete.gif","caption":[],"runtimePreview":null,"type":"step"}],"title":"Use the new player controller","anchor":"Use-the-new-player-controller"}]},{"kind":"callToAction","abstract":[{"text":"This tutorial builds off the Simple Runner game introduced in ","type":"text"},{"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","type":"reference","isActive":true},{"text":" and will introduce you","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating"},{"text":" ","type":"text"},{"type":"text","text":"an infinite runner."}],"featuredEyebrow":"Tutorial","action":{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts","overridingTitle":"Get started","overridingTitleInlineContent":[{"type":"text","text":"Get started"}]},"title":"Writing Multiple Scripts"}],"kind":"project","metadata":{"category":"SwiftGodot Tutorials","role":"project","categoryPathComponent":"SwiftGodot-Tutorials","title":"Your First Extension"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/swiftgodot\/your-first-extension"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"Godot-Filesystem-starter-2.png":{"alt":"The FileSystem tab in the Godot editor, with the player.tscn file selected in the tree.","type":"image","variants":[{"traits":["1x","light"],"url":"\/images\/SwiftGodot\/Godot-Filesystem-starter-2.png"}],"identifier":"Godot-Filesystem-starter-2.png"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Exten