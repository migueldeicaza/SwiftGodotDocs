pe":"paragraph","inlineContent":[{"text":"The name of the file corresponds to the built version of the dynamic library.","type":"text"}]}],"type":"step"},{"runtimePreview":null,"type":"step","code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the terminal, navigate to the SimpleRunnerDriver package and run "},{"code":"swift build","type":"codeVoice"},{"type":"text","text":" to build the package."}]}],"caption":[{"inlineContent":[{"text":"This will build both SwiftGodot and the SimpleRunnerDriver packages, creating the dynamic library files","type":"text"},{"type":"text","text":" "},{"text":"we need for Godot.","type":"text"}],"type":"paragraph"}],"media":"SwiftBuild.png"},{"caption":[],"media":"OpenSwiftBuild.png","runtimePreview":null,"code":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open the "},{"code":".build\/{arch}\/debug","type":"codeVoice"},{"text":" directory in the Finder using the ","type":"text"},{"type":"codeVoice","code":"open"},{"type":"text","text":" command, replacing "},{"code":"arch","type":"codeVoice"},{"text":" with","type":"text"},{"type":"text","text":" "},{"type":"text","text":"your Mac’s architecture folder."}]}]},{"code":null,"media":"DylibCopy.png","caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"Copy the ","type":"text"},{"code":"libSimpleRunnerDriver.dylib","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"libSwiftGodot.dylib","type":"codeVoice"},{"text":" files into the ","type":"text"},{"code":"bin","type":"codeVoice"},{"type":"text","text":" directory of the"},{"text":" ","type":"text"},{"text":"SimpleRunner Godot project.","type":"text"}]}],"runtimePreview":null,"type":"step"}],"title":"Set up the extension","anchor":"Set-up-the-extension"},{"title":"Use the new player controller","anchor":"Use-the-new-player-controller","contentSection":[{"kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Now that 