ion","abstract":[{"type":"text","text":"This tutorial builds off the Simple Runner game introduced in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension"},{"type":"text","text":" and will introduce you"},{"type":"text","text":" "},{"text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating","type":"text"},{"type":"text","text":" "},{"text":"an infinite runner.","type":"text"}],"title":"Using the new main level node"},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts#Handle-vertical-movement":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Handle-vertical-movement","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Handle-vertical-movement","type":"section","abstract":[{"text":"This tutorial builds off the Simple Runner game introduced in ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","isActive":true},{"text":" and will introduce you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating"},{"type":"text","text":" "},{"type":"text","text":"an infinite runner."}],"title":"Handle vertical movement"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Create-a-player-character":{"kind":"section","role":"pseudoSymbol","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-player-character","url":"\/tutorials\/swiftgodot\/your-first-extension#Create-a-player-character","type":"section","abstract":[{"type":"text","text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll"},{"type":"text","text":" "},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"type":"text","text":" "},{"text":"the horizontal axis.","type":"text"}],"title":"Create a player character"},"Package-starter-4.swift":{"content":["\/\/ swift-tools-version: 5.9","\/\/ The swift-tools-version declares the minimum version of Swift required to build this package.","","import PackageDescription","","let package = Package(","    name: \"SimpleRunnerDriver\",","    platforms: [.macOS(.v13)],","    products: [","        \/\/ Products define the executables and libraries a package produces, making them visible to other packages.","        .library(","            name: \"SimpleRunnerDriver\",","            type: .dynamic,","            targets: [\"SimpleRunnerDriver\"]),","    ],","    dependencies: [","        .package(url: \"https:\/\/github.com\/migueldeicaza\/SwiftGodot\", branch: \"main\")","    ],","    targets: [","        \/\/ Targets are the basic building blocks of a package, defining a module or a test suite.","        \/\/ Targets can depend on other targets in this package and products from dependencies.","        .target(","            name: \"SimpleRunnerDriver\",","            dependencies: [","                \"SwiftGodot\",","            ],","            swiftSettings: [.unsafeFlags([\"-suppress-warnings\"])]","        ),","        .testTarget(","            name: \"SimpleRunnerDriverTests\",","            dependencies: [\"SimpleRunnerDriver\"]),","    ]",")"],"type":"file","fileName":"Package.swift","syntax":"swift","highlights":[{"line":23},{"line":24},{"line":25},{"line":26},{"line":27},{"line":28}],"fileType":"swift","identifier":"Package-starter-4.swift"},"Package-starter-2.swift":{"content":["\/\/ swift-tools-version: 5.9","\/\/ The swift-tools-version declares the minimum version of Swift required to build this package.","","import PackageDescription","","let package = Package(","    name: \"SimpleRunnerDriver\",","    products: [","        \/\/ Products define the execu