{"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[{"image":"RunnerHeader.png","title":"Your First Extension","chapter":"SwiftGodot Essentials","projectFiles":"SimpleRunner-Starter.zip","estimatedTimeInMinutes":30,"backgroundImage":"RunnerHeader.png","kind":"hero","content":[{"inlineContent":[{"type":"text","text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll"},{"text":" ","type":"text"},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"text":" ","type":"text"},{"type":"text","text":"the horizontal axis."}],"type":"paragraph"}]},{"tasks":[{"anchor":"Create-a-Swift-package","title":"Create a Swift package","stepsSection":[{"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Open Xcode and select ","type":"text"},{"inlineContent":[{"type":"text","text":"File > New > Package…"}],"type":"strong"},{"type":"text","text":" to create a new Swift package."}]}],"media":"NewPackage.png","runtimePreview":null,"code":null},{"code":null,"type":"step","media":"LibraryPackageTemplate.png","content":[{"type":"paragraph","inlineContent":[{"text":"In the template chooser, select ","type":"text"},{"type":"strong","inlineContent":[{"text":"Library","type":"text"}]},{"type":"text","text":" and save the project near your game’s project files as"},{"type":"text","text":" "},{"inlineContent":[{"text":"SimpleRunnerDriver","type":"text"}],"type":"strong"},{"type":"text","text":"."}]}],"caption":[],"runtimePreview":null},{"runtimePreview":null,"media":null,"content":[{"type":"paragraph","inlineContent":[{"text":"In Package.swift, add the SwiftGodot binary dependency to your package.","type":"text"}]}],"type":"step","caption":[],"code":"Package-starter-2.swift"},{"media":null,"code":"Package-starter-3.swift","caption":[],"type":"step","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Set the type of the SimpleRunnerDriver library to dynamic and set the minimum platform target to macOS 13."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Update the SimpleRunnerDriver target to add in the appropriate Swift compiler and linker settings. These"},{"type":"text","text":" "},{"text":"flags are needed to allow dynamic lookup with the Godot engine.","type":"text"}],"type":"paragraph"}],"code":"Package-starter-4.swift","caption":[],"runtimePreview":null,"media":null,"type":"step"},{"type":"step","code":"SimpleRunnerDriver-starter-2.swift","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In SimpleRunnerDriver.swift, import the SwiftGodot library and call the"},{"text":" ","type":"text"},{"type":"codeVoice","code":"initSwiftExtension"},{"text":" macro to create an entry point. For now, we can pass an empty array for the nodes","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to be registered."}]}],"runtimePreview":null,"caption":[],"media":null}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"text":"Your extension for Godot lives as a Swift package alongside your Godot project. While Godot currently","type":"text"},{"type":"text","text":" "},{"type":"text","text":"doesn’t support editing Swift packages in its editor, you can use Xcode to do most of the heavy lifting."}]}]}]},{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Now that our package is set up, we can create a player controller to move the player around in."}],"type":"paragraph"}]}],"anchor":"Create-a-player-character","title":"Create a player character","stepsSection":[{"runtimePreview":null,"type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file called "},{"inlineContent":[{"type":"text","text":"PlayerController.swift"}],"type":"strong"},{"text":" in the ","type":"text"},{"code":"Sources\/SimpleRunnerDriver","type":"codeVoice"},{"type":"text","text":" directory and import the"},{"type":"text","text":" "},{"text":"SwiftGodot library.","type":"text"}],"type":"paragraph"}],"caption":[],"code":"PlayerController-starter-init.swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Write a new "},{"type":"codeVoice","code":"PlayerController"},{"type":"text","text":" class that inherits from "},{"type":"codeVoice","code":"CharacterBody2D"},{"text":" and add its required","type":"text"},{"type":"text","text":" "},{"type":"text","text":"initializers."}]}],"type":"step","code":"PlayerController-starter-2.swift","media":null,"runtimePreview":null,"caption":[]},{"caption":[{"type":"paragraph","inlineContent":[{"text":"These will be used to calculate the final velocity of the player.","type":"text"}]}],"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"type":"codeVoice","code":"acceleration"},{"type":"text","text":", "},{"type":"codeVoice","code":"friction"},{"text":", and ","type":"text"},{"type":"codeVoice","code":"speed"},{"text":" properties to the player controller.","type":"text"}]}],"code":"PlayerController-starter-3.swift","type":"step","runtimePreview":null},{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This vector will be used to determine the direction that the player is moving in along the X axis. For"},{"type":"text","text":" "},{"type":"text","text":"now, we will assume that the player does "},{"type":"emphasis","inlineContent":[{"text":"not","type":"text"}]},{"type":"text","text":" move on the vertical axis."}]}],"code":"PlayerController-starter-4.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a "},{"code":"movementVector","type":"codeVoice"},{"text":" computed property that creates a new vector and sets its X coordinate to the","type":"text"},{"type":"text","text":" "},{"text":"difference between the ","type":"text"},{"code":"move_right","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"move_left","type":"codeVoice"},{"text":" actions. Return the normalized vector in the block.","type":"text"}]}],"media":null,"type":"step"},{"caption":[{"type":"paragraph","inlineContent":[{"text":"This check is needed here to ensure that keypresses are registered only when running in-game, as the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extension runs at the engine level."}]}],"code":"PlayerController-starter-5.swift","type":"step","media":null,"content":[{"inlineContent":[{"text":"Add the ","type":"text"},{"type":"codeVoice","code":"_physicsProcess"},{"text":" method to the player controller class and return from the function if the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"engine reports that we’re in the editor."}],"type":"paragraph"}],"runtimePreview":null},{"caption":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"limitLength","type":"codeVoice"},{"type":"text","text":" method is used to clamp the velocity down to the maximum "},{"type":"codeVoice","code":"speed"},{"text":" value so that the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"player doesn’t build up a lot of speed."}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check if the movement vector is a non-zero value (i.e., the player is actively pressing a key), and"},{"text":" ","type":"text"},{"type":"text","text":"calculate the velocity at which the player moves. If your "},{"code":"acceleration","type":"codeVoice"},{"type":"text","text":", "},{"code":"friction","type":"codeVoice"},{"type":"text","text":", and\/or "},{"code":"speed","type":"codeVoice"},{"text":" ","type":"text"},{"text":"values are integers, be sure to explicitly define their types as floats\/doubles.","type":"text"}]}],"media":null,"code":"PlayerController-starter-6.swift","runtimePreview":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Add an else case that will have the player’s velocity moving towards zero, applying any ","type":"text"},{"code":"friction","type":"codeVoice"},{"type":"text","text":" as"},{"type":"text","text":" "},{"type":"text","text":"necessary."}]}],"caption":[],"code":"PlayerController-starter-7.swift","runtimePreview":null,"media":null},{"caption":[],"code":"PlayerController-starter-8.swift","runtimePreview":null,"media":null,"content":[{"inlineContent":[{"text":"Finally, call ","type":"text"},{"type":"codeVoice","code":"moveAndSlide"},{"text":" to move the player, sliding along any edges the player collides with, and","type":"text"},{"type":"text","text":" "},{"text":"call the parent’s ","type":"text"},{"type":"codeVoice","code":"physicsProcess(delta:)"},{"type":"text","text":" method."}],"type":"paragraph"}],"type":"step"},{"media":null,"runtimePreview":null,"code":"SimpleRunnerDriver-starter-3.swift","content":[{"inlineContent":[{"text":"In, SimpleRunnerDriver.swift, register the ","type":"text"},{"type":"codeVoice","code":"PlayerController"},{"type":"text","text":" class type by adding this to the array"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"type":"codeVoice","code":"initSwiftExtension"},{"text":".","type":"text"}],"type":"paragraph"}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"This registration call exposed the class type to Godot as a valid node that can be used in the engine.","type":"text"}]}]}]},{"contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"text":"Before our Swift package can be built and used, the extension must be created and registered with Godot. To","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"do this, you will create a "},{"type":"codeVoice","code":"gdextension"},{"text":" file that tells Godot where to look for the dynamic libraries.","type":"text"}]}],"mediaPosition":"trailing"}],"stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"text":"Create a new ","type":"text"},{"code":"bin","type":"codeVoice"},{"type":"text","text":" folder in the SimpleRunner Godot project with an empty file"},{"type":"text","text":" "},{"type":"codeVoice","code":"SimpleRunnerDriver.gdextension"},{"type":"text","text":"."}]}],"code":null,"media":"NewExtensionFile.png","type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Download the provided Example project "},{"type":"strong","inlineContent":[{"text":"SimpleRunner-Starter.zip","type":"text"}]},{"text":" at the top of the page.","type":"text"}]}],"runtimePreview":null},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"In SimpleRunnerDriver.gdextension, create a configuration section with an ","type":"text"},{"code":"entry_point","type":"codeVoice"},{"text":" key that points","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to "},{"type":"codeVoice","code":"\"swift_entry_point\""},{"type":"text","text":"."}]}],"media":null,"type":"step","code":"SimpleRunnerDriver-starter-2.txt","runtimePreview":null},{"media":null,"code":"SimpleRunnerDriver-starter-3.txt","runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The name of the file corresponds to the built version of the dynamic library."}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a "},{"type":"codeVoice","code":"libraries"},{"type":"text","text":" section and set the path of "},{"type":"codeVoice","code":"macos.debug"},{"type":"text","text":" to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"res:\/\/bin\/libSimpleRunnerDriver.dylib"},{"text":". And a ","type":"text"},{"code":"dependencies","type":"codeVoice"},{"text":" section that will be used to copy the library into the application when exporting the project.","type":"text"}]}]},{"runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"This will build both SwiftGodot and the SimpleRunnerDriver packages, creating the dynamic library files","type":"text"},{"type":"text","text":" "},{"text":"we need for Godot.","type":"text"}]}],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"In the terminal, navigate to the SimpleRunnerDriver package and run ","type":"text"},{"code":"swift build","type":"codeVoice"},{"type":"text","text":" to build the package."}]}],"media":"SwiftBuild.png","code":null},{"media":"OpenSwiftBuild.png","caption":[],"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open the "},{"code":".build\/{arch}\/debug","type":"codeVoice"},{"type":"text","text":" directory in the Finder using the "},{"code":"open","type":"codeVoice"},{"type":"text","text":" command, replacing "},{"type":"codeVoice","code":"arch"},{"type":"text","text":" with"},{"text":" ","type":"text"},{"type":"text","text":"your Mac’s architecture folder."}]}],"code":null},{"content":[{"inlineContent":[{"text":"Copy the ","type":"text"},{"code":"libSimpleRunnerDriver.dylib","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"libSwiftGodot.dylib","type":"codeVoice"},{"text":" files into the ","type":"text"},{"code":"bin","type":"codeVoice"},{"text":" directory of the","type":"text"},{"type":"text","text":" "},{"text":"SimpleRunner Godot project.","type":"text"}],"type":"paragraph"}],"type":"step","media":"DylibCopy.png","code":null,"runtimePreview":null,"caption":[]}],"title":"Set up the extension","anchor":"Set-up-the-extension"},{"stepsSection":[{"content":[{"inlineContent":[{"text":"Open the SimpleRunner project in the Godot editor. When the project opens, you should see a dialog that","type":"text"},{"type":"text","text":" "},{"text":"appears, asking to reloag Godot for extensions to take effect.","type":"text"}],"type":"paragraph"}],"caption":[],"media":"GodotExtensionPrompt.png","runtimePreview":null,"type":"step","code":null},{"media":"GodotMainEditor.png","runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Press Restart to restart the Godot editor and enable the extension."}]}],"caption":[],"code":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the FileSystem tab, navigate to the objects directory and open the "},{"code":"player.tscn","type":"codeVoice"},{"text":" file, which contains","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the player scene."}]}],"caption":[],"media":"Godot-Filesystem-starter-2.png","runtimePreview":null,"code":null,"type":"step"},{"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"In the Scene tab, right click on the ","type":"text"},{"code":"CharacterBody2D","type":"codeVoice"},{"type":"text","text":" node and select "},{"type":"strong","inlineContent":[{"type":"text","text":"Change Type"}]},{"type":"text","text":"."}]}],"caption":[],"code":null,"media":"Godot-Scene-starter-3.png","type":"step"},{"runtimePreview":null,"media":"Godot-NodePicker-starter-4.png","code":null,"content":[{"inlineContent":[{"type":"text","text":"Search for the PlayerController node and click "},{"inlineContent":[{"type":"text","text":"Change"}],"type":"strong"},{"type":"text","text":" to apply the changes and save the scene once"},{"type":"text","text":" "},{"type":"text","text":"the change is made."}],"type":"paragraph"}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the PlayerController doesn’t appear in this list, revisit the other sections of this tutorial. You"},{"type":"text","text":" "},{"type":"text","text":"may have misconfigured a setting or didn’t build the library."}]}]},{"type":"step","content":[{"inlineContent":[{"type":"text","text":"Run the project by pressing the Play button in the toolbar and press either the A\/D or left\/right arrow"},{"type":"text","text":" "},{"type":"text","text":"keys. Congrats; the player moves! 🎉"}],"type":"paragraph"}],"caption":[],"media":"SimpleRunner-complete.gif","code":null,"runtimePreview":null}],"contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that the extension is set up and you have a built dynamic library, you will be able to set the player"},{"type":"text","text":" "},{"text":"up in the Godot editor and enable the extension.","type":"text"}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"anchor":"Use-the-new-player-controller","title":"Use the new player controller"}],"kind":"tasks"},{"title":"Writing Multiple Scripts","featuredEyebrow":"Tutorial","action":{"overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts","isActive":true,"type":"reference","overridingTitle":"Get started"},"kind":"callToAction","abstract":[{"type":"text","text":"This tutorial builds off the Simple Runner game introduced in "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension"},{"type":"text","text":" and will introduce you"},{"type":"text","text":" "},{"text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating","type":"text"},{"type":"text","text":" "},{"text":"an infinite runner.","type":"text"}]}],"kind":"project","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/tutorials\/swiftgodot\/your-first-extension"]}],"hierarchy":{"paths":[["doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/$volume","doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/SwiftGodot-Essentials"]],"modules":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/SwiftGodot-Essentials","projects":[{"sections":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-Swift-package","kind":"task"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-player-character","kind":"task"},{"kind":"task","reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Set-up-the-extension"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Use-the-new-player-controller","kind":"task"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension"},{"sections":[{"kind":"task","reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Handle-vertical-movement"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Teleport-the-player","kind":"task"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Using-the-new-main-level-node","kind":"task"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts"}]},{"projects":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit","sections":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit#SwiftGodotKit-from-Xcode","kind":"task"}]}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/Embedding-Godot-in-Swift"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials"},"identifier":{"url":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","interfaceLanguage":"swift"},"metadata":{"role":"project","category":"SwiftGodot Tutorials","categoryPathComponent":"SwiftGodot-Tutorials","title":"Your First Extension"},"references":{"PlayerController-starter-6.swift":{"fileType":"swift","highlights":[{"line":12},{"line":13},{"line":14},{"line":25},{"line":26},{"line":27},{"line":28},{"line":29}],"syntax":"swift","type":"file","fileName":"PlayerController.swift","content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot","","@Godot","class PlayerController: CharacterBody2D {","    var acceleration: Float = 100","    var friction: Double = 100","    var speed: Double = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        return movement.normalized()","    }","","    override func _physicsProcess(delta: Double) {","        if Engine.isEditorHint() { return }","        if movementVector != .zero {","            let acceleratedVector = Vector2(x: acceleration, y: acceleration)","            let acceleratedMovement = movementVector * acceleratedVector","            self.velocity = acceleratedMovement.limitLength(speed)","        }","    }","}"],"identifier":"PlayerController-starter-6.swift"},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts":{"type":"topic","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts","estimatedTime":"15min","kind":"project","role":"project","abstract":[{"text":"This tutorial builds off the Simple Runner game introduced in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","type":"reference"},{"type":"text","text":" and will introduce you"},{"text":" ","type":"text"},{"text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating","type":"text"},{"text":" ","type":"text"},{"text":"an infinite runner.","type":"text"}],"title":"Writing Multiple Scripts"},"OpenSwiftBuild.png":{"variants":[{"url":"\/images\/OpenSwiftBuild.png","traits":["1x","light"]}],"identifier":"OpenSwiftBuild.png","alt":"A terminal window at the SwiftRunnerDriver package, about to run open.","type":"image"},"LibraryPackageTemplate.png":{"type":"image","alt":"A screenshot of Xcode's template chooser with Library selected.","variants":[{"traits":["1x","light"],"url":"\/images\/LibraryPackageTemplate.png"}],"identifier":"LibraryPackageTemplate.png"},"SimpleRunnerDriver-starter-2.swift":{"fileType":"swift","highlights":[{"line":3},{"line":4},{"line":5},{"line":6}],"syntax":"swift","type":"file","identifier":"SimpleRunnerDriver-starter-2.swift","fileName":"SimpleRunnerDriver.swift","content":["\/\/ The Swift Programming Language","\/\/ https:\/\/docs.swift.org\/swift-book","","import SwiftGodot","","#initSwiftExtension(cdecl: \"swift_entry_point\", types: [])"]},"doc://SwiftGodot/tutorials/SwiftGodot/Using-Swift-Godot-Kit#SwiftGodotKit-from-Xcode":{"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit#SwiftGodotKit-from-Xcode","abstract":[{"text":"SwiftGodotKit lets you drive Godot entirely from Swift, and treat Godot as just another Swift framework you can call into.","type":"text"}],"url":"\/tutorials\/swiftgodot\/using-swift-godot-kit#SwiftGodotKit-from-Xcode","type":"section","title":"SwiftGodotKit from Xcode","kind":"section","role":"pseudoSymbol"},"PlayerController-starter-init.swift":{"syntax":"swift","fileType":"swift","identifier":"PlayerController-starter-init.swift","highlights":[],"content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot"],"fileName":"PlayerController.swift","type":"file"},"doc://SwiftGodot/tutorials/SwiftGodot/Using-Swift-Godot-Kit":{"type":"topic","url":"\/tutorials\/swiftgodot\/using-swift-godot-kit","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit","estimatedTime":"5min","kind":"project","role":"project","abstract":[{"text":"SwiftGodotKit lets you drive Godot entirely from Swift, and treat Godot as just another Swift framework you can call into.","type":"text"}],"title":"Using SwiftGodotKit"},"Godot-NodePicker-starter-4.png":{"type":"image","identifier":"Godot-NodePicker-starte