(.v13)],","    products: [","        \/\/ Products define the executables and libraries a package produces, making them visible to other packages.","        .library(","            name: \"SimpleRunnerDriver\",","            type: .dynamic,","            targets: [\"SimpleRunnerDriver\"]),","    ],","    dependencies: [","        .package(url: \"https:\/\/github.com\/migueldeicaza\/SwiftGodot\", branch: \"main\")","    ],","    targets: [","        \/\/ Targets are the basic building blocks of a package, defining a module or a test suite.","        \/\/ Targets can depend on other targets in this package and products from dependencies.","        .target(","            name: \"SimpleRunnerDriver\"),","        .testTarget(","            name: \"SimpleRunnerDriverTests\",","            dependencies: [\"SimpleRunnerDriver\"]),","    ]",")"],"fileType":"swift","identifier":"Package-starter-3.swift","highlights":[{"line":8},{"line":13}]},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts":{"url":"\/tutorials\/swiftgodot\/writing-multiple-scripts","title":"Writing Multiple Scripts","abstract":[{"type":"text","text":"This tutorial builds off the Simple Runner game introduced in "},{"type":"reference","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","isActive":true},{"type":"text","text":" and will introduce you"},{"type":"text","text":" "},{"text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"an infinite runner."}],"kind":"project","role":"project","type":"topic","estimatedTime":"15min","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts"},"SimpleRunnerDriver-starter-2.swift":{"syntax":"swift","content":["\/\/ The Swift Programming Language","\/\/ https:\/\/docs.swift.org\/swift-book","","import SwiftGodot","","#initSwiftExtension(cdecl: \"swift_entry_point\", types: [])"],"highlights":[{"line":3},{"line":4},{"line":5},{"line":6}],"fileName":"SimpleRunnerDriver.swift","type":"file","identifier":"SimpleRunnerDriver-starter-2.swift","fileType":"swift"},"PlayerController-starter-5.swift":{"syntax":"swift","content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot","","@Godot","class PlayerController: CharacterBody2D {","    var acceleration = 100","    var friction = 100","    var speed = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        return movement.normalized()","    }","","    override func _physicsProcess(delta: Double) {","        if Engine.isEditorHint() { return }","    }","}"],"highlights":[{"line":22},{"line":23},{"line":24},{"line":25}],"fileName":"PlayerController.swift","type":"file","identifier":"PlayerController-starter-5.swift","fileType":"swift"},"PlayerController-starter-8.swift":{"syntax":"swift","content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot","","@Godot","class PlayerController: CharacterBody2D {","    var acceleration: Float = 100","    var friction: Double = 100","    var speed: Double = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        return movement.normalized()","    }","","    override func _physicsProcess(delta: Double) {","        if Engine.isEditorHint() { return }","        if movementVector != .zero {","            let acceleratedVector = Vector2(x: acceleration, y: acceleration)","            let acceleratedMovement = movementVector * acceleratedVector","            self.velocity = acceleratedMovement.limitLength(speed)","        } else {","            velocity = velocity.moveToward(to: .zero, delta: friction)","        }","        self.moveAndSlide()","        super._physicsProcess(delta: delta)","    }","}"],"highlights":[{"line":32},{"line":33}],"fileName":"PlayerController.swift","type":"file","identifier":"PlayerController-starter-8.swift","fileType":"swift"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Use-the-new-player-controller":{"url":"\/tutorials\/swiftgodot\/your-first-extension#Use-the-new-player-controller","role":"pseudoSymbol","type":"section","title":"Use the new player controller","abstract":[{"type":"text","text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll"},{"type":"text","text":" "},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"type":"text","text":" "},{"text":"the horizontal axis.","type":"text"}],"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Use-the-new-player-controller","kind":"section"},"PlayerController-starter-4.swift":{"syntax":"swift","content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot","","@Godot","class PlayerController: CharacterBody2D {","    var acceleration = 100","    var friction = 100","    var speed = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        return movement.normalized()","    }","}"],"highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21}],"fileName":"PlayerController.swift","type":"file","identifier":"PlayerController-starter-4.swift","fileType":"swift"},"GodotExtensionPrompt.png":{"variants":