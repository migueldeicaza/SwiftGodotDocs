rial will guide you through making your first Godot extension to create a player character. You’ll"},{"text":" ","type":"text"},{"text":"start by building off the Simple Runner game project and create a player character to move the character along","type":"text"},{"text":" ","type":"text"},{"text":"the horizontal axis.","type":"text"}]}],"title":"Your First Extension","chapter":"SwiftGodot Essentials"},{"kind":"tasks","tasks":[{"title":"Create a Swift package","stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Open Xcode and select "},{"type":"strong","inlineContent":[{"type":"text","text":"File > New > Package…"}]},{"text":" to create a new Swift package.","type":"text"}],"type":"paragraph"}],"caption":[],"code":null,"media":"NewPackage.png","runtimePreview":null,"type":"step"},{"runtimePreview":null,"code":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"In the template chooser, select ","type":"text"},{"inlineContent":[{"type":"text","text":"Library"}],"type":"strong"},{"text":" and save the project near your game’s project files as","type":"text"},{"text":" ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"SimpleRunnerDriver"}]},{"type":"text","text":"."}]}],"type":"step","media":"LibraryPackageTemplate.png"},{"type":"step","media":null,"code":"Package-starter-2.swift","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"text":"In Package.swift, add the SwiftGodot binary dependency to your package.","type":"text"}]}]},{"code":"Package-starter-3.swift","media":null,"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"text":"Set the type of the SimpleRunnerDriver library to dynamic and set the minimum platform target to macOS 13.","type":"text"}]}],"runtimePreview":null},{"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update the SimpleRunnerDriver target to add in the appropriate Swift compiler and linker settings. These"},{"text":" ","type":"text"},{"type":"text","text":"flags are needed to allow dynamic lookup with the Godot engine."}]}],"media":null,"runtimePreview":null,"caption":[],"code":"Package-starter-4.swift"},{"caption":[],"media":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"In SimpleRunnerDriver.swift, import the SwiftGodot library and call the"},{"type":"text","text":" "},{"type":"codeVoice","code":"initSwiftExtension"},{"type":"text","text":" macro to create an entry point. For now, we can pass an empty array for the nodes"},{"text":" ","type":"text"},{"text":"to be registered.","type":"text"}],"type":"paragraph"}],"code":"SimpleRunnerDriver-starter-2.swift","runtimePreview":null}],"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Your extension for Godot lives as a Swift package alongside your Godot project. While Godot currently"},{"type":"text","text":" "},{"type":"text","text":"doesn’t support editing Swift packages in its editor, you can use Xcode to do most of the heavy lifting."}],"type":"paragraph"}]}],"anchor":"Create-a-Swift-package"},{"stepsSection":[{"type":"step","code":"PlayerController-starter-init.swift","runtimePreview":null,"caption":[],"media":null,"content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file called "},{"inlineContent":[{"text":"PlayerController.swift","type":"text"}],"type":"strong"},{"text":" in the ","type":"text"},{"type":"codeVoice","code":"Sources\/SimpleRunnerDriver"},{"type":"text","text":" directory and import the"},{"text":" ","type":"text"},{"text":"SwiftGodot library.","type":"text"}],"type":"paragraph"}]},{"code":"PlayerController-starter-2.swift","type":"step","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Write a new ","type":"text"},{"code":"PlayerController","type":"codeVoice"},{"type":"text","text":" class that inherits from "},{"code":"CharacterBody2D","type":"codeVoice"},{"type":"text","text":" and add its required"},{"type":"text","text":" "},{"type":"text","text":"initializers."}]}],"caption":[],"media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"type":"codeVoice","code":"acceleration"},{"text":", ","type":"text"},{"code":"friction","type":"codeVoice"},{"type":"text","text":", and "},{"code":"speed","type":"codeVoice"},{"type":"text","text":" properties to the player controller."}]}],"caption":[{"type":"paragraph","inlineContent":[{"text":"These will be used to calculate the final velocity of the player.","type":"text"}]}],"media":null,"runtimePreview":null,"type":"step","code":"PlayerController-starter-3.swift"},{"type":"step","media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a "},{"type":"codeVoice","code":"movementVector"},{"type":"text","text":" computed property that creates a new vector and sets its X coordinate to the"},{"text":" ","type":"text"},{"type":"text","text":"difference between the "},{"type":"codeVoice","code":"move_right"},{"type":"text","text":" and "},{"type":"codeVoice","code":"move_left"},{"type":"text","text":" actions. Return the normalized vector in the block."}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This vector will be used to determine the direction that the player is moving in along the X axis. For"},{"type":"text","text":" "},{"text":"now, we will assume that the player does ","type":"text"},{"inlineContent":[{"text":"not","type":"text"}],"type":"emphasis"},{"type":"text","text":" move on the vertical axis."}]}],"code":"PlayerController-starter-4.swift","runtimePreview":null},{"code":"PlayerController-starter-5.swift","type":"step","runtimePreview":null,"caption":[{"inlineContent":[{"type":"text","text":"This check is needed here to ensure that keypresses are registered only when running in-game, as the"},{"text":" ","type":"text"},{"type":"text","text":"extension runs at the engine level."}],"type":"paragraph"}],"content":[{"inlineContent":[{"text":"Add the ","type":"text"},{"type":"codeVoice","code":"_physicsProcess"},{"type":"text","text":" method to the player controller class and return from the function if the"},{"type":"text","text":" "},{"type":"text","text":"engine reports that we’re in the editor."}],"type":"paragraph"}],"media":null},{"media":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"limitLength"},{"text":" method is used to clamp the velocity down to the maximum ","type":"text"},{"code":"speed","type":"codeVoice"},{"type":"text","text":" value so that the"},{"type":"text","text":" "},{"text":"player doesn’t build up a lot of speed.","type":"text"}]}],"type":"step","content":[{"inlineContent":[{"type":"text","text":"Check if the movement vector is a non-zero value (i.e., the player is actively pressing a key), and"},{"text":" ","type":"text"},{"text":"calculate the velocity at which the player moves. If your ","type":"text"},{"type":"codeVoice","code":"acceleration"},{"type":"text","text":", "},{"code":"friction","type":"codeVoice"},{"type":"text","text":", and\/or "},{"code":"speed","type":"codeVoice"},{"text":" ","type":"text"},{"text":"values are integers, be sure to explicitly define their types as floats\/doubles.","type":"text"}],"type":"paragraph"}],"code":"PlayerController-starter-6.swift","runtimePreview":null},{"type":"step","code":"PlayerController-starter-7.swift","content":[{"inlineContent":[{"type":"text","text":"Add an else case that will have the player’s velocity moving towards zero, applying any "},{"type":"codeVoice","code":"friction"},{"type":"text","text":" as"},{"type":"text","text":" "},{"text":"necessary.","type":"text"}],"type":"paragraph"}],"caption":[],"media":null,"runtimePreview":null},{"code":"PlayerController-starter-8.swift","caption":[],"content":[{"inlineContent":[{"text":"Finally, call ","type":"text"},{"type":"codeVoice","code":"moveAndSlide"},{"text":" to move the player, sliding along any edges the player collides with, and","type":"text"},{"type":"text","text":" "},{"type":"text","text":"call the parent’s "},{"type":"codeVoice","code":"physicsProcess(delta:)"},{"text":" method.","type":"text"}],"type":"paragraph"}],"type":"step","runtimePreview":null,"media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In, SimpleRunnerDriver.swift, register the "},{"type":"codeVoice","code":"PlayerController"},{"text":" class type by adding this to the array","type":"text"},{"type":"text","text":" "},{"type":"text","text":"in "},{"type":"codeVoice","code":"initSwiftExtension"},{"type":"text","text":"."}]}],"code":"SimpleRunnerDriver-starter-3.swift","type":"step","caption":[{"inlineContent":[{"type":"text","text":"This registration call exposed the class type to Godot as a valid node that can be used in the engine."}],"type":"paragraph"}],"media":null,"runtimePreview":null}],"contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that our package is set up, we can create a player controller to move the player around in."}]}]}],"title":"Create a player character","anchor":"Create-a-player-character"},{"stepsSection":[{"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a new "},{"code":"bin","type":"codeVoice"},{"text":" folder in the SimpleRunner Godot project with an empty file","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"SimpleRunnerDriver.gdextension"},{"text":".","type":"text"}]}],"code":null,"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Download the provided Example project "},{"inlineContent":[{"text":"SimpleRunner-Starter.zip","type":"text"}],"type":"strong"},{"text":" at the top of the page.","type":"text"}]}],"media":"NewExtensionFile.png"},{"media":null,"runtimePreview":null,"content":[{"inlineContent":[{"text":"In SimpleRunnerDriver.gdextension, create a configuration section with an ","type":"text"},{"type":"codeVoice","code":"entry_point"},{"text":" key that points","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to "},{"type":"codeVoice","code":"\"swift_entry_point\""},{"type":"text","text":"."}],"type":"paragraph"}],"code":"SimpleRunnerDriver-starter-2.txt","caption":[],"type":"step"},{"media":null,"type":"step","runtimePreview":null,"caption":[{"inlineContent":[{"type":"text","text":"The name of the file corresponds to the built version of the dynamic library."}],"type":"paragraph"}],"code":"SimpleRunnerDriver-starter-3.txt","content":[{"inlineContent":[{"text":"Create a ","type":"text"},{"type":"codeVoice","code":"libraries"},{"text":" section and set the path of ","type":"text"},{"type":"codeVoice","code":"macos.debug"},{"text":" to","type":"text"},{"type":"text","text":" "},{"type":"codeVoice","code":"res:\/\/bin\/libSimpleRunnerDriver.dylib"},{"text":". And a ","type":"text"},{"code":"dependencies","type":"codeVoice"},{"type":"text","text":" section that will be used to copy the library into the application when exporting the project."}],"type":"paragraph"}]},{"type":"step","code":null,"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the terminal, navigate to the SimpleRunnerDriver package and run "},{"code":"swift build","type":"codeVoice"},{"text":" to build the package.","type":"text"}]}],"caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This will build both SwiftGodot and the SimpleRunnerDriver packages, creating the dynamic library files"},{"text":" ","type":"text"},{"type":"text","text":"we need for Godot."}]}],"media":"SwiftBuild.png"},{"content":[{"inlineContent":[{"text":"Open the ","type":"text"},{"type":"codeVoice","code":".build\/{arch}\/debug"},{"type":"text","text":" directory in the Finder using the "},{"code":"open","type":"codeVoice"},{"text":" command, replacing ","type":"text"},{"code":"arch","type":"codeVoice"},{"type":"text","text":" with"},{"type":"text","text":" "},{"type":"text","text":"your Mac’s architecture folder."}],"type":"paragraph"}],"runtimePreview":null,"type":"step","caption":[],"media":"OpenSwiftBuild.png","code":null},{"code":null,"runtimePreview":null,"media":"DylibCopy.png","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Copy the "},{"code":"libSimpleRunnerDriver.dylib","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"libSwiftGodot.dylib","type":"codeVoice"},{"type":"text","text":" files into the "},{"type":"codeVoice","code":"bin"},{"text":" directory of the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"SimpleRunner Godot project."}]}],"type":"step","caption":[]}],"anchor":"Set-up-the-extension","title":"Set up the extension","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Before our Swift package can be built and used, the extension must be created and registered with Godot. To"},{"type":"text","text":" "},{"text":"do this, you will create a ","type":"text"},{"type":"codeVoice","code":"gdextension"},{"type":"text","text":" file that tells Godot where to look for the dynamic libraries."}]}],"mediaPosition":"trailing"}]},{"contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"inlineContent":[{"type":"text","text":"Now that the extension is set up and you have a built dynamic library, you will be able to set the player"},{"type":"text","text":" "},{"text":"up in the Godot editor and enable the extension.","type":"text"}],"type":"paragraph"}]}],"stepsSection":[{"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"text":"Open the SimpleRunner project in the Godot editor. When the project opens, you should see a dialog that","type":"text"},{"text":" ","type":"text"},{"text