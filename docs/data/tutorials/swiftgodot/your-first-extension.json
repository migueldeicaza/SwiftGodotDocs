rBody2D {","    var acceleration = 100","    var friction = 100","    var speed = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        return movement.normalized()","    }","","    override func _physicsProcess(delta: Double) {","        if Engine.isEditorHint() { return }","    }","}"],"fileName":"PlayerController.swift"},"RunnerHeader.png":{"variants":[{"url":"\/images\/SwiftGodot\/RunnerHeader.png","traits":["1x","light"]}],"alt":"A screenshot of the Simple Runner game. The player wears a bird costume and runs alongside boxes.","identifier":"RunnerHeader.png","type":"image"},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials/Embedding-Godot-in-Swift":{"kind":"article","abstract":[],"type":"topic","title":"Embedding Godot in Swift","role":"article","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/Embedding-Godot-in-Swift","url":"\/tutorials\/swiftgodot-tutorials\/embedding-godot-in-swift"},"SimpleRunnerDriver-starter-3.txt":{"highlights":[{"line":5},{"line":6},{"line":7},{"line":8},{"line":9}],"fileType":"gdextension","syntax":"gdextension","identifier":"SimpleRunnerDriver-starter-3.txt","type":"file","fileName":"SimpleRunnerDriver.gdextension","content":["[configuration]","entry_symbol = \"swift_entry_point\"","compatibility_minimum = 4.2","","[libraries]","macos.debug = \"res:\/\/bin\/libSimpleRunnerDriver.dylib\"","","[dependencies]","macos.debug = {\"res:\/\/bin\/libSwiftGodot.dylib\" : \"\"}"]},"OpenSwiftBuild.png":{"alt":"A terminal window at the SwiftRunnerDriver package, about to run open.","type":"image","variants":[{"url":"\/images\/SwiftGodot\/OpenSwiftBuild.png","traits":["1x","light"]}],"identifier":"OpenSwiftBuild.png"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Create-a-player-character":{"type":"section","role":"pseudoSymbol","url":"\/tuto