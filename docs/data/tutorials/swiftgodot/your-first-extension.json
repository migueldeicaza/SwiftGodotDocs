hould see a dialog that"},{"text":" ","type":"text"},{"type":"text","text":"appears, asking to reloag Godot for extensions to take effect."}]}],"media":"GodotExtensionPrompt.png","code":null},{"code":null,"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Press Restart to restart the Godot editor and enable the extension."}]}],"media":"GodotMainEditor.png","caption":[]},{"code":null,"runtimePreview":null,"caption":[],"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the FileSystem tab, navigate to the objects directory and open the "},{"code":"player.tscn","type":"codeVoice"},{"text":" file, which contains","type":"text"},{"type":"text","text":" "},{"type":"text","text":"the player scene."}]}],"media":"Godot-Filesystem-starter-2.png"},{"code":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the Scene tab, right click on the "},{"type":"codeVoice","code":"CharacterBody2D"},{"text":" node and select ","type":"text"},{"inlineContent":[{"type":"text","text":"Change Type"}],"type":"strong"},{"type":"text","text":"."}]}],"runtimePreview":null,"type":"step","media":"Godot-Scene-starter-3.png","caption":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Search for the PlayerController node and click ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"Change"}]},{"text":" to apply the changes and save the scene once","type":"text"},{"type":"text","text":" "},{"text":"the change is made.","type":"text"}]}],"media":"Godot-NodePicker-starter-4.png","type":"step","caption":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the PlayerController doesn’t appear in this list, revisit the other sections of this tutorial. You"},{"text":" ","type":"text"},{"text":"may have misconfigured a setting or didn’t build the library.","type":"text"}]}],"code":null,"runtimePreview":null},{"code":null,"content":[{"type":"paragrap