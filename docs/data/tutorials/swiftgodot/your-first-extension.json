 SimpleRunnerDriver library to dynamic and set the minimum platform target to macOS 13."}],"type":"paragraph"}],"runtimePreview":null,"code":"Package-starter-3.swift","caption":[]},{"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Update the SimpleRunnerDriver target to add in the appropriate Swift compiler and linker settings. These"},{"type":"text","text":" "},{"text":"flags are needed to allow dynamic lookup with the Godot engine.","type":"text"}]}],"code":"Package-starter-4.swift","type":"step","media":null,"caption":[]},{"type":"step","caption":[],"code":"SimpleRunnerDriver-starter-2.swift","runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In SimpleRunnerDriver.swift, import the SwiftGodot library and call the"},{"type":"text","text":" "},{"code":"initSwiftExtension","type":"codeVoice"},{"text":" macro to create an entry point. For now, we can pass an empty array for the nodes","type":"text"},{"type":"text","text":" "},{"text":"to be registered.","type":"text"}]}],"media":null}],"title":"Create a Swift package","contentSection":[{"kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Your extension for Godot lives as a Swift package alongside your Godot project. While Godot currently"},{"type":"text","text":" "},{"text":"doesn’t support editing Swift packages in its editor, you can use Xcode to do most of the heavy lifting.","type":"text"}]}],"mediaPosition":"trailing"}],"anchor":"Create-a-Swift-package"},{"stepsSection":[{"content":[{"inlineContent":[{"type":"text","text":"Create a new Swift file called "},{"type":"strong","inlineContent":[{"type":"text","text":"PlayerController.swift"}]},{"type":"text","text":" in the "},{"type":"codeVoice","code":"Sources\/SimpleRunnerDriver"},{"type":"text","text":" directory and import the"},{"type":"text","text":" "},{"type":"text","text":"SwiftGodot library."}],"type":"paragraph"}],"type":"step","media":null,"caption":[],"code":"PlayerController-starter-init.swift","runtimePreview":null},{"caption":[],"runtimePreview":null,"media":null,"code":"PlayerController-starter-2.swift","type":"step","content":[{"inlineContent":[{"type":"text","text":"Write a new "},{"type":"codeVoice","code":"PlayerController"},{"text":" class that inherits from ","type":"text"},{"type":"codeVoice","code":"CharacterBody2D"},{"type":"text","text":" and add its required"},{"type":"text","text":" "},{"text":"initializers.","type":"text"}],"type":"paragraph"}]},{"media":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"type":"codeVoice","code":"acceleration"},{"text":", ","type":"text"},{"code":"friction","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"speed","type":"codeVoice"},{"type":"text","text":" properties to the player controller."}]}],"caption":[{"inlineContent":[{"type":"text","text":"These will be used to calculate the final velocity of the player."}],"type":"paragraph"}],"code":"PlayerController-starter-3.swift","runtimePreview":null,"type":"step"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a "},{"type":"codeVoice","code":"movementVector"},{"type":"text","text":" computed property that creates a new vector and sets its X coordinate to the"},{"text":" ","type":"text"},{"text":"difference between the ","type":"text"},{"type":"codeVoice","code":"move_right"},{"type":"text","text":" and "},{"type":"codeVoice","code":"move_left"},{"text":" actions. Return the normalized vector in the block.","type":"text"}]}],"media":null,"code":"PlayerController-starter-4.swift","runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"This vector will be used to determine the direction that the player is moving in along the X axis. For","type":"text"},{"type":"text","text":" "},{"text":"now, we will assume that the player does ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" move on the vertical axis.","type":"text"}]}],"type":"step"},{"runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"This check is needed here to ensure that keypresses are registered only when running in-game, as the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"extension runs at the engine level."}]}],"content":[{"inlineContent":[{"text":"Add the ","type":"text"},{"type":"codeVoice","code":"_physicsProcess"},{"text":" method to the player controller class and return from the function if the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"engine reports that we’re in the editor."}],"type":"paragraph"}],"type":"step","media":null,"code":"PlayerController-starter-5.swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Check if the movement vector is a non-zero value (i.e., the player is actively pressing a key), and"},{"type":"text","text":" "},{"text":"calculate the velocity at which the player moves. If your ","type":"text"},{"code":"acceleration","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"friction"},{"type":"text","text":", and\/or "},{"type":"codeVoice","code":"speed"},{"type":"text","text":" "},{"type":"text","text":"values are integers, be sure to explicitly define their types as floats\/doubles."}]}],"media":null,"code":"PlayerController-starter-6.swift","caption":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"limitLength","type":"codeVoice"},{"type":"text","text":" method is used to clamp the velocity down to the maximum "},{"type":"codeVoice","code":"speed"},{"type":"text","text":" value so that the"},{"type":"text","text":" "},{"type":"text","text":"player doesn’t build up a lot of speed."}]}],"type":"step","runtimePreview":null},{"type":"step","runtimePreview":null,"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add an else case that will have the player’s velocity moving towards zero, applying any "},{"code":"friction","type":"codeVoice"},{"type":"text","text":" as"},{"text":" ","type":"text"},{"type":"text","text":"necessary."}]}],"media":null,"code":"PlayerController-starter-7.swift"},{"caption":[],"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Finally, call "},{"type":"codeVoice","code":"moveAndSlide"},{"type":"text","text":" to move the player, sliding along any edges the player collides with, and"},{"type":"text","text":" "},{"type":"text","text":"call the parent’s "},{"code":"physicsProcess(delta:)","type":"codeVoice"},{"type":"text","text":" method."}]}],"type":"step","media":null,"code":"PlayerController-starter-8.swift","runtimePreview":null},{"type":"step","runtimePreview":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"This registration call exposed the class type to Godot as a valid node that can be used in the engine.","type":"text"}]}],"content":[{"type":"paragraph","inlineContent":[{"text":"In, SimpleRunnerDriver.swift, register the ","type":"text"},{"code":"PlayerController","type":"codeVoice"},{"type":"text","text":" class type by adding this to the array"},{"text":" ","type":"text"},{"type":"text","text":"in "},{"code":"initSwiftExtension","type":"codeVoice"},{"type":"text","text":"."}]}],"code":"SimpleRunnerDriver-starter-3.swift","media":null}],"title":"Create a player character","anchor":"Create-a-player-character","contentSection":[{"mediaPosition":"trailing","kind":"contentAndMedia","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that our package is set up, we can create a player controller to move the player around in."}]}]}]},{"title":"Set up the extension","contentSection":[{"kind":"contentAndMedia","mediaPosition":"trailing","content":[{"inlineContent":[{"type":"text","text":"Before our Swift package can be built and used, the extension must be created and registered with Godot. To"},{"type":"text","text":" "