, creating"},{"type":"text","text":" "},{"text":"an infinite runner.","type":"text"}],"type":"section","title":"Handle vertical movement","role":"pseudoSymbol","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Handle-vertical-movement","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Handle-vertical-movement"},"MainLevel-multiscript-3.swift":{"fileName":"MainLevel.swift","highlights":[{"line":12},{"line":13},{"line":14},{"line":15}],"identifier":"MainLevel-multiscript-3.swift","content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"Spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","","}"],"fileType":"swift","syntax":"swift","type":"file"},"DylibCopy.png":{"variants":[{"url":"\/images\/SwiftGodot\/DylibCopy.png","traits":["1x","light"]}],"type":"image","alt":"Two Finder windows that show the dynamic library files being copied to the game's files.","identifier":"DylibCopy.png"},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts#Using-the-new-main-level-node":{"type":"section","role":"pseudoSymbol","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Using-the-new-main-level-node","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Using-the-new-main-level-node","abstract":[{"text":"This tutorial builds off the Simple Runner game introduced in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","type":"reference"},{"text":" and will introduce you","type":"text"},{"type":"text","text":" "},{"type":"text","text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating"},{"text":" ","type":"text"},{"type":"t