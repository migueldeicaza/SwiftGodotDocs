{"sections":[{"image":"RunnerHeader.png","chapter":"SwiftGodot Essentials","estimatedTimeInMinutes":15,"title":"Writing Multiple Scripts","backgroundImage":"RunnerHeader.png","kind":"hero","content":[{"inlineContent":[{"type":"text","text":"This tutorial builds off the Simple Runner game introduced in "},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","type":"reference"},{"text":" and will introduce you","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating"},{"text":" ","type":"text"},{"text":"an infinite runner.","type":"text"}],"type":"paragraph"}]},{"kind":"tasks","tasks":[{"title":"Handle vertical movement","contentSection":[{"mediaPosition":"trailing","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The player currently only moves along the horizontal axis, but remains in place vertically. Let’s adjust the"},{"type":"text","text":" "},{"text":"player code to include vertical motion.","type":"text"}]}],"kind":"contentAndMedia"}],"anchor":"Handle-vertical-movement","stepsSection":[{"caption":[],"runtimePreview":null,"code":"PlayerController-multiscript-2.swift","type":"step","media":null,"content":[{"inlineContent":[{"type":"text","text":"In "},{"code":"PlayerController.swift","type":"codeVoice"},{"type":"text","text":", find the "},{"type":"codeVoice","code":"movementVector"},{"type":"text","text":" computed property and update its y value to"},{"type":"text","text":" "},{"text":"include a constant speed of one.","type":"text"}],"type":"paragraph"}]},{"code":null,"runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"text":"In the terminal, navigate to the SimpleRunnerDriver package and run ","type":"text"},{"code":"swift build","type":"codeVoice"},{"text":" to build the package.","type":"text"}],"type":"paragraph"}],"media":"SwiftBuild.png","type":"step"},{"ty