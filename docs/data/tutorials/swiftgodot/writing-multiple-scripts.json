d spawn","type":"text"},{"type":"text","text":" "},{"text":"point exist.","type":"text"}],"type":"paragraph"}],"media":null,"type":"step","caption":[{"inlineContent":[{"type":"codeVoice","code":"GD.pushWarning(_:)"},{"type":"text","text":" allows us to send warning messages to Godot’s console."}],"type":"paragraph"}]},{"media":null,"code":"MainLevel-multiscript-5.swift","runtimePreview":null,"content":[{"inlineContent":[{"type":"text","text":"Set the player’s position so that their horizontal coordinate is kept, but the vertical coordinate is"},{"type":"text","text":" "},{"type":"text","text":"that of the spawn point."}],"type":"paragraph"}],"type":"step","caption":[{"type":"paragraph","inlineContent":[{"text":"This will effectively teleport the player to the top of the map, preserving where the player was on the","type":"text"},{"text":" ","type":"text"},{"text":"horizontal axis.","type":"text"}]}]},{"media":null,"runtimePreview":null,"type":"step","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"In the "},{"type":"codeVoice","code":"_ready()"},{"type":"text","text":" method, connect the teleport area’s "},{"type":"codeVoice","code":"bodyEntered"},{"text":" signal method to check if the player","type":"text"},{"type":"text","text":" "},{"type":"text","text":"has entered the area and teleport them when necessary."}]}],"code":"MainLevel-multiscript-6.swift","caption":[]},{"caption":[],"media":null,"code":"SimpleRunnerDriver-multiscript-2.swift","type":"step","runtimePreview":null,"content":[{"inlineContent":[{"text":"Register the class type in ","type":"text"},{"type":"codeVoice","code":"SimpleRunnerDriver.swift"},{"type":"text","text":" to expose it to Godot."}],"type":"paragraph"}]}],"title":"Teleport the player"},{"anchor":"Using-the-new-main-level-node","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that the main level code has been added, let’s replace the current main level node with its new instance"},{"type":"text","text":" "},{"text":"provided by your extension.","type":"text"}]}],"mediaPosition":"trailing","kind":"contentAndMedia"}],"stepsSection":[{"content":[{"inlineContent":[{"text":"Rebuild the extension and copy over ","type":"text"},{"code":"libSimpleRunnerDriver.dylib","type":"codeVoice"},{"type":"text","text":" as before."}],"type":"paragraph"}],"caption":[],"type":"step","runtimePreview":null,"media":"SwiftBuild.png","code":null},{"code":null,"runtimePreview":null,"type":"step","media":"GodotMainEditor.png","content":[{"inlineContent":[{"text":"Open the project in the Godot editor and open the ","type":"text"},{"type":"codeVoice","code":"main.tscn"},{"type":"text","text":" scene file."}],"type":"paragraph"}],"caption":[]},{"media":"Godot-MainLevel-ChangeType.png","code":null,"runtimePreview":null,"type":"step","content":[{"inlineContent":[{"type":"text","text":"Right click on the Main Level node and select "},{"type":"strong","inlineContent":[{"type":"text","text":"Change Type"}]},{"type":"text","text":"."}],"type":"paragraph"}],"caption":[]},{"runtimePreview":null,"caption":[{"inlineContent":[{"text":"If the node doesn’t appear in the search results, retry the steps for registering the class, rebuilding","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"the extension, and re-opening Godot."}],"type":"paragraph"}],"media":"Godot-ChangeType-MainLevel.png","code":null,"content":[{"inlineContent":[{"type":"text","text":"Search for “MainLevel” and set the node’s type to the new MainLevel node you created."}],"type":"paragraph"}],"type":"step"},{"media":"SimpleRunner-teleport.gif","content":[{"inlineContent":[{"type":"text","text":"Run the project by pressing the Play button in the toolbar. The player should now be moving down the"},{"type":"text","text":" "},{"text":"screen, teleporting to the top of the screen once the player reaches the bottom. 🎉","type":"text"}],"type":"paragraph"}],"caption":[],"code":null,"type":"step","runti