ot/tutorials/SwiftGodot-Tutorials/SwiftGodot-Essentials":{"type":"topic","url":"\/tutorials\/swiftgodot-tutorials\/swiftgodot-essentials","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/SwiftGodot-Essentials","kind":"article","role":"article","abstract":[],"title":"SwiftGodot Essentials"},"OpenSwiftBuild.png":{"alt":"A terminal window at the SwiftRunnerDriver package, about to run open.","identifier":"OpenSwiftBuild.png","type":"image","variants":[{"url":"\/images\/OpenSwiftBuild.png","traits":["1x","light"]}]},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Create-a-player-character":{"type":"section","url":"\/tutorials\/swiftgodot\/your-first-extension#Create-a-player-character","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-player-character","kind":"section","role":"pseudoSymbol","abstract":[{"text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"text":" ","type":"text"},{"text":"the horizontal axis.","type":"text"}],"title":"Create a player character"},"doc://SwiftGodot/tutorials/SwiftGodot/Using-Swift-Godot-Kit":{"type":"topic","url":"\/tutorials\/swiftgodot\/using-swift-godot-kit","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit","estimatedTime":"5min","kind":"project","role":"project","abstract":[{"text":"SwiftGodotKit lets you drive Godot entirely from Swift, and treat Godot as just another Swift framework you can call into.","type":"text"}],"title":"Using SwiftGodotKit"},"MainLevel-multiscript-3.swift":{"fileName":"MainLevel.swift","type":"file","content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"Spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","","}"],"identifier":"MainLevel-multiscript-3.swift","syntax":"swift","highlights":[{"line":12},{"line":13},{"line":14},{"line":15}],"fileType":"swift"},"PlayerController-multiscript-2.swift":{"fileName":"PlayerController.swift","type":"file","content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot","","@Godot","class PlayerController: CharacterBody2D {","    var acceleration: Float = 100","    var friction: Double = 100","    var speed: Double = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        movement.y = 1.0","        return movement.normalized()","    }","","    override func _physicsProcess(delta: Double) {","        if Engine.isEditorHint() { return }","        if movementVector != .zero {","            let acceleratedVector = Vector2(x: acceleration, y: acceleration)","            let acceleratedMovement = movementVector * acceleratedVector","            self.velocity = acceleratedMovement.limitLength(speed)","        } else {","            velocity = velocity.moveToward(to: .zero, delta: friction)","        }","        self.moveAndSlide()","        super._physicsProcess(delta: delta)","    }","}"],"identifier":"PlayerController-multiscript-2.swift","syntax":"swift","highlights":[{"line":20}],"fileType":"swift"},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts#Handle-vertical-movement":{"type":"section","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Handle-vertical-movement","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Handle-vertical-movement","kind":"section","role":"pseudoSymbol","abstract":[{"text":"This tutorial builds off the Simple Runner game introduced in ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","type":"reference"},{"type":"text","text":" and will introduce you"},{"text":" ","type":"text"},{"text":"to working with multiple scripts and interacting with Godot’s existing signals to teleport the player, creating","type":"text"},{"text":" ","type":"text"},{"text":"an infinite runner.","type":"text"}],"title":"Handle vertical movement"},"Godot-ChangeType-MainLevel.png":{"alt":"The Godot editor with the context menu for Main Level open, highlighting Change Type.","identifier":"Godot-ChangeType-MainLevel.png","type":"image","variants":[{"url":"\/images\/Godot-ChangeType-MainLevel.png","traits":["1x","light"]}]},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension":{"type":"topic","url":"\/tutorials\/swiftgodot\/your-first-extension","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","estimatedTime":"30min","kind":"project","role":"project","abstract":[{"text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"text":" ","type":"text"},{"text":"the horizontal axis.","type":"text"}],"title":"Your First Extension"},"Godot-MainLevel-SceneTree.png":{"alt":"A screenshot of the scene tree for the main level in Godot.","identifier":"Godot-MainLevel-SceneTree.png","type":"image","variants":[{"url":"\/images\/Godot-MainLevel-SceneTree.png","traits":["1x","light"]}]},"SimpleRunnerDriver-multiscript-2.swift":{"fileName":"SimpleRunnerDriver.swift","type":"file","content":["\/\/ The Swift Programming Language","\/\/ https:\/\/docs.swift.org\/swift-book","","import SwiftGodot","","let allNodes: [Wrapped.Type] = [PlayerController.self, MainLevel.self]","","#initSwiftExtension(cdecl: \"swift_entry_point\", types: allNodes)"],"identifier":"SimpleRunnerDriver-multiscript-2.swift","syntax":"swift","highlights":[{"line":6},{"line":7},{"line":8}],"fileType":"swift"},"GodotMainEditor.png":{"alt":"The Godot editor open with the main SimpleRunnerProject.","identifier":"GodotMainEditor.png","type":"image","variants":[{"url":"\/images\/GodotMainEditor.png","traits":["1x","light"]}]},"MainLevel-multiscript-5.swift":{"fileName":"MainLevel.swift","type":"file","content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"Spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","","    private func teleportPlayerToTop() {","        guard let player, let spawnpoint else {","            GD.pushWarning(\"Player or spawnpoint is missing.\")","            return","        }","","        player.position = Vector2(x: player.position.x, y: spawnpoint.position.y)","    }","}"],"identifier":"MainLevel-multiscript-5.swift","syntax":"swift","highlights":[{"line":21},{"line":22}],"fileType":"swift"},"MainLevel-multiscript-2.swift":{"fileName":"MainLevel.swift","type":"file","content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","}"],"identifier":"MainLevel-multiscript-2.swift","syntax":"swift","highlights":[{"line":9},{"line":10},{"line":11},{"line":12}],"fileType":"swift"},"SwiftBuild.png":{"alt":"A terminal window at the SwiftRunnerDriver package, about to run swift build.","identifier":"SwiftBuild.png","variants":[{"url":"\/images\/SwiftBuild.png","traits":["1x","light"]}],"type":"image"},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials":{"type":"topic","url":"\/tutorials\/swiftgodot-tutorials","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","kind":"overview","role":"overview","abstract":[{"text":"SwiftGodot allows developers to take new and existing Swift packages and use them as extensions for the Godot game engine.","type":"text"}],"title":"Meet SwiftGodot"},"MainLevel-multiscript-6.swift":{"fileName":"MainLevel.swift","type":"file","content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"Spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","","    override func _ready() {","        teleportArea?.bodyEntered.connect { [self] enteredBody in","            if enteredBody.isClass(\"\\(PlayerController.self)\") {","                teleportPlayerToTop()","            }","        }","","        super._ready()","    }","","    private func teleportPlayerToTop() {","        guard let player, let spawnpoint else {","            GD.pushWarning(\"Player or spawnpoint is missing.\")","            return","        }","","        player.position = Vector2(x: player.position.x, y: spawnpoint.position.y)","    }","}"],"identifier":"MainLevel-multiscript-6.swift","syntax":"swift","highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25}],"fileType":"swift"},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts#Using-the-new-main-level-node":{"type":"section","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Using-the-new-main-level-node","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Using-the-new-main-level-node","kind":"section","role":"pseudoSymbol","abstract":[{"text"