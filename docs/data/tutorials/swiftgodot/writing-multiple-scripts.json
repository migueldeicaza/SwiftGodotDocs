-multiscript-6.swift":{"identifier":"MainLevel-multiscript-6.swift","content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"Spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","","    override func _ready() {","        teleportArea?.bodyEntered.connect { [self] enteredBody in","            if enteredBody.isClass(\"\\(PlayerController.self)\") {","                teleportPlayerToTop()","            }","        }","","        super._ready()","    }","","    private func teleportPlayerToTop() {","        guard let player, let spawnpoint else {","            GD.pushWarning(\"Player or spawnpoint is missing.\")","            return","        }","","        player.position = Vector2(x: player.position.x, y: spawnpoint.position.y)","    }","}"],"fileName":"MainLevel.swift","highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22},{"line":23},{"line":24},{"line":25}],"type":"file","fileType":"swift","syntax":"swift"},"DylibCopy.png":{"variants":[{"url":"\/images\/DylibCopy.png","traits":["1x","light"]}],"alt":"Two Finder windows that show the dynamic library files being copied to the game's files.","type":"image","identifier":"DylibCopy.png"},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials/SwiftGodot-Essentials":{"type":"topic","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/SwiftGodot-Essentials","kind":"article","title":"SwiftGodot Essentials","url":"\/tutorials\/swiftgodot-tutorials\/swiftgodot-essentials","role":"article","abstract":[]},"doc://SwiftGodot/tutorials/SwiftGodot/Writing-Multiple-Scripts#Teleport-the-player":{"role":"pseudoSymbol","url":"\/tutorials\/swiftgodot\/writing-multiple-scripts#Teleport-the-player","kind":"section","abstract":[{