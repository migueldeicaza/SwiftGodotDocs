ng-Multiple-Scripts#Handle-vertical-movement","kind":"task"},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Teleport-the-player","kind":"task"},{"kind":"task","reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts#Using-the-new-main-level-node"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts"}]},{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/Embedding-Godot-in-Swift","projects":[{"sections":[{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit#SwiftGodotKit-from-Xcode","kind":"task"}],"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit"}]}]},"metadata":{"role":"project","title":"Writing Multiple Scripts","category":"SwiftGodot Tutorials","categoryPathComponent":"SwiftGodot-Tutorials"},"kind":"project","references":{"MainLevel-multiscript-4.swift":{"content":["\/\/","\/\/  MainLevel.swift","\/\/  ","\/\/","\/\/  Created by Marquis Kurt on 7\/22\/23.","\/\/","","import SwiftGodot","","@Godot","class MainLevel: Node2D {","    @SceneTree(path: \"CharacterBody2D\") var player: PlayerController?","    @SceneTree(path: \"Spawnpoint\") var spawnpoint: Node2D?","    @SceneTree(path: \"Telepoint\") var teleportArea: Area2D?","","    private func teleportPlayerToTop() {","        guard let player, let spawnpoint else {","            GD.pushWarning(\"Player or spawnpoint is missing.\")","            return","        }","        ","    }","}"],"highlights":[{"line":16},{"line":17},{"line":18},{"line":19},{"line":20},{"line":21},{"line":22}],"syntax":"swift","type":"file","fileType":"swift","identifier":"MainLevel-multiscript-4.swift","fileName":"MainLevel.swift"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Use-the-new-player-controller":{"type":"section","role":"pseudoSymbol","url":"\/tutorials\/swiftgodot\/your-first-extension#Use-the-new-player-controller","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Use-the-new-player-controller","abstract":[{"text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll","type":"text"},{"type":"text","text":" "},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"type":"text","text":" "},{"text":"the horizontal axis.","type":"text"}],"title":"Use the new player controller","kind":"section"},"PlayerController-multiscript-2.swift":{"type":"file","syntax":"swift","fileType":"swift","fileName":"PlayerController.swift","content":["\/\/","\/\/  PlayerController.swift","\/\/","\/\/","\/\/  Created by Marquis Kurt on 7\/19\/23.","\/\/","","import SwiftGodot","","@Godot","class PlayerController: CharacterBody2D {","    var acceleration: Float = 100","    var friction: Double = 100","    var speed: Double = 200","","    var movementVector: Vector2 {","        var movement = Vector2.zero","        movement.x = Float(","            Input.getActionStrength(action: \"move_right\") - Input.getActionStrength(action: \"move_left\"))","        movement.y = 1.0","        return movement.normalized()","    }","","    override func _physicsProcess(delta: Double) {","        if Engine.isEditorHint() { return }","        if movementVector != .zero {","            let acceleratedVector = Vector2(x: acceleration, y: acceleration)","            let acceleratedMovement = movementVector * acceleratedVector","            self.velocity = acceleratedMovement.limitLength(speed)","        } else {","            velocity = velocity.moveToward(to: .zero, delta: friction)","        }","        self.moveAndSlide()","        super._physicsProcess(delta: delta)","    }","}"],"highlights":[{"line":20}],"identifier":"PlayerController-multiscript-2.swift"},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials/Embedding-Godot-in-Swift":{"kind":"article","abstract":[],"type":"topic","title":"Embedding Godot in Swift","role":"article","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials\/Embedding-Godot-in-Swift","url":"\/tutorials\/swiftgodot-tutorials\/embedding-godot-in-swift"},"OpenSwiftBuild.png":{"variants":[{"url":"\/images\/SwiftGodot\/OpenSwiftBuild.png","traits":["1x","light"]}],"type":"image","alt":"A terminal window at the SwiftRunnerDriver package, about to run open.","identifier":"OpenSwiftBuild.png"},"Godot-MainLevel-ChangeType.png":{"variants":[{"url":"\/images\/SwiftGodot\/Godot-MainLevel-ChangeType.png","traits":["1x","light"]}],"type":"image","alt":"The Godot editor with the context menu for Main Level open, highlighting Change Type.","identifier":"Godot-MainLevel-ChangeType.png"},"Godot-MainLevel-SceneTree.png":{"variants":[{"url":"\/images\/SwiftGodot\/Godot-MainLevel-SceneTree.png","traits":["1x","light"]}],"type":"image","alt":"A screenshot of the scene tree for the main level in Godot.","identifier":"Godot-MainLevel-SceneTree.png"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Create-a-Swift-package":{"type":"section","role":"pseudoSymbol","url":"\/tutorials\/swiftgodot\/your-first-extension#Create-a-Swift-package","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension#Create-a-Swift-package","abstract":[{"text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll","type":"text"},{"text":" ","type":"text"},{"text":"start by building off the Simple Runner game project and create a player character to move the character along","type":"text"},{"type":"text","text":" "},{"text":"the horizontal axis.","type":"text"}],"title":"Create a Swift package","kind":"section"},"Godot-ChangeType-MainLevel.png":{"variants":[{"url":"\/images\/SwiftGodot\/Godot-ChangeType-MainLevel.png","traits":["1x","light"]}],"type":"image","alt":"The Godot editor with the context menu for Main Level open, highlighting Change Type.","identifier":"Godot-ChangeType-MainLevel.png"},"SimpleRunner-teleport.gif":{"variants":[{"url":"\/images\/SwiftGodot\/SimpleRunner-teleport.gif","traits":["1x","light"]}],"type":"image","alt":"The SimpleRunner project running, with the player moving down the screen and teleporting.","identifier":"SimpleRunner-teleport.gif"},"GodotMainEditor.png":{"variants":[{"url":"\/images\/SwiftGodot\/GodotMainEditor.png","traits":["1x","light"]}],"type":"image","alt":"The Godot editor open with the main SimpleRunnerProject.","identifier":"GodotMainEditor.png"},"doc://SwiftGodot/tutorials/SwiftGodot-Tutorials":{"kind":"overview","abstract":[{"text":"SwiftGodot allows developers to take new and existing Swift packages and use them as extensions for the Godot game engine.","type":"text"}],"type":"topic","title":"Meet SwiftGodot","role":"overview","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","url":"\/tutorials\/swiftgodot-tutorials"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension":{"kind":"project","estimatedTime":"30min","abstract":[{"text":"This tutorial will guide you through making your first Godot extension to create a player character. You’ll","type":"text"},{"type":"text","text":" "},{"type":"text","text":"start by building off the Simple Runner game project and create a player character to move the character along"},{"type":"text","text":" "},{"text":"the horizontal axis.","type":"text"}],"title":"Your First Extension","type":"topic","role":"project","identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","url":"\/tutorials\/swiftgodot\/your-first-extension"},"RunnerHeader.png":{"variants":[{"url":"\/images\/SwiftGodot\/RunnerHeader.png","traits":["1x","light"]}],"type":"image","alt":"A screenshot of the Simple Runner game. The player wears a bird costume and runs alongside boxes.","identifier":"RunnerHeader.png"},"doc://SwiftGodot/tutorials/SwiftGodot/Your-First-Extension#Create-a-player-character":{"type":"section","role":"pseudoSymbol","url":"\/tuto