ly teleport the player to the top of the map, preserving where the player was on the"},{"type":"text","text":" "},{"text":"horizontal axis.","type":"text"}],"type":"paragraph"}],"content":[{"inlineContent":[{"type":"text","text":"Set the player’s position so that their horizontal coordinate is kept, but the vertical coordinate is"},{"type":"text","text":" "},{"type":"text","text":"that of the spawn point."}],"type":"paragraph"}],"media":null,"type":"step"},{"type":"step","code":"MainLevel-multiscript-6.swift","content":[{"type":"paragraph","inlineContent":[{"text":"In the ","type":"text"},{"type":"codeVoice","code":"_ready()"},{"text":" method, connect the teleport area’s ","type":"text"},{"type":"codeVoice","code":"bodyEntered"},{"type":"text","text":" signal method to check if the player"},{"type":"text","text":" "},{"type":"text","text":"has entered the area and teleport them when necessary."}]}],"runtimePreview":null,"caption":[],"media":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Register the class type in "},{"code":"SimpleRunnerDriver.swift","type":"codeVoice"},{"type":"text","text":" to expose it to Godot."}]}],"code":"SimpleRunnerDriver-multiscript-2.swift","media":null,"runtimePreview":null,"caption":[],"type":"step"}],"contentSection":[{"mediaPosition":"trailing","content":[{"inlineContent":[{"text":"Now that the player can run down the screen, let’s allow the player to teleport to the top of the level when","type":"text"},{"type":"text","text":" "},{"type":"text","text":"they reach the bottom."}],"type":"paragraph"},{"inlineContent":[{"text":"To do so, you will create a new node class that represents the main level logic and detect when the player","type":"text"},{"type":"text","text":" "},{"text":"has reached the bottom and teleport them to the top.","type":"text"}],"type":"paragraph"}],"kind":"contentAndMedia"}],"anchor":"Teleport-the-player","title":"Teleport the player"},{"stepsSection":[{"type":"step","content":[{"t