ate a new node class that represents the main level logic and detect when the player"},{"text":" ","type":"text"},{"type":"text","text":"has reached the bottom and teleport them to the top."}],"type":"paragraph"}],"mediaPosition":"trailing"}],"title":"Teleport the player"},{"title":"Using the new main level node","contentSection":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Now that the main level code has been added, let’s replace the current main level node with its new instance"},{"text":" ","type":"text"},{"type":"text","text":"provided by your extension."}]}],"kind":"contentAndMedia","mediaPosition":"trailing"}],"stepsSection":[{"media":"SwiftBuild.png","code":null,"type":"step","runtimePreview":null,"caption":[],"content":[{"inlineContent":[{"text":"Rebuild the extension and copy over ","type":"text"},{"type":"codeVoice","code":"libSimpleRunnerDriver.dylib"},{"text":" as before.","type":"text"}],"type":"paragraph"}]},{"caption":[],"runtimePreview":null,"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open the project in the Godot editor and open the "},{"code":"main.tscn","type":"codeVoice"},{"type":"text","text":" scene file."}]}],"media":"GodotMainEditor.png","type":"step","code":null},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Right click on the Main Level node and select "},{"inlineContent":[{"type":"text","text":"Change Type"}],"type":"strong"},{"type":"text","text":"."}]}],"media":"Godot-MainLevel-ChangeType.png","type":"step","caption":[],"code":null,"runtimePreview":null},{"content":[{"inlineContent":[{"type":"text","text":"Search for “MainLevel” and set the node’s type to the new MainLevel node you created."}],"type":"paragraph"}],"runtimePreview":null,"code":null,"caption":[{"type":"paragraph","inlineContent":[{"text":"If the node doesn’t appear in the search results, retry the steps for registering the class, rebuilding","type":"text"},{"type":"text","text":" "},{"type":"