{"sections":[{"title":"Meet SwiftGodot","action":{"overridingTitle":"Get started","isActive":true,"identifier":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","overridingTitleInlineContent":[{"text":"Get started","type":"text"}],"type":"reference"},"content":[{"inlineContent":[{"text":"SwiftGodot allows developers to take new and existing Swift packages and use them as extensions for the Godot game engine.","type":"text"}],"type":"paragraph"}],"backgroundImage":"SwiftGodot Header.png","kind":"hero","image":"SwiftGodot Header.png"},{"chapters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Learn the fundamentals of the SwiftGodot package and create an infinite runner game using Swift and Godot.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Write node scripts using Swift, integrate dynamic libraries with Godot using GDExtension, and use custom nodes"},{"type":"text","text":" "},{"text":"in the editor.","type":"text"}]}],"tutorials":["doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Your-First-Extension","doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Writing-Multiple-Scripts"],"image":"Birdie2.png","name":"SwiftGodot Essentials"},{"tutorials":["doc:\/\/SwiftGodot\/tutorials\/SwiftGodot\/Using-Swift-Godot-Kit"],"name":"Embedding Godot in Swift","content":[{"inlineContent":[{"type":"text","text":"If rather than embedding Swift into Godot, you want to embed Godot into"},{"type":"text","text":" "},{"type":"text","text":"your Swift application or, if you prefer to prototype your code with"},{"text":" ","type":"text"},{"type":"text","text":"a code-first approach, you can use the companion SwiftGodotKit."}],"type":"paragraph"}],"image":"Birdie2.png"}],"image":null,"content":[],"kind":"volume","name":null}],"kind":"overview","hierarchy":{"reference":"doc:\/\/SwiftGodot\/tutorials\/SwiftGodot-Tutorials","paths":[]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["